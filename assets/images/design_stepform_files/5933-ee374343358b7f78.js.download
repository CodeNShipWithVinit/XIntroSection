ted":null,"date_updated":null,"readableId":"SKILL_PYTORCH","title":"PyTorch","icon":"79842722-4eec-47e1-93fc-1de4c6d6ac8f"},{"id":360,"status":"published","sort":null,"user_created":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_created":"2026-01-08T05:37:58.000Z","user_updated":null,"date_updated":null,"readableId":"SKILL_HUGGINGFACE","title":"HuggingFace","icon":"4dda6857-1c25-4942-8921-fb56392db0be"},{"id":361,"status":"published","sort":null,"user_created":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_created":"2026-01-08T05:41:20.000Z","user_updated":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_updated":"2026-01-08T05:41:24.000Z","readableId":"SKILL_MLFLOW","title":"MLFlow","icon":"c5387002-6aed-4c7a-8d1d-144a94803f92"},{"id":362,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2026-01-21T10:36:20.000Z","user_updated":null,"date_updated":null,"readableId":"SKILL_REST_API","title":"REST_API","icon":null},{"id":363,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2026-01-21T13:16:40.000Z","user_updated":null,"date_updated":null,"readableId":"SKILL_NEXT_JS","title":"NEXT JS","icon":null},{"id":364,"status":"published","sort":null,"user_created":"42670516-02dd-418e-abaa-d5ff0d183714","date_created":"2026-01-21T16:52:15.000Z","user_updated":null,"date_updated":null,"readableId":"SKILL_MYSQL","title":"MySQL","icon":null},{"id":365,"status":"published","sort":null,"user_created":"42670516-02dd-418e-abaa-d5ff0d183714","date_created":"2026-01-21T17:49:03.000Z","user_updated":null,"date_updated":null,"readableId":"SKILL_BCRYPT","title":"BCrypt","icon":null},{"id":366,"status":"published","sort":null,"user_created":"42670516-02dd-418e-abaa-d5ff0d183714","date_created":"2026-01-21T17:50:10.000Z","user_updated":null,"date_updated":null,"readableId":"SKILL_SPRING_SECURITY","title":"Spring Security","icon":null},{"id":367,"status":"published","sort":null,"user_created":"42670516-02dd-418e-abaa-d5ff0d183714","date_created":"2026-01-21T18:19:18.000Z","user_updated":null,"date_updated":null,"readableId":"SKILL_JWT","title":"JWT","icon":null}],"q":[{"id":1,"status":"published","sort":null,"user_created":"c9fde96d-9501-41ab-90fd-c90abdc4d0cf","date_created":"2022-06-23T07:11:33.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2023-10-26T12:20:40.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_QTRIPDYNAMIC","title":"QTripDynamic","description":"<p>QTrip is a travel website aimed at travellers looking for a multitude of adventures in different cities.&nbsp;</p>\\n<p>During the course of this project,</p>\\n<ul>\\n<li>Created web pages using HTML and CSS and made them dynamic using JavaScript</li>\\n<li>Improved UX with multi-select filters, image carousels</li>\\n<li>Utilised localStorage to persist user preferences at client-side</li>\\n</ul>","image":"0ba0c306-851a-451e-89bb-623289fca9a3","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>QTrip is a travel website aimed at travellers looking for a multitude of adventures in different cities.&nbsp;</p>\\n<p>During the course of this project,</p>\\n<ul>\\n<li>Created web pages using HTML and CSS and made them dynamic using JavaScript</li>\\n<li>Improved UX with multi-select filters, image carouselsImplemented conditional rendering of page elements</li>\\n<li><span style=\\"font-weight: 400;\\">Implemented conditional rendering of page elements</span></li>\\n<li>Utilized localStorage to persist user preferences at client-side and facilitated reservation form submission using fetch API.</li>\\n<li>Deployed the website using Netlify/Vercel for Frontend and Render for Backend.&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;</li>\\n</ul>\\n<div class=\\"image-container\\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; <img src=\\"https://directus.crio.do/assets/5ea9a041-3677-44dd-be8c-2f41b84977e9?\\" alt=\\"Q Trip Architecture Diagram\\" /></div>","skills":[]},{"id":3,"status":"published","sort":null,"user_created":"c9fde96d-9501-41ab-90fd-c90abdc4d0cf","date_created":"2022-06-28T10:01:18.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2023-10-20T13:02:41.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_QTRIPSTATIC","title":"QTripStatic","description":"<p>QTrip is a travel website aimed at travellers looking for a multitude of adventures in different cities.&nbsp;</p>\\n<p>During the course of this project,</p>\\n<ul>\\n<li>Created 3 different web pages from Wireframe layout using HTML and CSS</li>\\n<li>Utilized Bootstrap extensively for responsive design</li>\\n<li>&nbsp;Deployed the website to Netlify/Vercel</li>\\n</ul>","image":"ec48bef5-2566-4af5-8a6e-2f978e63d1b5","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>QTrip is a travel website aimed at travellers looking for a multitude of adventures in different cities.&nbsp;</p>\\n<p>During the course of this project,</p>\\n<ul>\\n<li>Created 3 different web pages from Wireframe layout using HTML and CSS</li>\\n<li>Utilized Bootstrap extensively for responsive design</li>\\n<li>Deployed the website to Netlify/Vercel</li>\\n</ul>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/4b996c66-44a8-49d6-bba3-684225f7cd21?\\" alt=\\"QTrip Landing page\\" /><img src=\\"https://directus.crio.do/assets/7b0df37a-c640-4bc7-9a0c-23d293683054?\\" alt=\\"QTrip Adventures page\\" /><img src=\\"https://directus.crio.do/assets/05be60d5-d3a1-4e34-bf63-47a26262c5bc?\\" alt=\\"QTrip Adventure details page\\" /></div>","skills":[]},{"id":4,"status":"draft","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-06-28T14:40:30.000Z","user_updated":"7f2f5989-e480-4334-866e-a80901840839","date_updated":"2022-07-20T11:35:20.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_QMONEY_V2","title":"QMoney","description":"<p>QMoney is a visual stock portfolio analyzer. It helps portfolio managers make trade recommendations for their clients.</p>\\n<p>During the course of this project,</p>\\n<ul>\\n<li>Implemented the core logic of the portfolio manager and published it as a library.</li>\\n<li>Refactored code to add support for multiple stock quote services.</li>\\n<li>Improved application stability and performance.</li>\\n</ul>","image":"bed446b9-7dba-4b0a-b42e-5744a26ad2f0","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>QMoney is a visual stock portfolio analyzer. It helps portfolio managers make trade recommendations for their clients.</p>\\n<p>During the course of this project,</p>\\n<ul>\\n<li>Implemented the core logic of the portfolio manager and published it as a library.</li>\\n<li>Refactored code to add support for multiple stock quote services.</li>\\n<li>Improved application stability and performance.</li>\\n</ul>\\n<h2>Image</h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/c1ecb8f4-e223-4524-9981-b724dae69857?\\" alt=\\"QMoney Architecture\\" /><img src=\\"https://directus.crio.do/assets/26bbdd88-044f-441f-8b2d-17423a498033?\\" alt=\\"QMoney Portfolio Manager Interface\\" /></div>","skills":[]},{"id":5,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-06-28T18:20:26.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2025-07-29T13:22:48.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_QEATS_V2","title":"QEats","description":"<p>QEats is a popular food ordering app that allows users to browse and order their favorite dishes from nearby restaurants.</p>\\n<p>During the course of this project,</p>\\n<ul>\\n<li>Built different parts of the QEats backend which is a Spring Boot application.</li>\\n<li>Several REST API endpoints are implemented to query restaurant information and place food orders.</li>\\n</ul>","image":"bcf8d7c1-09ec-40d6-9e8a-1047648e7e9f","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>QEats is a popular food ordering app that allows users to browse and order their favorite dishes from nearby restaurants.</p>\\n<p>During the course of this project,</p>\\n<ul>\\n<li>I had build different parts of the QEats backend which is a Spring Boot application.</li>\\n<li>Several REST API endpoints were implemented to query restaurant information and place food orders.</li>\\n<li>To give a sense of real-world problems, production issues were investigated using Scientific Debugging methods.</li>\\n<li>Along with this, I improved the app performance under large load scenarios as well as included an advanced search feature in the app.&nbsp;</li>\\n</ul>\\n<h3>Image</h3>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/c74964c8-fb52-42b3-b4d4-e74fa3661f8b?\\" alt=\\"\\" /></div>","skills":[]},{"id":6,"status":"draft","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-06-29T08:30:08.000Z","user_updated":"c9fde96d-9501-41ab-90fd-c90abdc4d0cf","date_updated":"2022-07-07T11:53:51.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_QA","title":"Q&A Application","description":"<p>A quiz application that supports the following API endpoint:</p>\\n<p>This endpoint supports the following operations:</p>\\n<ul>\\n<li>&nbsp; <strong>GET /quiz/{moduleId}</strong> : fetch quiz questions for a given module.</li>\\n<li>&nbsp; <strong>POST /quiz/{moduleId}</strong> : submit quiz answers and return an evaluation.</li>\\n</ul>","image":"0fa895fd-3568-4531-95a0-bb0e41dc6ed8","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>Created a quiz application that supports the following API endpoint:<br />```<br />/quiz<br />```<br />This endpoint supports the following operations:</p>\\n<p>`GET /quiz/{moduleId}`: fetch quiz questions for a given module.<br />`POST /quiz/{moduleId}`: submit quiz answers and return an evaluation.</p>\\n<h3>Image</h3>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/9255797a-8b81-4d1e-9b94-8a65fa90e854?\\" alt=\\"\\" /><img src=\\"https://directus.crio.do/assets/1924b2f8-f7ed-4dce-b74e-6e8c6436371a?\\" alt=\\"\\" /></div>","skills":[]},{"id":7,"status":"draft","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-06-29T17:52:59.000Z","user_updated":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_updated":"2022-07-04T05:54:20.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_XFLIX_REACT","title":"XFlix Frontend","description":"<p><span data-sheets-value=\\"{&quot;1&quot;:2,&quot;2&quot;:&quot;XFlix is a video sharing platform which hosts videos for the world to watch. It also features uploading new videos by using external video links (eg: Youtube) and playing these videos.\\\\n\\\\nDuring the course of this Project,\\\\n- Built XFlix frontend using React.js from scratch\\\\n- Used Postman collection to understand API requirements\\\\n- Mocked backend server using Postman Mock Server for API response&quot;}\\" data-sheets-userformat=\\"{&quot;2&quot;:334465,&quot;3&quot;:{&quot;1&quot;:0},&quot;10&quot;:2,&quot;12&quot;:0,&quot;14&quot;:{&quot;1&quot;:3,&quot;3&quot;:1},&quot;15&quot;:&quot;Arial&quot;,&quot;19&quot;:0,&quot;21&quot;:0}\\">XFlix is a video sharing platform which hosts videos for the world to watch. It also features uploading new videos by using external video links (eg: Youtube) and playing these videos.<br /></span></p>\\n<p><span data-sheets-value=\\"{&quot;1&quot;:2,&quot;2&quot;:&quot;XFlix is a video sharing platform which hosts videos for the world to watch. It also features uploading new videos by using external video links (eg: Youtube) and playing these videos.\\\\n\\\\nDuring the course of this Project,\\\\n- Built XFlix frontend using React.js from scratch\\\\n- Used Postman collection to understand API requirements\\\\n- Mocked backend server using Postman Mock Server for API response&quot;}\\" data-sheets-userformat=\\"{&quot;2&quot;:334465,&quot;3&quot;:{&quot;1&quot;:0},&quot;10&quot;:2,&quot;12&quot;:0,&quot;14&quot;:{&quot;1&quot;:3,&quot;3&quot;:1},&quot;15&quot;:&quot;Arial&quot;,&quot;19&quot;:0,&quot;21&quot;:0}\\">During the course of this project,</span></p>\\n<ul>\\n<li><span data-sheets-value=\\"{&quot;1&quot;:2,&quot;2&quot;:&quot;XFlix is a video sharing platform which hosts videos for the world to watch. It also features uploading new videos by using external video links (eg: Youtube) and playing these videos.\\\\n\\\\nDuring the course of this Project,\\\\n- Built XFlix frontend using React.js from scratch\\\\n- Used Postman collection to understand API requirements\\\\n- Mocked backend server using Postman Mock Server for API response&quot;}\\" data-sheets-userformat=\\"{&quot;2&quot;:334465,&quot;3&quot;:{&quot;1&quot;:0},&quot;10&quot;:2,&quot;12&quot;:0,&quot;14&quot;:{&quot;1&quot;:3,&quot;3&quot;:1},&quot;15&quot;:&quot;Arial&quot;,&quot;19&quot;:0,&quot;21&quot;:0}\\">Built XFlix frontend using React.js from scratch</span></li>\\n<li><span data-sheets-value=\\"{&quot;1&quot;:2,&quot;2&quot;:&quot;XFlix is a video sharing platform which hosts videos for the world to watch. It also features uploading new videos by using external video links (eg: Youtube) and playing these videos.\\\\n\\\\nDuring the course of this Project,\\\\n- Built XFlix frontend using React.js from scratch\\\\n- Used Postman collection to understand API requirements\\\\n- Mocked backend server using Postman Mock Server for API response&quot;}\\" data-sheets-userformat=\\"{&quot;2&quot;:334465,&quot;3&quot;:{&quot;1&quot;:0},&quot;10&quot;:2,&quot;12&quot;:0,&quot;14&quot;:{&quot;1&quot;:3,&quot;3&quot;:1},&quot;15&quot;:&quot;Arial&quot;,&quot;19&quot;:0,&quot;21&quot;:0}\\">Used Postman collection to understand API requirements</span></li>\\n<li><span data-sheets-value=\\"{&quot;1&quot;:2,&quot;2&quot;:&quot;XFlix is a video sharing platform which hosts videos for the world to watch. It also features uploading new videos by using external video links (eg: Youtube) and playing these videos.\\\\n\\\\nDuring the course of this Project,\\\\n- Built XFlix frontend using React.js from scratch\\\\n- Used Postman collection to understand API requirements\\\\n- Mocked backend server using Postman Mock Server for API response&quot;}\\" data-sheets-userformat=\\"{&quot;2&quot;:334465,&quot;3&quot;:{&quot;1&quot;:0},&quot;10&quot;:2,&quot;12&quot;:0,&quot;14&quot;:{&quot;1&quot;:3,&quot;3&quot;:1},&quot;15&quot;:&quot;Arial&quot;,&quot;19&quot;:0,&quot;21&quot;:0}\\">Mocked backend server using Postman Mock Server for API response</span></li>\\n</ul>","image":"6a8120e9-29e4-4bf0-a813-ebd6f9afcf24","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>XFlix is a video sharing platform which hosts videos for the world to watch. It also features uploading new videos by using external video links (eg: Youtube) and playing these videos.</p>\\n<p>During the course of this project,</p>\\n<ul>\\n<li>Built XFlix frontend using React.js from scratch</li>\\n<li>Utilized the figma file to understand the design requirements</li>\\n<li>Used Postman collection to understand API requirements</li>\\n<li>Mocked backend server using Postman Mock Server for API responses&nbsp;</li>\\n</ul>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/d3875f19-8dad-4ed6-9f43-924587394e89?\\" alt=\\"XFlix Landing Page\\" /><img src=\\"https://directus.crio.do/assets/dce905c9-ee3e-4f18-9332-b791e2f33f7d?\\" alt=\\"XFlix Video Page\\" /></div>","skills":[]},{"id":12,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2022-06-30T09:06:40.000Z","user_updated":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_updated":"2023-06-03T08:59:41.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_XCOMMERCE_ANALYTICS","title":"XCommerce","description":"<p>XCommerce is a tool to analyze multi-channel e-commerce sales data. Sellers can list their products for sale on multiple e-commerce websites like Amazon, Flipkart, etc. XCommerce helps to analyze transaction data across these channels and provide sales insights.</p>\\n<p>During the course of this project,</p>\\n<ol>\\n<li>Implemented the core logic of the data analytics module&nbsp;</li>\\n<li>Designed code based on OO concepts&nbsp;</li>\\n<li>Refactored code to support multiple data sources</li>\\n</ol>","image":"d805bc0d-034c-4834-972f-0db7eb10eea4","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>XCommerce is a tool to analyze multi-channel e-commerce sales data. Sellers can list their products for sale on multiple e-commerce websites like Amazon, Flipkart, etc. XCommerce helps to analyze transaction data across these channels and provide sales insights.</p>\\n<p>During the course of this project,</p>\\n<ul>\\n<li>Implemented the core logic of the data analytics module</li>\\n<li>Designed code based on OO concepts</li>\\n<li>Refactored code to support multiple data sources</li>\\n</ul>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/acd6f9b8-8fdc-4ee4-bb77-8ec5d192e342?\\" alt=\\"XCommerce Architecture\\" /></div>","skills":[]},{"id":16,"status":"draft","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-07-01T12:35:52.000Z","user_updated":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_updated":"2022-07-04T05:57:52.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_QKART_BACKEND","title":"QKart Backend","description":"<p>\\"QKart is an E-commerce application offering a variety of products for customers to choose from.&nbsp;</p>\\n<p>During the course of this project,</p>\\n<ul>\\n<li>Built the complete set of REST APIs for an E-commerce application following the best practices</li>\\n<li>Used MongoDB NoSQL database for data storage</li>\\n<li>Wrote unit and integration tests to test the implementation\\"</li>\\n</ul>","image":"f569c5c3-6bf6-470d-9f8c-91d837366d31","source_link":null,"overview_content":"<p>QKart is an E-commerce application offering a variety of products for customers to choose from.&nbsp;</p>\\n<p>During the course of this project,</p>\\n<ul>\\n<li>Built the complete set of REST APIs for an E-commerce application following the best practices</li>\\n<li>Followed a layered approach for easy maintenance</li>\\n<li>Used MongoDB NoSQL database for data storage</li>\\n<li>Implemented multiple authentication schemes</li>\\n<li>Wrote unit and integration tests to test the implementation</li>\\n</ul>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/1bafe70d-f2da-44db-950d-b14a49ffde7f?\\" alt=\\"QKart Layered Architecture\\" /></div>","skills":[]},{"id":17,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2022-07-01T13:32:24.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2023-10-20T13:10:13.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_XBOARD","title":"XBoard","description":"<p>XBoard is a News Feed website that will feature the latest news for select topics, from Flipboard.</p>\\n<p>During the course of this project,</p>\\n<ul>\\n<li>Built XBoard using HTML, CSS, Bootstrap and JavaScript from scratch</li>\\n<li>Used Accordions and Image Carousel to improve UI</li>\\n<li>Fetched news content from flipboard\'s RSS feed using REST API</li>\\n</ul>","image":"f7dfc8ad-a174-4d2b-8af7-c1ff1e1e8719","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>XBoard is a News Feed website that will feature the latest news for select topics, from Flipboard.</p>\\n<p>During the course of this project,</p>\\n<ul>\\n<li>Built XBoard using HTML, CSS, Bootstrap and JavaScript.</li>\\n<li>Utilized the figma file to understand the design requirements</li>\\n<li>Used Accordions and Image Carousel to improve UI</li>\\n<li>Fetched news content from flipboard\'s RSS feed using REST API</li>\\n<li>Deployed the website to Netlify/Vercel</li>\\n</ul>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/856a1f61-b124-4408-a5b6-d9a0bed3f2cd?\\" alt=\\"XBoard FIgma design (Left: Accordion expanded, Right: Accordion collapsed)\\" /><img src=\\"https://directus.crio.do/assets/b96a7da1-f1c3-4f60-8e6d-d00009826f4a?\\" alt=\\"XBoard Figma Design (Left: Desktop view, Right: Mobile view)\\" /><img src=\\"https://directus.crio.do/assets/8e15a16e-2961-4c00-aa3d-d87be9d1901c?\\" alt=\\"XBoard Image Carousel\\" /></div>","skills":[]},{"id":18,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2022-07-01T13:46:50.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2023-10-20T15:25:31.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_QKART_FRONTEND_V2","title":"QKart Frontend","description":"<p>QKart is an e-commerce application offering a variety of products for customers to choose from.&nbsp;</p>\\n<p>During the course of this project,</p>\\n<ul>\\n<li>Implemented the core logic for authentication, shopping cart and checkout</li>\\n<li>Improved UI by adding responsive design elements for uniform experience across different devices</li>\\n<li>Utilized REST APIs to dynamically load and render data served by the backend server</li>\\n</ul>","image":"e6fb82a2-423d-4f62-9962-f19f2f81fa8c","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>QKart is an E-commerce application offering a variety of products for customers to choose from.&nbsp;</p>\\n<p>During the course of this project,</p>\\n<ul>\\n<li>Implemented the core logic for authentication, shopping cart and checkout</li>\\n<li>Improved UI by adding responsive design elements for uniform experience across different devices</li>\\n<li>Utilized REST APIs to dynamically load and render data served by the backend server</li>\\n<li>Deployed website to Netlify/Vercel</li>\\n</ul>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/1034488f-e6c8-4489-bb93-4265fd12fc11?\\" alt=\\"QKart Component Architecture\\" /><img src=\\"https://directus.crio.do/assets/69a039c9-4499-424f-b66c-bc918c32a891?\\" alt=\\"QKart Shopping Interface (Products page)\\" /></div>","skills":[]},{"id":19,"status":"draft","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2022-07-01T15:56:10.000Z","user_updated":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_updated":"2022-08-05T05:52:35.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_XFLIX_NODE","title":"XFlix Node","description":"<p>XFlix is a video sharing platform which hosts videos for the world to watch. It also features uploading new videos by using external video links (eg: Youtube) and playing these videos.</p>\\n<p>During the course of this project,<br />- Built XFlix backend using Node.js, Express.js and MongoDB from scratch<br />- Implemented APIs according to the API contract set</p>","image":"939aec42-d73b-4007-8369-c420055f4e33","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>XFlix is a video sharing platform which hosts videos for the world to watch. It also features uploading new videos by using external video links (eg: Youtube) and playing these videos.</p>\\n<p>During the course of this project,</p>\\n<ul>\\n<li>Built XFlix backend using Node.js, Express.js and MongoDB from scratch</li>\\n<li>Implemented APIs according to the API contract set</li>\\n</ul>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/a894170d-e25e-4c00-a804-0b021d3ad2bb?\\" alt=\\"XFlix API contract in Postman\\" /></div>","skills":[]},{"id":20,"status":"draft","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2022-07-01T16:21:56.000Z","user_updated":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_updated":"2022-07-04T12:16:52.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_XMEME_JAVA","title":"XMeme","description":"<p>XMeme is a simple backend web application where users can post and see memes.</p>\\n<p>During the course of this project,<br />- Built XMeme by writing necessary GET and POST APIs for fetching and posting the memes.<br />- Built the backend application from scratch using a spring starter template and stored/retrieved the data from MongoDB.<br />- Tested the application functionality.</p>","image":"4a6fa325-17bd-4ee9-8b57-a9541084310b","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>XMeme is a simple backend web application where users can post and see memes.</p>\\n<p>During the course of this project,</p>\\n<ul>\\n<li>Built XMeme by writing necessary GET and POST APIs for fetching and posting the memes.</li>\\n<li>Built the backend application from scratch using a spring starter template and stored/retrieved the data from MongoDB.</li>\\n<li>Tested the application functionality.</li>\\n</ul>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/e32b3091-d2d4-4ea6-8ad1-c6a4d77cae62?\\" alt=\\"XMeme mock up\\" /><img src=\\"https://directus.crio.do/assets/edf5e62c-8aa5-42cb-bc7d-b7ba34bc47b0?\\" alt=\\"XMeme Architecture\\" /></div>","skills":[]},{"id":21,"status":"draft","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-07-02T05:58:06.000Z","user_updated":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_updated":"2022-07-04T06:25:10.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_OBJECT_MODELING_V2","title":"Object Modeling","description":"<p>During the course of this project,</p>\\n<ul>\\n<li>Understood the implementation of the Movie booking problem implementation provided by Crio.Do.</li>\\n<li>Built a Hackerrank like contest application by applying their Core Java + design skills</li>\\n<li>Designed &amp; implemented the classes required for a contest framework.</li>\\n<li>Implemented the business logic of running a simulated contest.</li>\\n<li>Built a JukeBox application based on a problem statement, from scratch.</li>\\n</ul>","image":"c495b2a5-b525-4a6b-bd2c-8fa4008cdcf1","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>There is a lot of research and development effort that goes into building an enterprise software, which serves the customers in achieving their business goals. There are certain techniques to be followed to build the software iteratively and adapt to the changing requirements of the end users. This is where good low level design architecture helps.&nbsp;</p>\\n<p>During the course of this project,</p>\\n<ul>\\n<li>Understood the implementation of the Movie booking problem implementation provided by Crio.Do.</li>\\n<li>Built a Hackerrank like contest application by applying their Core Java + design skills</li>\\n<li>Designed &amp; implemented the classes required for a contest framework.</li>\\n<li>Implemented the business logic of running a simulated contest.</li>\\n<li>Built a JukeBox application based on a problem statement, from scratch.</li>\\n</ul>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/f9c45cd7-30b6-430b-b4f0-2aa8b31885fe?\\" alt=\\"\\" /></div>","skills":[]},{"id":22,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-07-19T16:44:34.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2023-04-12T05:45:06.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_QKART_QA","title":"QKart QA","description":"<p>The application under test is <a title=\\"QKart - Ecommerce Platform\\" href=\\"https://crio-qkart-frontend-qa.vercel.app/\\" target=\\"_blank\\" rel=\\"noopener\\">QKart</a>, an e-commerce platform.&nbsp;</p>\\n<p>During the course of this project,</p>\\n<ul>\\n<li>Debugged failing test cases and issues with log statements</li>\\n<li>Automated testing with selenium</li>\\n<li>Improved the tests with XPath</li>\\n<li>Migrated tests to the TestNG test automation framework</li>\\n<li>Performed Data-driven test automation with Apache POI</li>\\n</ul>","image":"eda37aa9-8c78-49ac-b7c8-cc34982c3d91","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p><span style=\\"font-weight: 400;\\">The application under test is </span><a href=\\"https://crio-qkart-frontend-qa.vercel.app/\\"><span style=\\"font-weight: 400;\\">QKart</span></a><span style=\\"font-weight: 400;\\">, an e-commerce platform.&nbsp;</span></p>\\n<p>During the course of this project,</p>\\n<ul>\\n<li>Debugged failing test cases and issues with log statements</li>\\n<li>Automated testing with selenium</li>\\n<li>Utilised implicit and explicit waits correctly to avoid synchronisation issues</li>\\n<li>Improved the tests with XPath</li>\\n<li>Migrated tests to the TestNG test automation framework</li>\\n<li>Performed Data-driven test automation with Apache POI</li>\\n</ul>\\n<h2>Image</h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/525d594c-84af-4a19-92b9-cf6a54f8a4b8?\\" alt=\\"QKart Shopping Interface (Products page)\\" /></div>","skills":[]},{"id":23,"status":"draft","sort":null,"user_created":"7f2f5989-e480-4334-866e-a80901840839","date_created":"2022-07-20T11:35:58.000Z","user_updated":"7f2f5989-e480-4334-866e-a80901840839","date_updated":"2022-07-20T11:35:20.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_QMONEY","title":"QMoney","description":"<p>QMoney is a visual stock portfolio analyzer. It helps portfolio managers make trade recommendations for their clients.</p>\\n<p>During the course of this project,</p>\\n<ul>\\n<li>Implemented the core logic of the portfolio manager and published it as a library.</li>\\n<li>Refactored code to add support for multiple stock quote services.</li>\\n<li>Improved application stability and performance.</li>\\n</ul>","image":"bed446b9-7dba-4b0a-b42e-5744a26ad2f0","source_link":"https://www.google.com/","overview_content":"<h1>Overview</h1>\\n<p>QMoney is a visual stock portfolio analyzer. It helps portfolio managers make trade recommendations for their clients.</p>\\n<p>During the course of this project,</p>\\n<ul>\\n<li>Implemented the core logic of the portfolio manager and published it as a library.</li>\\n<li>Refactored code to add support for multiple stock quote services.</li>\\n<li>Improved application stability and performance.</li>\\n</ul>\\n<h2>Image</h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/c1ecb8f4-e223-4524-9981-b724dae69857?\\" alt=\\"QMoney Architecture\\" /><img src=\\"https://directus.crio.do/assets/26bbdd88-044f-441f-8b2d-17423a498033?\\" alt=\\"QMoney Portfolio Manager Interface\\" /></div>","skills":[]},{"id":24,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-07-20T16:00:19.000Z","user_updated":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_updated":"2023-06-03T08:59:01.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_XURL","title":"XURL","description":"<p>XURL is a utility that can be used to generate and retrieve short URLs when we don&rsquo;t want to use the original longer URLs.</p>\\n<p>During the course of this project,</p>\\n<ol>\\n<li>Created a short url library with required methods.</li>\\n<li>Implemented register method to take a long URL and return a shorter URL.</li>\\n<li>Implemented hit count to track number of long URL lookups.</li>\\n</ol>","image":"7b1f5136-4373-4d31-a265-d7906f11c707","source_link":null,"overview_content":"<p>XURL is a utility that can be used to generate and retrieve short URLs when we don&rsquo;t want to use the original longer URLs.</p>\\n<p>During the course of this project,</p>\\n<ol>\\n<li>Created a short url library with required methods.</li>\\n<li>Implemented register method to take a long URL and return a shorter URL.</li>\\n<li>Implemented a method to lookup the long URL by providing the short URL.</li>\\n<li>Implemented hit count to track number of long URL lookups.</li>\\n<li>Tested this implementation with test cases.</li>\\n</ol>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/ab8dd8fa-eb03-4a52-8b87-666ebc0d164b?\\" alt=\\"XURL Interface\\" /></div>","skills":[]},{"id":25,"status":"draft","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2022-08-03T06:14:37.000Z","user_updated":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_updated":"2022-08-24T09:29:43.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_XCOMPANY","title":"XCompany","description":"<p><span style=\\"font-weight: 400;\\">XCompany is a KYC (Know Your Company) application which allows employees working in their respective company to know about the hierarchy structure of the people working with them.</span></p>\\n<p>During the course of this project,</p>\\n<ul>\\n<li><span style=\\"font-weight: 400;\\">Setup a new Project with required methods.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Understand the application requirements and implemented the project from scratch</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Tested the implementation with test cases to ensure correctness</span></li>\\n</ul>","image":"57da3417-a614-4ca9-9526-d3b1d6826fea","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p><span style=\\"font-weight: 400;\\">XCompany is a KYC (Know your Company) application which allows employees working in their respective company to know about the hierarchy structure of the people working with them. It gives an overview of employees working under different teams across the company which makes it easier to reach out to them.</span></p>\\n<p><span style=\\"font-weight: 400;\\">During the course of this Micro-Experience, the developer:</span></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Setup a new Project with required methods.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Understand the application requirements and implemented the project from scratch</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Tested the implementation with test cases to ensure correctness</span></li>\\n</ul>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/c3cddb88-95f1-42b6-9ff5-45ea5c3428e0?\\" alt=\\"Commands Implemented for XCompany Application\\" /></div>","skills":[]},{"id":26,"status":"draft","sort":null,"user_created":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_created":"2022-08-04T11:18:17.000Z","user_updated":"c9fde96d-9501-41ab-90fd-c90abdc4d0cf","date_updated":"2023-10-24T09:20:12.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_XPATH_ADVANCED","title":"Redbus Automation","description":"<p><span style=\\"font-weight: 400;\\">Automated finding of the lowest fare between two cities on Redbus using </span><em><span style=\\"font-weight: 400;\\">Selenium</span></em><span style=\\"font-weight: 400;\\">, </span><em><span style=\\"font-weight: 400;\\">Implicit wait</span></em><span style=\\"font-weight: 400;\\"> and </span><em><span style=\\"font-weight: 400;\\">Dynamic XPath</span></em></p>\\n<p><span style=\\"font-weight: 400;\\"><a href=\\"https://youtube.com/embed/9gASL7QTpg0\\" target=\\"_blank\\" rel=\\"noopener\\">View Demo</a></span></p>","image":"7fa5665c-26e0-4f2d-9ef2-eb4b5fbbc103","source_link":null,"overview_content":null,"skills":[]},{"id":28,"status":"draft","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2022-08-04T11:28:48.000Z","user_updated":"c9fde96d-9501-41ab-90fd-c90abdc4d0cf","date_updated":"2023-10-24T09:21:15.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_SELENIUM_WEB_ACTIONS_WEB_TABLE","title":"Automated web elements","description":"<p><span style=\\"font-weight: 400;\\">Utilised Selenium to interact with and automate buttons, text fields, hyperlinks, images, radio buttons, checkboxes, single and multi-select dropdowns, calendars and tables <a href=\\"https://web-locators-static-site-qa.vercel.app/\\" target=\\"_blank\\" rel=\\"noopener\\">on a static website</a>.</span></p>\\n<p><span style=\\"font-weight: 400;\\"><a href=\\"https://www.youtube.com/embed/-lo5vffel7I\\" target=\\"_blank\\" rel=\\"noopener\\">View Demo</a></span></p>","image":"3bfd0171-8d6d-4dad-8032-0af332eb74f9","source_link":null,"overview_content":null,"skills":[]},{"id":29,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2022-08-04T11:30:39.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2024-06-24T10:06:51.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_APACHE_POI","title":"Test Automation with Apache POI","description":"<p><span style=\\"font-weight: 400;\\">Used </span><em><span style=\\"font-weight: 400;\\">TestNG</span></em><span style=\\"font-weight: 400;\\"> to automate the validation of user credentials. Credentials were read from an </span><span style=\\"font-weight: 400;\\">Excel</span><span style=\\"font-weight: 400;\\"> file using </span><span style=\\"font-weight: 400;\\">Apache POI</span><span style=\\"font-weight: 400;\\"> and validation results were written back to the Excel file.</span></p>","image":"b0b38e3d-2cce-4e2f-ad55-f25ac6f9c8bc","source_link":null,"overview_content":null,"skills":[]},{"id":30,"status":"draft","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2022-08-04T11:31:14.000Z","user_updated":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_updated":"2022-08-24T09:28:46.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_MYSQL","title":"CRUD with SQL","description":"<p><span style=\\"font-weight: 400;\\">Created </span><em><span style=\\"font-weight: 400;\\">MySQL</span></em><span style=\\"font-weight: 400;\\"> tables and performed </span><em><span style=\\"font-weight: 400;\\">CRUD</span></em><span style=\\"font-weight: 400;\\"> operations on a travel booking company database. Analysed the data with SQL queries for </span><span style=\\"font-weight: 400;\\">ordering</span><span style=\\"font-weight: 400;\\">, </span><span style=\\"font-weight: 400;\\">filtering</span><span style=\\"font-weight: 400;\\"> and </span><span style=\\"font-weight: 400;\\">aggregate</span><span style=\\"font-weight: 400;\\"> operations.</span></p>","image":"0b9f1a1b-57b7-4fee-ae56-7aac33648a76","source_link":null,"overview_content":null,"skills":[]},{"id":31,"status":"draft","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2022-08-04T11:32:02.000Z","user_updated":"c9fde96d-9501-41ab-90fd-c90abdc4d0cf","date_updated":"2023-10-24T09:21:34.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_JENKINS_V2","title":"CI/CD pipeline with Jenkins","description":"<p><span style=\\"font-weight: 400;\\">Used Jenkins to create jobs for executing tests, and sending email notifications</span></p>\\n<p><span style=\\"font-weight: 400;\\"><a href=\\"https://www.youtube.com/embed/5I5Rsvb0HMo\\" target=\\"_blank\\" rel=\\"noopener\\">View Demo</a></span></p>","image":"667e6bdf-544d-45b4-aaf2-db43de9f6028","source_link":null,"overview_content":null,"skills":[]},{"id":32,"status":"draft","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2022-08-04T11:32:32.000Z","user_updated":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_updated":"2022-08-24T09:29:27.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_TEST_CASE_DESIGN_TECHNIQUES","title":"Test case design","description":"<p><span style=\\"font-weight: 400;\\">Designed test cases and test data for an E-commerce application using different test case design techniques like Boundary Value Analysis &amp; Decision Tables</span></p>","image":"5fa30acb-0697-4f33-bcc6-60dd0216509c","source_link":null,"overview_content":null,"skills":[]},{"id":33,"status":"draft","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2022-08-04T11:34:36.000Z","user_updated":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_updated":"2022-08-24T09:27:46.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_BI_PROJECT","title":"E-commerce website Test Automation","description":"<p><span style=\\"font-weight: 400;\\">Performed audit of an e-commerce website for the correctness of product pricing using </span><em><span style=\\"font-weight: 400;\\">Selenium. </span></em><span style=\\"font-weight: 400;\\">Took full page screenshots with </span><span style=\\"font-weight: 400;\\">Ashot</span><span style=\\"font-weight: 400;\\"> library. </span><span style=\\"font-weight: 400;\\">Web Driver Manager</span><span style=\\"font-weight: 400;\\"> was used to download the appropriate driver executable and </span><span style=\\"font-weight: 400;\\">Gradle</span><span style=\\"font-weight: 400;\\"> for build automation.</span></p>","image":"cad6de00-0cbc-4e3a-9bba-7a420dfd1b9f","source_link":null,"overview_content":null,"skills":[]},{"id":35,"status":"draft","sort":null,"user_created":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_created":"2022-08-24T09:31:36.000Z","user_updated":"c9fde96d-9501-41ab-90fd-c90abdc4d0cf","date_updated":"2023-10-24T09:18:52.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_TESTNG1","title":"WhatsApp Automation","description":"<p><span style=\\"font-weight: 400;\\">Automated sending of personalised Whatsapp messages using </span><span style=\\"font-weight: 400;\\">Selenium keyboard operations</span><span style=\\"font-weight: 400;\\"> and </span><span style=\\"font-weight: 400;\\">Chained XPath.</span></p>\\n<p><span style=\\"font-weight: 400;\\"><a href=\\"https://www.youtube.com/embed/4d0ekxWWY-0\\" target=\\"_blank\\" rel=\\"noopener\\">View Demo</a></span></p>","image":"4c27cf93-e44b-4434-8a39-74f63313b649","source_link":null,"overview_content":null,"skills":[]},{"id":36,"status":"published","sort":null,"user_created":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_created":"2022-08-30T06:15:03.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2023-06-05T12:16:55.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_QCALC_V2","title":"QCalc","description":"<p><span style=\\"font-weight: 400;\\">The objective of this project is to obtain basic skills in Java and OOPs principles by building a subset of features seen in calculators.</span></p>\\n<p><span style=\\"font-weight: 400;\\">During the course of this project,&nbsp;</span></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Made use of different features of VSCode IDE to build the project.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Built feature of a calculator by taking OOPS Principles into consideration.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Fixed the bugs in the implementation for newly introduced features of calculator.</span></li>\\n</ul>","image":"7104b205-e28c-417c-8ff4-bb7e43131a64","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>The objective of this project is to obtain basic skills in Java and OOPs principles by building a subset of features seen in calculators.</p>\\n<p>During the course of this project,</p>\\n<ul>\\n<li>Made use of different features of VSCode IDE to build the project.</li>\\n<li><span style=\\"font-weight: 400;\\">Built feature of a calculator by taking OOPS Principles into consideration.</span></li>\\n<li>Fixed the bugs in the implementation for newly introduced features of calculator.</li>\\n</ul>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/ef4cab57-0746-4102-ab12-096b226c6fd5?\\" alt=\\"\\" /></div>","skills":[]},{"id":37,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2023-02-02T14:23:18.000Z","user_updated":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_updated":"2023-04-12T08:40:18.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_QCALC_QA","title":"QCalc","description":"<p><span style=\\"font-weight: 400;\\">This project aims to obtain basic skills in Java and OOPs principles by building a subset of features seen in calculators.</span></p>\\n<p><span style=\\"font-weight: 400;\\">During the course of this project:</span></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Made use of different features of VSCode IDE to build the project.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Built feature of a calculator by following OOPS Principles.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Wrote unit tests to ensure edge cases are handled correctly.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Fixed the bugs in the implementation of newly introduced features of the calculator.</span></li>\\n</ul>","image":"36156344-bf57-4ae8-9e5e-019a9e49fa7c","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>This project aims to obtain basic skills in Java and OOPs principles by building a subset of features seen in calculators..</p>\\n<p>During the course of this Micro-Experience, the developer:</p>\\n<ul>\\n<li>Made use of different features of VSCode IDE to build the project.</li>\\n<li><span style=\\"font-weight: 400;\\">Built feature of a calculator by taking OOPS Principles into consideration.</span></li>\\n<li>Wrote unit tests to ensure edge cases are handled correctly.</li>\\n<li>Fixed the bugs in the implementation for newly introduced features of the calculator.</li>\\n</ul>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/ef4cab57-0746-4102-ab12-096b226c6fd5?\\" alt=\\"\\" /></div>","skills":[]},{"id":38,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2023-02-21T11:19:33.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2023-02-22T11:20:26.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_QCONTEST","title":"QContest","description":"<p>Pick up a problem statement, approach it systematically, develop a Low-Level Design, and implement it.</p>","image":"8f3bf4b5-58d8-4971-8b47-d861125a4d88","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>A lot of research and development effort goes into building enterprise software that serves the customers in achieving their business goals. There are specific techniques to be followed to build the software iteratively and adapt to the changing requirements of the end users. This is where good low-level design architecture helps.&nbsp;</p>\\n<h2>During this Micro-Experience, the developer:</h2>\\n<p>Built a Hackerrank-like contest application by applying their Core Java + design skills<br />Designed &amp; implemented the classes required for a contest framework.<br />Implemented the business logic of running a simulated contest.</p>\\n<p>Milestone 0:&nbsp;</p>\\n<p>Extended Overview</p>\\n<p><img src=\\"https://directus.crio.do/assets/c3d2df4c-a776-4359-8fa3-f310311c0485?\\" alt=\\"Image1\\" /></p>","skills":[]},{"id":39,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2023-02-21T12:07:56.000Z","user_updated":null,"date_updated":null,"type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_MACHINE_CODING_JUKEBOX","title":"Buildout Machine Coding Jukebox","description":"<p>Pick up a problem statement, approach it systematically, develop a Low-Level Design, and implement it.</p>","image":"2c1c74fa-a707-466f-a01c-a6e1963a9c40","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>Everyone listens to songs on their favorite app ( Savvn, Wynk ) but have you ever thought about How you would make your music player? Design a music player with the features given below.&nbsp;</p>\\n<ul>\\n<li>A user can create a playlist from an available pool of songs.</li>\\n<li>A user can add songs to the playlist.</li>\\n<li>Users can play the playlist and be able to switch songs (forward or backward)</li>\\n<li>List all the songs in the pool.</li>\\n</ul>\\n<h2>During this Micro-Experience, the developer:</h2>\\n<ul>\\n<li>Set up a new Project with the required classes.</li>\\n<li>Understand the application requirements and implement the problem statement from scratch.</li>\\n<li>Tested the implementation with test cases to ensure correctness.</li>\\n</ul>\\n<p>Milestone 0:&nbsp;</p>\\n<p>Extended Overview</p>\\n<p><img src=\\"https://directus.crio.do/assets/cc7e20af-944d-4e48-9a1b-09417f1df713?\\" alt=\\"Image1\\" /></p>","skills":[]},{"id":40,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2023-02-21T12:26:50.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2023-02-22T11:21:33.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_MACHINE_CODING_RESTAURANT_RATING","title":"Machine Coding - Restaurant Rating","description":"<p>Pick up a problem statement, approach it systematically, develop a Low-Level Design, and implement it.</p>","image":"da5c8526-dd70-4576-8252-1e208622314a","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>Everyone uses zomato or swiggy, but have you ever seen how restaurant rating systems work? Design a restaurant rating platform with the features given below.</p>\\n<h2>During this Micro-Experience, the developer:</h2>\\n<ul>\\n<li>\\n<p>Users should be able to register to give ratings ( 1 to 5 ) &nbsp;for restaurants.</p>\\n</li>\\n<li>\\n<p>Users can add optional dish name(s) and rating descriptions along with a rating. Basically, It is a review.</p>\\n</li>\\n<li>\\n<p>Fetch reviews for a restaurant based on filter and order conditions mentioned below:</p>\\n</li>\\n<li>\\n<p>Filter reviews based on a range of ratings ( e.g., Filter reviews that have a rating between 2 and 5<br />Display ratings in ascending or descending order The default order is to display ratings in descending order List restaurants based on descending order of (average) rating.</p>\\n</li>\\n<li>\\n<p>&nbsp;</p>\\n<p>During this Micro-Experience, the developer:</p>\\n</li>\\n<li>\\n<p>Set up a new Project with the required classes.</p>\\n</li>\\n<li>\\n<p>Understand the application requirements and implement the problem statement from scratch.<br />Tested the implementation with test cases to ensure correctness.</p>\\n</li>\\n</ul>\\n<p>Milestone 0:&nbsp;</p>\\n<p>Extended Overview</p>\\n<p><img src=\\"https://directus.crio.do/assets/42bda357-029b-41fd-a4d2-dc9a23521746?\\" alt=\\"Image1\\" /></p>","skills":[]},{"id":41,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2023-04-12T05:54:45.000Z","user_updated":"c9fde96d-9501-41ab-90fd-c90abdc4d0cf","date_updated":"2023-10-24T08:56:21.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_QTRIP_QA","title":"QTrip QA","description":"<p>The application under test is <a href=\\"https://qtripdynamic-qa-frontend.vercel.app/\\" target=\\"_blank\\" rel=\\"noopener\\">QTrip</a>, a travel website.</p>\\n<p>During the course of this project,:</p>\\n<ul>\\n<li>Wrote manual test cases for the different webpages in the application.</li>\\n<li>Automated 4 test cases of end to end user flows using Selenium.</li>\\n<li>Created a TestNG project for easily running automated test cases.</li>\\n<li>Generated customised test reports for the TestNG project.</li>\\n</ul>","image":"ec48bef5-2566-4af5-8a6e-2f978e63d1b5","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>The application under test is <a href=\\"https://qtripdynamic-qa-frontend.vercel.app/\\" target=\\"_blank\\" rel=\\"noopener\\">QTrip</a>, a travel website.</p>\\n<p>During the course of this project,:</p>\\n<ul>\\n<li>Wrote manual test cases for the different webpages in the application.</li>\\n<li>Automated more than X test cases using Selenium.</li>\\n<li>Created a TestNG project for easily running automated test cases.</li>\\n<li>Generated customised test reports for the TestNG project.</li>\\n</ul>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/b3f32a8f-08ac-40c5-8ed9-2a594090be5a?\\" alt=\\"Image1\\" /></div>","skills":[]},{"id":42,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2023-06-08T12:25:14.000Z","user_updated":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_updated":"2023-06-09T11:59:59.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_SHORT_URL","title":"Short URL","description":"<p>SHORT URL is a utility that can be used to generate and retrieve short URLs when we don&rsquo;t want to use the original longer URLs.</p>\\n<p>During the course of this project,</p>\\n<ol>\\n<li>Created a short url library with required methods.</li>\\n<li>Implemented register method to take a long URL and return a shorter URL.</li>\\n<li>Implemented hit count to track number of long URL lookups.</li>\\n</ol>","image":"de142c3b-46e6-438f-8944-9474b7593688","source_link":null,"overview_content":"<p>SHORT URL is a utility that can be used to generate and retrieve short URLs when we don&rsquo;t want to use the original longer URLs.</p>\\n<p>During the course of this project,</p>\\n<ol>\\n<li>Created a short url library with required methods.</li>\\n<li>Implemented register method to take a long URL and return a shorter URL.</li>\\n<li>Implemented a method to lookup the long URL by providing the short URL.</li>\\n<li>Implemented hit count to track number of long URL lookups.</li>\\n<li>Tested this implementation with test cases</li>\\n</ol>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/ab8dd8fa-eb03-4a52-8b87-666ebc0d164b?\\" alt=\\"XURL Interface\\" /></div>","skills":[]},{"id":43,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2023-06-08T12:28:32.000Z","user_updated":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_updated":"2023-06-14T04:52:51.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_QCOMMERCE_ANALYTICS","title":"QCommerce Analytics","description":"<p>QCommerce is a tool to analyze multi-channel e-commerce sales data. Sellers can list their products for sale on multiple e-commerce websites like Amazon, Flipkart, etc. QCommerce helps to analyze transaction data across these channels and provide sales insights.</p>\\n<p>During the course of this project,</p>\\n<ol>\\n<li>Implemented the core logic of the data analytics module&nbsp;</li>\\n<li>Designed code based on OO concepts&nbsp;</li>\\n<li>Refactored code to support multiple data sources</li>\\n</ol>","image":"c7bfe5c6-3058-4285-8440-f5a43ece2edf","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>QCommerce is a tool to analyze multi-channel e-commerce sales data. Sellers can list their products for sale on multiple e-commerce websites like Amazon, Flipkart, etc. QCommerce helps to analyze transaction data across these channels and provide sales insights.</p>\\n<p>During the course of this project,</p>\\n<ul>\\n<li>Implemented the core logic of the data analytics module</li>\\n<li>Designed code based on OO concepts</li>\\n<li>Refactored code to support multiple data sources</li>\\n</ul>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/acd6f9b8-8fdc-4ee4-bb77-8ec5d192e342?\\" alt=\\"XCommerce Architecture\\" /></div>","skills":[]},{"id":44,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2023-06-13T12:01:26.000Z","user_updated":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_updated":"2023-06-14T02:52:32.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_API_TESTING_PROJECT","title":" API Testing Project","description":"<p>API Testing on travel Website using automation</p>\\n<p>The application under test is <a href=\\"https://qtripdynamic-qa-frontend.vercel.app/\\" target=\\"_blank\\" rel=\\"noopener\\">QTrip</a>, a travel website.&nbsp;</p>\\n<p>During the course of this project,<br />&nbsp; &nbsp; &nbsp;- Executed manual End to End API testing for APIs of different web pages using Postman.<br />&nbsp; &nbsp; &nbsp;- Automated the API tests using Rest Assured Framework and Java.<br />&nbsp; &nbsp; &nbsp;- Integrated API tests along with UI Tests.<br />&nbsp; &nbsp; &nbsp;- Created a TestNG project for easily running automated testing and used XML file to selectively run tests.</p>","image":"1f3567fa-52e0-45ad-a30f-b3131889d320","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>The application under test is <a href=\\"https://qtripdynamic-qa-frontend.vercel.app/\\" target=\\"_blank\\" rel=\\"noopener\\">QTrip</a>, a travel website.&nbsp;</p>\\n<p>During the course of this project,<br />&nbsp; &nbsp; &nbsp;- Executed manual End to End API testing for APIs of different web pages using Postman.<br />&nbsp; &nbsp; &nbsp;- Automated the API tests using Rest Assured Framework and Java.<br />&nbsp; &nbsp; &nbsp;- Integrated API tests along with UI Tests.<br />&nbsp; &nbsp; &nbsp;- Created a TestNG project for easily running automated testing and used XML file to selectively run tests.&nbsp;</p>","skills":[]},{"id":45,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2023-06-19T12:00:55.000Z","user_updated":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_updated":"2023-12-01T08:46:07.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_QCALC_V3","title":"QCalc","description":"<p>Headline</p>\\n<p>Build a simple calculator project using Java from scratch</p>\\n<p>Overview</p>\\n<p>This project aims to obtain basic skills in Java by building a subset of features seen in calculators.</p>\\n<p>During the course of this Micro-Experience, the developer:</p>\\n<ul>\\n<li>Generated a new Java project using Gradle.</li>\\n<li>Built features of a calculator by using Java.</li>\\n<li>Fixed the bugs in the implementation of newly introduced features of the calculator.</li>\\n</ul>","image":"1f3567fa-52e0-45ad-a30f-b3131889d320","source_link":null,"overview_content":"<p>Overview<br />This project aims to obtain basic skills in Java by building a subset of features seen in calculators.</p>\\n<p>During the course of this Micro-Experience, the developer:</p>\\n<ul>\\n<li>Generated a new Java project using Gradle.</li>\\n<li>Built features of a calculator by using Java.</li>\\n<li>Fixed the bugs in the implementation of newly introduced features of the calculator.</li>\\n</ul>","skills":[]},{"id":46,"status":"published","sort":null,"user_created":"42670516-02dd-418e-abaa-d5ff0d183714","date_created":"2023-06-28T10:30:28.000Z","user_updated":"96947060-767d-4dc3-8a57-ab05646a591f","date_updated":"2025-05-02T07:29:06.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_XQUIZ","title":"A Quiz application","description":"<p>XQuiz is a quiz application that allows us to create a Quiz comprising multiple Questions. Each Question will have multiple choices, of which one will be a correct answer. This application can display the created Quiz to a user, get their choices for the Quiz, evaluate them, and provide a score.</p>\\n<p>During the course of this Micro-Experience, the developer:</p>\\n<ul>\\n<li>Comprehended the requirements of the application.</li>\\n<li>Built the command line quiz application by following the OOPs concepts.</li>\\n<li>Performed unit tests for checking the correctness of working of the application.</li>\\n</ul>","image":"578bbdef-de3c-43a9-9b13-af641eb15df4","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>&nbsp;</p>\\n<p>XQuiz is a quiz application that allows us to create a Quiz comprising multiple Questions. Each Question will have multiple choices, of which one will be a correct answer. This application can display the created Quiz to a user, get their choices for the Quiz, evaluate them, and provide a score.</p>\\n<p>During the course of this Micro-Experience, the developer:</p>\\n<ul>\\n<li>Comprehended the requirements of the application.</li>\\n<li>Built the command line quiz application by following the OOPs concepts.</li>\\n<li>Performed unit tests for checking the correctness of working of the application.</li>\\n</ul>","skills":[]},{"id":47,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2023-07-24T06:15:07.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2023-07-24T11:09:39.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_QTRIP_QA_V2","title":"QTrip QA","description":"<p>The application under test is <a href=\\"https://qtripdynamic-qa-frontend.vercel.app/\\" target=\\"_blank\\" rel=\\"noopener\\">QTrip</a>, a travel website.</p>\\n<p>During the course of this project,:</p>\\n<ul>\\n<li>Designed and automated 4+ test cases following Page Object Model design pattern using Page Factory, Selenium and TestNG</li>\\n<li>Utilized Apache POI in each test to accept dynamic test data.</li>\\n<li>Created a TestNG project for easily running automated test cases.</li>\\n<li>Implemented Singleton pattern for initializing Wedbriver to make effective use of resources.</li>\\n<li>Generated customized test reports for the TestNG project using Extent Reports.<br /><br /></li>\\n</ul>","image":"a38aa5b9-6e97-40d5-b7cb-5a35e9d32c88","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>The application under test is <a href=\\"https://qtripdynamic-qa-frontend.vercel.app/\\" target=\\"_blank\\" rel=\\"noopener\\">QTrip</a>, a travel website.</p>\\n<p>During the course of this project,:</p>\\n<ul>\\n<li>Designed and automated 4+ test cases following Page Object Model design pattern using Page Factory, Selenium and TestNG</li>\\n<li>Utilized Apache POI in each test to accept dynamic test data.</li>\\n<li>Created a TestNG project for easily running automated test cases.</li>\\n<li>Implemented Singleton pattern for initializing Wedbriver to make effective use of resources.</li>\\n<li>Generated customized test reports for the TestNG project using Extent Reports.</li>\\n</ul>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/b3f32a8f-08ac-40c5-8ed9-2a594090be5a?\\" alt=\\"Image1\\" /></div>","skills":[]},{"id":48,"status":"draft","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2023-08-31T05:19:38.000Z","user_updated":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_updated":"2026-02-04T13:46:52.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_QKART_QA_V2","title":"QKart QA","description":"<p>The application under test is <a title=\\"QKart - Ecommerce Platform\\" href=\\"https://crio-qkart-frontend-qa.vercel.app/\\" target=\\"_blank\\" rel=\\"noopener\\">QKart</a>, an e-commerce platform.&nbsp;</p>\\n<p>During the course of this project,</p>\\n<ul>\\n<li>Debugged failing test cases and issues with log statements</li>\\n<li>Automated testing with selenium</li>\\n<li>Utilised implicit and explicit waits correctly to avoid synchronisation issues</li>\\n<li>Improved the tests with XPath</li>\\n<li>Migrated tests to the TestNG test automation framework</li>\\n<li>Performed Data-driven test automation with Apache POI</li>\\n</ul>","image":"b2ae0d1b-2876-4f8d-9184-aedcbdc8ab48","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p><span style=\\"font-weight: 400;\\">The application under test is </span><a href=\\"https://crio-qkart-frontend-qa.vercel.app/\\"><span style=\\"font-weight: 400;\\">QKart</span></a><span style=\\"font-weight: 400;\\">, an e-commerce platform.&nbsp;</span></p>\\n<p>During the course of this project,</p>\\n<ul>\\n<li>Debugged failing test cases and issues with log statements</li>\\n<li>Automated testing with selenium</li>\\n<li>Utilised implicit and explicit waits correctly to avoid synchronisation issues</li>\\n<li>Improved the tests with XPath</li>\\n<li>Migrated tests to the TestNG test automation framework</li>\\n<li>Performed Data-driven test automation with Apache POI</li>\\n</ul>\\n<h2>Image</h2>\\n<div class=\\"image-container\\">&nbsp;</div>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/e8f0f67a-82db-4fba-bf63-aea7763e233f?\\" alt=\\"QKart Shopping Interface (Products page)\\" /></div>","skills":[]},{"id":49,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2023-11-26T11:46:11.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2023-12-08T07:26:30.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_XSEARCH1","title":"Amazon Store Automation","description":"<p>This project involves automating the search feature of <a href=\\"https://www.amazon.in/\\" target=\\"_blank\\" rel=\\"noopener\\">Amazon</a> store and validating the resultant data. Additionally menu features and footers are also being validated.</p>","image":"2cd49a29-bd6a-48da-a652-09a17effa7bb","source_link":null,"overview_content":"<p>This project involves automating the search feature of Amazon store and validating the resultant data. Additionally menu features and footers are also being validated.</p>\\n<p>&nbsp;</p>\\n<p><img src=\\"https://directus.crio.do/assets/e769e691-d01d-44dd-bc68-158e1de8dfb1?\\" alt=\\"Xsearch Milestone\\" /></p>","skills":[]},{"id":50,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2023-11-26T11:49:29.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2023-12-08T07:36:36.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_XSEARCH2","title":"Wikipedia Automation","description":"<p>This project involves automating the search feature of <a href=\\"https://www.wikipedia.org/\\" target=\\"_blank\\" rel=\\"noopener\\">Wikipedia</a> to validate certain factual data, such as the name of the founder of certain organizations, as well as validating ohter basic functionalities.</p>","image":"c2403973-90db-40cf-b4d1-4fb63b044286","source_link":null,"overview_content":"<p>This project involves automating the search feature of Wikipedia to validate certain factual data, such as the name of the founder of certain organizations, as well as validating other basic functionalities.</p>\\n<p><img src=\\"https://directus.crio.do/assets/e49b5fa6-c5cf-48bb-8317-7b998ed0b74d?\\" alt=\\"Xsearch2 Overview\\" /></p>","skills":[]},{"id":51,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2023-12-08T07:49:21.000Z","user_updated":null,"date_updated":null,"type":"MICRO_EXPERIENCE","readable_id":"ME_ZCOMMERCE_QA","title":"Distributed Systems Testing","description":"<p>ZCommerce is an E-commerce application with distributed microservice architecture. This project involved performing test bed configuration, API testing, DB Testing and Logging<br />During the course of this project,</p>\\n<ul>\\n<li>Used docker containers to configure the test environment and test bed</li>\\n<li>RestAssured is used to perform API Tests based on Swagger documentation. The Microservices under consideration were -<br />&nbsp; - Order Service<br />&nbsp; - Product Service<br />&nbsp; - Notification Service<br />&nbsp; - Frontend</li>\\n<li>JDBC is used to perform automated ests on the MySQL database</li>\\n<li>Log4J is used to log important information within the test suite.</li>\\n</ul>","image":"4619c729-831c-4250-86ae-a949642e9d34","source_link":null,"overview_content":"<p>ZCommerce QA project uses Docker, Restassured, JDBC, and Log4j to set up an environment and test a microservice, specifically the Order service of ZCommerce Application.</p>\\n<ul>\\n<li>Docker is used to configure the test environment and test bed</li>\\n<li>Mock server is configured using Postman client</li>\\n<li>RestAssured is used to perform API Tests based on Swagger documentation</li>\\n<li>JDBC is used to perform DB Tests on the application</li>\\n<li>Log4J is used to log important information within the test suite.</li>\\n</ul>\\n<p>Architecture of the AUT can be found here:</p>\\n<p><img src=\\"https://directus.crio.do/assets/6ba5cce8-15a0-4605-8412-60b818405dcf?\\" alt=\\"Zcommerce Overview\\" /></p>","skills":[]},{"id":52,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2023-12-08T08:44:47.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2023-12-16T11:48:47.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_AWS_CLOUD","title":"Cloud Video to Audio Converter","description":"<p>Explored AWS Cloud services like EC2, RDS, Lambda, S3 to combine and create a Video to Audio convertor application.&nbsp;<br />During the course of this project</p>\\n<ul>\\n<li>Hosted the UI of the application with EC2 service and set up inbound rules to expose the application to the internet.&nbsp;</li>\\n<li>Stored user and video related info using the RDS service</li>\\n<li>Stored the uploaded video and generated audio files in S3 buckets</li>\\n<li>Set up the logic for video to audio conversion with Lambda service</li>\\n<li>Set up cloudwatch to monitor the recently brought up services</li>\\n</ul>","image":"6568dca7-07bd-4bf5-89ad-71b0ab643cfe","source_link":null,"overview_content":null,"skills":[]},{"id":53,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2023-12-15T13:05:37.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2023-12-18T11:01:44.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_QA_XGMAIL_CAL1","title":"Google Calendar Automation","description":"<p>During the course of this project automated Google Calendar to create, delete and schedule Tasks on the Calendar using and explored methods of having a signed google chrome Instance.</p>","image":"df9806c0-3101-4646-a6ab-9b7cc6f41d1c","source_link":null,"overview_content":"<p>During the course of this project automated Google Calendar to create, delete and schedule Tasks on the Calendar using and explored methods of having a signed google chrome Instance.</p>\\n<p><img src=\\"https://directus.crio.do/assets/f828f5bc-db45-4c78-8c71-5ee0ade37d7d\\" alt=\\"Image1\\" /></p>","skills":[]},{"id":54,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2023-12-16T09:11:55.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2023-12-18T11:04:08.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_QA_XGOOGLE_CALC1","title":"Google Calculator Automation ","description":"<p>During the course of this project automated Google Calculator to validate arithmetic operations and &nbsp;&ldquo;AC&rdquo; button functionality of the Website.</p>","image":"e01c71e8-d914-4075-a309-dbf8031852fa","source_link":null,"overview_content":"<p>During the course of this project automated Google Calculator to validate arithmetic operations and &nbsp;&ldquo;AC&rdquo; button functionality of the Website.</p>\\n<p><img src=\\"https://directus.crio.do/assets/7af61e40-04e0-4c61-ab2f-e6b2884a0f1b\\" alt=\\"Image1\\" /></p>","skills":[]},{"id":55,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2023-12-16T10:38:16.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2023-12-18T11:06:30.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_QA_XLEETCODE1","title":"LeetCode automation","description":"<p>During the course of this project automated Leetcode website to check and validate the latest 5 questions from the LeetCode problems page and ensure submitting solutions are blocked without Sign In.</p>","image":"5616fde8-2015-434e-934c-e3b61ef385fe","source_link":null,"overview_content":"<p>During the course of this project automated Leetcode website to check and validate the latest 5 questions from the LeetCode problems page and ensure submitting solutions are blocked without Sign In.</p>\\n<p><img src=\\"https://directus.crio.do/assets/8ee15cc2-3d5c-41a0-92ad-c496196c86a0\\" alt=\\"Image1\\" /></p>","skills":[]},{"id":56,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2023-12-16T11:18:08.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2023-12-18T11:08:30.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_QA_XMMT_SEARCH1","title":"Make My Trip Automation","description":"<p>During the course of this project automated Make My Trip website to get flight, bus and train details from 2 destinations and validating the search functionality of the website.</p>","image":"7cd88c41-6fee-447f-a54e-55afe9649e7b","source_link":null,"overview_content":"<p>During the course of this project automated Make My Trip website to get flight, bus and train details from 2 destinations and validating the search functionality of the website.</p>\\n<p><img src=\\"https://directus.crio.do/assets/1c5fa788-19d1-4089-ae80-2e89f001a81e\\" alt=\\"Image1\\" /></p>","skills":[]},{"id":57,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2024-01-19T13:23:37.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2024-01-24T05:33:44.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_QTIFY","title":"QTify","description":"<p>QTify is a song-browsing application built from scratch using ReactJS paired with Material UI and Swiper to deliver a seamless and aesthetic user interface, offering songs from different albums and genres for music lovers.</p>\\n<p>While building this Micro-Experience, the developer:</p>\\n<ul>\\n<li>Conducted a thorough analysis of the provided Figma design, successfully identifying and documenting required front-end components.</li>\\n<li>Created modular UI components including Cards, Carousels, and Buttons optimizing for reusability across various sections of the application.</li>\\n<li>Implemented an intuitive genre-based song filtering system using a tab component by modifying the one provided by MaterialUI, allowing users to browse songs by their preferred genre effortlessly.</li>\\n<li>Utilized REST APIs to fetch data served by the backend server</li>\\n</ul>","image":"f5c1998d-d5ae-401b-9874-3a623ac95129","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>QTify is a song-browsing application built from scratch using ReactJS paired with Material UI and Swiper to deliver a seamless and aesthetic user interface, offering songs from different albums and genres for music lovers.</p>\\n<p>While building this Micro-Experience, the developer:</p>\\n<ul>\\n<li>Conducted a thorough analysis of the provided Figma design, successfully identifying and documenting required front-end components.</li>\\n<li>Created modular UI components including Cards, Carousels, and Buttons optimizing for reusability across various sections of the application.</li>\\n<li>Implemented an intuitive genre-based song filtering system using a tab component by modifying the one provided by MaterialUI, allowing users to browse songs by their preferred genre effortlessly.</li>\\n<li>Utilized REST APIs to fetch data served by the backend server</li>\\n<li>Deployed the website to Vercel</li>\\n</ul>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/3ff2189e-e893-4718-86e1-0ce4524663aa?\\" alt=\\"QTify Component Architecture\\" /><img src=\\"https://directus.crio.do/assets/b45041bc-7a49-48d5-a8a3-937c3329e643?\\" alt=\\"QTify UI (Albums Section)\\" /></div>","skills":[]},{"id":58,"status":"published","sort":null,"user_created":"42670516-02dd-418e-abaa-d5ff0d183714","date_created":"2024-01-24T17:17:24.000Z","user_updated":"42670516-02dd-418e-abaa-d5ff0d183714","date_updated":"2024-01-25T12:52:10.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_SDET_XDB","title":"Food Delivery App Database Testing","description":"<p>This project involves testing the QEats Database across QA and STAGE environments and validating if the Database used is conforming to the Database Schema.</p>","image":"bae698e1-80f9-4c5d-9abc-c4dbdb3c0398","source_link":null,"overview_content":"<p>This project involves testing the QEats Database across QA and STAGE environments and validating if the Database used is conforming to &nbsp;the Database Schema.</p>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/c9dc6238-a2e1-4340-ba33-eb4c11b03bd3?\\" alt=\\"Image1\\" /></div>","skills":[]},{"id":59,"status":"published","sort":null,"user_created":"42670516-02dd-418e-abaa-d5ff0d183714","date_created":"2024-01-24T17:24:00.000Z","user_updated":"42670516-02dd-418e-abaa-d5ff0d183714","date_updated":"2024-01-25T12:53:48.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_SDET_XPERF","title":"Food Delivery App Performance Testing","description":"<p>This project involves testing the performance of QEats application under different loads and determining if it matches the expected benchmark metrics. Additionally SigNoz is used to monitor the performance of the host VM in which the test-bed is spun up.</p>","image":"59aee4c4-e46b-4a80-be2b-ee50f3eb44b2","source_link":null,"overview_content":"<p>This project involves testing the performance of QEats application under different loads and determining if it matches the expected benchmark metrics. Additionally SigNoz is used to monitor the performance of the host VM in which the test-bed is spun up.</p>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/e93ca34d-5dfc-4c33-9034-22ea7dd0ffaa?\\" alt=\\"Image1\\" /></div>","skills":[]},{"id":60,"status":"published","sort":null,"user_created":"42670516-02dd-418e-abaa-d5ff0d183714","date_created":"2024-01-24T17:28:07.000Z","user_updated":"42670516-02dd-418e-abaa-d5ff0d183714","date_updated":"2024-01-25T12:58:59.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_SDET_XSERVICE","title":"Food Delivery App API Testing","description":"<p>This project involves testing the QEats API, validating if the Microservices are functioning as intended</p>","image":"318dba56-a023-421b-b01f-3962ccbd3dd5","source_link":null,"overview_content":"<p>This project involves testing the QEats API, validating if the Microservices are functioning as intended.</p>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/ea11ed5d-e232-4432-bb24-fa898c692c5f?\\" alt=\\"Image1\\" /></div>","skills":[]},{"id":61,"status":"published","sort":null,"user_created":"42670516-02dd-418e-abaa-d5ff0d183714","date_created":"2024-01-24T17:32:04.000Z","user_updated":"42670516-02dd-418e-abaa-d5ff0d183714","date_updated":"2024-01-25T13:00:20.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_QKART_PERF_SDET","title":"Performance Testing on E-commerce application","description":"<p>The project thoroughly tests the QKart e-commerce application under different scenarios to ensure its robustness and performance during the anticipated high loads on \\"Big Billion Day.\\"&nbsp;<br />The tasks involve configuring JMeter tests, analyzing results, identifying breaking points, and creating a Python script for additional data retrieval. The ultimate goal is to provide users a reliable and smooth shopping experience during the event.</p>","image":"6732d651-0888-4fef-9f5c-d357e8d0a2a7","source_link":null,"overview_content":"<p>The project involves performance testing and analysis of an e-commerce platform named QKart in preparation for an upcoming event called \\"Big Billion Day.\\" The objective is to ensure that the QKart application can handle specific loads and to identify its breaking point.&nbsp;</p>\\n<p>The project is divided into several tasks and milestones, covering various aspects of performance testing using JMeter.</p>\\n<p>The architecture of the AUT can be found here:</p>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/f420010c-c9c9-4062-a8f0-6eecf89e3ee8?\\" alt=\\"Image2\\" /></div>","skills":[]},{"id":62,"status":"published","sort":null,"user_created":"42670516-02dd-418e-abaa-d5ff0d183714","date_created":"2024-02-03T10:53:14.000Z","user_updated":null,"date_updated":null,"type":"MICRO_EXPERIENCE","readable_id":"ME_JENKINS","title":"CI/CD pipeline with Jenkins","description":"<p><span style=\\"font-weight: 400;\\">Used Jenkins to create jobs for executing tests, and sending email notifications</span></p>\\n<p><span style=\\"font-weight: 400;\\"><a href=\\"https://www.youtube.com/embed/5I5Rsvb0HMo\\" target=\\"_blank\\" rel=\\"noopener\\">View Demo</a></span></p>","image":"fa4621db-0365-4bb4-8f3f-761cd4ff8be5","source_link":null,"overview_content":null,"skills":[]},{"id":63,"status":"published","sort":null,"user_created":"42670516-02dd-418e-abaa-d5ff0d183714","date_created":"2024-02-28T06:12:14.000Z","user_updated":"42670516-02dd-418e-abaa-d5ff0d183714","date_updated":"2024-02-28T11:59:37.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_SDET_KAFKA_TESTING","title":" Kafka Testing Project","description":"<p>This project involves testing the asynchronous order flow for ZCommerce application.</p>","image":"7e8654e3-9f06-4873-bef5-bd9353ff3846","source_link":null,"overview_content":"<p>This project involves testing the asynchronous order flow for ZCommerce application. The flow async flow for placing order is the following:</p>\\n<ul>\\n<li>&nbsp;UI: User places an order</li>\\n<li>&nbsp;Order travels to API Gateway</li>\\n<li>&nbsp;When Order travels to Order service, it sends an event to Kafka topic `zcommerce-orders` with user-id as key,</li>\\n<li>&nbsp;That data is consumed by multiple consumer groups such as webhooks</li>\\n</ul>","skills":[]},{"id":64,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2024-03-25T09:26:25.000Z","user_updated":null,"date_updated":null,"type":"MICRO_EXPERIENCE","readable_id":"ME_QKART_FRONTEND","title":"QKart Frontend","description":"<p><span style=\\"font-weight: 400;\\">QKart is an E-commerce application offering a variety of products for customers to choose from.&nbsp;</span></p>\\n<p>During the course of this Micro-Experience, the developer:</p>\\n<ul>\\n<li>Implemented the core logic for authentication, shopping cart and checkout</li>\\n<li>Improved UI by adding responsive design elements for uniform experience across different devices</li>\\n<li>Utilized REST APIs to dynamically load and render data served by the backend server</li>\\n<li>Deployed website to Netlify</li>\\n</ul>","image":"6705e165-567d-4eb8-9716-a7d45bfd4e00","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>QKart is an E-commerce application offering a variety of products for customers to choose from.&nbsp;</p>\\n<p>During the course of this Micro-Experience, the developer:,</p>\\n<ul>\\n<li>Implemented the core logic for authentication, shopping cart and checkout</li>\\n<li>Improved UI by adding responsive design elements for uniform experience across different devices</li>\\n<li>Utilized REST APIs to dynamically load and render data served by the backend server</li>\\n<li>Deployed website to Netlify</li>\\n</ul>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/dcbef5a2-61fd-4952-8097-d9a80adbc3e4?\\" alt=\\"QKart Shopping Interface (Products page)\\" /><img src=\\"https://directus.crio.do/assets/1034488f-e6c8-4489-bb93-4265fd12fc11?\\" alt=\\"QKart Component Architecture\\" /></div>","skills":[]},{"id":65,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2024-05-31T11:08:33.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2024-06-06T06:55:35.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_MACHINE_CODING_TODOLIST","title":"Todolist LLD","description":"<p>The TODO-LIST application is designed to help users efficiently manage and keep track of their daily office tasks. The application allows users to record tasks with associated attributes such as tags for categorization and deadlines for better organization.</p>","image":"767789e2-8d23-4875-b216-4cd773eddde3","source_link":null,"overview_content":"<p>The TODO-LIST application is designed to help users efficiently manage and keep track of their daily office tasks. The application allows users to record tasks with associated attributes such as tags for categorization and deadlines for better organization.</p>\\n<p><br />During this Micro-Experience, the developer:</p>\\n<p>&nbsp; &nbsp;- Understood the application requirements and implemented the project from scratch.</p>\\n<p>&nbsp; &nbsp;- Tested the implementation with test cases to ensure correctness.</p>\\n<p>&nbsp; &nbsp;- Made use of OOP concepts, SOLID principles, and Design patterns to ensure the extensibility of the application.</p>","skills":[]},{"id":66,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2024-05-31T12:33:20.000Z","user_updated":null,"date_updated":null,"type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_MACHINE_CODING_SOCIAL_NETWORK","title":"Crio Social Network Design","description":"<p>The application being developed is a tech social media platform called Crio Tech Social Media helps learners engage and share knowledge. This platform supports user sign-ups, posts, following, voting, commenting, and filtering feed items by various criteria.</p>","image":"2e0be71c-4f93-49cd-90f6-a20a0b310497","source_link":null,"overview_content":"<p>The application being developed is a tech social media platform called Crio Tech Social Media helps learners engage and share knowledge. This platform supports user sign-ups, posts, following, voting, commenting, and filtering feed items by various criteria.</p>\\n<p><br />During this Micro-Experience, the developer:</p>\\n<p>&nbsp; &nbsp;- Understood the application requirements and implemented the project from scratch.</p>\\n<p>&nbsp; &nbsp;- Tested the implementation with test cases to ensure correctness.</p>\\n<p>&nbsp; &nbsp;- Made use of OOP concepts, SOLID principles, and Design patterns to ensure the extensibility of the application.</p>\\n<p>&nbsp; &nbsp;- Ensured concurrent requests were handled well using Multithreading.</p>","skills":[]},{"id":67,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2024-05-31T15:15:33.000Z","user_updated":null,"date_updated":null,"type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_MACHINE_CODING_ORDER_MANAGEMENT","title":"Order Management System","description":"<p>The Order Management System (OMS) &nbsp;is designed to facilitate the smooth handling of orders, ensuring precise inventory management and timely fulfillment. This system allows sellers to manage their inventory, and customers to place and manage their orders efficiently.</p>","image":"c38454cd-b7c2-47cf-bfb6-dee65aa6ab7d","source_link":null,"overview_content":"<p>The Order Management System (OMS) &nbsp;is designed to facilitate the smooth handling of orders, ensuring precise inventory management and timely fulfillment. This system allows sellers to manage their inventory, and customers to place and manage their orders efficiently.</p>\\n<p><br />During this Micro-Experience, the developer:</p>\\n<p>- Understood the application requirements and implemented the project from scratch.<br />&nbsp;- Tested the implementation with test cases to ensure correctness.<br />&nbsp;- Made use of OOP concepts, SOLID principles, and Design patterns to ensure the extensibility of the application.<br />&nbsp;- Ensured Concurrent requests are handled well using Multithreading.<br />&nbsp;- Handled RACE conditions using locks and thread-safe data structures.</p>","skills":[]},{"id":68,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2024-05-31T15:24:13.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2024-06-06T10:14:45.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_MACHINE_CODING_KAFKA","title":"Kafka Application Design","description":"<p>The Kafka-like Messaging System is designed to facilitate efficient signaling and message handling between producer and consumer threads. The system supports multiple topics, each with several partitions, enabling a robust messaging framework.</p>","image":"fc1f32e9-3d09-4eeb-8bd5-081394cacc95","source_link":null,"overview_content":"<p>The Kafka-like Messaging System is designed to facilitate efficient signaling and message handling between producer and consumer threads. The system supports multiple topics, each with several partitions, enabling a robust messaging framework.</p>\\n<p><br />During this Micro-Experience, the developer:</p>\\n<ul>\\n<li>Understood the application requirements and implemented the project from scratch.</li>\\n<li>Tested the implementation with test cases to ensure correctness.</li>\\n<li>Made use of OOP concepts, SOLID principles, and Design patterns to ensure the extensibility of the application.</li>\\n<li>Ensured concurrent requests were handled well using Multithreading.</li>\\n<li>Made use of thread-signaling to ensure efficient resource utilization.</li>\\n</ul>","skills":[]},{"id":69,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2024-05-31T15:36:12.000Z","user_updated":null,"date_updated":null,"type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_MACHINE_CODING_STOCK_EXCHANGE","title":"Stock Exchange Design","description":"<p>StockPlay is a user-friendly stock trading game designed to help beginners understand the stock market\'s dynamics through a simplified, interactive platform. Players use virtual money to buy and sell stocks, simulating real-world trading.</p>","image":"8d0885e6-ed59-4a8e-b953-d6954417d27c","source_link":null,"overview_content":"<p>StockPlay is a user-friendly stock trading game designed to help beginners understand the stock market\'s dynamics through a simplified, interactive platform. Players use virtual money to buy and sell stocks, simulating real-world trading.</p>\\n<p>During this Micro-Experience, the developer:</p>\\n<p>&nbsp;- Understood the application requirements and implemented the project from scratch.<br />&nbsp;- Tested the implementation with test cases to ensure correctness.<br />&nbsp;- Made use of OOP concepts, SOLID principles, and Design patterns to ensure the extensibility of the application.<br />&nbsp;- Ensured concurrent requests were handled well using Multithreading.</p>","skills":[]},{"id":70,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2024-05-31T15:47:35.000Z","user_updated":null,"date_updated":null,"type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_MACHINE_CODING_PAYMENT_GATEWAY","title":"Payment Gateway Design","description":"<p>The Payment Gateway System (PGS) is designed to facilitate payments for clients by integrating multiple banks and supporting various payment methods. The system simulates a real-world payment gateway like Razorpay or PhonePe, allowing clients to process transactions through different banks.</p>","image":"809a37d9-e10f-4f6a-a6a0-0311db7e556c","source_link":null,"overview_content":"<p>The Payment Gateway System (PGS) is designed to facilitate payments for clients by integrating multiple banks and supporting various payment methods. The system simulates a real-world payment gateway like Razorpay or PhonePe, allowing clients to process transactions through different banks.</p>","skills":[]},{"id":71,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2024-06-03T02:27:30.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2024-06-05T09:34:27.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_XELLO","title":"Xello Application Development","description":"<p>Xello is an application designed to enhance task management and collaboration by organizing user interactions into structured workflows. This project involved developing core functionalities such as user registration, board creation, column management, and card management.</p>","image":"b33cc185-b895-4564-b0f0-cb69d67d0e66","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>&nbsp;</p>\\n<p>Xello is an application designed to enhance task management and collaboration by organizing user interactions into structured workflows. This project involved developing core functionalities such as user registration, board creation, column management, and card management.</p>\\n<p><br />During this Micro-Experience, the developer:</p>\\n<ul>\\n<li>Understand the application requirements and implement the project from scratch</li>\\n<li>Tested the implementation with test cases to ensure correctness</li>\\n<li>Made use of OOPs and SOLID principles to ensure the extensibility of the application.</li>\\n</ul>","skills":[]},{"id":72,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2024-06-05T08:49:37.000Z","user_updated":null,"date_updated":null,"type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_MACHINE_CODING_BIDBLAST","title":"Bidblast Application","description":"<p>BidBlast is a rewards bidding system designed for Crio members, allowing them to win lavish items daily by placing bids using Crio Coins. The system enhances member engagement and provides an exciting and rewarding experience for Crio learners. The lowest unique bid determines the winner, who is announced at the end of each day. Members can also view the winners of past events.</p>","image":"424d0366-6679-4965-9ddc-17696a7cb980","source_link":null,"overview_content":"<p>BidBlast is a rewards bidding system designed for Crio members, allowing them to win lavish items daily by placing bids using Crio Coins. The system enhances member engagement and provides an exciting and rewarding experience for Crio learners. The lowest unique bid determines the winner, who is announced at the end of each day. Members can also view the winners of past events.</p>\\n<p><br />During this Micro-Experience, the developer:</p>\\n<ul>\\n<li>Set up a new project with the required methods.</li>\\n<li>Implemented the application from scratch following the given requirements.</li>\\n<li>Tested the implementation with various test cases to ensure correctness.</li>\\n<li>Applied OOP concepts, SOLID principles, and Design patterns for maintainability and scalability.</li>\\n</ul>","skills":[]},{"id":73,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2024-06-05T09:35:17.000Z","user_updated":null,"date_updated":null,"type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_MACHINE_CODING_VEHICLE_RENTAL","title":"Vehicle Rental Design","description":"<p>The Vehicle Rental System allows users to rent different kinds of vehicles, such as cars and bikes, from various branches throughout the city. The system supports onboarding new branches and vehicles, renting vehicles for specific time slots, and dynamic pricing based on demand.</p>","image":"c81d495f-647a-43b6-9c74-f086e4743a0d","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p><br />The Vehicle Rental System allows users to rent different kinds of vehicles, such as cars and bikes, from various branches throughout the city. The system supports onboarding new branches and vehicles, renting vehicles for specific time slots, and dynamic pricing based on demand.</p>\\n<p><br />During this Micro-Experience, the developer:</p>\\n<ul>\\n<li>Understood the application requirements and implemented the project from scratch.</li>\\n<li>Tested the implementation with test cases to ensure correctness.</li>\\n<li>Made use of OOP concepts, SOLID principles, and Design patterns to ensure the extensibility of the application.</li>\\n<li>Ensured concurrent requests were handled well using Multithreading.</li>\\n</ul>","skills":[]},{"id":74,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2024-06-05T10:16:12.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2024-06-06T06:31:02.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_MACHINE_CODING_APPOINTMENT_BOOKING","title":"Appointment Booking Application","description":"<p><span style=\\"font-weight: 400;\\">The Appointment booking application is designed to facilitate the scheduling of appointments for various services offered by professionals.Professionals can log in to the system and declare their availability for the specific day, specifying which time slots they can accommodate clients. Clients can book appointments, and they also have the option to cancel existing appointments.</span></p>","image":"5db3fead-b35e-4dba-8e29-efce073d1dc1","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>&nbsp;</p>\\n<p><span style=\\"font-weight: 400;\\">The Appointment booking application is designed to facilitate the scheduling of appointments for various services offered by professionals.Professionals can log in to the system and declare their availability for the specific day, specifying which time slots they can accommodate clients. Clients can book appointments, and they also have the option to cancel existing appointments.</span></p>\\n<p><br />During this Micro-Experience, the developer:</p>\\n<ul>\\n<li>Set up a new project with the required methods.</li>\\n<li>Understood the application requirements and implemented the project from scratch.</li>\\n<li>Tested the implementation with test cases to ensure correctness.</li>\\n<li>Made use of OOP concepts, SOLID principles, and Design patterns to ensure the extensibility of the application.</li>\\n</ul>","skills":[]},{"id":75,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2024-06-05T10:49:51.000Z","user_updated":null,"date_updated":null,"type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_MACHINE_CODING_COUPON_MANAGEMENT","title":"Coupon Management Application","description":"<p>The Coupon Management System facilitates the efficient distribution of coupons to users.</p>","image":"4092112c-31b5-4cfb-9c41-d731b2c7dacc","source_link":null,"overview_content":"<p>The Coupon Management System facilitates the efficient distribution of coupons to users.</p>\\n<p><br />During this Micro-Experience, the developer:</p>\\n<ul>\\n<li>Set up a new project with the necessary methods.</li>\\n<li>Implemented the application from scratch while adhering to the specified requirements.</li>\\n<li>Ensured the correctness of the implementation by testing it with appropriate test cases.</li>\\n<li>Leveraged OOP concepts, SOLID principles, and Design patterns to ensure scalability and maintainability.</li>\\n</ul>","skills":[]},{"id":76,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2024-06-05T11:08:25.000Z","user_updated":null,"date_updated":null,"type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_MACHINE_CODING_FPL_AUCTION","title":"FPL Auction Application","description":"<p>The FPL Auction System is designed to facilitate the auctioning of players to various teams, enabling efficient and fair bidding processes. This system supports player and team registrations, manages auction sessions, processes bids, and maintains the state and overview of players and teams.</p>","image":"e9fdcd1a-404f-497e-a931-4b2490b858d0","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>&nbsp;</p>\\n<p><span style=\\"font-weight: 400;\\">The FPL Auction System is designed to facilitate the auctioning of players to various teams, enabling efficient and fair bidding processes. This system supports player and team registrations, manages auction sessions, processes bids, and maintains the state and overview of players and teams.</span></p>\\n<p><span style=\\"font-weight: 400;\\">During this Micro-Experience, the developer:</span></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Set up a new project with the required methods.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Implemented the application from scratch following the given requirements.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Tested the implementation with various test cases to ensure correctness.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Applied OOP concepts, SOLID principles, and Design patterns for maintainability and scalability.</span></li>\\n</ul>","skills":[]},{"id":77,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2024-06-05T14:40:12.000Z","user_updated":"1cf39172-720b-4dd9-90b7-f6ebc62f1ab5","date_updated":"2024-06-06T09:25:09.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_FE_BUILDOUT_XCRUISE","title":"XCruise","description":"<p>XCruise is a responsive static website built from scratch using HTML and CSS to provide a seamless and visually appealing experience for users looking to book cruise vacations. The project involved developing a responsive and interactive website that showcases various cruise destinations and provides essential information about XCruise offerings.</p>","image":"7b3e9edb-08c2-4fb9-af53-1c9d73f5ee11","source_link":null,"overview_content":"<p>XCruise is a responsive static website built from scratch using HTML and CSS to provide a seamless and visually appealing experience for users looking to book cruise vacations. The project involved developing a responsive and interactive website that showcases various cruise destinations and provides essential information about XCruise offerings.</p>\\n<p>While building this Buildout, the developer:<br />&nbsp; &nbsp;- Understood the application requirements and implemented the project from scratch.<br />&nbsp; &nbsp;- Tested the implementation to ensure correctness and responsiveness across different devices.<br />&nbsp; &nbsp;- Made use of CSS Flexbox and CSS Grids to create a visually appealing layout.</p>","skills":[]},{"id":78,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2024-06-13T11:25:14.000Z","user_updated":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_updated":"2024-06-20T06:34:07.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_QA_XFLIX","title":"Video Sharing Platform Automation","description":"<p>Automated tests on XFlix to verify URLs, retrieve details of uploaded videos, verify video upload functionality, and check data persistence.</p>","image":"f07c60bf-6517-4445-9b34-61374c1f2e99","source_link":null,"overview_content":"<h1>Overview Content:</h1>\\n<p>This project involves automating the XFlix video sharing platform to verify URLs, retrieve details of uploaded videos, verify video upload functionality, and check data persistence.</p>\\n<div class=\\"image-container\\">&nbsp; <img src=\\"https://directus.crio.do/assets/7fe9e2ea-b6ff-4d9f-b9c5-e2da76a73656?\\" alt=\\"Image2\\" /></div>","skills":[]},{"id":79,"status":"published","sort":null,"user_created":"96947060-767d-4dc3-8a57-ab05646a591f","date_created":"2024-06-18T08:55:12.000Z","user_updated":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_updated":"2024-06-20T06:34:26.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_QA_XGOOGLE_FORM","title":"Google Form Automation","description":"<p>This project involves automating a google form, end-to-end, with a variety of different inputs such as checkboxes, dropdowns, radio-buttons and more.</p>","image":"29a03787-91f2-4d9c-9c31-90821e4348eb","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>This project involves automating a google form, end-to-end, with a variety of different inputs such as checkboxes, dropdowns, radio-buttons and more.</p>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/5bd9af30-1aef-48d5-9d56-804e06a069c6?\\" alt=\\"null\\" /></div>","skills":[]},{"id":80,"status":"published","sort":null,"user_created":"96947060-767d-4dc3-8a57-ab05646a591f","date_created":"2024-06-18T11:04:35.000Z","user_updated":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_updated":"2024-06-20T06:34:40.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_QA_XFLIPKART_SEARCH","title":"Flipkart Automation","description":"<p>This project involves automating the Flipkart e-commerce website and operating on the number of likes, reviews, etc and printing relevant item-details.</p>","image":"41b66f24-3eb1-4891-b99d-8a5066234994","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>This project involves automating the Flipkart e-commerce website and operating on the number of likes, reviews, etc and printing relevant item-details.</p>\\n<p><img src=\\"https://directus.crio.do/assets/7e4f8cfd-804b-49cf-807a-8bc2bb90e67c?\\" alt=\\"null\\" /></p>","skills":[]},{"id":81,"status":"published","sort":null,"user_created":"96947060-767d-4dc3-8a57-ab05646a591f","date_created":"2024-06-18T11:52:18.000Z","user_updated":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_updated":"2024-06-20T06:34:53.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_QA_XYOUTUBE_SEARCH","title":"YouTube Automation","description":"<p>This project involves automating the YouTube video streaming website, and asserting on various properties such as number of likes, views etc</p>","image":"c651b876-157e-4a82-9ea0-c82045975b1b","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>This project involves automating the YouTube video streaming website, and asserting on various properties such as number of likes, views etc</p>\\n<p><img src=\\"https://directus.crio.do/assets/d75e69af-0c41-4c75-a75a-93be0e494d4b?\\" alt=\\"null\\" /></p>","skills":[]},{"id":82,"status":"published","sort":null,"user_created":"96947060-767d-4dc3-8a57-ab05646a591f","date_created":"2024-06-18T12:39:50.000Z","user_updated":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_updated":"2024-06-20T06:35:15.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_QA_XSCRAPE_DATA","title":"Mini Web Scraper","description":"<p>This project involves creating a mini scraper to scrape film and sports information from a given website</p>","image":"fad7549b-9078-4ab8-b328-dffbb7dde1bf","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>This project involves creating a mini scraper to scrape film and sports information from a given website</p>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/d26ebb48-3d02-45e0-a1ac-b9272f91a810?\\" alt=\\"null\\" /></div>","skills":[]},{"id":83,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2024-07-25T11:12:19.000Z","user_updated":null,"date_updated":null,"type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_AWS_DEPLOYMENT_HLD","title":"Deploying Dynamic Web Application on AWS","description":"<p>The AWS Deployment of a Dynamic Web Application project demonstrates the ability to deploy a full-stack dynamic application (Todo-app) on Amazon Web Services (AWS), leveraging various cloud services to ensure scalability, reliability, and efficiency.</p>\\n<p>During the course of this project,</p>\\n<ul>\\n<li>Set up and configured various AWS services.</li>\\n<li>Implemented deployment strategies for both front-end and back-end applications.</li>\\n<li>Ensured secure and efficient data management using RDS and IAM.</li>\\n<li>Tested the deployed application to verify its functionality.</li>\\n</ul>","image":"44e0fd88-a2fb-4103-b22b-da78009a5dcb","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>The AWS Deployment of a Dynamic Web Application project demonstrates the ability to deploy a full-stack dynamic application (Todo-app) on Amazon Web Services (AWS), leveraging various cloud services to ensure scalability, reliability, and efficiency.</p>\\n<p>During the course of this project,</p>\\n<p>Set up and configured various AWS services.</p>\\n<ul>\\n<li>Implemented deployment strategies for both front-end and back-end applications.</li>\\n<li>Ensured secure and efficient data management using RDS and IAM.</li>\\n<li>Tested the deployed application to verify its functionality.</li>\\n</ul>","skills":[]},{"id":84,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2024-08-01T14:59:25.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2024-08-01T15:11:03.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_QCONTEST_V2","title":"QContest","description":"<p>QContest is a robust contest application designed to simulate programming challenges, similar to platforms like Hackerrank. This project aims to develop an application that enables users to participate in and manage coding contests. By focusing on core Java and design principles, developers are tasked with creating a scalable and maintainable contest framework.</p>","image":"adc5ecdb-2c73-49b3-bb72-be36d1be0d47","source_link":null,"overview_content":"<p>QContest is a robust contest application designed to simulate programming challenges, similar to platforms like Hackerrank. This project aims to develop an application that enables users to participate in and manage coding contests. By focusing on core Java and design principles, developers are tasked with creating a scalable and maintainable contest framework.</p>\\n<p>During this project:</p>\\n<p>- Built a Hackerrank-like contest application by applying their Core Java and Low-Level Design skills</p>\\n<ol>\\n<li>Designed &amp; implemented the classes required for a contest framework.</li>\\n<li>Implemented the business logic of running a simulated contest.</li>\\n</ol>\\n<p>Image:</p>\\n<p><img src=\\"https://directus.crio.do/assets/ba3fa8b8-fb84-457c-9dd8-d74422ed534e?\\" alt=\\"Qcon\\" /></p>","skills":[]},{"id":85,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2024-08-01T15:21:37.000Z","user_updated":null,"date_updated":null,"type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_XLIDO","title":"Xlido","description":"<p>Xlido is an application designed to enhance audience engagement and interaction by providing real-time participation tools for events and meetings. This project involved developing core functionalities such as Q&amp;A sessions enabling seamless and dynamic communication between organizers and participants.</p>","image":"cc4f2bae-ed7e-4687-beca-92eee30381f4","source_link":null,"overview_content":"<p>Xlido is an application designed to enhance audience engagement and interaction by providing real-time participation tools for events and meetings. This project involved developing core functionalities such as Q&amp;A sessions enabling seamless and dynamic communication between organizers and participants.</p>\\n<p><br />During this project:</p>\\n<ol>\\n<li>Built a well-designed Slido-like application</li>\\n<li>Understood the application requirements and implemented the project from scratch</li>\\n<li>Tested the implementation with test cases to ensure correctness</li>\\n<li>Made use of OOPs and SOLID principles to ensure the extensibility of the application.</li>\\n</ol>","skills":[]},{"id":86,"status":"published","sort":null,"user_created":"96947060-767d-4dc3-8a57-ab05646a591f","date_created":"2024-08-13T11:43:07.000Z","user_updated":"96947060-767d-4dc3-8a57-ab05646a591f","date_updated":"2024-08-16T12:00:07.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_XPENSE_TRACKER","title":"XPense Tracker","description":"<p>A dynamic expense tracking application</p>","image":"1e5c3b0a-6084-4821-9400-a39f0437efcd","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>&nbsp;</p>\\n<p><span style=\\"font-weight: 400;\\">XpenseTracker is a dynamic expense management application designed to help users monitor their monthly budget and expenses across various categories.</span></p>\\n<p>&nbsp;</p>\\n<p><span style=\\"font-weight: 400;\\">During the course of this project, the developer:</span></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Built XpenseTracker from scratch using ReactJS and Redux Toolkit for state management</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Created a user-friendly interface with comprehensive form validations and budget calculations.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Implemented real-time data updates and transaction management using Redux</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Ensured data persistence and seamless user experience across multiple pages.</span></li>\\n</ul>","skills":[]},{"id":87,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2024-08-24T06:06:56.000Z","user_updated":null,"date_updated":null,"type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_QTIFY_V2","title":"QTIFY","description":"<p>QTify is a song-browsing application built from scratch using ReactJS paired with Material UI and Swiper to deliver a seamless and aesthetic user interface, offering songs from different albums and genres for music lovers.</p>","image":"6d1a22a2-22f7-4321-8677-3d62a85fca8c","source_link":null,"overview_content":"<p>QTify is a song-browsing application built from scratch using ReactJS paired with Material UI and Swiper to deliver a seamless and aesthetic user interface, offering songs from different albums and genres for music lovers.</p>\\n<p>While building this Micro-Experience, the developer:</p>\\n<ul>\\n<li>Conducted a thorough analysis of the provided Figma design, successfully identifying and documenting required front-end components.</li>\\n<li>Created modular UI components including Cards, Carousels, and Buttons optimizing for reusability across various sections of the application.</li>\\n<li>Implemented an intuitive genre-based song filtering system using a tab component by modifying the one provided by MaterialUI, allowing users to browse songs by their preferred genre effortlessly.</li>\\n<li>Utilized REST APIs to fetch data served by the backend server</li>\\n<li>Deployed the website to Vercel</li>\\n</ul>","skills":[]},{"id":88,"status":"published","sort":null,"user_created":"5510f2c8-1978-48f2-b672-9484b0611511","date_created":"2024-09-09T10:06:00.000Z","user_updated":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_updated":"2024-09-10T06:18:57.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_EXCEL_QSTOCKS_TEST_BLANK","title":"Stock Trend Analysis","description":"<p><span style=\\"font-weight: 400;\\">Analyze stock performance over time by leveraging MS Excel tools. This project involves cleaning stock data, visualizing trends using pivot tables, and generating data-driven insights. It&rsquo;s a comprehensive analysis aimed at understanding stock performance through data manipulation and visualization techniques, similar to professional stock analysts.</span></p>","image":"d8a2e9ab-1074-47e1-bced-bb74f0f49ed5","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p><strong>Objective</strong><span style=\\"font-weight: 400;\\">: </span><span style=\\"font-weight: 400;\\">Analyze stock trends using historical data to identify performance patterns.</span></p>\\n<p><strong>Data Cleaning</strong><span style=\\"font-weight: 400;\\">: </span><span style=\\"font-weight: 400;\\">Ensured the dataset is free from inconsistencies, duplicates, and errors.</span></p>\\n<p><strong>Pivot Tables</strong><span style=\\"font-weight: 400;\\">: </span><span style=\\"font-weight: 400;\\">Created pivot tables to organize and summarize stock performance data.</span></p>\\n<p><strong>Data Visualization</strong><span style=\\"font-weight: 400;\\">: </span><span style=\\"font-weight: 400;\\">Generated visualizations like line charts and bar graphs to highlight key trends in stock prices.</span></p>\\n<p><strong>Insights</strong><span style=\\"font-weight: 400;\\">: </span><span style=\\"font-weight: 400;\\">Drew conclusions about stock volatility, growth patterns, and overall performance through comparative analysis.</span></p>\\n<p><strong>Deliverable</strong><span style=\\"font-weight: 400;\\">: </span><span style=\\"font-weight: 400;\\">Developed a stock performance report similar to those used by professional analysts.</span></p>","skills":[]},{"id":89,"status":"draft","sort":null,"user_created":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_created":"2024-09-09T10:32:54.000Z","user_updated":null,"date_updated":null,"type":"MICRO_EXPERIENCE","readable_id":"ME_SQL_QMATO_TEST_BLANK","title":"Food Order Insights","description":"<p><span style=\\"font-weight: 400;\\">Analyze Zomato\'s food order data to uncover customer behavior patterns and key insights. This project involves querying databases using SQL, analyzing trends, and identifying business insights. The data analysis mimics the tasks performed by business analysts to inform better decision-making and strategies in the food delivery industry.</span></p>","image":"504717b5-a287-4106-a0f6-e7ecd5d9cf04","source_link":null,"overview_content":"<h1><strong>Overview</strong></h1>\\n<p><strong>Objective</strong><span style=\\"font-weight: 400;\\">: Extract insights about customer orders, preferences, and peak order times using SQL.</span></p>\\n<p><strong>Data Aggregation</strong><span style=\\"font-weight: 400;\\">: Summarized order data by city, cuisine, and order volume using SQL queries.</span></p>\\n<p><strong>Business Insights</strong><span style=\\"font-weight: 400;\\">: Derived actionable insights into customer preferences, popular cuisines, and peak ordering times.</span></p>\\n<p><strong>Order Patterns</strong><span style=\\"font-weight: 400;\\">: Analyzed customer behavior to find frequent orders, repeat customers, and high-traffic areas.</span></p>\\n<p><strong>Deliverable</strong><span style=\\"font-weight: 400;\\">: Generated a business report with data-driven recommendations for improving sales and customer engagement.</span></p>","skills":[]},{"id":90,"status":"published","sort":null,"user_created":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_created":"2024-09-09T10:59:48.000Z","user_updated":null,"date_updated":null,"type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_XUBER_TEST_BLANK","title":"Ride Pattern Analysis","description":"<p><span style=\\"font-weight: 400;\\">Perform data analysis on Uber ride data to identify ride patterns and customer behaviors. This project uses Python libraries like Pandas and Seaborn for statistical analysis and visualization, helping uncover actionable insights. The project simulates the work of an Uber data analyst, focused on optimizing user experience and operations.</span></p>","image":"2516e53d-69fa-4b5e-bc10-da5f4e008fc1","source_link":null,"overview_content":"<h2><span style=\\"font-weight: 400;\\">Overview</span></h2>\\n<p><strong>Objective</strong><span style=\\"font-weight: 400;\\">: Analyze Uber ride data to find behavioral patterns such as peak ride times, popular routes, and frequent ride durations.</span></p>\\n<p><strong>Data Cleaning</strong><span style=\\"font-weight: 400;\\">: Used Pandas to clean and prepare ride data for analysis.</span></p>\\n<p><strong>Statistical Analysis</strong><span style=\\"font-weight: 400;\\">: Applied statistical methods to examine average ride durations, busiest locations, and frequent riders.</span></p>\\n<p><strong>Data Visualization</strong><span style=\\"font-weight: 400;\\">: Created visual representations of trends using Seaborn to highlight key insights.</span></p>\\n<p><strong>Deliverable</strong><span style=\\"font-weight: 400;\\">: Generated a detailed report providing insights into ride trends and customer behavior for better service optimization.</span></p>","skills":[]},{"id":91,"status":"published","sort":null,"user_created":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_created":"2024-09-09T11:22:40.000Z","user_updated":null,"date_updated":null,"type":"MICRO_EXPERIENCE","readable_id":"ME_PYTHON_QSPINNY_TEST_BLANK","title":"Vehicle Sell Price Prediction","description":"<p><span style=\\"font-weight: 400;\\">Predict optimal selling prices for used cars using data-driven regression models. This project involves analyzing historical car sale data using Python libraries like NumPy, Pandas, and Matplotlib to create a price prediction model. It mimics the role of a price analyst at Spinny, focused on maximizing vehicle sales.</span></p>","image":"12c010c0-ca52-4a94-85ce-b1fa04c76497","source_link":null,"overview_content":"<h2><span style=\\"font-weight: 400;\\">Overview</span></h2>\\n<p><strong>Objective</strong><span style=\\"font-weight: 400;\\">: Predict the selling prices of used cars using historical data and regression models.</span></p>\\n<p><strong>Data Analysis</strong><span style=\\"font-weight: 400;\\">: Analyzed factors affecting car prices such as make, model, year, and mileage using Pandas.</span></p>\\n<p><strong>Regression Modelling</strong><span style=\\"font-weight: 400;\\">: Built a linear regression model to predict prices based on car attributes.</span></p>\\n<p><strong>Visualization</strong><span style=\\"font-weight: 400;\\">: Used Matplotlib to visualize the relationship between various factors and car prices.</span></p>\\n<p><strong>Deliverable</strong><span style=\\"font-weight: 400;\\">: Created a predictive model to help price used cars effectively, optimizing profitability for dealers.</span></p>","skills":[]},{"id":92,"status":"published","sort":null,"user_created":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_created":"2024-09-09T11:33:23.000Z","user_updated":"ea2fb751-43c1-43af-b9d9-d8aa13f737c4","date_updated":"2025-05-07T07:13:10.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_XFLIPKART_TEST_BLANK","title":"eCommerce Sales insights","description":"<p><span style=\\"font-weight: 400;\\">Create data-driven dashboards to visualize eCommerce sales trends. This project involves building dynamic dashboards using PowerBI to provide actionable business insights. It mirrors the work of sales teams at Flipkart, focusing on driving business decisions through data visualization and business intelligence.</span></p>","image":"61fd83e6-93c0-4a3f-ad82-7954545e0626","source_link":null,"overview_content":"<h2><span style=\\"font-weight: 400;\\">Overview</span></h2>\\n<p><strong>Objective</strong><span style=\\"font-weight: 400;\\">: Build dynamic dashboards to visualize sales data and trends for an eCommerce business.</span></p>\\n<p><strong>Data Cleaning</strong><span style=\\"font-weight: 400;\\">: Prepared and structured raw sales data for analysis.</span></p>\\n<p><strong>Business Intelligence</strong><span style=\\"font-weight: 400;\\">: Created visual insights on sales performance, revenue trends, and product demand.</span></p>\\n<p><strong>Data Visualization</strong><span style=\\"font-weight: 400;\\">: Used PowerBI to create interactive dashboards displaying real-time sales data.</span></p>\\n<p><strong>Deliverable</strong><span style=\\"font-weight: 400;\\">: Developed a comprehensive dashboard that allows stakeholders to make data-driven decisions based on sales trends and performance.</span></p>","skills":[]},{"id":93,"status":"published","sort":null,"user_created":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_created":"2024-09-09T11:41:14.000Z","user_updated":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_updated":"2024-09-09T16:17:53.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_PYTHON_QMMTAGENT_TEST_BLANK","title":"Agentic AI Project","description":"<p><span style=\\"font-weight: 400;\\">Develop an AI-driven holiday planner using multi-agent systems. This project involves building Python-based AI agents that interact with various APIs to create personalized holiday itineraries. It simulates the work of ML engineers at MakeMyTrip, focusing on intelligent, data-driven planning solutions for travelers.</span></p>","image":"cae2bdff-d840-436d-aba5-f918d60d80f6","source_link":null,"overview_content":"<h2><span style=\\"font-weight: 400;\\">Overview</span></h2>\\n<p><strong>Objective</strong><span style=\\"font-weight: 400;\\">: Build AI agents that plan personalized holiday itineraries based on user preferences.</span></p>\\n<p><strong>API Integration</strong><span style=\\"font-weight: 400;\\">: Integrated travel-related APIs to retrieve real-time data on flights, hotels, and activities.</span></p>\\n<p><strong>AI Agents</strong><span style=\\"font-weight: 400;\\">: Designed multi-agent systems where each agent is responsible for a specific task (e.g., flights, accommodations).</span></p>\\n<p><strong>Machine Learning</strong><span style=\\"font-weight: 400;\\">: Implemented machine learning algorithms to optimize itinerary suggestions based on user data.</span></p>\\n<p><strong>Deliverable</strong><span style=\\"font-weight: 400;\\">: Developed a holiday planning solution that generates dynamic, personalized itineraries for users.</span></p>","skills":[]},{"id":94,"status":"published","sort":null,"user_created":"ea2fb751-43c1-43af-b9d9-d8aa13f737c4","date_created":"2025-03-11T04:37:56.000Z","user_updated":null,"date_updated":null,"type":"MICRO_EXPERIENCE","readable_id":"ME_BYTE_XFLIX_GENAI","title":"Fullstack Development with GenAI","description":"<p><span style=\\"font-weight: 400;\\">Developed Frontend and Backend for a video sharing platform from scratch with Bolt and Cursor</span></p>","image":"179d28e9-d2da-450a-a1c1-25db71e2aa40","source_link":null,"overview_content":null,"skills":[]},{"id":95,"status":"published","sort":null,"user_created":"ea2fb751-43c1-43af-b9d9-d8aa13f737c4","date_created":"2025-03-11T04:38:28.000Z","user_updated":null,"date_updated":null,"type":"MICRO_EXPERIENCE","readable_id":"ME_BYTE_AGENTIC_GENAI","title":"Agentic Workflows with GenAI","description":"<p><span style=\\"font-weight: 400;\\">Automated tasks across industries with AI-powered Agentic workflows with CrewAI</span></p>","image":"ecb0c961-6a01-412f-bb58-80cc54fd9807","source_link":null,"overview_content":null,"skills":[]},{"id":96,"status":"published","sort":null,"user_created":"96947060-767d-4dc3-8a57-ab05646a591f","date_created":"2025-05-02T07:22:45.000Z","user_updated":null,"date_updated":null,"type":"MICRO_EXPERIENCE","readable_id":"ME_FE_BUILDOUT_XPROFILE","title":"XProfile","description":"<p><span style=\\"font-weight: 400;\\">A Responsive Virtual Profile Card</span></p>","image":"6ed6db8b-570f-4038-a8ab-1e4edf18a9c0","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>&nbsp;</p>\\n<p><span style=\\"font-weight: 400;\\">XProfile is a static, responsive profile card that represents an individual\'s professional identity online. The card is built using only HTML and CSS and adapts seamlessly across devices.</span></p>\\n<p><span style=\\"font-weight: 400;\\">During the course of this Micro-Experience, the developer:</span></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Comprehended the requirements of the application.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Built a responsive profile card following frontend best practices.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Verified the correctness of the implementation through automated assessments.</span></li>\\n</ul>","skills":[]},{"id":97,"status":"published","sort":null,"user_created":"96947060-767d-4dc3-8a57-ab05646a591f","date_created":"2025-05-02T12:09:10.000Z","user_updated":"ea2fb751-43c1-43af-b9d9-d8aa13f737c4","date_updated":"2025-05-05T12:27:10.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_SPRING_BOOT_XBLOG","title":"XBlog","description":"<p>XBLOG is a responsive, full-stack blogging platform developed with ReactJS for the frontend and Spring Boot with MongoDB for the backend. It supports user authentication, content creation, commenting, liking, and admin-level access, ensuring seamless integration between components and a clean user experience.</p>","image":"2e277471-deed-49b7-ac5e-dfb109ac72d8","source_link":null,"overview_content":"<h1>Overview</h1>\\n<p>&nbsp;</p>\\n<p><strong>XBLOG</strong><span style=\\"font-weight: 400;\\"> is a responsive, full-stack blogging platform developed with ReactJS for the frontend and Spring Boot with MongoDB for the backend. It supports user authentication, content creation, commenting, liking, and admin-level access, ensuring seamless integration between components and a clean user experience.</span></p>","skills":[]},{"id":98,"status":"published","sort":null,"user_created":"96947060-767d-4dc3-8a57-ab05646a591f","date_created":"2025-07-22T12:00:53.000Z","user_updated":null,"date_updated":null,"type":"MICRO_EXPERIENCE","readable_id":"ME_JUPYTER_AIRBNBANALYSIS","title":"Airbnb Analysis","description":"<p><strong>Airbnb Analysis: </strong><span style=\\"font-weight: 400;\\">The goal of this analysis is to understand the key factors influencing Airbnb listing performance in terms of pricing, reviews, and location. This is a fundamental analysis for identifying trends and patterns that could aid both hosts and guests in improving or selecting listings.</span></p>","image":"2c130109-f379-4a50-bd9f-b98213558edc","source_link":null,"overview_content":"<h2><span style=\\"font-weight: 400;\\">Overview</span></h2>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Objective:</strong><span style=\\"font-weight: 400;\\"> Analyze the dataset of Airbnb listings to uncover insights on factors like pricing, reviews, and geographical locations that influence listing performance.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Data Cleaning:</strong><span style=\\"font-weight: 400;\\"> Handle missing values, clean data types, and ensure consistency in key columns.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Data Analysis:</strong><span style=\\"font-weight: 400;\\"> Examine relationships between variables such as room type, location, price, and reviews.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Data Visualization:</strong><span style=\\"font-weight: 400;\\"> Create visualizations to highlight key trends, distributions, and comparisons.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Insights:</strong><span style=\\"font-weight: 400;\\"> Provide actionable insights based on the analysis of data, such as recommendations for hosts to improve their listings.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Deliverable:</strong><span> A comprehensive report and visualizations to help Airbnb hosts optimize their listings and provide insights into the platform\'s offerings.</span></li>\\n</ul>","skills":[]},{"id":99,"status":"published","sort":null,"user_created":"42670516-02dd-418e-abaa-d5ff0d183714","date_created":"2025-07-22T12:27:44.000Z","user_updated":"42670516-02dd-418e-abaa-d5ff0d183714","date_updated":"2025-07-24T08:00:21.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_JUPYTER_UBERANALYSIS","title":"Ride-Hailing Analysis","description":"<p>Ride-Hailing Analysis: Optimizing service fulfillment and revenue through comprehensive trip data exploration.</p>","image":"a64737b9-26d1-4b42-b21f-7a154791dc91","source_link":null,"overview_content":"<h2><span style=\\"font-weight: 400;\\">Overview</span></h2>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Objective:</strong><span style=\\"font-weight: 400;\\"> Understand demand&ndash;supply dynamics, cancellation drivers, revenue patterns, and weather impacts in Uber rides to inform operational and pricing strategies.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Data Cleaning:</strong><span style=\\"font-weight: 400;\\"> Parsed timestamps; normalized location names; handled missing pickup/drop times (for cancelled/no-cars trips); computed &ldquo;wait time&rdquo; and &ldquo;trip duration&rdquo; features; encoded categorical variables.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Data Analysis:</strong><span style=\\"font-weight: 400;\\"> Examined temporal demand (hour/day), ride-type popularity, cancellation rates by time and location, revenue breakdown by ride type, and weather correlations.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Data Visualization: </strong><span style=\\"font-weight: 400;\\">Created heatmaps of requests vs. hour and pickup zone; line charts of request volume over time; bar charts of cancellation rates; box plots of trip durations and wait times; scatter plots of revenue vs. ride type.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Insights:</strong><span style=\\"font-weight: 400;\\"> Peak-hour supply shortfalls drive &ldquo;No Cars Available&rdquo; alerts and cancellations, especially in congested zones. Rainy weather spikes cancellation rates by ~20%. UberXL, though only ~33% of trips, contributes ~40% of revenue.</span></li>\\n</ul>\\n<p><strong>Deliverable: </strong><span style=\\"font-weight: 400;\\">A fully annotated Jupyter Notebook with summarized actionable findings and recommendations.</span></p>","skills":[]},{"id":100,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2025-07-22T12:49:53.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2025-07-22T13:05:41.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_JUPYTER_BANKATTRITIONANALYSIS","title":"Bank Attrition Analysis","description":"<p>Bank Customer Attrition Analysis:</p>\\n<p>Uncovering the drivers of customer churn through exploratory data analysis and actionable insights using Python and additional libraries like pandas, numpy, plotly, matplotlib &amp; seaborn.</p>","image":"2277258e-1bb7-4c4a-9dbd-ab51b87f1d79","source_link":null,"overview_content":"<h1>Overview</h1>\\n<ul>\\n<li><strong>Objective: </strong>Identify the key factors that influence customer attrition (&ldquo;Exited&rdquo;) in the bank and suggest strategies to reduce churn.</li>\\n<li><strong>Data Cleaning</strong>: Standardized column names, converted blanks to NaN, imputed or dropped missing values, and engineered categorical bins for continuous variables.</li>\\n<li><strong>Data Analysis:</strong> Conducted univariate, bivariate, and multivariate analyses to explore relationships between demographics, product usage, satisfaction, and churn.</li>\\n<li><strong>Data Visualization:</strong> Employed histograms, box plots, bar charts, and heatmaps (using Matplotlib, Seaborn, and Plotly) to reveal patterns and correlations.</li>\\n<li><strong>Insights:</strong> Discovered that low tenure, low satisfaction, inactive membership, and certain age/salary groups are strongly associated with higher churn rates.</li>\\n<li><strong>Deliverable</strong>: A comprehensive Jupyter Notebook with annotated code, clean datasets, interactive visualizations, and a slide deck summarizing key findings and recommendations.</li>\\n</ul>","skills":[]},{"id":101,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2025-07-23T06:25:34.000Z","user_updated":null,"date_updated":null,"type":"MICRO_EXPERIENCE","readable_id":"ME_JUPYTER_AMAZONFEEDBACKANALYSIS","title":"Amazon Product Feedback Analysis","description":"<p><strong>Amazon Product Feedback Analysis: </strong></p>\\n<p>Leveraging textual and quantitative insights to enhance product quality and customer satisfaction.</p>","image":"2062ec29-7392-454e-9ee7-89bb112a4d6c","source_link":null,"overview_content":"<h1>Overview</h1>\\n<ul>\\n<li><strong>Objective</strong>: Uncover the drivers of customer sentiment and engagement in Amazon product reviews to inform product development and marketing strategies.</li>\\n<li><strong>Data Cleaning:</strong> Standardized column names, parsed review dates, handled missing values in text and recommendation flags, and engineered features such as review length and sentiment polarity.</li>\\n<li><strong>Data Analysis</strong>: Explored distributions of ratings and recommendation flags, identified top brands and categories by sentiment, examined the relationship between review length, helpfulness votes, and ratings.</li>\\n<li><strong>Data Visualization</strong>: Employed bar charts for rating counts, word clouds for positive vs. negative reviews, scatter plots of helpful votes vs. review length, and heatmaps of sentiment across brands.</li>\\n<li><strong>Insights</strong>: High ratings (4&ndash;5 stars) dominate but negative reviews contain recurring product-specific complaints; longer reviews tend to garner more helpful votes; certain brands/categories show consistently higher sentiment.</li>\\n<li><strong>Deliverable</strong>: A thoroughly documented Jupyter Notebook with all code and outputs, plus a concise slide deck summarizing actionable findings and recommendations.</li>\\n</ul>","skills":[]},{"id":102,"status":"published","sort":null,"user_created":"96947060-767d-4dc3-8a57-ab05646a591f","date_created":"2025-07-24T08:48:31.000Z","user_updated":null,"date_updated":null,"type":"MICRO_EXPERIENCE","readable_id":"ME_POWERBI_FOODELIVERY","title":"Food Delivery Dashboard","description":"<p><strong>Food Delivery Dashboard:</strong><span style=\\"font-weight: 400;\\"> This project focuses on analyzing food delivery performance using Power BI. The objective is to transform raw delivery data into actionable insights using data transformations, visualizations, and metrics such as sales, delivery efficiency, customer demographics, and order types. The goal is to enhance decision-making for the food delivery service by creating intuitive and meaningful reports.</span></p>","image":"9444ce52-3839-4b03-aec0-3b73844db075","source_link":null,"overview_content":"<h2><span style=\\"font-weight: 400;\\">Overview</span></h2>\\n<p><strong>Objective:</strong><span style=\\"font-weight: 400;\\"> To analyze and visualize key food delivery performance metrics such as total sales, average order value, delivery efficiency, and customer demographics.</span></p>\\n<p><strong>Data Cleaning:</strong><span style=\\"font-weight: 400;\\"> We transformed and cleaned the dataset, including handling missing values, correcting data types, and merging multiple data sources.</span></p>\\n<p><strong>Data Analysis:</strong><span style=\\"font-weight: 400;\\"> DAX measures were created for key performance indicators such as total sales, sales by category, average order value, and on-time delivery percentage.</span></p>\\n<p><strong>Data Visualization:</strong><span style=\\"font-weight: 400;\\"> Various Power BI visualizations such as card visuals, donut charts, and stacked column charts were used to represent key metrics and trends.</span></p>\\n<p><strong>Insights:</strong><span style=\\"font-weight: 400;\\"> Key findings from the analysis include the impact of food category and delivery types on sales, as well as customer age group trends.</span></p>\\n<p><strong>Deliverable:</strong><span style=\\"font-weight: 400;\\"> An interactive Power BI report visualizing sales performance, delivery metrics, and customer demographics to drive operational improvements.</span></p>","skills":[]},{"id":103,"status":"published","sort":null,"user_created":"42670516-02dd-418e-abaa-d5ff0d183714","date_created":"2025-07-24T10:16:15.000Z","user_updated":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_updated":"2025-12-24T04:48:22.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_POWERBI_ECOMMERCE","title":"Ecommerce Sales Dashboard","description":"<p><strong>Ecommerce Sales Dashboard:</strong><span style=\\"font-weight: 400;\\"> This project revolves around analyzing e-commerce sales data using Power BI to evaluate key metrics like sales performance, order trends, and customer behavior. By utilizing data transformations, DAX measures, and interactive visualizations, the project aims to optimize decision-making for sales and marketing teams.</span></p>","image":"8214808c-68de-42bf-987c-28d3688836a5","source_link":null,"overview_content":"<p class=\\"p1\\"><strong>Overview</strong></p>\\n<ul class=\\"ul1\\">\\n<li class=\\"li2\\"><strong>Objective: </strong>To analyze e-commerce sales data to identify key sales trends, customer behavior, and product performance. The goal is to deliver actionable insights for improving sales strategies and customer engagement.</li>\\n<li class=\\"li2\\"><strong>Data Cleaning: </strong>The data was cleaned by handling duplicates, verifying data types, and transforming specific fields like Discount, Order Date, and Ship Date. Custom columns such as Product Amount and Sales Amount were created.</li>\\n<li class=\\"li2\\"><strong>Data Analysis: </strong>DAX measures were applied to calculate total sales, average order value (AOV), total orders, and customer metrics. Trends in sales, quantity, and discounts were analyzed over time.</li>\\n<li class=\\"li2\\"><strong>Data Visualization: </strong>Various Power BI visuals were created, including bar charts, line charts, donut charts, and card visuals, to represent key metrics such as sales, profit margin, and regional performance.</li>\\n<li class=\\"li2\\"><strong>Insights:</strong> Key insights include the impact of discounts on sales, customer segmentation by region, and performance variations across product categories and sales channels.</li>\\n<li class=\\"li2\\"><strong style=\\"font-family: Inter, -apple-system, BlinkMacSystemFont, \'Segoe UI\', Roboto, Helvetica, Arial, sans-serif, \'Apple Color Emoji\', \'Segoe UI Emoji\', \'Segoe UI Symbol\', serif;\\">Deliverable</strong><span style=\\"font-family: Inter, -apple-system, BlinkMacSystemFont, \'Segoe UI\', Roboto, Helvetica, Arial, sans-serif, \'Apple Color Emoji\', \'Segoe UI Emoji\', \'Segoe UI Symbol\', serif;\\">: A comprehensive Power BI report visualizing the sales, customer demographics, and product performance. The dashboard provides interactive filtering options for users to explore different segments.</span></li>\\n</ul>","skills":[]},{"id":104,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2025-07-24T14:54:39.000Z","user_updated":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_updated":"2025-12-24T04:49:45.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_POWERBI_MAJORPROJECT","title":"Finance Dashboard","description":"<p>Finance Dashboard:</p>\\n<p>This project focuses on analyzing customer and loan data to assess financial risks, loan performance, and customer demographics using Power BI. The goal is to create an insightful dashboard that helps understand loan distribution, defaults, and credit risk across different customer segments.</p>","image":"c38956d1-37d7-4095-a901-84db5bd04218","source_link":null,"overview_content":"<h1>Overview</h1>\\n<ul>\\n<li class=\\"p1\\"><strong>Objective:</strong> To analyze and visualize key financial metrics related to customer loans, defaults, and credit risk, and categorize customers and loans based on various factors like age, income, credit score, and loan type.</li>\\n<li><strong>Data Cleaning:</strong> The dataset was cleaned by categorizing data into different buckets (e.g., age, credit score, income), and verifying the data types across columns. Relationships were created between Customer_Details, Loan_Details, and Date tables.</li>\\n<li class=\\"p1\\"><br /><strong>Data Analysis:</strong> DAX measures were used to calculate total loan amounts, average interest rates, monthly installments, customer demographics, loan status, and financial risk indicators like defaulted loans and high-risk loans.</li>\\n<li class=\\"p1\\"><br /><strong>Data Visualization: </strong>Power BI was used to create interactive visualizations, including pie charts, stacked bar charts, and gauge visuals to explore loan portfolios, financial risk, and customer segmentation.</li>\\n<li class=\\"p1\\"><br /><strong>Insights</strong>: Key findings include the distribution of loan types by status, the correlation between income and default rates, and the breakdown of loan risks by customer demographics.</li>\\n<li class=\\"p1\\"><br /><strong>Deliverable</strong>: An interactive Power BI dashboard providing insights into customer segmentation, loan portfolio performance, and financial risk analysis, enabling better decision-making for loan approval and risk management.</li>\\n</ul>","skills":[]},{"id":105,"status":"published","sort":null,"user_created":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_created":"2025-10-08T08:52:50.000Z","user_updated":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_updated":"2025-10-15T10:12:57.000Z","type":"ACTIVITY","readable_id":"ACTIVITY_EXCEL_WORLD_BANK_INTRO_QUIZ_ACTIVITY","title":"EXCEL World Bank Intro","description":"<p><strong>Problem Statement:</strong></p>\\n<p><span style=\\"font-weight: 400;\\">We want to analyze the factors affecting sales. For example:</span></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Month with lowest and highest sales?</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">How do sales vary across regions?</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">How do sales vary for different brands?</span></li>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">How do sales vary for different brands and different months?</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">How do sales vary for different brands and different regions?</span></li>\\n</ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">How do sales vary with different retailers? &hellip;.. etc</span></li>\\n</ul>","image":"dce02882-1f68-436f-85cd-15969d9e2430","source_link":"https://docs.google.com/document/d/1226KpTivrTxL0b85Y84CPCGDeggcmBWgVOOtWWs5k7s/edit?pli=1&tab=t.0","overview_content":null,"skills":[1]},{"id":106,"status":"published","sort":null,"user_created":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_created":"2026-01-08T06:27:36.000Z","user_updated":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_updated":"2026-01-08T06:59:56.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_QTREND_ANALYTICS","title":"Social Media Trend & Content Idea Generator","description":"<p><strong>Description</strong><span style=\\"font-weight: 400;\\">:</span></p>\\n<p><span style=\\"font-weight: 400;\\">QTrend is a content analytics and generation engine. This project involved processing engagement metrics from social media posts to identify high-performing hooks and using Generative AI to suggest new content ideas based on those insights.</span></p>\\n<p><span style=\\"font-weight: 400;\\">During the course of this project,</span></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Analyzed engagement metrics (Likes, Shares, Comments) to calculate \\"Virality Score\\".</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Extracted key entities and hooks from top-performing posts using NLP.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Integrated a Text Generation model to create new post variations.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Built a dashboard to recommend the \\"Best Time to Post\\".</span></li>\\n</ul>","image":"f8fecd42-7a97-4f40-b2d8-170b9dc49541","source_link":null,"overview_content":"<p><span style=\\"font-weight: 400;\\">QTrend combines traditional data analytics with GenAI to optimize social media strategy.</span></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Data Analysis</strong><span style=\\"font-weight: 400;\\">: Aggregating metrics to find correlations between format and performance.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>NLP</strong><span style=\\"font-weight: 400;\\">: N-gram analysis to find common phrases in successful titles.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>GenAI</strong><span style=\\"font-weight: 400;\\">: Few-shot prompting to generate content matching a specific tone.</span></li>\\n</ul>","skills":[]},{"id":107,"status":"published","sort":null,"user_created":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_created":"2026-01-08T06:28:34.000Z","user_updated":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_updated":"2026-01-08T06:59:18.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_QFACTORY_IOT","title":"Predictive Maintenance for Factory Machines","description":"<p><span style=\\"font-weight: 400;\\">QFactory is an IoT-enabled predictive analytics system. This project involved ingesting sensor data from industrial machinery, identifying anomalous behavior patterns, and predicting the Remaining Useful Life (RUL) to prevent unplanned downtime.</span></p>\\n<p><span style=\\"font-weight: 400;\\">During the course of this project,</span></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Simulated IoT sensor streams (vibration, temperature, voltage).</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Implemented Anomaly Detection algorithms (Isolation Forest/Autoencoders) to flag irregularities.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Trained a Time-Series Regression model to estimate time-to-failure.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Built a real-time monitoring dashboard for maintenance alerts.</span></li>\\n</ul>","image":"3158a9fd-dd74-4c6b-80c3-aa9242b8e741","source_link":null,"overview_content":"<p><span style=\\"font-weight: 400;\\">QFactory demonstrates the application of Industry 4.0 concepts using Machine Learning.</span></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Data Ingestion</strong><span style=\\"font-weight: 400;\\">: Handling high-frequency time-series data from sensors.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Feature Engineering</strong><span style=\\"font-weight: 400;\\">: Creating rolling statistics (mean, variance) and lag features.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Anomaly Detection</strong><span style=\\"font-weight: 400;\\">: Unsupervised learning to detect deviation from \\"normal\\" operating states.</span></li>\\n</ul>\\n<p><strong>Predictive Modeling</strong><span style=\\"font-weight: 400;\\">: LSTM or XGBoost to forecast the degradation curve.</span></p>","skills":[]},{"id":108,"status":"published","sort":null,"user_created":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_created":"2026-01-08T06:29:52.000Z","user_updated":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_updated":"2026-01-08T06:58:30.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_QTRAFFIC_GEO","title":"Smart Traffic & Accident Risk Predictor","description":"<p><span style=\\"font-weight: 400;\\">QTraffic is a geospatial risk assessment system for urban planning. This project involved merging accident reports with road network and weather data to predict high-risk zones and suggest safety interventions.</span></p>\\n<p><span style=\\"font-weight: 400;\\">During the course of this project,</span></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Ingested Geospatial data (Shapefiles/GeoJSON) of city road networks.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Mapped historical accident data to specific road segments.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Engineered features including weather conditions, time of day, and road curvature.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Trained a Classification model to predict \\"Accident Risk Level\\" (High/Medium/Low).</span></li>\\n</ul>","image":"6efa3cdf-dca0-48ff-8aa2-be12f751b228","source_link":null,"overview_content":"<p><span style=\\"font-weight: 400;\\">QTraffic utilizes spatial intelligence to improve road safety.</span></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>GeoPandas</strong><span style=\\"font-weight: 400;\\">: Handling spatial joins between accident points and road polygons.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Feature Engineering</strong><span style=\\"font-weight: 400;\\">: Creating spatial lag features and temporal features.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Classification</strong><span style=\\"font-weight: 400;\\">: XGBoost/Random Forest to classify risk probability.</span></li>\\n</ul>\\n<p><strong>Visualization</strong><span style=\\"font-weight: 400;\\">: Interactive Folium/Kepler.gl maps.</span></p>","skills":[]},{"id":109,"status":"published","sort":null,"user_created":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_created":"2026-01-13T05:32:47.000Z","user_updated":null,"date_updated":null,"type":"MICRO_EXPERIENCE","readable_id":"ME_QA_XSTACKOVERFLOW_QUERY","title":"Web Automation on Stack Overflow","description":"<p>This project focuses on the automation of web application testing using Java and Selenium. The primary objective is to automate test cases for the Stack Overflow website to verify its functionality. The project involves setting up a local automation environment, managing code repositories with Git, and executing automated test suites.</p>\\n<p>During the course of this project, you will:</p>\\n<ul>\\n<li aria-level=\\"1\\">Configure a local development environment for Java and Selenium.</li>\\n<li aria-level=\\"1\\">Use Git for version control to clone repositories and fetch code stubs.</li>\\n<li aria-level=\\"1\\">Write automation scripts to interact with the Stack Overflow website.</li>\\n<li aria-level=\\"1\\">Handle real-world automation challenges such as captchas and synchronization.</li>\\n<li aria-level=\\"1\\">Execute build and test commands using Gradle</li>\\n</ul>","image":"c5fb16fa-a601-4535-92d6-e0af3b415f33","source_link":null,"overview_content":"<p>The Stack Overflow QA project utilizes Java, Selenium, Git, and Gradle to set up an automation framework and test the functionality of an external website.</p>\\n<ul>\\n<li aria-level=\\"1\\">Java (Version 11) is used as the primary programming language for writing test scripts.</li>\\n<li aria-level=\\"1\\">Selenium is utilized to perform browser automation and interaction with the Application Under Test (AUT).</li>\\n<li aria-level=\\"1\\">Git is used for version control, specifically to clone repositories, manage remote stubs, and push code for assessment.</li>\\n<li aria-level=\\"1\\">Gradle is used as the build automation tool to run tests and manage dependencies.</li>\\n</ul>\\n<p>Python is used to handle specific assessment dependencies (requests module).</p>","skills":[]},{"id":110,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2026-01-21T10:20:13.000Z","user_updated":"b185e49a-001c-4fbe-82dd-1c95b8257ed8","date_updated":"2026-01-23T10:35:37.000Z","type":"MICRO_EXPERIENCE","readable_id":"ME_MERN_XEXIT","title":"XEXIT","description":"<p><strong>Built a Full-Stack MERN Employee Resignation &amp; Exit Interview Management System.</strong></p>\\n<p>Developed a full-stack application using React, Node.js, Express, and MongoDB to manage employee resignations, HR approval workflows, and exit interview questionnaires with role-based access control and notifications.<br />.</p>","image":"4caa858b-54ed-4d13-b9e5-638a8d22b941","source_link":null,"overview_content":"<p>Develop a full stack application - XExit for managing employee resignations and exit interviews with two user roles: Employees and HR.</p>","skills":[]},{"id":111,"status":"published","sort":null,"user_created":"96947060-767d-4dc3-8a57-ab05646a591f","date_created":"2026-01-21T11:03:23.000Z","user_updated":null,"date_updated":null,"type":"MICRO_EXPERIENCE","readable_id":"ME_FE_XEXPENSETRACKER_V2","title":"Expense Tracker","description":"<p><strong>Built a Responsive React Expense Tracker with Real-Time Wallet Balance &amp; Visual Analytics.</strong><span style=\\"font-weight: 400;\\"> <br /></span></p>\\n<p><span style=\\"font-weight: 400;\\">Developed a frontend expense tracking application using React.js with CRUD expense management, wallet balance control, charts for insights, and localStorage persistence.</span></p>","image":"b7d263f2-d797-4a6c-91ac-efa02d487bcc","source_link":null,"overview_content":"<p><span style=\\"font-weight: 400;\\">Built a web-based expense tracker that lets users manage daily expenses by adding, editing, and deleting transactions, while tracking wallet balance and viewing spending insights through charts.</span></p>","skills":[]},{"id":112,"status":"published","sort":null,"user_created":"96947060-767d-4dc3-8a57-ab05646a591f","date_created":"2026-01-21T12:20:53.000Z","user_updated":null,"date_updated":null,"type":"MICRO_EXPERIENCE","readable_id":"ME_FE_XBOTAI_V2","title":"XBot AI","description":"<p><strong>Built a Responsive AI Chat Application with Conversation History &amp; Feedback Tracking. </strong></p>\\n<p><span style=\\"font-weight: 400;\\">Developed a React-based chat interface where users can interact with an AI bot, save multiple conversations, revisit chat history, and provide structured feedback through likes/dislikes, ratings, and text reviews.</span></p>","image":"3f598277-4317-46a0-adaf-d9ccfa0e8008","source_link":null,"overview_content":"<p>Built a frontend application that allows users to chat with an AI model and provide feedback at different stages of the conversation, including reactions per message and rating-based feedback at the end.</p>","skills":[]},{"id":113,"status":"published","sort":null,"user_created":"96947060-767d-4dc3-8a57-ab05646a591f","date_created":"2026-01-21T12:41:57.000Z","user_updated":null,"date_updated":null,"type":"MICRO_EXPERIENCE","readable_id":"ME_FE_XMEDIFY_V2","title":"XMedify","description":"<p><strong>Built a React Medical Center Finder with Appointment Booking &amp; LocalStorage Persistence. </strong></p>\\n<p><span style=\\"font-weight: 400;\\">Developed a responsive React web application to search medical centers by state and city across the USA, view available hospitals, and book appointments with date/time selection and stored booking history.</span></p>","image":"e3dae262-45eb-43f8-98fc-c9e01defcf68","source_link":null,"overview_content":"<p><span style=\\"font-weight: 400;\\">Built a React-based web application that allows users to find medical centers in a specific state and city across the USA and book appointments.</span></p>","skills":[]},{"id":114,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2026-01-21T13:06:23.000Z","user_updated":null,"date_updated":null,"type":"MICRO_EXPERIENCE","readable_id":"ME_QEVENT","title":"QEVENT","description":"<h3>Headline:</h3>\\n<p>Built a Next.js Event Management Platform with Dynamic Routing, Filters, and Google OAuth. Developed a full-featured event browsing and creation platform using Next.js, with dedicated pages for events, artists, and tags, API-driven listings, query-based filtering, and authentication using NextAuth + Google OAuth.</p>","image":"ac78e8db-4c36-40ed-9465-20fbd7f01baa","source_link":null,"overview_content":"<p>Built an event management platform where users can browse upcoming events, explore artists and tags, view detailed event pages, filter events using query parameters, and create new events after logging in with Google OAuth.</p>","skills":[]},{"id":115,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2026-01-21T13:37:49.000Z","user_updated":null,"date_updated":null,"type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_CODERHACK","title":"Buildout Coderhack","description":"<p><strong>Developed a Spring Boot API to Manage Contest Leaderboards</strong></p>\\n<p>Built a backend service for user registration, score updates, and badge assignments using Java, Spring Boot, and MongoDB.<br />.</p>","image":"2111fd41-317f-436a-a192-09624c7958a2","source_link":null,"overview_content":"<p>Developed a RESTful API to manage a coding contest leaderboard, handling user registration, score updates, and badge assignments based on performance. The backend service supports full CRUD operations and ensures users are retrieved in ascending order based on scores.</p>","skills":[]},{"id":116,"status":"published","sort":null,"user_created":"42670516-02dd-418e-abaa-d5ff0d183714","date_created":"2026-01-21T16:27:23.000Z","user_updated":null,"date_updated":null,"type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_LEARNING_NAVIGATOR","title":"Buildout Learning Navigator","description":"<p><strong>Built a Spring Boot API for Managing Exam Enrollment in a Learning Management System</strong></p>\\n<p>Developed a RESTful API to manage students, subjects, and exams using Spring Boot and MySQL.</p>","image":"804791bf-037b-4dea-abff-0e1721088288","source_link":null,"overview_content":"<p>&nbsp;Created an API service to handle the exam enrollment process in a Learning Management System (LMS). This service supports managing student registrations, subject enrollments, exam creation, and enrollment in exams.</p>","skills":[]},{"id":117,"status":"published","sort":null,"user_created":"42670516-02dd-418e-abaa-d5ff0d183714","date_created":"2026-01-21T17:16:57.000Z","user_updated":null,"date_updated":null,"type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_RENTREAD","title":"Buildout RentRead","description":"<p><strong>Built a Secure Spring Boot API for an Online Book Rental Platform</strong><strong><br /></strong></p>\\n<p><em>Developed a role-based, authenticated backend system for managing users, books, and rentals using Spring Boot and MySQL.</em></p>","image":"08d23b14-027c-4260-9ca0-900b4eacfde7","source_link":null,"overview_content":"<p>&nbsp;Built a RESTful backend service for an online book rental platform that supports secure user authentication, role-based authorization, book management, and rental workflows.</p>","skills":[]},{"id":118,"status":"published","sort":null,"user_created":"42670516-02dd-418e-abaa-d5ff0d183714","date_created":"2026-01-21T18:05:50.000Z","user_updated":null,"date_updated":null,"type":"MICRO_EXPERIENCE","readable_id":"ME_BUILDOUT_STAYEASE","title":"Buildout Stayease","description":"<p><strong>Built a JWT-Secured Spring Boot API for a Hotel Booking Aggregator</strong></p>\\n<p><strong><br /></strong><em><span style=\\"font-weight: 400;\\">Developed a role-based backend system for hotel management and room booking using Spring Boot, JWT authentication, and MySQL.</span></em></p>","image":"20b8dca6-be37-4637-ba58-b1b3f120ac37","source_link":null,"overview_content":"<p>&nbsp;Built a RESTful backend service to streamline hotel room bookings for a hotel management aggregator. The system supports secure user authentication, role-based authorization, hotel management, and booking workflows.</p>","skills":[]}],"FM":[{"id":1,"status":"published","sort":null,"user_created":"c9fde96d-9501-41ab-90fd-c90abdc4d0cf","date_created":"2022-06-23T07:38:41.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2023-02-20T15:06:57.000Z","me_id":"ME_QTRIPDYNAMIC","slug":"me-qtripdynamic-milestone-1","title":"Fetch data using REST API","content":"<h1>Fetch data using REST API and dynamically render landing page</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li><span style=\\"font-weight: 400;\\">Retrieved cities data from the backend REST API endpoint using Javascript&rsquo;s Fetch API</span></li>\\n<li><span style=\\"font-weight: 400;\\">Created HTML for the cities grid with Bootstrap class to add responsiveness </span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Implemented logic to dynamically plug in city data to the Landing page&rsquo;s DOM</span></li>\\n</ul>\\n<h2>Skills used</h2>\\n<p><span style=\\"font-weight: 400;\\">HTML, CSS, JS, Bootstrap, REST APIs, JSON, DOM Manipulation, cURL</span></p>\\n<h2>Image(s)</h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/2ea56c1c-96f7-4a02-ae6f-6889bad99423?\\" alt=\\"QTrip Landing page\\" /></div>","completed_modules":"1","skills":[{"id":1,"me_milestone_id":1,"skills_id":10,"ordering":0},{"id":3,"me_milestone_id":1,"skills_id":12,"ordering":1},{"id":521,"me_milestone_id":1,"skills_id":163,"ordering":1},{"id":5,"me_milestone_id":1,"skills_id":22,"ordering":2},{"id":522,"me_milestone_id":1,"skills_id":181,"ordering":2},{"id":4,"me_milestone_id":1,"skills_id":13,"ordering":3},{"id":523,"me_milestone_id":1,"skills_id":56,"ordering":3},{"id":2,"me_milestone_id":1,"skills_id":11,"ordering":4},{"id":524,"me_milestone_id":1,"skills_id":136,"ordering":4},{"id":525,"me_milestone_id":1,"skills_id":154,"ordering":5},{"id":214,"me_milestone_id":1,"skills_id":161,"ordering":null},{"id":215,"me_milestone_id":1,"skills_id":162,"ordering":null},{"id":216,"me_milestone_id":1,"skills_id":232,"ordering":null}]},{"id":3,"status":"draft","sort":null,"user_created":"c9fde96d-9501-41ab-90fd-c90abdc4d0cf","date_created":"2022-06-26T15:22:18.000Z","user_updated":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_updated":"2022-09-15T04:53:11.000Z","me_id":"ME_QTRIPDYNAMIC","slug":"me-qtripdynamic-milestone-2","title":"Implement the adventures page","content":"<h1>Implement the adventures page with multi-select filters</h1>\\n<h2>Scope of work</h2>\\n<ul>\\n<li>Fetched adventures data for the city by invoking the backend API from the page URL&rsquo;s query parameter</li>\\n<li>Inserted HTML populated with API response data to the adventure page&rsquo;s DOM</li>\\n<li>Implemented logic to add both multi-select and single-select filters</li>\\n<li>Added logic to persist the filters selected by the user in the browser&rsquo;s localStorage</li>\\n</ul>\\n<h3>Skills used</h3>\\n<p>JS, Bootstrap Flex, Bootstrap Spacing, ES6, localStorage</p>\\n<p><br />Image(s)</p>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/f6f858c6-409b-4a0f-bbbd-8bc8b8c59739?\\" alt=\\"QTrip Adventures page\\" /></div>","completed_modules":"3","skills":[{"id":538,"me_milestone_id":3,"skills_id":130,"ordering":13},{"id":220,"me_milestone_id":3,"skills_id":132,"ordering":null}]},{"id":4,"status":"draft","sort":null,"user_created":"c9fde96d-9501-41ab-90fd-c90abdc4d0cf","date_created":"2022-06-26T15:26:55.000Z","user_updated":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_updated":"2022-09-16T07:22:43.000Z","me_id":"ME_QTRIPDYNAMIC","slug":"me-qtripdynamic-milestone-3","title":"Create the Adventure details page","content":"<h1>Create the Adventure details page with reservation support and the Reservations page to show all reservations</h1>\\n<h2>Scope of work</h2>\\n<ul>\\n<li>Added a sleek image carousel using Bootstrap2</li>\\n<li>Implemented reservation logic by using Fetch API to send a POST request to the backend, on form submission</li>\\n<li>Conditionally rendered the &ldquo;Sold out&rdquo; panel and the reservations page based on the API response</li>\\n</ul>\\n<h3>Skills used</h3>\\n<p>JS, Bootstrap, Conditional rendering, Bootstrap Carousel<br />Image(s)</p>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/dd79cabf-8e7d-49a1-bf5c-9013ceafa19a?\\" alt=\\"QTrip Adventure Details\\" /><img src=\\"https://directus.crio.do/assets/dbe1d87d-b815-47dd-929a-1f63a57b58a0?\\" alt=\\"Image carousel on the Adventures page\\" /><img src=\\"https://directus.crio.do/assets/26d7adc8-3889-411f-9409-0eeef8b4360d?\\" alt=\\"QTrip Reservations page\\" /></div>","completed_modules":"5","skills":[{"id":221,"me_milestone_id":4,"skills_id":138,"ordering":null},{"id":222,"me_milestone_id":4,"skills_id":165,"ordering":null}]},{"id":5,"status":"draft","sort":null,"user_created":"c9fde96d-9501-41ab-90fd-c90abdc4d0cf","date_created":"2022-06-26T15:28:34.000Z","user_updated":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_updated":"2022-09-15T04:55:59.000Z","me_id":"ME_QTRIPDYNAMIC","slug":"me-qtripdynamic-milestone-4","title":"Deploy the QTripDynamic website","content":"<h1>Deploy the QTripDynamic website</h1>\\n<h2>Scope of work</h2>\\n<ul>\\n<li>Deployed the QTrip backend to Heroku</li>\\n<li>Configured the QTrip dynamic frontend to use the Heroku deployed backend</li>\\n<li>Deployed the QTrip dynamic frontend to Netlify</li>\\n</ul>\\n<h3>Skills used</h3>\\n<p>Deployment, Heroku, Netlify</p>","completed_modules":"6","skills":[{"id":570,"me_milestone_id":5,"skills_id":160,"ordering":17},{"id":224,"me_milestone_id":5,"skills_id":140,"ordering":null},{"id":225,"me_milestone_id":5,"skills_id":152,"ordering":null},{"id":226,"me_milestone_id":5,"skills_id":141,"ordering":null}]},{"id":6,"status":"draft","sort":null,"user_created":"c9fde96d-9501-41ab-90fd-c90abdc4d0cf","date_created":"2022-06-28T10:13:54.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2022-09-14T12:12:01.000Z","me_id":"ME_QTRIPSTATIC","slug":"me-qtripstatic-milestone-1","title":"Create layout for the landing page","content":"<h1>Create layout for the landing page and make it responsive</h1>\\n<h2>Scope of work</h2>\\n<ul>\\n<li>Added a navigation bar which collapses automatically on smaller devices to display a toggle icon</li>\\n<li>Utilized CSS properties to add the hero image and align elements in it as per the design</li>\\n<li>Implemented the cities grid section by using Bootstrap&rsquo;s grid</li>\\n<li>Improved the cities grid section by making images responsive and added effect on hovering over an image tile</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>HTML, CSS, CSS Flexbox, Responsive Design, Bootstrap, VS Code Live Server</p>\\n<h2>Image(s)</h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/b1547410-a096-4252-80a3-bcebe1bcb37c?\\" alt=\\"Wireframe used for building QTrip landing page\\" /><img src=\\"https://directus.crio.do/assets/8c2e24a0-dbe8-44fe-ac5c-ad0dd394e3d6?\\" alt=\\"QTrip Landing page\\" /><img src=\\"https://directus.crio.do/assets/4c6a82cc-cb1c-4f77-ac56-6cc21bfed0ca?\\" alt=\\"Responsive navigation bar (Top: Expanded, Bottom: Collapsed/Expanded)\\" /></div>","completed_modules":"2","skills":[{"id":55,"me_milestone_id":6,"skills_id":10,"ordering":0},{"id":60,"me_milestone_id":6,"skills_id":12,"ordering":1},{"id":490,"me_milestone_id":6,"skills_id":181,"ordering":1},{"id":56,"me_milestone_id":6,"skills_id":13,"ordering":2},{"id":204,"me_milestone_id":6,"skills_id":153,"ordering":null},{"id":205,"me_milestone_id":6,"skills_id":136,"ordering":null},{"id":206,"me_milestone_id":6,"skills_id":154,"ordering":null}]},{"id":12,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2022-06-30T16:25:09.000Z","user_updated":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_updated":"2023-06-03T08:59:54.000Z","me_id":"ME_BUILDOUT_XCOMMERCE_ANALYTICS","slug":"me-xcommerce-milestone-1","title":"ME_BUILDOUT_XCOMMERCE_ANALYTICS","content":"<h2>Scope of work</h2>\\n<ul>\\n<li>Understood the requirements and the code base provided</li>\\n<li>Used OOP design with interfaces and factory design pattern to write extensible code</li>\\n<li>Created the core logic to consume sale data from a csv file and generate annual and monthly data insights</li>\\n<li>Extended the implementation to handle sale data from multiple vendors with minimum disruption to existing users of the module</li>\\n<li>Handled error cases and threw exceptions</li>\\n</ul>\\n<h2>Skills used</h2>\\n<ul>\\n<li>Core Java, OOP Design, Code Refactoring, Exception Handling</li>\\n</ul>","completed_modules":"1","skills":[{"id":334,"me_milestone_id":12,"skills_id":26,"ordering":1},{"id":335,"me_milestone_id":12,"skills_id":175,"ordering":2},{"id":336,"me_milestone_id":12,"skills_id":148,"ordering":3},{"id":337,"me_milestone_id":12,"skills_id":178,"ordering":4},{"id":338,"me_milestone_id":12,"skills_id":179,"ordering":5},{"id":339,"me_milestone_id":12,"skills_id":188,"ordering":6}]},{"id":14,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-06-30T17:03:54.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2023-01-30T14:14:27.000Z","me_id":"ME_QMONEY_V2","slug":"me-qmoney-v2-milestone-1","title":"Fetch stock quotes and annual returns","content":"<h1>Fetch stock quotes and compute annualized stock returns</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Used Tiingo&rsquo;s REST APIs to fetch stock quotes.</li>\\n<li>Computed the annualized returns based on stock purchase date and holding period.</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Java, REST API, Jackson</p>","completed_modules":"3","skills":[{"id":291,"me_milestone_id":14,"skills_id":148,"ordering":1},{"id":292,"me_milestone_id":14,"skills_id":56,"ordering":2},{"id":31,"me_milestone_id":14,"skills_id":26,"ordering":null},{"id":32,"me_milestone_id":14,"skills_id":11,"ordering":null},{"id":33,"me_milestone_id":14,"skills_id":32,"ordering":null}]},{"id":15,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-06-30T17:05:52.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2025-01-09T12:16:27.000Z","me_id":"ME_QMONEY_V2","slug":"me-qmoney-v2-milestone-2","title":"Refactor and publish a JAR file","content":"<h1>Refactor using Java interfaces and publish a JAR file</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Refactored code to adapt to an updated interface contract published by the backend team.</li>\\n<li>Published the portfolio manager library as a JAR for easy versioning and distribution.</li>\\n<li>Created examples to help document library (JAR) usage.</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Interfaces, Code Refactoring, Gradle</p>","completed_modules":"5","skills":[{"id":295,"me_milestone_id":15,"skills_id":178,"ordering":3},{"id":131,"me_milestone_id":15,"skills_id":36,"ordering":null},{"id":167,"me_milestone_id":15,"skills_id":186,"ordering":null}]},{"id":16,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-06-30T17:09:08.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2025-01-09T12:16:53.000Z","me_id":"ME_QMONEY_V2","slug":"me-qmoney-v2-milestone-3","title":"Improve application availability and stability","content":"<h1>Improve application availability and stability</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Added support for a backup stock quote service (Alpha Vantage) to improve service availability.</li>\\n<li>Improved application stability with comprehensive error reporting and better exception handling.</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Interfaces, Exception Handling</p>","completed_modules":"7","skills":[{"id":271,"me_milestone_id":16,"skills_id":188,"ordering":null}]},{"id":17,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-06-30T17:12:25.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2025-01-09T12:16:58.000Z","me_id":"ME_QMONEY_V2","slug":"me-qmoney-v2-milestone-4","title":"Enhance application performance","content":"<h1>Enhance application performance</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Improved application responsiveness by introducing multithreading.</li>\\n<li>Wrote unit tests to measure performance improvements.</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Multithreading</p>","completed_modules":"8","skills":[{"id":272,"me_milestone_id":17,"skills_id":189,"ordering":null}]},{"id":18,"status":"draft","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-06-30T17:21:07.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2022-09-14T08:59:30.000Z","me_id":"ME_QEATS_V2","slug":"me-qeats-milestone-1","title":"Retrieve restaurant data","content":"<h1>Retrieve restaurant data for a given user location</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Implemented GET /API/v1/restaurants and the corresponding request handler and response methods.</li>\\n<li>Used Mockito to enable the development of the relevant MVCS layers independently.</li>\\n<li>Retrieved a list of restaurants from MongoDB based on a user location.</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Spring Boot, Spring Data, REST API, Jackson, Mockito, JUnit, MongoDB</p>\\n<h2>Image(s)</h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/561c94bc-7180-484f-bf2d-b193a9f7e719?\\" alt=\\"\\" /></div>","completed_modules":"4","skills":[{"id":340,"me_milestone_id":18,"skills_id":26,"ordering":1},{"id":341,"me_milestone_id":18,"skills_id":32,"ordering":2},{"id":342,"me_milestone_id":18,"skills_id":27,"ordering":3},{"id":343,"me_milestone_id":18,"skills_id":148,"ordering":4},{"id":344,"me_milestone_id":18,"skills_id":56,"ordering":5},{"id":345,"me_milestone_id":18,"skills_id":11,"ordering":6},{"id":346,"me_milestone_id":18,"skills_id":24,"ordering":7},{"id":347,"me_milestone_id":18,"skills_id":187,"ordering":8},{"id":348,"me_milestone_id":18,"skills_id":28,"ordering":9},{"id":349,"me_milestone_id":18,"skills_id":19,"ordering":10},{"id":350,"me_milestone_id":18,"skills_id":23,"ordering":11}]},{"id":19,"status":"draft","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-06-30T17:25:31.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2022-09-15T05:19:01.000Z","me_id":"ME_QEATS_V2","slug":"me-qeats-milestone-2","title":"Resolved production issues","content":"<h1>Resolve production issues using Scientific Debugging</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Debug QEats app crashes from backend leveraging log messages and structured debugging techniques.</li>\\n<li>Use IDE features (breakpoints) and assert statements to identify the root cause.</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Scientific Debugging</p>","completed_modules":"5","skills":[{"id":354,"me_milestone_id":19,"skills_id":244,"ordering":4}]},{"id":20,"status":"draft","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-06-30T17:30:29.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2022-09-15T05:19:35.000Z","me_id":"ME_QEATS_V2","slug":"me-qeats-milestone-3","title":"Solved performance issues","content":"<h1>Replicate performance issues and solve them using caching strategies</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Employed JMeter or load testing to expose performance issues.</li>\\n<li>Identified DB queries contributing to degradation in performance.</li>\\n<li>Used a Redis cache to alleviate read performance.</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Redis, JMeter</p>\\n<h2>Image(s)</h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/7ac3bc10-6de8-4f27-867c-60f49d029c6f?\\" alt=\\"\\" /></div>","completed_modules":"6","skills":[{"id":359,"me_milestone_id":20,"skills_id":187,"ordering":4},{"id":140,"me_milestone_id":20,"skills_id":25,"ordering":null},{"id":182,"me_milestone_id":20,"skills_id":191,"ordering":null}]},{"id":21,"status":"draft","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-06-30T17:35:08.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2022-09-15T05:20:16.000Z","me_id":"ME_QEATS_V2","slug":"me-qeats-milestone-4","title":"Performed search operations","content":"<h1>Perform search operations using custom attributes</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Used MongoDB queries to enable users to search for restaurants using attributes like name, cuisine, dish, and price.</li>\\n<li>Used multithreading to increase the number of concurrent searches that can be performed.</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>MongoDB querying, Multithreading</p>\\n<h2>Image(s)</h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/eb6cae6a-2858-466d-83b4-fbca0d5e3d36?\\" alt=\\"\\" /><img src=\\"https://directus.crio.do/assets/ebd221b6-7eef-44ad-8caf-fccc5448985e?\\" alt=\\"\\" /><img src=\\"https://directus.crio.do/assets/e1522a23-f94d-4b5c-9c8e-d381bf1da4b8?\\" alt=\\"\\" /></div>","completed_modules":"8","skills":[]},{"id":23,"status":"draft","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-06-30T17:50:16.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2022-08-01T15:52:07.000Z","me_id":"ME_BUILDOUT_QA","slug":"me-buildout-milestone-1","title":"Create APIs to fetch quiz questions and submit answers","content":"<h1>Create APIs to fetch quiz questions and submit answers</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Implemented GET /quiz/{module-id} and the corresponding request handler and response methods.</li>\\n<li>Retrieved a list of questions from MongoDB based on the module-id</li>\\n<li>Accepted user answers to a given quiz via a POST request</li>\\n<li>Evaluated user answers for correctness and computed the total score</li>\\n<li>Returned a response with explanations for all answers</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Spring Boot, Spring Data, REST API, Jackson, JUnit, MongoDB, HTTP GET, POST</p>","completed_modules":"1","skills":[{"id":144,"me_milestone_id":23,"skills_id":32,"ordering":null},{"id":145,"me_milestone_id":23,"skills_id":24,"ordering":null},{"id":146,"me_milestone_id":23,"skills_id":23,"ordering":null},{"id":147,"me_milestone_id":23,"skills_id":11,"ordering":null},{"id":148,"me_milestone_id":23,"skills_id":30,"ordering":null},{"id":149,"me_milestone_id":23,"skills_id":19,"ordering":null},{"id":185,"me_milestone_id":23,"skills_id":56,"ordering":null}]},{"id":24,"status":"draft","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-06-30T17:59:45.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2022-09-14T11:25:42.000Z","me_id":"ME_BUILDOUT_XFLIX_REACT","slug":"me-xflixfrontend-milestone-1","title":"Build XFlix Frontend from scratch","content":"<h1>Build XFlix Frontend completely from scratch</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Implemented 3 views - Landing page, Video page, Video Upload Modal - in alignment to the Figma design</li>\\n<li>Used Postman collection to understand the API requirements for 5 different REST APIs</li>\\n<li>Utilized Postman Mock Server to check working of the Frontend application end-to-end</li>\\n<li>Deployed the React application to Netlify</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>React.js, Figma, Postman, REST API, Netlify</p>\\n<h2>Image(s)</h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/98b59adb-f8c0-4fac-a753-9b63c3c580b5?\\" alt=\\"XFlix Video Upload Modal\\" /></div>","completed_modules":"1","skills":[{"id":415,"me_milestone_id":24,"skills_id":167,"ordering":1},{"id":416,"me_milestone_id":24,"skills_id":169,"ordering":2},{"id":417,"me_milestone_id":24,"skills_id":170,"ordering":3},{"id":418,"me_milestone_id":24,"skills_id":172,"ordering":4},{"id":419,"me_milestone_id":24,"skills_id":133,"ordering":5},{"id":420,"me_milestone_id":24,"skills_id":131,"ordering":6},{"id":421,"me_milestone_id":24,"skills_id":181,"ordering":7},{"id":422,"me_milestone_id":24,"skills_id":160,"ordering":8},{"id":423,"me_milestone_id":24,"skills_id":163,"ordering":9},{"id":424,"me_milestone_id":24,"skills_id":166,"ordering":10},{"id":425,"me_milestone_id":24,"skills_id":171,"ordering":11},{"id":426,"me_milestone_id":24,"skills_id":130,"ordering":12},{"id":427,"me_milestone_id":24,"skills_id":136,"ordering":13},{"id":428,"me_milestone_id":24,"skills_id":140,"ordering":14},{"id":150,"me_milestone_id":24,"skills_id":16,"ordering":null},{"id":186,"me_milestone_id":24,"skills_id":141,"ordering":null},{"id":187,"me_milestone_id":24,"skills_id":193,"ordering":null}]},{"id":25,"status":"draft","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-07-01T10:45:50.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2022-09-14T11:33:58.000Z","me_id":"ME_QKART_BACKEND","slug":"me-qkartbackend-milestone-1","title":"Set up application","content":"<h1>Set up application and implement the first API</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Implemented `GET /v1/users` API endpoint to send user data to clients</li>\\n<li>Followed a layered approach to implement the request-response cycle for ease of maintenance</li>\\n<li>Used Mongoose (Node.js-MongoDB ODM) to fetch user data from MongoDB</li>\\n<li>Defined JOI schema to easily validate client requests</li>\\n<li>Utilized middlewares to reduce code duplication</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Node.js, Express.js, MongoDB, Mongoose ODM, JOI validation</p>\\n<h2>Image(s)</h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/995c6746-976b-4dbf-a3db-e7de6af3162d?\\" alt=\\"Request-response cycle in QKart (Endpoint: /v1/users)\\" /></div>","completed_modules":"1","skills":[{"id":429,"me_milestone_id":25,"skills_id":142,"ordering":1},{"id":434,"me_milestone_id":25,"skills_id":143,"ordering":1},{"id":430,"me_milestone_id":25,"skills_id":194,"ordering":2},{"id":431,"me_milestone_id":25,"skills_id":11,"ordering":3},{"id":432,"me_milestone_id":25,"skills_id":163,"ordering":4},{"id":433,"me_milestone_id":25,"skills_id":249,"ordering":5},{"id":152,"me_milestone_id":25,"skills_id":15,"ordering":null},{"id":153,"me_milestone_id":25,"skills_id":17,"ordering":null},{"id":154,"me_milestone_id":25,"skills_id":19,"ordering":null}]},{"id":26,"status":"draft","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2022-07-01T11:06:00.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2022-09-15T05:37:03.000Z","me_id":"ME_QTRIPSTATIC","slug":"me-qtripstatic-milestone-2","title":"Implement the adventures page","content":"<h1>Implement the adventures page</h1>\\n<h2>Scope of work</h2>\\n<ul>\\n<li>Created a responsive grid of adventures using Bootstrap&rsquo;s grid</li>\\n<li>Made adventure type and price text on the cards responsive using Bootstrap&rsquo;s flex containers</li>\\n<li>Added proper spacing between the adventure&rsquo;s grid using Bootstrap spacing shorthands</li>\\n<li>Made the images to be responsive using Bootstrap&rsquo;s responsive image classes</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>HTML, CSS, Bootstrap, Bootstrap Flex, Bootstrap Spacing, Bootstrap Responsive Images</p>\\n<h2>Image(s)</h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/665e2c16-9a19-4d84-b967-7c4210833e8d?\\" alt=\\"Adventures page on varying screen sizes\\" /></div>","completed_modules":"3","skills":[{"id":498,"me_milestone_id":26,"skills_id":157,"ordering":8},{"id":207,"me_milestone_id":26,"skills_id":155,"ordering":null},{"id":208,"me_milestone_id":26,"skills_id":156,"ordering":null}]},{"id":27,"status":"draft","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-07-01T11:19:15.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2022-09-15T05:29:53.000Z","me_id":"ME_QKART_BACKEND","slug":"me-qkartbackend-milestone-2","title":"Secure API endpoints and implement register/login APIs","content":"<h1>Secure API endpoints and implement register/login APIs</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Implemented logic to generate short-lived JWT tokens</li>\\n<li>Set token authentication strategy by using the Passport library</li>\\n<li>Secured `GET /v1/users` endpoint using token authentication</li>\\n<li>Created POST APIs for user registration and login</li>\\n<li>Implemented password authentication to facilitate register / login flow</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>REST APIs, Token authentication, JWT Token, Password authentication, Hashing</p>\\n<h2>Image(s)</h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/32671ec9-8074-4f0e-b45c-3cf951bc48f7?\\" alt=\\"JWT Token authentication flow for QKart APIs\\" /></div>","completed_modules":"2","skills":[{"id":653,"me_milestone_id":27,"skills_id":147,"ordering":1},{"id":191,"me_milestone_id":27,"skills_id":144,"ordering":null},{"id":192,"me_milestone_id":27,"skills_id":145,"ordering":null},{"id":193,"me_milestone_id":27,"skills_id":146,"ordering":null}]},{"id":28,"status":"draft","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2022-07-01T11:32:49.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2022-09-15T05:37:42.000Z","me_id":"ME_QTRIPSTATIC","slug":"me-qtripstatic-milestone-3","title":"Add the adventure details page","content":"<h1>Add the adventure details page to complete the static web page features</h1>\\n<h2>Scope of work</h2>\\n<ul>\\n<li>Came up with the page&rsquo;s HTML layout from scratch</li>\\n<li>Positioned images of varying sizes and set them to toggle visibility based on screen sizes</li>\\n<li>Created the &ldquo;Sold out&rdquo; side section to be fixed on the screen even on scrolling</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>HTML, CSS, Bootstrap, Bootstrap Display, CSS Positioning</p>\\n<h2>Image(s)</h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/65df23d0-bd86-4541-bac7-4491189dae83?\\" alt=\\"Adventure details page wireframe\\" /><img src=\\"https://directus.crio.do/assets/d2192e14-3901-4e25-bfcd-361f265b881d?\\" alt=\\"Adventure details page on different screen sizes\\" /></div>","completed_modules":"4","skills":[{"id":209,"me_milestone_id":28,"skills_id":158,"ordering":null},{"id":210,"me_milestone_id":28,"skills_id":159,"ordering":null}]},{"id":29,"status":"draft","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-07-01T12:16:35.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2022-09-15T05:30:30.000Z","me_id":"ME_QKART_BACKEND","slug":"me-qkartbackend-milestone-3","title":"Implement APIs related to shopping cart","content":"<h1>Implement APIs related to shopping cart</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Implemented the GET/POST/PUT API endpoints for a user&rsquo;s shopping cart</li>\\n<li>Improved the `GET /v1/users` endpoint by supporting filtering for user address via query parameters</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>REST APIs, Filtered API Queries</p>","completed_modules":"3","skills":[]},{"id":30,"status":"draft","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-07-01T12:23:06.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2022-09-15T05:32:42.000Z","me_id":"ME_QKART_BACKEND","slug":"me-qkartbackend-milestone-4","title":"Complete the checkout logic using TDD","content":"<h1>Complete the checkout logic using TDD</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Added Jest-based assertions to unit tests for checkout requirements provided</li>\\n<li>Implemented the checkout logic in a Test-driven development style</li>\\n<li>Utilized integration tests to find and resolve bugs on integrating checkout logic to the application</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Test-driven development, Unit testing, Integration testing, Jest framework</p>","completed_modules":"4","skills":[{"id":275,"me_milestone_id":30,"skills_id":177,"ordering":0},{"id":195,"me_milestone_id":30,"skills_id":148,"ordering":1},{"id":196,"me_milestone_id":30,"skills_id":149,"ordering":2},{"id":197,"me_milestone_id":30,"skills_id":150,"ordering":3}]},{"id":31,"status":"draft","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-07-01T12:26:04.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2022-09-15T05:35:26.000Z","me_id":"ME_QKART_BACKEND","slug":"me-qkartbackend-milestone-5","title":"Deploy the QKart backend server","content":"<h1>Deploy the QKart backend server</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Created a MongoDB instance on MongoDB Atlas cloud and uploaded products data to the cloud DB.</li>\\n<li>Deployed the QKart Node.js app to Heroku</li>\\n<li>Deployed the QKart React frontend to Netlify after configuring it to use the deployed Node.js backend.</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>MongoDB Atlas, Deployment, Heroku, Netlify</p>","completed_modules":"5","skills":[{"id":654,"me_milestone_id":31,"skills_id":140,"ordering":1},{"id":655,"me_milestone_id":31,"skills_id":152,"ordering":2},{"id":656,"me_milestone_id":31,"skills_id":141,"ordering":3},{"id":202,"me_milestone_id":31,"skills_id":196,"ordering":null}]},{"id":32,"status":"draft","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2022-07-01T12:39:48.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2022-09-15T05:38:29.000Z","me_id":"ME_QTRIPSTATIC","slug":"me-qtripstatic-milestone-4","title":"Deploy the QTripStatic website","content":"<h1>Deploy the QTripStatic website</h1>\\n<h2>Scope of work</h2>\\n<ul>\\n<li>Deployed the QTripStatic website to Netlify using Netlify CLI commands</li>\\n</ul>\\n<h3>Skills used</h3>\\n<p>Deployment, Netlify, Netlify CLI</p>","completed_modules":"5","skills":[{"id":211,"me_milestone_id":32,"skills_id":140,"ordering":null},{"id":212,"me_milestone_id":32,"skills_id":141,"ordering":null},{"id":213,"me_milestone_id":32,"skills_id":160,"ordering":null}]},{"id":34,"status":"draft","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2022-07-01T14:01:11.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2022-09-14T13:01:46.000Z","me_id":"ME_QKART_FRONTEND_V2","slug":"me-qkart-milestone-1","title":"Add Registration feature","content":"<h1>Add Registration feature</h1>\\n<h2>Scope of work</h2>\\n<ul>\\n<li>Implemented logic and used backend API to get the registration feature ready</li>\\n<li>Added validation for the register form user input values to display informative error messages</li>\\n</ul>\\n<h3>Skills used</h3>\\n<p>React.js, Event Handling, Forms, React Hooks, REST API, Error Handling</p>","completed_modules":"1","skills":[{"id":571,"me_milestone_id":34,"skills_id":167,"ordering":1},{"id":572,"me_milestone_id":34,"skills_id":166,"ordering":2},{"id":573,"me_milestone_id":34,"skills_id":171,"ordering":3},{"id":574,"me_milestone_id":34,"skills_id":11,"ordering":4},{"id":575,"me_milestone_id":34,"skills_id":232,"ordering":5},{"id":576,"me_milestone_id":34,"skills_id":168,"ordering":6},{"id":577,"me_milestone_id":34,"skills_id":181,"ordering":7},{"id":578,"me_milestone_id":34,"skills_id":163,"ordering":8},{"id":579,"me_milestone_id":34,"skills_id":138,"ordering":9},{"id":580,"me_milestone_id":34,"skills_id":131,"ordering":10},{"id":130,"me_milestone_id":34,"skills_id":16,"ordering":null},{"id":238,"me_milestone_id":34,"skills_id":130,"ordering":null}]},{"id":35,"status":"draft","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2022-07-01T14:12:35.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2022-09-15T05:41:56.000Z","me_id":"ME_QKART_FRONTEND_V2","slug":"me-qkart-milestone-2","title":"Implement registration-login flow and set up routing","content":"<h1>Implement registration-login flow and set up routing</h1>\\n<h2>Scope of work</h2>\\n<ul>\\n<li>Used React Router library to set up routes in the application and redirect customers to appropriate pages</li>\\n<li>Added UI and logic to get the Login page ready</li>\\n<li>Stored user information at client side using localStorage to avoid login on revisit</li>\\n</ul>\\n<h3>Skills used</h3>\\n<p>React Router, Material UI, localStorage, Controlled Components, Conditional Rendering</p>\\n<h3>Image(s)</h3>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/e7fffbe8-0d6b-4b82-a353-42787b551cda?\\" alt=\\"Request-response cycle for QKart User signup and login\\" /><img src=\\"https://directus.crio.do/assets/e049e742-f405-4e09-9bf0-5db1fd7a07bc?\\" alt=\\"User flow on website for signup and login\\" /></div>","completed_modules":"2","skills":[{"id":593,"me_milestone_id":35,"skills_id":250,"ordering":1},{"id":657,"me_milestone_id":35,"skills_id":169,"ordering":1},{"id":590,"me_milestone_id":35,"skills_id":170,"ordering":10},{"id":592,"me_milestone_id":35,"skills_id":136,"ordering":12},{"id":244,"me_milestone_id":35,"skills_id":132,"ordering":null}]},{"id":36,"status":"draft","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2022-07-01T15:41:29.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2022-09-15T05:43:28.000Z","me_id":"ME_QKART_FRONTEND_V2","slug":"me-qkart-milestone-3","title":"Display products and implement search feature","content":"<h1>Display products and implement search feature</h1>\\n<h2>Scope of work</h2>\\n<ul>\\n<li>Utilized the useEffect() hook to fetch products data after DOM is rendered for faster page loading</li>\\n<li>Added search bar to display only on the Products page&rsquo;s header and implemented search logic</li>\\n<li>Implemented debouncing for improved UX and reduced API calls on search</li>\\n</ul>\\n<h3>Skills used</h3>\\n<p>Keyword Search, Debouncing, Material UI Grid</p>\\n<h2>Image(s)</h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/ff900517-2e55-454d-9419-25bd4ce4db49?\\" alt=\\"QKart Products page\\" /></div>","completed_modules":"3","skills":[{"id":658,"me_milestone_id":36,"skills_id":172,"ordering":1},{"id":247,"me_milestone_id":36,"skills_id":134,"ordering":null},{"id":248,"me_milestone_id":36,"skills_id":135,"ordering":null}]},{"id":37,"status":"draft","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2022-07-01T15:46:56.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2022-09-15T05:44:10.000Z","me_id":"ME_QKART_FRONTEND_V2","slug":"me-qkart-milestone-4","title":"Add shopping cart and implement checkout flow","content":"<h1>Add shopping cart and implement checkout flow</h1>\\n<h2>Scope of work</h2>\\n<ul>\\n<li>Added Cart to Products page and made it responsive</li>\\n<li>Made authenticated POST API calls to implement Cart logic</li>\\n<li>Rendered Cart with differing designs in Products page and Checkout page using conditional rendering</li>\\n<li>Implemented UI and logic to add and select new addresses</li>\\n</ul>\\n<h3>Skills used</h3>\\n<p>Responsive Design, Reusable Components</p>\\n<h3>Image(s)</h3>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/cee7a520-32d5-4fd1-9661-c5e257f1b98d?\\" alt=\\"Products page UI with responsive Cart design (Left: Desktop, Right: Mobile)\\" /><img src=\\"https://directus.crio.do/assets/58527646-a8d2-4d39-ae15-5356da347459?\\" alt=\\"QKart Checkout page\\" /></div>","completed_modules":"5","skills":[]},{"id":38,"status":"draft","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2022-07-01T15:48:49.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2022-09-15T05:14:21.000Z","me_id":"ME_QKART_FRONTEND_V2","slug":"me-qkart-milestone-5","title":"Deploy the QKart website","content":"<h1>Deploy the QKart website</h1>\\n<h2>Scope of work</h2>\\n<ul>\\n<li>Deployed the QKart React app to Netlify</li>\\n<li>Configured Netlify to support visiting any sub pages directly as React is a single page application</li>\\n</ul>\\n<h3>Skills used</h3>\\n<p>Deployment, Netlify</p>","completed_modules":"6","skills":[{"id":651,"me_milestone_id":38,"skills_id":140,"ordering":1},{"id":652,"me_milestone_id":38,"skills_id":141,"ordering":2}]},{"id":39,"status":"draft","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2022-07-01T16:01:23.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2022-09-14T12:11:09.000Z","me_id":"ME_BUILDOUT_XFLIX_NODE","slug":"me-xflix-milestone-1","title":"Build XFlix Backend from scratch","content":"<h1>Build XFlix Backend completely from scratch</h1>\\n<h2>Scope of work</h2>\\n<ul>\\n<li>Implemented a set of 5 REST APIs<br />```<br />GET /v1/videos<br />GET /v1/videos/:videoId<br />POST /v1/videos<br />PATCH /v1/videos/:videoId/votes<br />PATCH /v1/videos/:videoId/views<br />```</li>\\n<li>Improved `GET /v1/videos` endpoint to allow</li>\\n</ul>\\n<ol>\\n<li style=\\"list-style-type: none;\\">\\n<ol>\\n<li>video title search</li>\\n<li>filtering by multiple genres</li>\\n<li>filtering by content rating</li>\\n<li>sorting by video upload date or view count</li>\\n</ol>\\n</li>\\n</ol>\\n<ul>\\n<li>Utilized MongoDB to persist video data</li>\\n<li>Plugged-in the backend to XFlix frontend and deployed the Full-stack application</li>\\n</ul>\\n<h3>Skills used</h3>\\n<p>Node.js, Express.js, MongoDB, REST API, Postman</p>\\n<h3>Image(s)</h3>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/b08887c0-4590-42b7-9f75-675dedfb3f35?\\" alt=\\"Request variants supported by &ldquo;GET /v1/videos&rdquo; endpoint\\" /></div>","completed_modules":"1","skills":[{"id":485,"me_milestone_id":39,"skills_id":142,"ordering":1},{"id":486,"me_milestone_id":39,"skills_id":192,"ordering":2},{"id":487,"me_milestone_id":39,"skills_id":152,"ordering":3},{"id":488,"me_milestone_id":39,"skills_id":163,"ordering":4},{"id":489,"me_milestone_id":39,"skills_id":140,"ordering":5},{"id":101,"me_milestone_id":39,"skills_id":17,"ordering":null},{"id":102,"me_milestone_id":39,"skills_id":15,"ordering":null},{"id":103,"me_milestone_id":39,"skills_id":19,"ordering":null},{"id":104,"me_milestone_id":39,"skills_id":11,"ordering":null},{"id":203,"me_milestone_id":39,"skills_id":194,"ordering":null}]},{"id":40,"status":"draft","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2022-07-01T16:28:00.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2022-09-14T09:15:05.000Z","me_id":"ME_BUILDOUT_XMEME_JAVA","slug":"me-xmeme-milestone-1","title":"Built XMeme backend from scratch","content":"<h1>Built XMeme backend completely from scratch</h1>\\n<h2>Scope of work</h2>\\n<ul>\\n<li>Created a Backend Server using Spring template with the REST API handlers.</li>\\n<li>Implemented support for POST API that can be used to post Memes.</li>\\n<li>Implemented support for GET API that can be used to fetch the 100 newest memes posted, including these fields - name, caption and image URLs.</li>\\n<li>Implemented support for GET API to fetch individual Memes using Meme Id.</li>\\n<li>Used MongoDB to store the Meme related fields and extract them.</li>\\n<li>Handled incorrect requests and used appropriate HTTP Response codes for error scenarios.</li>\\n<li>Tested the functionality and wrote code with clear comments and documentation.</li>\\n<li>Wrote modular code following MVCS layering architecture.</li>\\n</ul>\\n<h3>Skills used</h3>\\n<p>Core Java, Backend Server, Jackson, Spring Boot, Spring Data, REST API, MongoDB, Docker and Swagger</p>","completed_modules":"1","skills":[{"id":373,"me_milestone_id":40,"skills_id":56,"ordering":1},{"id":374,"me_milestone_id":40,"skills_id":187,"ordering":2},{"id":375,"me_milestone_id":40,"skills_id":148,"ordering":3},{"id":109,"me_milestone_id":40,"skills_id":26,"ordering":null},{"id":110,"me_milestone_id":40,"skills_id":24,"ordering":null},{"id":111,"me_milestone_id":40,"skills_id":23,"ordering":null},{"id":112,"me_milestone_id":40,"skills_id":11,"ordering":null},{"id":113,"me_milestone_id":40,"skills_id":19,"ordering":null}]},{"id":41,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2022-07-01T17:10:42.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2023-10-26T11:24:00.000Z","me_id":"ME_BUILDOUT_XBOARD","slug":"me-xboard-milestone-1","title":"Build XBoard completely from scratch","content":"<h1>Build XBoard completely from scratch</h1>\\n<h2>Scope of work</h2>\\n<ul>\\n<li>Created web page for XBoard, to show news articles</li>\\n<li>Invoked API to fetch the necessary data from flipboard&rsquo;s rss feed and integrate that into the web page</li>\\n<li>Implemented desktop and mobile views with reference to the Figma design</li>\\n<li>Improved UI by setting each section as an accordion and including image carousels</li>\\n<li>Deployed the dynamic webpage to Netlify</li>\\n</ul>\\n<h3>Skills used</h3>\\n<p>HTML, CSS, Bootstrap, JavaScript, JQuery</p>","completed_modules":"1","skills":[{"id":126,"me_milestone_id":41,"skills_id":10,"ordering":0},{"id":129,"me_milestone_id":41,"skills_id":12,"ordering":1},{"id":636,"me_milestone_id":41,"skills_id":193,"ordering":1},{"id":751,"me_milestone_id":41,"skills_id":268,"ordering":1},{"id":127,"me_milestone_id":41,"skills_id":13,"ordering":2},{"id":637,"me_milestone_id":41,"skills_id":163,"ordering":2},{"id":128,"me_milestone_id":41,"skills_id":22,"ordering":3},{"id":638,"me_milestone_id":41,"skills_id":161,"ordering":3},{"id":639,"me_milestone_id":41,"skills_id":181,"ordering":4},{"id":640,"me_milestone_id":41,"skills_id":11,"ordering":5},{"id":641,"me_milestone_id":41,"skills_id":232,"ordering":6},{"id":642,"me_milestone_id":41,"skills_id":141,"ordering":7},{"id":643,"me_milestone_id":41,"skills_id":160,"ordering":8},{"id":644,"me_milestone_id":41,"skills_id":140,"ordering":9},{"id":645,"me_milestone_id":41,"skills_id":154,"ordering":10},{"id":646,"me_milestone_id":41,"skills_id":165,"ordering":11}]},{"id":42,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-07-02T06:05:00.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2023-04-21T10:31:15.000Z","me_id":"ME_OBJECT_MODELING_V2","slug":"me-objectmodeling-milestone-1","title":"Introduction to Low Level Design","content":"<h1>Introduction to Low Level Design</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Get introduced to the components of Clean Architecture.</li>\\n<li>Understand entities and identify them with the help of real-world examples.</li>\\n<li>Gather requirements and translate them into use cases.</li>\\n<li>Understand the need for a datastore.</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Clean Architecture</p>\\n<h2>Image(s)</h2>\\n<p>&nbsp;</p>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/404ffa81-c0c1-473a-ba47-3ca8acddeb30?\\" alt=\\"Components of Clean Architecture\\" /></div>","completed_modules":"1","skills":[{"id":254,"me_milestone_id":42,"skills_id":174,"ordering":null}]},{"id":43,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-07-02T06:10:36.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2023-04-21T10:31:06.000Z","me_id":"ME_OBJECT_MODELING_V2","slug":"me-objectmodeling-milestone-2","title":"Identify relationships between entities","content":"<h1>Identify relationships between entities</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Explore different types of class relationships and their purpose.</li>\\n<li>Discover relationships for different scenarios and draw an object diagram.</li>\\n<li>Understand the provided Object Relationship Diagram of Movie Booking Problem statement.</li>\\n<li>Understand the CodinGame problem statement. Draw Use Case and Object Diagram for the given scenarios</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Object Oriented Design</p>\\n<h2>Image(s)</h2>\\n<div class=\\"image-container\\">&nbsp;</div>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/909c4a95-3716-42c3-ac72-c1cf055e63f5?\\" alt=\\"Use Case Diagram for Coding Game\\" /></div>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/1984aa85-e771-4404-896a-c5aa7939e99d?\\" alt=\\"Object Diagram for CodinGame\\" /></div>","completed_modules":"2","skills":[{"id":255,"me_milestone_id":43,"skills_id":175,"ordering":null}]},{"id":44,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-07-02T06:14:29.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2023-04-21T10:31:21.000Z","me_id":"ME_OBJECT_MODELING_V2","slug":"me-objectmodeling-milestone-3","title":"Implement Entities","content":"<h1>Implement Entities</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Understand the entities of the provided implementation of Movie Booking Problem statement.</li>\\n<li>For CodinGame Problem Statement\\n<ul>\\n<li>Implement entities with the identified attributes and their behaviour.</li>\\n<li>Implement the relationship between the entities</li>\\n<li>Write good quality tests for entitles, which cover all the relevant behaviour.</li>\\n</ul>\\n</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Java, Unit Testing, Test Driven Development</p>","completed_modules":"3","skills":[{"id":307,"me_milestone_id":44,"skills_id":26,"ordering":3},{"id":308,"me_milestone_id":44,"skills_id":148,"ordering":4}]},{"id":45,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-07-02T06:16:55.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2023-04-21T10:31:31.000Z","me_id":"ME_OBJECT_MODELING_V2","slug":"me-objectmodeling-milestone-4","title":"Implement Services and Repositories","content":"<h1>Implement Services and Repositories</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Understood the services &amp; repositories layer of the provided implementation of Movie Booking Problem Statement.</li>\\n<li>Implemented services &amp; repositories layer of CodinGame adhering to the SOLID principles.</li>\\n<li>Followed Test Driven Development to ensure correctness and better code coverage.</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Java, Unit Testing, Test Driven Development, Design Patterns, SOLID Principles</p>","completed_modules":"4","skills":[{"id":313,"me_milestone_id":45,"skills_id":178,"ordering":5},{"id":314,"me_milestone_id":45,"skills_id":179,"ordering":6},{"id":315,"me_milestone_id":45,"skills_id":187,"ordering":7},{"id":316,"me_milestone_id":45,"skills_id":188,"ordering":8}]},{"id":46,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-07-02T06:20:22.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2023-04-21T10:31:38.000Z","me_id":"ME_OBJECT_MODELING_V2","slug":"me-objectmodeling-milestone-5","title":"Implement Commands and finish up the Project","content":"<h1>Implement Commands and finish up the Project</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Understand the controller layer of the provided implementation of Movie Booking Problem Statement.</li>\\n<li>Implement all the required commands in the controller layer for the CodinGame problem statement using Test Driven Development.</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Java,Unit Testing, Test Driven Development, Design Patterns, SOLID Principles</p>","completed_modules":"5","skills":[]},{"id":47,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-07-02T06:23:52.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2023-04-21T10:31:53.000Z","me_id":"ME_OBJECT_MODELING_V2","slug":"me-objectmodeling-milestone-6","title":"Implement JukeBox from Scratch","content":"<h1>Implement JukeBox from Scratch</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Clearly understand the Problem Statement Requirements.</li>\\n<li>Identify the Primary Use Cases / Behaviour of the system.</li>\\n<li>Identify the Key Objects / Entities from the listed use cases.</li>\\n<li>Identify the behaviours / supported operations for Identified objects.</li>\\n<li>Identify Interactions between the entities (Class Relationships).</li>\\n<li>Implement all the required layers embracing the clean architecture style.</li>\\n<li>Implement all the required layers step by step in a Test-driven development style to ensure correctness and better code coverage.</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Java, Object Oriented Design, Design Patterns, Test Driven Development, Unit Testing</p>\\n<h2>Image(s)</h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/932401c3-7a0a-438d-b20a-a94917f2128c?\\" alt=\\"JukeBox Conceptual Overview\\" /></div>","completed_modules":"6","skills":[{"id":330,"me_milestone_id":47,"skills_id":187,"ordering":7},{"id":331,"me_milestone_id":47,"skills_id":30,"ordering":8},{"id":332,"me_milestone_id":47,"skills_id":28,"ordering":9}]},{"id":50,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-07-19T16:57:35.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2023-04-12T05:55:18.000Z","me_id":"ME_QKART_QA","slug":"me-qkartqa-milestone-1","title":"Modularise test code and debug issues","content":"<h1>Modularise test code and debug issues</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Modularised existing test code for readability and to avoid code duplication</li>\\n<li>Fixed various bugs present in the existing code base for Register and Login pages</li>\\n<li>Used IDE debugger with breakpoints to find and resolve issues faster</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Java, Selenium, Locators, HTML, Developer Tools</p>\\n<h2>Image(s)</h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/eaf1aa7f-3576-423e-9401-a53decd0e575?\\" alt=\\"QKart Registration Page\\" /> <img src=\\"https://directus.crio.do/assets/43a6d026-13aa-4e74-95d2-8597ed9ed9c2?\\" alt=\\"Test case requirements\\" /></div>","completed_modules":"1","skills":[{"id":635,"me_milestone_id":50,"skills_id":148,"ordering":1},{"id":159,"me_milestone_id":50,"skills_id":26,"ordering":null},{"id":160,"me_milestone_id":50,"skills_id":42,"ordering":null},{"id":261,"me_milestone_id":50,"skills_id":180,"ordering":null},{"id":262,"me_milestone_id":50,"skills_id":10,"ordering":null},{"id":263,"me_milestone_id":50,"skills_id":181,"ordering":null}]},{"id":51,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-07-19T17:09:37.000Z","user_updated":"42670516-02dd-418e-abaa-d5ff0d183714","date_updated":"2023-11-22T17:14:17.000Z","me_id":"ME_QKART_QA","slug":"me-qkart-qa-milestone-2","title":"Automate given manual test cases","content":"<h1>Automate given manual test cases</h1>\\n<h2>Scope of Work</h2>\\n<ol>\\n<li>Implemented automated tests for functionalities like product search, editing user cart items, cart content persistence across sessions</li>\\n<li>Added log statements appropriately to aid in debugging any issues</li>\\n<li>Reused methods like searching for products, and add items to the cart thus making the code more maintainable</li>\\n</ol>\\n<h2>Skills used</h2>\\n<p>Java, Selenium, Locators, HTML, Developer Tools</p>\\n<h2>Image(s)</h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/60ceae94-371d-4828-87b7-4a05887c4a57?\\" alt=\\"QKart Shopping Interface (Products page)\\" /></div>","completed_modules":"2","skills":[]},{"id":52,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-07-19T17:12:42.000Z","user_updated":"42670516-02dd-418e-abaa-d5ff0d183714","date_updated":"2023-11-22T17:14:33.000Z","me_id":"ME_QKART_QA","slug":"me-qkart-qa-milestone-3","title":"Enhance reliability of the automation code","content":"<h1>Enhance reliability of the automation code by using implicit and explicit waits correctly</h1>\\n<h2>Scope of Work</h2>\\n<ol>\\n<li>Placed appropriate wait statements in code base to improve script synchronization</li>\\n<li>Implemented feature request to take screenshots before and after the test case and also capture screenshots in case of error</li>\\n<li>Performed automation tests/validations that span across different browser tabs and windows<br /><br /></li>\\n</ol>\\n<h2>Skills used</h2>\\n<p>Java, Selenium, Locators, HTML, Developer Tools</p>","completed_modules":"3","skills":[{"id":282,"me_milestone_id":52,"skills_id":246,"ordering":1},{"id":283,"me_milestone_id":52,"skills_id":245,"ordering":2},{"id":284,"me_milestone_id":52,"skills_id":247,"ordering":3}]},{"id":53,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-07-19T17:33:24.000Z","user_updated":"42670516-02dd-418e-abaa-d5ff0d183714","date_updated":"2023-11-22T17:14:39.000Z","me_id":"ME_QKART_QA","slug":"me-qkart-qa-milestone-4","title":"Making the automation code more resilient with XPath","content":"<h1>Making the automation code more resilient with XPath</h1>\\n<h2>Scope of Work</h2>\\n<ol>\\n<li>Fixed a few bugs in the existing codebase as a result of incorrect locators by replacing them with XPath</li>\\n<li>Improved code by replacing existing locators with Dynamic XPath<br /><br /></li>\\n</ol>\\n<h2>Skills used</h2>\\n<p>Java, Selenium, Locators, HTML, Developer Tools, XPath</p>\\n<h2>Image(s)</h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/84fbb7e8-b9cc-433f-aa8c-471020398e2e?\\" alt=\\"Errors due to incorrect locators\\" /></div>","completed_modules":"4","skills":[{"id":264,"me_milestone_id":53,"skills_id":182,"ordering":null}]},{"id":54,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-07-19T17:36:46.000Z","user_updated":"42670516-02dd-418e-abaa-d5ff0d183714","date_updated":"2023-11-22T17:14:48.000Z","me_id":"ME_QKART_QA","slug":"me-qkart-qa-milestone-5","title":"Using TestNG to enable features","content":"<h1>Using TestNG to enable features like grouping, prioritising, and parameterising of tests</h1>\\n<h2>Scope of Work</h2>\\n<ol>\\n<li>Migrated existing Selenium test code to use the TestNG framework</li>\\n<li>Parameterised the test cases and used XML configuration to send the parameters dynamically</li>\\n<li>Created sanity and regression test groups</li>\\n<li>Utilised Test Listeners to take screenshots on different events<br /><br /></li>\\n</ol>\\n<h2>Skills used</h2>\\n<p>Java, Selenium, Locators, HTML, Developer Tools, XPath, TestNG</p>\\n<h2>Image(s)</h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/c37a6309-e5c7-4112-8fd1-6ba609abf544?\\" alt=\\"Test report with TestNG\\" /></div>","completed_modules":"5","skills":[{"id":265,"me_milestone_id":54,"skills_id":34,"ordering":null}]},{"id":55,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-07-19T17:40:53.000Z","user_updated":"42670516-02dd-418e-abaa-d5ff0d183714","date_updated":"2023-11-22T14:12:30.000Z","me_id":"ME_QKART_QA","slug":"me-qkart-qa-milestone-6","title":"Utilise Apache POI to read and write","content":"<h1>Utilise Apache POI to read and write excel data</h1>\\n<h2>Scope of Work</h2>\\n<ol>\\n<li>Created multiple test data sets for each test case in excel</li>\\n<li>Used Apache POI and DataProviders to consume test data from excel</li>\\n<li>Saved the test output by writing it back to excel</li>\\n<li>Improved test completion time by adding parallelisation</li>\\n</ol>\\n<h2>Skills used</h2>\\n<p>Java, Selenium, Locators, HTML, Developer Tools, XPath, TestNG, Apache POI, Selenium Grid</p>\\n<h2>Image(s)</h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/453bed70-8ebe-49bc-973e-09971b8a64c6?\\" alt=\\"Test output saved to excel file\\" /></div>","completed_modules":"6","skills":[{"id":266,"me_milestone_id":55,"skills_id":184,"ordering":null}]},{"id":56,"status":"draft","sort":null,"user_created":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_created":"2022-07-20T12:40:38.000Z","user_updated":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_updated":"2022-07-20T12:40:55.000Z","me_id":"ME_QMONEY","slug":"me-qmoney-v1-milestone-1","title":"Fetch stock quotes and annual returns","content":"<h1>Fetch stock quotes and compute annualized stock returns</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Used Tiingo&rsquo;s REST APIs to fetch stock quotes.</li>\\n<li>Computed the annualized returns based on stock purchase date and holding period.</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Java, REST API, Jackson</p>","completed_modules":"3","skills":[{"id":162,"me_milestone_id":56,"skills_id":26,"ordering":null},{"id":163,"me_milestone_id":56,"skills_id":11,"ordering":null},{"id":164,"me_milestone_id":56,"skills_id":32,"ordering":null}]},{"id":57,"status":"draft","sort":null,"user_created":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_created":"2022-07-20T14:30:44.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2022-08-01T14:16:28.000Z","me_id":"ME_QMONEY","slug":"me-qmoney-v1-milestone-2","title":"Refactor and publish a JAR file","content":"<h1>Refactor using Java interfaces and publish a JAR file</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Refactored code to adapt to an updated interface contract published by the backend team.</li>\\n<li>Published the portfolio manager library as a JAR for easy versioning and distribution.</li>\\n<li>Created examples to help document library (JAR) usage.</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Interfaces, Code Refactoring, Gradle</p>","completed_modules":"5","skills":[{"id":165,"me_milestone_id":57,"skills_id":36,"ordering":null},{"id":171,"me_milestone_id":57,"skills_id":187,"ordering":null},{"id":172,"me_milestone_id":57,"skills_id":186,"ordering":null}]},{"id":58,"status":"draft","sort":null,"user_created":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_created":"2022-07-20T14:31:28.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2022-08-01T14:16:54.000Z","me_id":"ME_QMONEY","slug":"me-qmoney-v1-milestone-3","title":"Improve application availability and stability","content":"<h1>Improve application availability and stability</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Added support for a backup stock quote service (Alpha Vantage) to improve service availability.</li>\\n<li>Improved application stability with comprehensive error reporting and better exception handling.</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Interfaces, Exception Handling</p>","completed_modules":"7","skills":[{"id":173,"me_milestone_id":58,"skills_id":188,"ordering":null}]},{"id":59,"status":"draft","sort":null,"user_created":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_created":"2022-07-20T14:32:06.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2022-08-01T14:17:40.000Z","me_id":"ME_QMONEY","slug":"me-qmoney-v1-milestone-4","title":"Enhance application performance","content":"<h1>Enhance application performance</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Improved application responsiveness by introducing multithreading.</li>\\n<li>Wrote unit tests to measure performance improvements.</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Multithreading</p>","completed_modules":"8","skills":[{"id":174,"me_milestone_id":59,"skills_id":189,"ordering":null}]},{"id":60,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2022-07-20T16:05:51.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2023-10-26T10:38:15.000Z","me_id":"ME_BUILDOUT_XURL","slug":"me-buildoutxurl-milestone-1","title":"Build XURL from scratch","content":"<h1>Build XURL from scratch</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Create a concrete class which implements a short URL interface class provided. It contains all the methods that can be used to create long URL to short URL mappings.</li>\\n<li>Implement a method to take a long URL as input, generate a random 9 character short URL and return it. Also maintain this mapping using a hash map for quick retrieval.</li>\\n<li>Implement a method to take a long URL and a custom short URL as input and register that mapping.&nbsp;</li>\\n<li>Error handling to make sure each long URL maps to only one short URL and vice versa.</li>\\n<li>Implement a method to lookup short URL for a given long URL, from the mapping created.</li>\\n<li>Implement a method to delete the mapping based on a long URL.</li>\\n<li>Implement a counter to keep track of the hit count for each long URL - which tells us how many times a particular long URL has been looked up.</li>\\n<li>Test these methods using test cases.<br /><br /></li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Core Java, Interfaces, Debugging</p>\\n<p>&nbsp;</p>","completed_modules":"1","skills":[{"id":236,"me_milestone_id":60,"skills_id":26,"ordering":0},{"id":232,"me_milestone_id":60,"skills_id":187,"ordering":1}]},{"id":61,"status":"draft","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2022-08-03T06:21:03.000Z","user_updated":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_updated":"2022-08-03T07:46:07.000Z","me_id":"ME_BUILDOUT_XCOMPANY","slug":"me-buildoutxcompany-milestone-1","title":"Build XCompany Application from scratch","content":"<h1>Build XCompany Application completely from scratch</h1>\\n<h2>Scope of work</h2>\\n<ul>\\n<li><span style=\\"font-weight: 400;\\">Implemented all the required methods in Company and Employee class for the application to support the mentioned commands.</span></li>\\n<li><span style=\\"font-weight: 400;\\">Implemented maintainable and extensible code by following Object Oriented programming principles.</span></li>\\n<li><span style=\\"font-weight: 400;\\">Made use of appropriate data structures to store and retrieve data in an efficient manner.</span></li>\\n<li><span style=\\"font-weight: 400;\\">Approached the Employee Hierarchy Search requirement by applying DSA Skills.</span></li>\\n</ul>\\n<h2>Skills used</h2>\\n<p><span style=\\"font-weight: 400;\\">Java, Python</span></p>","completed_modules":"1","skills":[{"id":268,"me_milestone_id":61,"skills_id":26,"ordering":null},{"id":269,"me_milestone_id":61,"skills_id":241,"ordering":null}]},{"id":62,"status":"draft","sort":null,"user_created":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_created":"2022-08-30T06:54:49.000Z","user_updated":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_updated":"2022-08-30T06:58:32.000Z","me_id":"ME_QCALC_V2","slug":"me-qcalc-v2-milestone-1","title":"Implement Simple Calculator","content":"<h1><strong>Implement Simple Calculator</strong></h1>\\n<h2><strong>Scope of work</strong></h2>\\n<ol>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Generate a Java Gradle Project using Spring Initializer Extension in VSCode IDE.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Implement basic arithmetic operations with two numbers and write unit tests to verify the functionalities.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Implement new methods to support floating point arithmetic operations using method overloading.</span></li>\\n</ol>\\n<h2><strong>Skills used</strong></h2>\\n<p><span style=\\"font-weight: 400;\\">Java, Unit Testing, JUnit</span></p>","completed_modules":"3","skills":[{"id":278,"me_milestone_id":62,"skills_id":26,"ordering":null},{"id":280,"me_milestone_id":62,"skills_id":176,"ordering":null},{"id":281,"me_milestone_id":62,"skills_id":30,"ordering":null}]},{"id":63,"status":"draft","sort":null,"user_created":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_created":"2022-08-30T06:58:00.000Z","user_updated":null,"date_updated":null,"me_id":"ME_QCALC_V2","slug":"me-qcalc-v2-milestone-2","title":"Identify and Handle Exceptions","content":"<h1><strong>Identify and Handle Exceptions</strong></h1>\\n<h2><strong>Scope of work&nbsp;</strong></h2>\\n<ol>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Identify and Handle Exceptions for invalid data.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Write unit tests to validate the Exception being thrown.</span></li>\\n</ol>\\n<h2><strong>Skills used</strong></h2>\\n<p><span style=\\"font-weight: 400;\\">Java, Unit Testing, JUnit, Exception Handling</span></p>","completed_modules":"4","skills":[{"id":279,"me_milestone_id":63,"skills_id":188,"ordering":null}]},{"id":64,"status":"draft","sort":null,"user_created":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_created":"2022-08-30T06:59:27.000Z","user_updated":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_updated":"2022-08-30T07:00:50.000Z","me_id":"ME_QCALC_V2","slug":"me-qcalc-v2-milestone-3","title":"Implement Scientific Calculator","content":"<h1><strong>Implement Scientific Calculator</strong></h1>\\n<h2><strong>Scope of work</strong></h2>\\n<ol>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Extend the existing class to support new features for a Scientific Calculator.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Re-use and improve upon the existing features.</span></li>\\n</ol>\\n<h2><strong>Skills used</strong></h2>\\n<p><span style=\\"font-weight: 400;\\">Java</span></p>","completed_modules":"5","skills":[]},{"id":65,"status":"draft","sort":null,"user_created":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_created":"2022-08-30T07:00:26.000Z","user_updated":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_updated":"2022-08-30T07:00:55.000Z","me_id":"ME_QCALC_V2","slug":"me-qcalc-v2-milestone-4","title":"Debug and Fix Issues","content":"<h1><strong>Debug and Fix Issues</strong></h1>\\n<h2><strong>Scope of work</strong></h2>\\n<ol>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Fix compilation errors caused probably due to syntax / import issues.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Correct logical issues in the code.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Fix the behaviour of a method when data is invalid.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Write Unit Tests for edge cases initially not thought of.&nbsp;</span></li>\\n</ol>\\n<h2><strong>Skills used</strong></h2>\\n<p><span style=\\"font-weight: 400;\\">Java, Unit Testing, JUnit, Exception Handling</span></p>","completed_modules":"6","skills":[]},{"id":66,"status":"draft","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2023-02-02T14:31:26.000Z","user_updated":null,"date_updated":null,"me_id":"ME_QCALC_QA","slug":"me-qcalc-qa-milestone-1","title":"Implement Simple Calculator","content":"<h1><span style=\\"font-weight: 400;\\">Implement Simple Calculator</span></h1>\\n<h2><span style=\\"font-weight: 400;\\">Scope of work</span></h2>\\n<ol>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Generate a Java Gradle Project using Spring Initializer Extension in VSCode IDE.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Implement basic arithmetic operations with two numbers and write unit tests to verify the functionalities.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Implement new methods to support floating point arithmetic operations using method overloading.</span></li>\\n</ol>\\n<h2><span style=\\"font-weight: 400;\\">Skills used</span></h2>\\n<p><span style=\\"font-weight: 400;\\">Java, Unit Testing, JUnit</span></p>\\n<p>&nbsp;</p>","completed_modules":"3","skills":[{"id":659,"me_milestone_id":66,"skills_id":26,"ordering":1},{"id":660,"me_milestone_id":66,"skills_id":148,"ordering":2},{"id":661,"me_milestone_id":66,"skills_id":30,"ordering":3}]},{"id":67,"status":"draft","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2023-02-02T14:33:48.000Z","user_updated":"c9fde96d-9501-41ab-90fd-c90abdc4d0cf","date_updated":"2023-02-02T16:06:03.000Z","me_id":"ME_QCALC_QA","slug":"me-qcalc-qa-milestone-2","title":"Identify and Handle Exceptions","content":"<h1><span style=\\"font-weight: 400;\\">Identify and Handle Exceptions</span></h1>\\n<h2><span style=\\"font-weight: 400;\\">Scope of work&nbsp;</span></h2>\\n<ol>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Identify and Handle Exceptions for invalid data.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Write unit tests to validate the Exception being thrown.</span></li>\\n</ol>\\n<h2><span style=\\"font-weight: 400;\\">Skills used</span></h2>\\n<p><span style=\\"font-weight: 400;\\">Java, Unit Testing, JUnit, Exception Handling</span></p>\\n<p>&nbsp;</p>","completed_modules":"4","skills":[{"id":665,"me_milestone_id":67,"skills_id":188,"ordering":4}]},{"id":68,"status":"draft","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2023-02-02T14:35:38.000Z","user_updated":"c9fde96d-9501-41ab-90fd-c90abdc4d0cf","date_updated":"2023-02-02T16:06:43.000Z","me_id":"ME_QCALC_QA","slug":"me-qcalc-qa-milestone-3","title":"Implement Scientific Calculator","content":"<h1><span style=\\"font-weight: 400;\\">Implement Scientific Calculator</span></h1>\\n<h2><span style=\\"font-weight: 400;\\">Scope of work</span></h2>\\n<ol>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Extend the existing class to support new features for a Scientific Calculator.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Re-use and improve upon the existing features.</span></li>\\n</ol>\\n<h2><span style=\\"font-weight: 400;\\">Skills used</span></h2>\\n<p><span style=\\"font-weight: 400;\\">Java</span></p>","completed_modules":"1","skills":[]},{"id":69,"status":"draft","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2023-02-02T14:37:07.000Z","user_updated":"c9fde96d-9501-41ab-90fd-c90abdc4d0cf","date_updated":"2023-02-02T16:06:50.000Z","me_id":"ME_QCALC_QA","slug":"me-qcalc-v2-milestone-4","title":"Debug and Fix Issues","content":"<h1><span style=\\"font-weight: 400;\\">Debug and Fix Issues</span></h1>\\n<h2><span style=\\"font-weight: 400;\\">Scope of work</span></h2>\\n<ol>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Fix compilation errors caused probably due to syntax / import issues.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Correct logical issues in the code.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Fix the behaviour of a method when data is invalid.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Write Unit Tests for edge cases initially not thought of.&nbsp;</span></li>\\n</ol>\\n<h2><span style=\\"font-weight: 400;\\">Skills used</span></h2>\\n<p><span style=\\"font-weight: 400;\\">Java, Unit Testing, JUnit, Exception Handling</span></p>\\n<p>&nbsp;</p>","completed_modules":"4","skills":[]},{"id":70,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2023-02-21T11:49:29.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2023-02-21T11:54:17.000Z","me_id":"ME_QCONTEST","slug":"me-qcontest-milestone-2","title":"Implement Services and Repositories","content":"<h1><span style=\\"font-weight: 400;\\">Implement Entities</span></h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li><span style=\\"font-weight: 400;\\">Implement services &amp; repositories layer of QContest adhering to the SOLID principles.</span></li>\\n<li><span style=\\"font-weight: 400;\\">Follow Test Driven Development to ensure correctness and better code coverage.&nbsp;<br /></span></li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Object Oriented Design, Java, Python, Unit Testing, Design Patterns, SOLID Principles, Exception Handling</p>","completed_modules":"2","skills":[{"id":669,"me_milestone_id":70,"skills_id":241,"ordering":1},{"id":670,"me_milestone_id":70,"skills_id":178,"ordering":2},{"id":671,"me_milestone_id":70,"skills_id":179,"ordering":3},{"id":672,"me_milestone_id":70,"skills_id":188,"ordering":4}]},{"id":71,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2023-02-21T11:59:11.000Z","user_updated":null,"date_updated":null,"me_id":"ME_QCONTEST","slug":"me-qcontest-milestone-1","title":"Implement Entities","content":"<h1><span style=\\"font-weight: 400;\\">Implement Entities</span></h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li><span style=\\"font-weight: 400;\\">Implement entities with the identified attributes and their behavior.</span></li>\\n<li><span style=\\"font-weight: 400;\\">Implement the relationship between the entities</span></li>\\n<li><span style=\\"font-weight: 400;\\">Write good quality tests for entities that cover all the appropriate behavior.<br /></span><span style=\\"font-weight: 400;\\">&nbsp;<br /></span></li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Object Oriented Design, Java, Unit Testing</p>","completed_modules":"1","skills":[{"id":673,"me_milestone_id":71,"skills_id":175,"ordering":1},{"id":674,"me_milestone_id":71,"skills_id":26,"ordering":2},{"id":675,"me_milestone_id":71,"skills_id":176,"ordering":3}]},{"id":72,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2023-02-21T12:16:53.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2023-02-21T12:17:48.000Z","me_id":"ME_BUILDOUT_MACHINE_CODING_JUKEBOX","slug":"me-buildoutmachinecodingjukebox-milestone-1","title":"Implement JukeBox from Scratch","content":"<h1>Implement JukeBox from Scratch</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li><span style=\\"font-weight: 400;\\">Clearly understand the Problem Statement Requirements.</span></li>\\n<li><span style=\\"font-weight: 400;\\">Identify the system\'s Primary Use Cases / Behaviour.</span></li>\\n<li><span style=\\"font-weight: 400;\\">Identify the Key Objects / Entities from the listed use cases.</span></li>\\n<li><span style=\\"font-weight: 400;\\">Implement entities with the identified attributes and their behavior.</span></li>\\n<li><span style=\\"font-weight: 400;\\">Implement the relationship between the entities.</span></li>\\n<li><span style=\\"font-weight: 400;\\">Write good quality tests for entities that cover all the appropriate behavior.</span></li>\\n<li><span style=\\"font-weight: 400;\\">Implement services &amp; repositories layer of QContest adhering to the SOLID principles.</span></li>\\n<li><span style=\\"font-weight: 400;\\">Follow Test Driven Development to ensure correctness and better code coverage.&nbsp;<br /></span><span style=\\"font-weight: 400;\\"><br /></span><span style=\\"font-weight: 400;\\">&nbsp;<br /></span></li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Object Oriented Design, Java, Python, Unit Testing, Design Patterns, SOLID Principles</p>","completed_modules":"1","skills":[{"id":676,"me_milestone_id":72,"skills_id":175,"ordering":1},{"id":678,"me_milestone_id":72,"skills_id":241,"ordering":1},{"id":677,"me_milestone_id":72,"skills_id":26,"ordering":2},{"id":679,"me_milestone_id":72,"skills_id":176,"ordering":2},{"id":680,"me_milestone_id":72,"skills_id":178,"ordering":3},{"id":681,"me_milestone_id":72,"skills_id":179,"ordering":4}]},{"id":73,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2023-02-21T12:56:07.000Z","user_updated":null,"date_updated":null,"me_id":"ME_BUILDOUT_MACHINE_CODING_RESTAURANT_RATING","slug":"me-buildoutmachinecodingrestaurantrating-milestone-1","title":"Implement Restaurant Rating from Scratch","content":"<h1>Implement Restaurant Rating from Scratch</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li><span style=\\"font-weight: 400;\\">Clearly understand the Problem Statement Requirements.</span></li>\\n<li><span style=\\"font-weight: 400;\\">Identify the system\'s Primary Use Cases / Behaviour.</span></li>\\n<li><span style=\\"font-weight: 400;\\">Identify the Key Objects / Entities from the listed use cases.</span></li>\\n<li><span style=\\"font-weight: 400;\\">Implement entities with the identified attributes and their behavior.</span></li>\\n<li><span style=\\"font-weight: 400;\\">Implement the relationship between the entities.</span></li>\\n<li><span style=\\"font-weight: 400;\\">Write good quality tests for entities that cover all the appropriate behavior.</span></li>\\n<li><span style=\\"font-weight: 400;\\">Implement services &amp; repositories layer of QContest adhering to the SOLID principles.</span></li>\\n<li><span style=\\"font-weight: 400;\\">Follow Test Driven Development to ensure correctness and better code coverage.&nbsp;<br /></span><span style=\\"font-weight: 400;\\">&nbsp;<br /></span></li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Object Oriented Design, Java, Python, Unit Testing, Design Patterns, SOLID Principles</p>","completed_modules":"1","skills":[{"id":682,"me_milestone_id":73,"skills_id":175,"ordering":1},{"id":683,"me_milestone_id":73,"skills_id":26,"ordering":2},{"id":684,"me_milestone_id":73,"skills_id":241,"ordering":3},{"id":685,"me_milestone_id":73,"skills_id":176,"ordering":4},{"id":686,"me_milestone_id":73,"skills_id":178,"ordering":5},{"id":687,"me_milestone_id":73,"skills_id":179,"ordering":6}]},{"id":74,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2023-04-12T06:11:08.000Z","user_updated":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_updated":"2023-04-12T08:54:39.000Z","me_id":"ME_QTRIP_QA","slug":"me-qtripqa-milestone-1","title":"Explore Qtrip Architecture and write manual test cases","content":"<h1>Explore QTrip Architecture and write manual test cases</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Browse through the QTrip application.</li>\\n<li>Understand the architecture of the QTrip application.</li>\\n<li>Practice manual testing on QTrip.</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Test Case Design, Test Data Enumeration, Test Suites, Page Object Model</p>\\n<h2>Image(s)</h2>\\n<div class=\\"image-container\\">&nbsp;</div>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/9854211e-3805-4996-9102-0316de54bd19?\\" alt=\\"The flow when a user enters the landing page.\\" /></div>\\n<div class=\\"image-container\\">&nbsp;</div>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/70229d11-0ce4-4a10-a365-5da7e8a6796e?\\" alt=\\"The flow when a user makes a booking.\\" /></div>","completed_modules":"1","skills":[{"id":688,"me_milestone_id":74,"skills_id":256,"ordering":1},{"id":689,"me_milestone_id":74,"skills_id":257,"ordering":2},{"id":690,"me_milestone_id":74,"skills_id":258,"ordering":3},{"id":691,"me_milestone_id":74,"skills_id":259,"ordering":4}]},{"id":75,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2023-04-12T06:16:34.000Z","user_updated":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_updated":"2023-04-12T08:53:42.000Z","me_id":"ME_QTRIP_QA","slug":"me-qtripqa-milestone-2","title":"Automate QTrip test cases with TestNG","content":"<h1>Automate QTrip test cases with TestNG</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Modified the structure of the project using TestNG.</li>\\n<li>Figured out the Page definitions and Test definitions to be used in the automation framework.</li>\\n<li>Prepared sheets for Data driven testing using Apache POI.</li>\\n<li>Grouped test cases into functional groups to execute the test cases sequentially.</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Java, Selenium, Locators, HTML, Developer Tools, TestNG, Page Object Model, XPath</p>\\n<h2>Image(s)<br /><br /></h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/d35a3b38-d9e5-4ad7-b307-690faa4c6387?\\" alt=\\"QTrip Test Cases: Defining Group and Priority\\" /></div>\\n<div class=\\"image-container\\">&nbsp;</div>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/5d030ed3-e88f-4ab9-95d1-e929721d7d67?\\" alt=\\"QTrip Test Cases\\" /></div>","completed_modules":"2","skills":[{"id":692,"me_milestone_id":75,"skills_id":26,"ordering":1},{"id":693,"me_milestone_id":75,"skills_id":42,"ordering":2},{"id":694,"me_milestone_id":75,"skills_id":180,"ordering":3},{"id":695,"me_milestone_id":75,"skills_id":10,"ordering":4},{"id":696,"me_milestone_id":75,"skills_id":181,"ordering":5},{"id":697,"me_milestone_id":75,"skills_id":34,"ordering":6},{"id":698,"me_milestone_id":75,"skills_id":182,"ordering":7}]},{"id":76,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2023-04-12T06:22:25.000Z","user_updated":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_updated":"2023-04-12T08:53:53.000Z","me_id":"ME_QTRIP_QA","slug":"me-qtripqa-milestone-3","title":"Generate Customized Test Reports for TestNG Project","content":"<h1>Generate Customized Test Reports for TestNG Project</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Enhanced inbuilt selenium methods with added functionality</li>\\n<li>Implemented Wrapper methods in the code wherever required</li>\\n<li>Added steps to generate customized test reports using Extent Reports</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Extent Reports, Wrapper Methods</p>\\n<h2>Image(s)<br /><br /></h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/a229212e-d867-40bd-b8a8-ac21480932a0?\\" alt=\\"Customized Test Report for QTrip\\" /></div>","completed_modules":"3","skills":[{"id":699,"me_milestone_id":76,"skills_id":260,"ordering":1},{"id":700,"me_milestone_id":76,"skills_id":261,"ordering":2}]},{"id":77,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2023-06-10T11:26:56.000Z","user_updated":null,"date_updated":null,"me_id":"ME_BUILDOUT_SHORT_URL","slug":"me-buildoutshorturl-milestone-1","title":"Build SHORT URL from scratch","content":"<h1>Build SHORT URL from scratch</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Create a concrete class which implements a short URL interface class provided. It contains all the methods that can be used to create long URL to short URL mappings.</li>\\n<li>Implement a method to take a long URL as input, generate a random 9 character short URL and return it. Also maintain this mapping using a hash map for quick retrieval.</li>\\n<li>Implement a method to take a long URL and a custom short URL as input and register that mapping.&nbsp;</li>\\n<li>Error handling to make sure each long URL maps to only one short URL and vice versa.</li>\\n<li>Implement a method to lookup short URL for a given long URL, from the mapping created.</li>\\n<li>Implement a method to delete the mapping based on a long URL.</li>\\n<li>Implement a counter to keep track of the hit count for each long URL - which tells us how many times a particular long URL has been looked up.</li>\\n<li>Test these methods using test cases.<br /><br /></li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Core Java, Interfaces, Debugging</p>\\n<p>&nbsp;</p>\\n<p>&nbsp;</p>","completed_modules":"1","skills":[{"id":701,"me_milestone_id":77,"skills_id":26,"ordering":1},{"id":702,"me_milestone_id":77,"skills_id":187,"ordering":2},{"id":703,"me_milestone_id":77,"skills_id":148,"ordering":3}]},{"id":78,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2023-06-10T11:34:56.000Z","user_updated":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_updated":"2023-06-14T04:54:00.000Z","me_id":"ME_BUILDOUT_QCOMMERCE_ANALYTICS","slug":"me-qcommerce-milestone-1","title":"ME_BUILDOUT_QCOMMERCE_INSIGHTS","content":"<h2>Scope of work</h2>\\n<ul>\\n<li>Understood the requirements and the code base provided</li>\\n<li>Used OOP design with interfaces and factory design pattern to write extensible code</li>\\n<li>Created the core logic to consume sale data from a csv file and generate annual and monthly data insights</li>\\n<li>Extended the implementation to handle sale data from multiple vendors with minimum disruption to existing users of the module</li>\\n<li>Handled error cases and threw exceptions</li>\\n</ul>\\n<h2>Skills used</h2>\\n<ul>\\n<li>Core Java, OOP Design, Code Refactoring, Exception Handling</li>\\n</ul>","completed_modules":"1","skills":[{"id":704,"me_milestone_id":78,"skills_id":26,"ordering":1},{"id":705,"me_milestone_id":78,"skills_id":175,"ordering":2},{"id":706,"me_milestone_id":78,"skills_id":148,"ordering":3},{"id":707,"me_milestone_id":78,"skills_id":178,"ordering":4},{"id":708,"me_milestone_id":78,"skills_id":179,"ordering":5},{"id":709,"me_milestone_id":78,"skills_id":188,"ordering":6}]},{"id":79,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2023-06-13T12:16:23.000Z","user_updated":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_updated":"2023-06-14T02:54:30.000Z","me_id":"ME_API_TESTING_PROJECT","slug":"me-apitestingproject-milestone-1","title":"Analyze QTrip API","content":"<h1>Analyze QTrip API&nbsp;</h1>\\n<h2>Scope of work</h2>\\n<p>&nbsp; &nbsp; &nbsp;1. Analyzed the QTrip application and its API Documentation.<br />&nbsp; &nbsp; &nbsp;2. Designed API Tests for different functional modules of the application.<br />&nbsp; &nbsp; &nbsp;3. Executed manual API tests using Postman.</p>\\n<h3>Skills used</h3>\\n<p>Test Case Design, Test Data Enumeration, API Testing, Postman</p>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/65535cbc-7713-42a7-bb58-479660d4c778\\" alt=\\"QTrip: Booking Page\\" /></div>","completed_modules":"1","skills":[{"id":711,"me_milestone_id":79,"skills_id":256,"ordering":1},{"id":712,"me_milestone_id":79,"skills_id":257,"ordering":2},{"id":710,"me_milestone_id":79,"skills_id":262,"ordering":3},{"id":713,"me_milestone_id":79,"skills_id":194,"ordering":4}]},{"id":80,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2023-06-13T12:31:34.000Z","user_updated":"ecb2af59-d47f-416b-b25c-bda20bc2cf05","date_updated":"2023-06-14T02:55:45.000Z","me_id":"ME_API_TESTING_PROJECT","slug":"me-apitestingproject-milestone-2","title":"Analyze QTrip API","content":"<h1>Automate QTrip API test cases with Rest Assured and TestNG</h1>\\n<h2>Scope of work</h2>\\n<ol>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Automated the API tests using Rest Assured Framework.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Modified the structure of the project using TestNG.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Executed API tests along with UI tests.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Grouped test cases into functional groups to execute the API and UI tests alongside.</span></li>\\n</ol>\\n<h2>Skills used</h2>\\n<p><span style=\\"font-weight: 400;\\">Java, Selenium, Developer Tools, Rest Assured, TestNG</span></p>\\n<h2><span style=\\"font-weight: 400;\\">Image</span></h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/3bcc2d5f-ef26-48eb-bdc6-c3945eac80de\\" alt=\\"Running only QTrip API tests using TestNG\\" /></div>","completed_modules":"1","skills":[{"id":714,"me_milestone_id":80,"skills_id":26,"ordering":1},{"id":715,"me_milestone_id":80,"skills_id":42,"ordering":2},{"id":716,"me_milestone_id":80,"skills_id":181,"ordering":3},{"id":717,"me_milestone_id":80,"skills_id":263,"ordering":4},{"id":718,"me_milestone_id":80,"skills_id":34,"ordering":5}]},{"id":81,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2023-06-19T12:05:11.000Z","user_updated":null,"date_updated":null,"me_id":"ME_QCALC_V3","slug":"me-qcalc-v3-milestone-1","title":"Implement Simple Calculator","content":"<h1><strong>Implement Simple Calculator</strong></h1>\\n<h2><strong>Scope of work</strong></h2>\\n<ol>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Generate a Java Gradle Project using the command line tool.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Implement basic arithmetic operations and run unit tests to verify the functionalities.</span></li>\\n</ol>\\n<h2><strong>Skills used</strong></h2>\\n<p><span style=\\"font-weight: 400;\\">Java, Unit Testing</span></p>","completed_modules":"1","skills":[{"id":719,"me_milestone_id":81,"skills_id":26,"ordering":1},{"id":720,"me_milestone_id":81,"skills_id":176,"ordering":2}]},{"id":82,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2023-06-19T12:10:00.000Z","user_updated":null,"date_updated":null,"me_id":"ME_QCALC_V3","slug":"me-qcalc-v3-milestone-2","title":"Debug and Fix Issues","content":"<h1>Debug and Fix Issues</h1>\\n<h2><strong>Scope of work</strong></h2>\\n<ol>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\">Fix compilation errors caused due to syntax/import issues.</li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\">Resolve logical issues in the code.</li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\">Fix the definition of a method based on a given datatype.</li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\">Execute Unit Tests to verify the correctness of the functionalities</li>\\n</ol>\\n<h2><strong>Skills used</strong></h2>\\n<p>Java, Unit Testing, Debugging</p>","completed_modules":"2","skills":[{"id":721,"me_milestone_id":82,"skills_id":264,"ordering":1}]},{"id":83,"status":"published","sort":null,"user_created":"42670516-02dd-418e-abaa-d5ff0d183714","date_created":"2023-06-28T10:44:35.000Z","user_updated":"42670516-02dd-418e-abaa-d5ff0d183714","date_updated":"2023-06-28T10:53:59.000Z","me_id":"ME_BUILDOUT_XQUIZ","slug":"me-buildoutxquiz-milestone-1","title":"Build XQuiz using OOPs","content":"<h1>Build XQuiz using OOPs</h1>\\n<h2>Scope of work</h2>\\n<ul>\\n<li>Created Java classes using the concept of OOPs.</li>\\n<li>Implemented a feature to display the quiz containing questions.</li>\\n<li>Implemented a feature to allow users to attempt the quiz.</li>\\n<li>Performed unit tests to check the correctness of the working of the application.</li>\\n</ul>\\n<p><img src=\\"https://directus.crio.do/assets/2b6c3379-ab1c-4f4c-afc1-a4eb290d7557?\\" alt=\\"Image1\\" /></p>\\n<h3>Skills used</h3>\\n<p>Java, OOPs, Unit Testing</p>","completed_modules":"1","skills":[{"id":722,"me_milestone_id":83,"skills_id":26,"ordering":1},{"id":723,"me_milestone_id":83,"skills_id":265,"ordering":2},{"id":724,"me_milestone_id":83,"skills_id":148,"ordering":3}]},{"id":84,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2023-07-24T07:01:35.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2023-07-24T11:13:56.000Z","me_id":"ME_QTRIP_QA_V2","slug":"me-qtripqa-v2-milestone-1","title":"Explore QTrip and Create TestNG project","content":"<h1>Explore QTrip and Create TestNG project</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Executed all the important user flows in QTrip manually to understand the application</li>\\n<li>Analyzed the test cases to be automated.</li>\\n<li>Defined pages and corresponding actions to convert the manual test cases to automation scripts using the Page object model.<br /><br /></li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Page Object Model, Test Case Design, Java, Selenium, TestNG, XPath</p>\\n<h2>Image(s)</h2>\\n<div class=\\"image-container\\">&nbsp;</div>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/39fa63e8-b205-40a7-a835-3d2b44ece6fb?\\" alt=\\"The project structure for automating test cases using TestNG\\" /></div>","completed_modules":"1","skills":[{"id":725,"me_milestone_id":84,"skills_id":256,"ordering":1},{"id":726,"me_milestone_id":84,"skills_id":26,"ordering":2},{"id":727,"me_milestone_id":84,"skills_id":42,"ordering":3},{"id":731,"me_milestone_id":84,"skills_id":34,"ordering":7},{"id":732,"me_milestone_id":84,"skills_id":259,"ordering":8},{"id":733,"me_milestone_id":84,"skills_id":182,"ordering":9}]},{"id":85,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2023-07-24T07:16:46.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2023-07-24T11:17:45.000Z","me_id":"ME_QTRIP_QA_V2","slug":"me-qtripqa-v2-milestone-2","title":"Automate QTrip test cases with TestNG","content":"<h1>Automate QTrip test cases with TestNG</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Automated four different test cases to test the working of the QTrip Application.</li>\\n<li>Populated sheets for Data driven testing using Apache POI.</li>\\n<li>Grouped test cases into functional groups to execute the test cases in custom sequence.</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Java, Selenium, Locators, HTML, Developer Tools, TestNG, Page Object Model, XPath</p>\\n<h2>Image(s)<br /><br /></h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/a9014d97-ab6e-472e-af71-10c8eb187447?\\" alt=\\"QTrip Test Cases: Defining Group and Priority\\" /></div>\\n<div class=\\"image-container\\">&nbsp;</div>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/33a46744-ee4d-45b4-b587-b644898838ef?\\" alt=\\"QTrip Test Cases\\" /></div>","completed_modules":"2","skills":[{"id":736,"me_milestone_id":85,"skills_id":180,"ordering":1},{"id":737,"me_milestone_id":85,"skills_id":10,"ordering":2},{"id":738,"me_milestone_id":85,"skills_id":181,"ordering":3}]},{"id":86,"status":"published","sort":null,"user_created":"42670516-02dd-418e-abaa-d5ff0d183714","date_created":"2023-07-24T07:26:15.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2023-07-24T11:20:48.000Z","me_id":"ME_QTRIP_QA_V2","slug":"me-qtripqa-v2-milestone-3","title":"Generate Customized Test Reports for TestNG Project","content":"<h1>Generate Customized Test Reports for TestNG Project</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Enhanced inbuilt selenium methods with added functionality</li>\\n<li>Implemented Wrapper methods for screenshots and retry mechanisms.</li>\\n<li>Generated customized test reports using Extent Reports</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Extent Reports, Wrapper Methods</p>\\n<h2>Image(s)<br /><br /></h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/a229212e-d867-40bd-b8a8-ac21480932a0?\\" alt=\\"Customized Test Report for QTrip\\" /></div>","completed_modules":"3","skills":[{"id":734,"me_milestone_id":86,"skills_id":260,"ordering":1},{"id":735,"me_milestone_id":86,"skills_id":261,"ordering":2}]},{"id":87,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2023-08-31T05:24:38.000Z","user_updated":null,"date_updated":null,"me_id":"ME_QKART_QA_V2","slug":"me-qkartqa-v2-milestone-0","title":"Extended Overview","content":"<p><img src=\\"https://directus.crio.do/assets/de3cc7eb-1abb-4d34-b6cc-03428ef616a5?\\" alt=\\"QKart Shopping Interface (Products page)\\" /></p>","completed_modules":"0","skills":[]},{"id":88,"status":"published","sort":null,"user_created":"42670516-02dd-418e-abaa-d5ff0d183714","date_created":"2023-08-31T09:03:19.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2023-11-02T12:31:09.000Z","me_id":"ME_QKART_QA_V2","slug":"me-qkartqa-v2-milestone-1","title":"Modularise test code and debug issues","content":"<h1>Modularise test code and debug issues</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Modularised existing test code for readability and to avoid code duplication</li>\\n<li>Fixed various bugs present in the existing code base for Register and Login pages</li>\\n<li>Used IDE debugger with breakpoints to find and resolve issues faster</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Java, Selenium, Locators, HTML, Developer Tools</p>\\n<h2>Image(s)</h2>\\n<p><img src=\\"https://directus.crio.do/assets/05b9437e-79df-473d-aed3-a6198a028c1e?\\" alt=\\"QKart Registration Page\\" /></p>\\n<p><img src=\\"https://directus.crio.do/assets/10efc19d-f0a3-439b-a702-52ec7b3fa010?\\" alt=\\"Test case requirements\\" /></p>","completed_modules":"1","skills":[{"id":739,"me_milestone_id":88,"skills_id":26,"ordering":1},{"id":752,"me_milestone_id":88,"skills_id":148,"ordering":1},{"id":740,"me_milestone_id":88,"skills_id":42,"ordering":2},{"id":741,"me_milestone_id":88,"skills_id":180,"ordering":3},{"id":742,"me_milestone_id":88,"skills_id":10,"ordering":4},{"id":743,"me_milestone_id":88,"skills_id":181,"ordering":5}]},{"id":89,"status":"published","sort":null,"user_created":"42670516-02dd-418e-abaa-d5ff0d183714","date_created":"2023-08-31T09:07:16.000Z","user_updated":"42670516-02dd-418e-abaa-d5ff0d183714","date_updated":"2023-08-31T12:00:52.000Z","me_id":"ME_QKART_QA_V2","slug":"me-qkartqa-v2-milestone-2","title":"Automate given manual test cases","content":"<h1>Automate given manual test cases</h1>\\n<h2>Scope of Work</h2>\\n<ol>\\n<li>Implemented automated tests for functionalities like product search, editing user cart items, cart content persistence across sessions</li>\\n<li>Added log statements appropriately to aid in debugging any issues</li>\\n<li>Reused methods like searching for products, and add items to the cart thus making the code more maintainable</li>\\n</ol>\\n<h2>Skills used</h2>\\n<p>Java, Selenium, Locators, HTML, Developer Tools</p>\\n<h2>Image(s)</h2>\\n<p><img src=\\"https://directus.crio.do/assets/311a307e-4596-48c2-84cc-406d746fa4f3?\\" alt=\\"QKart Shopping Interface (Products page)\\" /></p>","completed_modules":"2","skills":[]},{"id":90,"status":"published","sort":null,"user_created":"42670516-02dd-418e-abaa-d5ff0d183714","date_created":"2023-08-31T09:11:02.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2023-11-03T09:27:58.000Z","me_id":"ME_QKART_QA_V2","slug":"me-qkartqa-v2-milestone-3","title":"Enhance reliability of the automation code","content":"<h1>Enhance reliability of the automation code by using implicit and explicit waits correctly</h1>\\n<h2>Scope of Work</h2>\\n<ol>\\n<li>Placed appropriate wait statements in the code base to improve script synchronization</li>\\n<li>Implemented feature request to take screenshots before and after the test case and also capture screenshots in case of error</li>\\n<li>Performed automation tests/validations that span across different browser tabs and windows<br /><br /></li>\\n</ol>\\n<h2>Skills used</h2>\\n<p>Java, Selenium, Locators, HTML, Developer Tools</p>\\n<p><img src=\\"https://directus.crio.do/assets/75823f7d-4aa9-4e1a-bd5b-2d53fc0ac114?\\" alt=\\"Screenshots at the start and end of test case\\" /></p>","completed_modules":"3","skills":[{"id":748,"me_milestone_id":90,"skills_id":246,"ordering":1},{"id":749,"me_milestone_id":90,"skills_id":245,"ordering":2},{"id":750,"me_milestone_id":90,"skills_id":247,"ordering":3}]},{"id":91,"status":"published","sort":null,"user_created":"42670516-02dd-418e-abaa-d5ff0d183714","date_created":"2023-08-31T09:19:00.000Z","user_updated":"42670516-02dd-418e-abaa-d5ff0d183714","date_updated":"2023-08-31T11:59:40.000Z","me_id":"ME_QKART_QA_V2","slug":"me-qkartqa-v2-milestone-4","title":"Making the automation code more resilient with XPath","content":"<h1>Making the automation code more resilient with XPath</h1>\\n<h2>Scope of Work</h2>\\n<ol>\\n<li>Fixed a few bugs in the existing codebase as a result of incorrect locators by replacing them with XPath</li>\\n<li>Improved code by replacing existing locators with Dynamic XPath<br /><br /></li>\\n</ol>\\n<h2>Skills used</h2>\\n<p>Java, Selenium, Locators, HTML, Developer Tools, XPath</p>\\n<h2>Image(s)</h2>\\n<p><img src=\\"https://directus.crio.do/assets/ac9b2a10-d06b-4132-a9ea-c12748b264fa?\\" alt=\\"Image1\\" /><img src=\\"https://directus.crio.do/assets/fdecd058-f439-4d2d-8b1c-5aaba9f2f166?\\" alt=\\"Errors due to incorrect locators\\" /></p>\\n<p>&nbsp;</p>","completed_modules":"4","skills":[{"id":744,"me_milestone_id":91,"skills_id":182,"ordering":1}]},{"id":92,"status":"published","sort":null,"user_created":"42670516-02dd-418e-abaa-d5ff0d183714","date_created":"2023-08-31T09:30:07.000Z","user_updated":"42670516-02dd-418e-abaa-d5ff0d183714","date_updated":"2023-08-31T11:55:39.000Z","me_id":"ME_QKART_QA_V2","slug":"me-qkartqa-v2-milestone-5","title":"Using TestNG to enable features","content":"<h1>Using TestNG to enable features like grouping, prioritising, and parameterising of tests</h1>\\n<h2>Scope of Work</h2>\\n<ol>\\n<li>Migrated existing Selenium test code to use the TestNG framework</li>\\n<li>Parameterised the test cases and used XML configuration to send the parameters dynamically</li>\\n<li>Created sanity and regression test groups</li>\\n<li>Utilised Test Listeners to take screenshots on different events<br /><br /></li>\\n</ol>\\n<h2>Skills used</h2>\\n<p>Java, Selenium, Locators, HTML, Developer Tools, XPath, TestNG</p>\\n<h2>Image(s)</h2>\\n<p><img src=\\"https://directus.crio.do/assets/fc7a4e0f-3981-4f98-8711-052a0b30f50e?\\" alt=\\"Test report with TestNG\\" /></p>","completed_modules":"5","skills":[{"id":745,"me_milestone_id":92,"skills_id":34,"ordering":1}]},{"id":93,"status":"published","sort":null,"user_created":"42670516-02dd-418e-abaa-d5ff0d183714","date_created":"2023-08-31T09:35:29.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2023-11-02T12:33:50.000Z","me_id":"ME_QKART_QA_V2","slug":"me-qkartqa-v2-milestone-6","title":"Utilise Apache POI to read and write Excel data","content":"<h1>Utilise Apache POI to read and write Excel data</h1>\\n<h2>Scope of Work</h2>\\n<ol>\\n<li>Created multiple test data sets for each test case in Excel</li>\\n<li>Used Apache POI and DataProviders to consume test data from Excel</li>\\n<li>Saved the test output by writing it back to Excel</li>\\n<li>Improved test completion time by adding parallelization</li>\\n</ol>\\n<h2>Skills used</h2>\\n<p>Java, Selenium, Locators, HTML, Developer Tools, XPath, TestNG, Apache POI, Selenium Grid</p>\\n<h2>Image(s)</h2>\\n<p><img src=\\"https://directus.crio.do/assets/bcf69f69-b0b7-493f-95e2-0962c11ec6b6?\\" alt=\\"Test output saved to Excel file\\" /></p>","completed_modules":"6","skills":[{"id":746,"me_milestone_id":93,"skills_id":184,"ordering":1}]},{"id":94,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2023-12-08T07:29:54.000Z","user_updated":null,"date_updated":null,"me_id":"ME_XSEARCH1","slug":"me-xsearch1-milestone-0","title":"Automating Amazon!","content":"<h2>Scope of work</h2>\\n<ul>\\n<li>Automated the following test cases:</li>\\n<li>Verify the URL of the homepage</li>\\n<li>Verify the search functionality</li>\\n<li>Verify the navigation menu</li>\\n</ul>\\n<h2>Skills used</h2>\\n<ul>\\n<li>Selenium, Xpath</li>\\n</ul>","completed_modules":"1","skills":[{"id":753,"me_milestone_id":94,"skills_id":42,"ordering":1},{"id":754,"me_milestone_id":94,"skills_id":182,"ordering":2}]},{"id":95,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2023-12-08T07:40:23.000Z","user_updated":null,"date_updated":null,"me_id":"ME_XSEARCH2","slug":"me-xsearch2-milestone-0","title":"Automating Wikipedia!","content":"<h2>Scope of work</h2>\\n<ul>\\n<li>Automated the following test cases:</li>\\n<li>Verify Wikipedia Homepage URL</li>\\n<li>Verify Wikipedia Header and Footer</li>\\n<li>Verify the search functionality</li>\\n<li>Validate Hyperlink Functionality</li>\\n<li>Verify \'About Wikipedia\' Link and URL in Dropdown</li>\\n</ul>\\n<h2>Skills used</h2>\\n<ul>\\n<li>Selenium, Xpath, Window Handling</li>\\n</ul>","completed_modules":"1","skills":[{"id":755,"me_milestone_id":95,"skills_id":42,"ordering":1},{"id":756,"me_milestone_id":95,"skills_id":182,"ordering":2},{"id":757,"me_milestone_id":95,"skills_id":246,"ordering":3}]},{"id":96,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2023-12-08T08:25:14.000Z","user_updated":null,"date_updated":null,"me_id":"ME_ZCOMMERCE_QA","slug":"me-zcommerce-qa-milestone-0","title":"Configure and bring up test bed to run API tests on the Order microservice","content":"<h2>Scope of work</h2>\\n<ul>\\n<li>Resolved inter service dependency<br />&nbsp; &nbsp;a. Using multiple docker containers<br />&nbsp; &nbsp;b. Using mock servers</li>\\n<li>Configured Ports required for docker networking for microservices to communicate with each other.</li>\\n<li>Configured Mock servers to avoid dependencies and cut down costs.</li>\\n<li>Executed test suite to check functionality of ordering products &amp; adding to cart.</li>\\n</ul>\\n<h2>Skills used</h2>\\n<ul>\\n<li>Docker, Mock Servers, Swagger, Test Bed Configuration.</li>\\n</ul>\\n<p><img src=\\"https://directus.crio.do/assets/a1d4bb76-7eaa-4fed-b901-4b767e8f5e1f?\\" alt=\\"Configuring test bed, service ports and mock servers\\" /></p>","completed_modules":"0","skills":[{"id":758,"me_milestone_id":96,"skills_id":20,"ordering":1},{"id":759,"me_milestone_id":96,"skills_id":272,"ordering":2},{"id":760,"me_milestone_id":96,"skills_id":237,"ordering":3},{"id":761,"me_milestone_id":96,"skills_id":273,"ordering":4}]},{"id":97,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2023-12-08T08:30:08.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2023-12-08T08:33:46.000Z","me_id":"ME_ZCOMMERCE_QA","slug":"me-zcommerce-qa-milestone-1","title":"Perform automated tests on the MySQL DB with JDBC","content":"<h2>Scope of work</h2>\\n<ul>\\n<li>Used JDBC to test Order service Database<br />&nbsp; &nbsp;a. Brought up test DB with seeded sample data<br />&nbsp; &nbsp;b. Wrote multiple queries spanning across 6 tables in order DB<br />&nbsp; &nbsp;c. Used JDBC to automate DB queries and run tests</li>\\n</ul>\\n<h2>Skills used</h2>\\n<ul>\\n<li>JDBC, SQL</li>\\n</ul>\\n<p><img src=\\"https://directus.crio.do/assets/72cb2974-4bdb-4af2-93be-8308d374df9c?\\" alt=\\"Configuring JDBC Tests to run on Order Service Database\\" /></p>","completed_modules":"1","skills":[{"id":762,"me_milestone_id":97,"skills_id":270,"ordering":1},{"id":763,"me_milestone_id":97,"skills_id":242,"ordering":2}]},{"id":98,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2023-12-08T08:37:36.000Z","user_updated":null,"date_updated":null,"me_id":"ME_ZCOMMERCE_QA","slug":"me-zcommerce-qa-milestone-2","title":"Implement custom logging requirements for test logs","content":"<h2>Scope of work</h2>\\n<ul>\\n<li>Setting up Log4J Layouts and Appenders</li>\\n<li>Custom formatting of the Layout pattern for logs</li>\\n<li>Configured log4j to have dedicated files to store logs for each environment</li>\\n<li>Used Log4J JDBC appender to upload logs to MySQL Database</li>\\n</ul>\\n<h2>Skills used</h2>\\n<ul>\\n<li>Log4J</li>\\n</ul>\\n<p><img src=\\"https://directus.crio.do/assets/519687b5-f976-490b-a3be-a7041cbb4d1a?\\" alt=\\"Uploading Test Suite logs to MySQL Database\\" /></p>","completed_modules":"2","skills":[{"id":764,"me_milestone_id":98,"skills_id":271,"ordering":1}]},{"id":99,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2023-12-15T13:17:45.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2024-02-03T10:28:41.000Z","me_id":"ME_QA_XGMAIL_CAL1","slug":"me-qa-xgmail-cal1-milestone-1","title":"Google Calendar Automation","content":"<h2>Scope of Work:</h2>\\n<p>Automated the following test cases:</p>\\n<ul>\\n<li>Verify calendar home page</li>\\n<li>Verify calendar navigation and add task</li>\\n<li>Verify the task details updation</li>\\n<li>Verify the task deletion</li>\\n</ul>\\n<h2>Skill Used:</h2>\\n<ul>\\n<li>Selenium, Dynamic Xpaths</li>\\n</ul>","completed_modules":"1","skills":[{"id":765,"me_milestone_id":99,"skills_id":42,"ordering":1},{"id":766,"me_milestone_id":99,"skills_id":274,"ordering":2}]},{"id":100,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2023-12-16T09:59:19.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2024-02-03T10:31:39.000Z","me_id":"ME_QA_XGOOGLE_CALC1","slug":"me-qa-xgoogle-calc1-milestone-1","title":"Google Calculator Automation","content":"<h2>Scope of Work:</h2>\\n<p>&nbsp;</p>\\n<p>Automated the following test cases:</p>\\n<ul>\\n<li>Verify the Homepage URL and Initial Display</li>\\n<li>Verify Addition and Subtraction Operations</li>\\n<li>Verify the Functionality of the All Clear (AC) Button and Multiplication Operation</li>\\n<li>Verify Division Operation</li>\\n</ul>\\n<h2>Skill Used:</h2>\\n<p>Selenium, Dynamic Xpaths&nbsp;</p>","completed_modules":"1","skills":[{"id":767,"me_milestone_id":100,"skills_id":42,"ordering":1},{"id":768,"me_milestone_id":100,"skills_id":274,"ordering":2}]},{"id":101,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2023-12-16T11:01:13.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2023-12-18T11:09:59.000Z","me_id":"ME_QA_XLEETCODE1","slug":"me-qa-xleetcode1-milestone-1","title":"LeetCode automation","content":"<h2>Scope of Work:</h2>\\n<p>&nbsp;</p>\\n<p>Automated the following test cases:</p>\\n<ul>\\n<li>Verify the Leetcode Homepage URL</li>\\n<li>Verify Problem Set URL and Display First 5 Questions</li>\\n<li>Verify the Two Sum problem</li>\\n<li>Ensure the submissions tab displays \\"Register or Sign In\\"</li>\\n</ul>\\n<h2>Skill Used:</h2>\\n<p>Selenium, Dynamic Xpaths</p>","completed_modules":"1","skills":[{"id":769,"me_milestone_id":101,"skills_id":42,"ordering":1},{"id":770,"me_milestone_id":101,"skills_id":274,"ordering":2}]},{"id":102,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2023-12-16T11:23:02.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2023-12-18T11:09:36.000Z","me_id":"ME_QA_XMMT_SEARCH1","slug":"me-qa-xmmt-search1-milestone-1","title":"Make My Trip Automation","content":"<h2>Scope of Work:</h2>\\n<p>&nbsp;</p>\\n<p>Automated the following test cases:</p>\\n<ul>\\n<li>Verify Make My Trip Homepage URL</li>\\n<li>Get Flight Details from Bangalore to New Delhi</li>\\n<li>Get Train Details from Bangalore to New Delhi</li>\\n<li>Verify that there are no buses from Bangalore to New Delhi</li>\\n</ul>\\n<h2>Skill Used:</h2>\\n<p>Selenium, Dynamic Xpaths, Window handling</p>","completed_modules":"1","skills":[{"id":771,"me_milestone_id":102,"skills_id":42,"ordering":1},{"id":772,"me_milestone_id":102,"skills_id":274,"ordering":2},{"id":773,"me_milestone_id":102,"skills_id":246,"ordering":3}]},{"id":103,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2024-01-19T14:05:10.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2024-01-22T12:39:34.000Z","me_id":"ME_QTIFY","slug":"me-qtify-milestone-1","title":"Component breakdown and building the Navbar and Hero Section","content":"<h1>Component breakdown and building the Navbar and Hero Section</h1>\\n<h1>Scope of work</h1>\\n<ul>\\n<li>Conducted a thorough analysis of the provided Figma design, successfully identifying and documenting required front-end components</li>\\n<li>Designed a reusable button component with unique styling, adaptable for various functionalities across the application.</li>\\n<li>Developed a responsive navigation bar featuring a custom logo, a search component with custom styling, and a feedback button.</li>\\n<li>Created an eye-catching hero section with promotional content, effectively capturing user interest.</li>\\n</ul>\\n<h3>Skills used</h3>\\n<p>ReactJS, Module-scoped CSS, Flexbox, CSS variables</p>","completed_modules":"1","skills":[{"id":794,"me_milestone_id":103,"skills_id":285,"ordering":1},{"id":775,"me_milestone_id":103,"skills_id":276,"ordering":3},{"id":781,"me_milestone_id":103,"skills_id":279,"ordering":4},{"id":777,"me_milestone_id":103,"skills_id":277,"ordering":5}]},{"id":104,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2024-01-20T13:28:45.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2024-01-24T05:34:27.000Z","me_id":"ME_QTIFY","slug":"me-qtify-milestone-2","title":"Albums Section","content":"<h1>Albums Section</h1>\\n<h2>Scope of work</h2>\\n<ul>\\n<li>Developed a dynamic, responsive, and reusable Card component with Material-UI integration, featuring custom CSS, efficient data handling, and enhanced user interaction through tooltips and lazy-loaded images.</li>\\n<li>Implemented and customized a carousel feature using the Swiper library and utilizing custom navigation.</li>\\n<li>Developed a dynamic Section component capable of dynamically displaying content in both carousel and grid layouts using conditional rendering.</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>ReactJS, Module-scoped CSS, Condition Rendering, Component Reusability, Swiper Library usage, Material UI, Customizing Third-Party Components</p>\\n<h2>Image(s)</h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/6f1bb778-061a-4e7c-994c-926411e73df5?\\" alt=\\"Top Albums Carousel View (Conditional Rendering)\\" /><img src=\\"https://directus.crio.do/assets/e0a5ff8c-e3f6-4ee9-84f1-43a564e05f23?\\" alt=\\"Top Albums Grid View (Conditional Rendering)\\" /></div>","completed_modules":"2","skills":[{"id":795,"me_milestone_id":104,"skills_id":285,"ordering":2},{"id":779,"me_milestone_id":104,"skills_id":276,"ordering":3},{"id":780,"me_milestone_id":104,"skills_id":278,"ordering":4},{"id":785,"me_milestone_id":104,"skills_id":280,"ordering":5},{"id":782,"me_milestone_id":104,"skills_id":281,"ordering":6},{"id":783,"me_milestone_id":104,"skills_id":170,"ordering":7},{"id":784,"me_milestone_id":104,"skills_id":282,"ordering":8}]},{"id":105,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2024-01-21T05:18:44.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2024-01-24T05:34:49.000Z","me_id":"ME_QTIFY","slug":"me-qtify-milestone-3","title":"Songs Section","content":"<h1>Songs Section</h1>\\n<h2>Scope of work</h2>\\n<ul>\\n<li>Created a reusable Filters component, using Material-UI Tabs for a seamless and interactive filtering experience</li>\\n<li>Utilized Axios to fetch the genre options and song data served by the backend, and performed error handling for the same.</li>\\n<li>Implemented conditional rendering logic to display filter options within the Section component exclusively in the Songs section.</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>ReactJS, Module-scoped CSS, API Integration and Data Handling, Condition Rendering, Component Reusability, Customizing Third-Party Components</p>\\n<h2>Image(s)</h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/bba356d7-087e-4fe9-ad98-e9fd0d000bda?\\" alt=\\"Songs Section reusing the Section component as Albums Section but includes Tab as well\\" /><img src=\\"https://directus.crio.do/assets/41fe32e1-98c1-4226-b3db-c3fc16234db5?\\" alt=\\"Songs Section (now filtered as per Jazz genre)\\" /></div>","completed_modules":"3","skills":[{"id":796,"me_milestone_id":105,"skills_id":285,"ordering":2},{"id":789,"me_milestone_id":105,"skills_id":276,"ordering":3},{"id":790,"me_milestone_id":105,"skills_id":284,"ordering":4},{"id":791,"me_milestone_id":105,"skills_id":278,"ordering":5},{"id":792,"me_milestone_id":105,"skills_id":280,"ordering":6},{"id":793,"me_milestone_id":105,"skills_id":282,"ordering":7}]},{"id":106,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2024-01-21T05:24:31.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2024-01-22T13:25:55.000Z","me_id":"ME_QTIFY","slug":"me-qtify-milestone-4","title":"Deploy the QTify website","content":"<h1>Deploy the QTify website</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li>Deployed the Qtify React app to Vercel by importing the project repository from GitHub.</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Deployment, Vercel</p>","completed_modules":"4","skills":[{"id":786,"me_milestone_id":106,"skills_id":140,"ordering":1},{"id":787,"me_milestone_id":106,"skills_id":283,"ordering":2}]},{"id":107,"status":"published","sort":null,"user_created":"42670516-02dd-418e-abaa-d5ff0d183714","date_created":"2024-01-24T17:51:06.000Z","user_updated":"42670516-02dd-418e-abaa-d5ff0d183714","date_updated":"2024-01-25T13:08:20.000Z","me_id":"ME_QKART_PERF_SDET","slug":"me-qkart-perf-sdet-milestone-0","title":"Performance testing using Jmeter","content":"<h2>Scope of Work:</h2>\\n<ul>\\n<li>Understand the business requirements for testing QKart.</li>\\n<li>Ensure the test environment closely resembles the production setup.</li>\\n<li>Set up JMeter test plans to replicate the user flow.</li>\\n<li>Utilize CSV files for storing and retrieving dynamic data.</li>\\n<li>Create reports of aggregate and summary listeners based on test plan execution.</li>\\n<li>Experiment with different thread counts to identify the breaking points.</li>\\n<li>Retrieve the count of orders placed during specified time intervals using Python and log the results into a text file.</li>\\n</ul>\\n<h2>Skills used:</h2>\\n<ul>\\n<li>Jmeter, Python</li>\\n</ul>\\n<h2>Image(s)</h2>\\n<p>&nbsp;</p>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/cf033cbf-cc0f-4ca9-8e7d-94178bf103fa?\\" alt=\\"Environment Setup\\" /><img src=\\"https://directus.crio.do/assets/033d92e4-56c3-472f-8aaf-1ac76bab2dbc?\\" alt=\\"User Flow of the Application\\" /><img src=\\"https://directus.crio.do/assets/5cec5a53-102f-49b5-9abd-6aa32696d202?\\" alt=\\"Python Script output logs\\" /></div>","completed_modules":"1","skills":[{"id":797,"me_milestone_id":107,"skills_id":191,"ordering":1},{"id":798,"me_milestone_id":107,"skills_id":241,"ordering":2}]},{"id":108,"status":"published","sort":null,"user_created":"42670516-02dd-418e-abaa-d5ff0d183714","date_created":"2024-01-24T17:55:47.000Z","user_updated":"42670516-02dd-418e-abaa-d5ff0d183714","date_updated":"2024-01-25T12:58:13.000Z","me_id":"ME_SDET_XSERVICE","slug":"me-sdet-xservice-milestone-0","title":"Validating APIs with Happy Flow","content":"<h2>Scope of work</h2>\\n<p>&nbsp; &nbsp;Wrote and executed test cases to:</p>\\n<ul>\\n<li>Verify that the API for fetching restaurant list is working and functional.</li>\\n<li>Verify that fetching menu for a given restaurant is functioning properly.</li>\\n<li>Verify add to cart functionality.</li>\\n<li>Verify fetching the cart is working.</li>\\n<li>Verify checkout functionality.</li>\\n</ul>\\n<h2>Skills used:</h2>\\n<ul>\\n<li>Restassured</li>\\n</ul>","completed_modules":"1","skills":[{"id":799,"me_milestone_id":108,"skills_id":263,"ordering":1}]},{"id":109,"status":"published","sort":null,"user_created":"42670516-02dd-418e-abaa-d5ff0d183714","date_created":"2024-01-24T17:59:18.000Z","user_updated":"42670516-02dd-418e-abaa-d5ff0d183714","date_updated":"2024-01-25T12:58:35.000Z","me_id":"ME_SDET_XPERF","slug":"me-sdet-xperf-milestone-0","title":"Monitoring Performance of Application under High Load","content":"<h2>Scope of work:</h2>\\n<ul>\\n<li>Wrote and executed JMeter test to:</li>\\n<li>Go through the entire happy flow of application</li>\\n<li>Test under different loads to test business metrics + markup</li>\\n<li>Monitor host metrics using SigNoz cloud</li>\\n</ul>\\n<h2>Skills used:</h2>\\n<ul>\\n<li>JMeter, SigNoz</li>\\n</ul>","completed_modules":"1","skills":[{"id":800,"me_milestone_id":109,"skills_id":191,"ordering":1},{"id":801,"me_milestone_id":109,"skills_id":275,"ordering":2}]},{"id":110,"status":"published","sort":null,"user_created":"42670516-02dd-418e-abaa-d5ff0d183714","date_created":"2024-01-24T18:02:56.000Z","user_updated":"42670516-02dd-418e-abaa-d5ff0d183714","date_updated":"2024-01-25T12:58:27.000Z","me_id":"ME_SDET_XDB","slug":"me-sdet-xdb-milestone-0","title":"Validating databases with Database Schema","content":"<h2>Scope of work:</h2>\\n<ul>\\n<li>Wrote and executed test cases to:</li>\\n<li>Get existing tables count in the Database</li>\\n<li>Verify entry in database on placing an order</li>\\n<li>Verify if Order Deletion is allowed, validate foreign key constraints</li>\\n<li>Validate if restaurant id of each order in Order DB has a corresponding restaurant in the restaurant DB</li>\\n<li>Validate if placing an order with an invalid restaurant id fails.</li>\\n</ul>\\n<h2>Skills used:</h2>\\n<ul>\\n<li>JDBC, SQL</li>\\n</ul>","completed_modules":"1","skills":[{"id":802,"me_milestone_id":110,"skills_id":270,"ordering":1},{"id":803,"me_milestone_id":110,"skills_id":242,"ordering":2}]},{"id":111,"status":"published","sort":null,"user_created":"42670516-02dd-418e-abaa-d5ff0d183714","date_created":"2024-02-28T11:59:16.000Z","user_updated":"42670516-02dd-418e-abaa-d5ff0d183714","date_updated":"2024-03-02T12:35:00.000Z","me_id":"ME_SDET_KAFKA_TESTING","slug":"me-sdet-kafka-testing-milestone-0","title":"Validating Kafka Functionality for the application","content":"<h1>Validating Kafka Functionality for the application</h1>\\n<h2>Scope of work</h2>\\n<ul>\\n<li>Manually Executed check for:</li>\\n<li>Placing an order on the application and checking if data is populated under correct topic in Kafka</li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>Kafka</p>\\n<h2>Image(s)</h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/e98b5faf-1fd5-48ed-adfa-6a0d88d4516d?\\" alt=\\"Image1\\" /></div>\\n<div class=\\"image-container\\">Wrote consumer code to listen to the application&rsquo;s kafka broker.<img src=\\"https://directus.crio.do/assets/8d4664a9-a59b-496d-977c-ba7dad07111d?\\" alt=\\"Image2\\" /></div>\\n<div class=\\"image-container\\">Wrote JMeter test to load test the kafka broker</div>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/2f932c68-c39e-4302-9dd4-9cd95e6d9b23?\\" alt=\\"Image3\\" /></div>\\n<div class=\\"image-container\\">Wrote Producer code to read from a CSV file and programmatically send and receive messages from a kafka topic to check the time difference between producing and consuming code</div>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/b3d423cf-6446-4b6b-9e2d-fdf1ea74b674?\\" alt=\\"Image4\\" /></div>","completed_modules":"1","skills":[{"id":804,"me_milestone_id":111,"skills_id":286,"ordering":1}]},{"id":112,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2024-03-25T10:31:45.000Z","user_updated":null,"date_updated":null,"me_id":"ME_QKART_FRONTEND","slug":"me-qkart-milestone-1","title":"Add routing and improve UI","content":"<h1><span style=\\"font-weight: 400;\\">Add routing and improve UI</span></h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Used React Router library to implement routing</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Improved UI with Antd library&rsquo;s UI components</span></li>\\n</ul>\\n<h2>Skills used</h2>\\n<p><span style=\\"font-weight: 400;\\">React.js, React Routing, React Components, Event Handling</span></p>","completed_modules":"1","skills":[{"id":805,"me_milestone_id":112,"skills_id":285,"ordering":1},{"id":806,"me_milestone_id":112,"skills_id":129,"ordering":2},{"id":807,"me_milestone_id":112,"skills_id":287,"ordering":3},{"id":808,"me_milestone_id":112,"skills_id":130,"ordering":4}]},{"id":113,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2024-03-25T10:41:17.000Z","user_updated":null,"date_updated":null,"me_id":"ME_QKART_FRONTEND","slug":"me-qkart-milestone-2","title":"Implement register/login flow","content":"<h1><span style=\\"font-weight: 400;\\">Implement register/login flow</span></h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Validated user input and set to display informative error messages</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Utilized backend API to facilitate user registration and login</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Stored user information at client side using localStorage to avoid login on revisit</span></li>\\n</ul>\\n<h2>Skills used</h2>\\n<p><span style=\\"font-weight: 400;\\">React State &amp; Props, REST APIs, Fetch API, cURL, Input Validation, localStorage</span></p>\\n<h2>Image(s)</h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/882fe354-6002-41a3-a7d0-05f7912e4c94?\\" alt=\\"Request-response cycle for QKart User signup and login\\" /></div>\\n<div class=\\"image-container\\">&nbsp;</div>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/52d55756-623c-4f10-8566-96e572ad018c?\\" alt=\\"User flow on website for signup and login\\" /></div>","completed_modules":"2","skills":[{"id":809,"me_milestone_id":113,"skills_id":131,"ordering":1},{"id":810,"me_milestone_id":113,"skills_id":11,"ordering":2},{"id":811,"me_milestone_id":113,"skills_id":288,"ordering":3},{"id":812,"me_milestone_id":113,"skills_id":162,"ordering":4},{"id":813,"me_milestone_id":113,"skills_id":289,"ordering":5},{"id":814,"me_milestone_id":113,"skills_id":132,"ordering":6}]},{"id":114,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2024-03-25T10:44:18.000Z","user_updated":null,"date_updated":null,"me_id":"ME_QKART_FRONTEND","slug":"me-qkart-milestone-3","title":"Display products and implement search feature","content":"<h1><span style=\\"font-weight: 400;\\">Display products and implement search feature</span></h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Utilized React&rsquo;s lifecycle methods to fetch products data after DOM is rendered for faster page loading</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Added search bar to display only on the Products page&rsquo;s header and implemented search logic</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Implemented debouncing for improved UX and reduced page re-renderings on search</span></li>\\n</ul>\\n<h2>Skills used</h2>\\n<p><span style=\\"font-weight: 400;\\">Functional and Class Components, Lifecycle Methods, Keyword Search, Debouncing</span></p>\\n<h2>Image(s)</h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/b7d208c1-7fa5-4989-9cd2-a0e3f33085ea?\\" alt=\\"QKart Products page\\" /></div>","completed_modules":"3","skills":[{"id":818,"me_milestone_id":114,"skills_id":290,"ordering":1},{"id":815,"me_milestone_id":114,"skills_id":133,"ordering":2},{"id":816,"me_milestone_id":114,"skills_id":134,"ordering":3},{"id":817,"me_milestone_id":114,"skills_id":135,"ordering":4}]},{"id":115,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2024-03-25T10:49:46.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2024-03-25T10:54:00.000Z","me_id":"ME_QKART_FRONTEND","slug":"me-qkart-milestone-4","title":"Add shopping cart and implement checkout flow","content":"<h1><span style=\\"font-weight: 400;\\">Add shopping cart and implement checkout flow</span></h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Added Cart to Products page and make it responsive</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Made authenticated POST API calls to implement Cart logic</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Rendered Cart with differing designs in Products page and Checkout page using conditional rendering</span></li>\\n</ul>\\n<h2>Skills used</h2>\\n<p><span style=\\"font-weight: 400;\\">Responsive Design, Antd Grid, Conditional Rendering, React Refs</span></p>\\n<h2>Image(s)</h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/0fcec7be-b28c-4af1-b0cc-4b586322594d?\\" alt=\\"Products page UI with responsive Cart design\\" /></div>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/511fb8c3-53a0-4f4b-9cad-4704a6a16d1f?\\" alt=\\"QKart Checkout page\\" /></div>","completed_modules":"4","skills":[{"id":819,"me_milestone_id":115,"skills_id":248,"ordering":1},{"id":820,"me_milestone_id":115,"skills_id":185,"ordering":2},{"id":821,"me_milestone_id":115,"skills_id":138,"ordering":3},{"id":822,"me_milestone_id":115,"skills_id":139,"ordering":4}]},{"id":116,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2024-03-25T10:51:07.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2024-03-25T10:54:43.000Z","me_id":"ME_QKART_FRONTEND","slug":"me-qkart-milestone-5","title":"Deploy the QKart website","content":"<h1><span style=\\"font-weight: 400;\\">Deploy the QKart website</span></h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Deployed the QKart React app to Netlify</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Configured Netlify to support visiting any sub pages directly as React is a single page application</span></li>\\n</ul>\\n<h2>Skills used</h2>\\n<p><span style=\\"font-weight: 400;\\">Deployment, Netlify</span></p>","completed_modules":"5","skills":[{"id":823,"me_milestone_id":116,"skills_id":140,"ordering":1},{"id":824,"me_milestone_id":116,"skills_id":141,"ordering":2}]},{"id":117,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2024-05-31T11:13:01.000Z","user_updated":null,"date_updated":null,"me_id":"ME_BUILDOUT_MACHINE_CODING_TODOLIST","slug":"me-todolist-milestone-0","title":"Extended Overview","content":"<h1>Extended Overview</h1>\\n<h2>Image(s)</h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/cee96528-6105-4d39-aebd-d47bbecf63ed?\\" alt=\\"Todoinput\\" /></div>","completed_modules":"0","skills":[]},{"id":118,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2024-05-31T11:23:31.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2024-06-03T08:32:04.000Z","me_id":"ME_BUILDOUT_MACHINE_CODING_TODOLIST","slug":"me-todolist-milestone-1","title":"Low-level Design Implementation of functional-features","content":"<h1>Low-level Design Implementation of functional-features</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li><span style=\\"font-weight: 400;\\">Implemented functionality for users to add, modify, and remove tasks, ensuring data integrity and proper resource management, following SOLID and OOP principles.</span></li>\\n<li><span style=\\"font-weight: 400;\\">Created validation to prevent duplicate tasks in \\"OPEN\\" or \\"IN_PROGRESS\\" status, and allowed status updates to \\"IN_PROGRESS\\" or \\"COMPLETED\\", applying encapsulation and efficient data structures.</span></li>\\n<li><span style=\\"font-weight: 400;\\">Provided features to list tasks with optional filtering by status and sorting by deadline, using efficient algorithms and design patterns.<br /></span></li>\\n<li><span style=\\"font-weight: 400;\\">Implemented an activity log to track task creation, modifications, and removals, ensuring transparency and traceability.<br /></span></li>\\n<li><span style=\\"font-weight: 400;\\">Developed functionality to provide statistics on tasks added, completed, and spilled over, demonstrating proficiency in data aggregation and reporting.<br /></span></li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>API Development, Low-Level Design, OOP, SOLID principles, Design Pattern</p>","completed_modules":"1","skills":[{"id":825,"me_milestone_id":118,"skills_id":292,"ordering":1},{"id":866,"me_milestone_id":118,"skills_id":238,"ordering":1},{"id":826,"me_milestone_id":118,"skills_id":293,"ordering":2},{"id":867,"me_milestone_id":118,"skills_id":179,"ordering":2},{"id":829,"me_milestone_id":118,"skills_id":178,"ordering":5}]},{"id":119,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2024-05-31T15:03:22.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2024-06-06T10:19:17.000Z","me_id":"ME_BUILDOUT_MACHINE_CODING_SOCIAL_NETWORK","slug":"me-socialnetwork-milestone-0","title":"Extended Overview","content":"<h2>Image(s)</h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/f7a23131-81dd-45f4-bf68-fceb50c2877b?\\" alt=\\"Social Network application features\\" /></div>","completed_modules":"0","skills":[]},{"id":120,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2024-05-31T15:07:19.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2024-06-03T09:28:01.000Z","me_id":"ME_BUILDOUT_MACHINE_CODING_SOCIAL_NETWORK","slug":"me-socialnetwork-milestone-1","title":"Low-level Design Implementation of functional-features","content":"<h1>Fetch data using REST API and dynamically render landing page</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li><span style=\\"font-weight: 400;\\">Implemented user registration and login functionality using OOP principles.</span></li>\\n<li><span style=\\"font-weight: 400;\\">Developed functionality for logged-in users to post feed items with predefined tags.<br /></span></li>\\n<li><span style=\\"font-weight: 400;\\">Enabled users to follow other users using design patterns.<br /></span></li>\\n<li><span style=\\"font-weight: 400;\\">Allowed users to upvote and downvote feed items with score calculation.<br /></span></li>\\n<li><span style=\\"font-weight: 400;\\">Enabled users to comment on feed items.<br /></span></li>\\n<li><span style=\\"font-weight: 400;\\">Provided functionality to filter feed items based on tags, comment count, and score.<br /></span></li>\\n</ul>\\n<h2>Skills used</h2>\\n<p><span style=\\"font-weight: 400;\\">API Development, Low-Level Design, OOP, SOLID principles, Design Patterns, Multi-threading</span></p>","completed_modules":"1","skills":[{"id":830,"me_milestone_id":120,"skills_id":292,"ordering":1},{"id":868,"me_milestone_id":120,"skills_id":238,"ordering":1},{"id":831,"me_milestone_id":120,"skills_id":293,"ordering":2},{"id":869,"me_milestone_id":120,"skills_id":179,"ordering":2},{"id":834,"me_milestone_id":120,"skills_id":178,"ordering":5},{"id":835,"me_milestone_id":120,"skills_id":296,"ordering":6}]},{"id":121,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2024-05-31T15:17:23.000Z","user_updated":null,"date_updated":null,"me_id":"ME_BUILDOUT_MACHINE_CODING_ORDER_MANAGEMENT","slug":"me-ordermanagement-milestone-0","title":"Extended Overview","content":"<p><img src=\\"https://directus.crio.do/assets/3b9d21c2-c154-4a47-8a75-ca8b6af1a370?\\" alt=\\"Order Mangement Application Features\\" /></p>","completed_modules":"0","skills":[]},{"id":122,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2024-05-31T15:20:56.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2024-06-03T09:28:29.000Z","me_id":"ME_BUILDOUT_MACHINE_CODING_ORDER_MANAGEMENT","slug":"me-ordermanagement-milestone-1","title":"Low-level Design Implementation of functional-features","content":"<h1>Low-level Design Implementation of functional-features</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li><span style=\\"font-weight: 400;\\">Implemented functionality for sellers to add and fetch inventory details, using SOLID principles and OOP concepts.<br /></span></li>\\n<li><span style=\\"font-weight: 400;\\">Developed functionality for customers to create orders with multiple items, applying encapsulation and efficient data structures.<br /></span></li>\\n<li><span style=\\"font-weight: 400;\\">Enabled users to update order status (confirm, cancel, fulfill), handling race conditions effectively.<br /></span></li>\\n<li><span style=\\"font-weight: 400;\\">Provided features for listing tasks with filtering by status and sorting by deadline, using efficient algorithms and design patterns.<br /></span></li>\\n<li><span style=\\"font-weight: 400;\\">Implemented activity logs and statistics for tasks, demonstrating proficiency in data aggregation and reporting.<br /></span></li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>API Development, Low-Level Design, OOP, SOLID principles, Design Patterns, Multi-threading</p>","completed_modules":"1","skills":[{"id":836,"me_milestone_id":122,"skills_id":292,"ordering":1},{"id":870,"me_milestone_id":122,"skills_id":238,"ordering":1},{"id":837,"me_milestone_id":122,"skills_id":293,"ordering":2},{"id":871,"me_milestone_id":122,"skills_id":179,"ordering":2},{"id":840,"me_milestone_id":122,"skills_id":178,"ordering":5},{"id":841,"me_milestone_id":122,"skills_id":296,"ordering":6}]},{"id":123,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2024-05-31T15:27:42.000Z","user_updated":null,"date_updated":null,"me_id":"ME_BUILDOUT_MACHINE_CODING_KAFKA","slug":"me-codingkafka-milestone-0","title":"Extended Overview","content":"<h1>Extended Overview</h1>\\n<p>&nbsp;</p>\\n<h2>Image(s)</h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/d9964470-4024-46a4-9d8c-6455c4fb2971?\\" alt=\\"Kafka Architecture\\" /></div>","completed_modules":"0","skills":[]},{"id":124,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2024-05-31T15:31:39.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2024-06-03T09:58:16.000Z","me_id":"ME_BUILDOUT_MACHINE_CODING_KAFKA","slug":"me-codingkafka-milestone-1","title":"Low-level Design Implementation of functional-features","content":"<h1>Low-level Design Implementation of functional-features</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li><span style=\\"font-weight: 400;\\">Implemented functionality to create topics with specified partitions.</span></li>\\n<li><span style=\\"font-weight: 400;\\">Used appropriate data structures to store messages, categorized by topics and partitions.<br /></span></li>\\n<li><span style=\\"font-weight: 400;\\">Enabled producers to send messages with keys and values to specific topics and partitions.<br /></span></li>\\n<li><span style=\\"font-weight: 400;\\">Allowed consumers to subscribe to specific topics and partitions, receiving messages in real-time.<br /></span></li>\\n<li><span style=\\"font-weight: 400;\\">Ensured efficient and thread-safe message delivery to consumers.<br /></span></li>\\n<li><span style=\\"font-weight: 400;\\">Implemented mechanisms for consumers to acknowledge successful message processing.<br /></span></li>\\n<li><span style=\\"font-weight: 400;\\">Developed a signaling mechanism to notify consumers about new messages, avoiding busy-waiting.<br /></span></li>\\n</ul>\\n<h2>Skills used</h2>\\n<p><span style=\\"font-weight: 400;\\">API Development, Low-Level Design, OOP, SOLID principles, Design Patterns, Multi-threading</span></p>","completed_modules":"1","skills":[{"id":842,"me_milestone_id":124,"skills_id":292,"ordering":1},{"id":872,"me_milestone_id":124,"skills_id":238,"ordering":1},{"id":843,"me_milestone_id":124,"skills_id":293,"ordering":2},{"id":873,"me_milestone_id":124,"skills_id":179,"ordering":2},{"id":846,"me_milestone_id":124,"skills_id":178,"ordering":5},{"id":847,"me_milestone_id":124,"skills_id":296,"ordering":6}]},{"id":125,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2024-05-31T15:39:25.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2024-06-06T10:04:11.000Z","me_id":"ME_BUILDOUT_MACHINE_CODING_STOCK_EXCHANGE","slug":"me-stockexchange-milestone-0","title":"Extended Overview","content":"<h1>Extended Overview</h1>\\n<h2>Image(s)</h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/f8b77693-fed9-4bc2-8620-f2905ef1d19f?\\" alt=\\"Stockplay application features\\" /></div>","completed_modules":"0","skills":[]},{"id":126,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2024-05-31T15:44:34.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2024-06-06T10:03:48.000Z","me_id":"ME_BUILDOUT_MACHINE_CODING_STOCK_EXCHANGE","slug":"me-stockexchange-milestone-1","title":"Low-level Design Implementation of functional-features","content":"<h1>Low-level Design Implementation of functional-features</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li><span style=\\"font-weight: 400;\\">Implemented functionality to add new users.</span></li>\\n<li><span style=\\"font-weight: 400;\\">Enabled adding new stocks with associated prices.<br /></span></li>\\n<li><span style=\\"font-weight: 400;\\">Allowed users to place buy or sell orders for stocks, with orders tracked in different states (Created, Pending, Executed).<br /></span></li>\\n<li><span style=\\"font-weight: 400;\\">Developed an algorithm to execute orders, matching buy and sell orders based on price and quantity.<br /></span></li>\\n<li><span style=\\"font-weight: 400;\\">Ensured the system can handle concurrent operations and maintain data integrity.<br /></span></li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>API Development, Low-Level Design, OOP, SOLID principles, Design Patterns, Multi-threading</p>\\n<h2>Image(s)</h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/37b23988-e22e-49f2-b430-0f37170f3129?\\" alt=\\"Stockplay application Classes and Functions\\" /></div>","completed_modules":"1","skills":[{"id":848,"me_milestone_id":126,"skills_id":292,"ordering":1},{"id":874,"me_milestone_id":126,"skills_id":238,"ordering":1},{"id":849,"me_milestone_id":126,"skills_id":293,"ordering":2},{"id":875,"me_milestone_id":126,"skills_id":179,"ordering":2},{"id":852,"me_milestone_id":126,"skills_id":178,"ordering":5},{"id":853,"me_milestone_id":126,"skills_id":296,"ordering":6}]},{"id":127,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2024-05-31T15:49:32.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2024-05-31T15:57:01.000Z","me_id":"ME_BUILDOUT_MACHINE_CODING_PAYMENT_GATEWAY","slug":"me-paymentgateway-milestone-0","title":"Payment Gateway Design","content":"<h1>Extended Overview</h1>\\n<h2>Image(s)</h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/f1133b61-b1bc-43d3-9182-a0078adcece1?\\" alt=\\"Payment Gateway application features\\" /></div>","completed_modules":"0","skills":[]},{"id":128,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2024-05-31T15:54:52.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2024-06-03T10:08:15.000Z","me_id":"ME_BUILDOUT_MACHINE_CODING_PAYMENT_GATEWAY","slug":"me-paymentgateway-milestone-1","title":"Low-level Design Implementation of functional-features","content":"<h1>Low-level Design Implementation of functional-features</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li><span style=\\"font-weight: 400;\\">Implemented onboarding and removal of clients using OOP principles to ensure modularity and maintainability.</span></li>\\n<li><span style=\\"font-weight: 400;\\">Developed functionality to add and remove payment modes for clients, ensuring proper validation and error handling.<br /></span></li>\\n<li><span style=\\"font-weight: 400;\\">Integrated multiple banks with simulated random success/failure responses for transactions.<br /></span></li>\\n<li><span style=\\"font-weight: 400;\\">Implemented payment processing logic for different payment methods (UPI, Credit/Debit Card, Netbanking), ensuring correct handling of payment details.<br /></span></li>\\n<li><span style=\\"font-weight: 400;\\">Utilized in-memory data structures to store client, payment mode, and transaction details, ensuring efficient data retrieval and updates.<br /></span></li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>API Development, Low-Level Design, OOP, SOLID principles, Design Patterns, Multi-threading</p>","completed_modules":"1","skills":[{"id":854,"me_milestone_id":128,"skills_id":292,"ordering":1},{"id":876,"me_milestone_id":128,"skills_id":238,"ordering":1},{"id":855,"me_milestone_id":128,"skills_id":293,"ordering":2},{"id":877,"me_milestone_id":128,"skills_id":179,"ordering":2},{"id":858,"me_milestone_id":128,"skills_id":178,"ordering":5},{"id":859,"me_milestone_id":128,"skills_id":296,"ordering":6}]},{"id":129,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2024-06-03T02:53:45.000Z","user_updated":null,"date_updated":null,"me_id":"ME_BUILDOUT_XELLO","slug":"me-buildout-xello-milestone-0","title":"Extended Overview","content":"<h1>Extended Overview</h1>\\n<h3>Image:</h3>\\n<p><img src=\\"https://directus.crio.do/assets/42da433b-10c1-4415-a244-7ba052930b88?\\" alt=\\"Application Design - Xello\\" /></p>","completed_modules":"0","skills":[]},{"id":130,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2024-06-03T04:01:02.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2024-06-03T08:21:30.000Z","me_id":"ME_BUILDOUT_XELLO","slug":"me-buildout-xello-milestone-1","title":"Low-level Design Implementation of the functional features","content":"<h1><strong>Low-level Design Implementation of the functional features</strong></h1>\\n<h2>Scope of Work</h2>\\n<ol>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Developed user registration with unique email validation and RESTful API endpoints, following SOLID principles and OOP.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Enabled users to create new boards with titles, descriptions, and visibility settings, and implemented board management endpoints.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Allowed users to add columns to boards, developed creation and management endpoints, ensuring correct association with respective boards.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Developed card management features with correct column association, ensuring maintainability and adherence to SOLID principles.</span></li>\\n</ol>\\n<h2>Skills used</h2>\\n<p>API Development, Low-Level Design, OOP, SOLID principles</p>\\n<h2>Image(s)</h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/0dca2ae0-94e6-48e4-99fb-05b857de6cbf?\\" alt=\\"Implementing User Registration\\" /></div>","completed_modules":"1","skills":[{"id":860,"me_milestone_id":130,"skills_id":292,"ordering":1},{"id":864,"me_milestone_id":130,"skills_id":238,"ordering":1},{"id":861,"me_milestone_id":130,"skills_id":293,"ordering":2},{"id":865,"me_milestone_id":130,"skills_id":179,"ordering":2}]},{"id":131,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2024-06-05T08:55:09.000Z","user_updated":null,"date_updated":null,"me_id":"ME_BUILDOUT_MACHINE_CODING_BIDBLAST","slug":"me-buildout-machine-coding-bidblast-milestone-1","title":" Low-level Design Implementation of functional-features","content":"<h1><strong>Low-level Design Implementation of functional features</strong></h1>\\n<h2>Scope of Work</h2>\\n<ol>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Developed functionality to add members with an assigned number of Crio Coins greater than zero.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Implemented the ability to add unique events to the platform, ensuring only one event per day.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Enabled members to register for events, ensuring only registered members can participate.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Created functionality for members to submit up to 5 unique bids for an event, deducting only the highest bid from their wallet.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Developed features to declare the winner based on the highest unique bid, considering the submission time for tie-breaking.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Implemented functionality for members to view the winners of the last 5 events, sorted by event date.</span></li>\\n</ol>\\n<h2>Skills used</h2>\\n<p><span style=\\"font-weight: 400;\\">API Development, Low-Level Design, OOP, SOLID principles, Design Patterns, Multi-threading</span></p>","completed_modules":"1","skills":[{"id":878,"me_milestone_id":131,"skills_id":292,"ordering":1},{"id":879,"me_milestone_id":131,"skills_id":293,"ordering":2},{"id":880,"me_milestone_id":131,"skills_id":238,"ordering":3},{"id":881,"me_milestone_id":131,"skills_id":179,"ordering":4},{"id":882,"me_milestone_id":131,"skills_id":178,"ordering":5},{"id":883,"me_milestone_id":131,"skills_id":189,"ordering":6}]},{"id":132,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2024-06-05T09:44:28.000Z","user_updated":null,"date_updated":null,"me_id":"ME_BUILDOUT_MACHINE_CODING_VEHICLE_RENTAL","slug":"me-buildout-machine-coding-vehicle-rental-milestone-0","title":"Extended Overview","content":"<h1>Extended Overview</h1>\\n<h3>Image:</h3>\\n<p>&nbsp;</p>\\n<p><img src=\\"https://directus.crio.do/assets/401f2a0b-7ca1-477f-bff6-807aa84a9239?\\" alt=\\"Vehicle Rental application features\\" /></p>","completed_modules":"0","skills":[]},{"id":133,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2024-06-05T09:50:21.000Z","user_updated":null,"date_updated":null,"me_id":"ME_BUILDOUT_MACHINE_CODING_VEHICLE_RENTAL","slug":"me-buildout-machine-coding-vehicle-rental-milestone-1","title":"Low-level Design Implementation of functional-features","content":"<h1><strong>Low-level Design Implementation of functional-features</strong></h1>\\n<h2>Scope of work</h2>\\n<ol>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Implemented functionality to onboard new branches with available vehicles.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Developed functionality to add new vehicles to existing branches.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Allowed renting of vehicles for specific time slots, with the lowest price as the default choice.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Implemented dynamic pricing by increasing the price by 10% if 80% of vehicles in a branch are booked.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Provided functionality to display available vehicles for a given branch, sorted by price.</span></li>\\n</ol>\\n<h3>Skills used</h3>\\n<p><span style=\\"font-weight: 400;\\">API Development, Low-Level Design, OOP, SOLID principles, Design Patterns, Multi-threading</span></p>","completed_modules":"1","skills":[{"id":884,"me_milestone_id":133,"skills_id":292,"ordering":1},{"id":885,"me_milestone_id":133,"skills_id":293,"ordering":2},{"id":886,"me_milestone_id":133,"skills_id":238,"ordering":3},{"id":887,"me_milestone_id":133,"skills_id":179,"ordering":4},{"id":888,"me_milestone_id":133,"skills_id":178,"ordering":5},{"id":889,"me_milestone_id":133,"skills_id":189,"ordering":6}]},{"id":134,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2024-06-05T10:22:29.000Z","user_updated":null,"date_updated":null,"me_id":"ME_BUILDOUT_MACHINE_CODING_APPOINTMENT_BOOKING","slug":"me-buildout-machine-coding-appointment-booking-milestone-0","title":"Extended Overview","content":"<h1>Extended Overview</h1>\\n<h3>Image:</h3>\\n<p>&nbsp;</p>\\n<p><img src=\\"https://directus.crio.do/assets/37b54e79-2b9a-4361-9bf3-f2f0398c8941?\\" alt=\\"Appointment Booking application features\\" /></p>","completed_modules":"0","skills":[]},{"id":135,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2024-06-05T10:42:00.000Z","user_updated":null,"date_updated":null,"me_id":"ME_BUILDOUT_MACHINE_CODING_APPOINTMENT_BOOKING","slug":"me-buildout-machine-coding-appointment-booking-milestone-1","title":"Low-level Design Implementation of functional-features","content":"<h1><strong>Low-level Design Implementation of functional-features</strong></h1>\\n<h2>Scope of Work</h2>\\n<ol>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Developed seamless registration for professionals to specify their service categories.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Enabled professionals to easily declare daily availability for each time slot.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Implemented intuitive client registration using robust OOP principles.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Created efficient search functionality for clients to find available slots by service category with advanced filtering.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Enabled clients to book appointments and join waitlists effortlessly.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Implemented straightforward appointment cancellations for clients.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Developed comprehensive viewing features for both clients and professionals to manage their appointments.</span></li>\\n</ol>\\n<h2>Skills used</h2>\\n<p><span style=\\"font-weight: 400;\\">API Development, Low-Level Design, OOP, SOLID principles, Design Patterns</span></p>","completed_modules":"1","skills":[{"id":890,"me_milestone_id":135,"skills_id":292,"ordering":1},{"id":891,"me_milestone_id":135,"skills_id":293,"ordering":2},{"id":892,"me_milestone_id":135,"skills_id":238,"ordering":3},{"id":893,"me_milestone_id":135,"skills_id":179,"ordering":4},{"id":894,"me_milestone_id":135,"skills_id":178,"ordering":5}]},{"id":136,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2024-06-05T10:53:08.000Z","user_updated":null,"date_updated":null,"me_id":"ME_BUILDOUT_MACHINE_CODING_COUPON_MANAGEMENT","slug":"me-buildout-machine-coding-coupon-management-milestone-1","title":"Low-level Design Implementation of functional-features","content":"<h1><strong>Low-level Design Implementation of functional-features</strong></h1>\\n<h2>Scope of Work</h2>\\n<ol>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Developed functionality to create batches with specified attributes such as distributor, validity period, and coupon type.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Implemented the ability to ingest coupons into batches, supporting both \\"OPEN\\" and \\"CLOSED\\" coupon types with appropriate coupon codes.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Established a state machine to manage batch states, including transitions like approval, suspension, and termination.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Integrated time-bound features for batches to remain active within their specified duration and automatically expire afterward.</span></li>\\n</ol>\\n<h2>Skills used</h2>\\n<p><span style=\\"font-weight: 400;\\">API Development, Low-Level Design, OOP, SOLID principles, Design Patterns</span></p>","completed_modules":"1","skills":[{"id":895,"me_milestone_id":136,"skills_id":292,"ordering":1},{"id":896,"me_milestone_id":136,"skills_id":293,"ordering":2},{"id":897,"me_milestone_id":136,"skills_id":238,"ordering":3},{"id":898,"me_milestone_id":136,"skills_id":179,"ordering":4},{"id":899,"me_milestone_id":136,"skills_id":178,"ordering":5}]},{"id":137,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2024-06-05T11:12:35.000Z","user_updated":null,"date_updated":null,"me_id":"ME_BUILDOUT_MACHINE_CODING_FPL_AUCTION","slug":"me-buildout-machine-coding-fpl-auction-milestone-1","title":"Low-level Design Implementation of functional-features","content":"<h1><strong>Low-level Design Implementation of functional-features</strong></h1>\\n<h2>Scope of Work</h2>\\n<ol>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Developed functionality to register players with their base prices.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Enabled team registration with a fixed wallet amount for participating in the auction.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Implemented the ability to start auctions for players, allowing teams to place bids.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Created functionality for teams to place bids on players, ensuring the highest bid wins.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Developed features to close the auction and declare the highest bidder for each player.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Enabled display of players in each team along with their remaining wallet amount.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Implemented functionality to display the status of each player, including whether they are sold or unsold.</span></li>\\n</ol>\\n<h2>Skills used</h2>\\n<p><span style=\\"font-weight: 400;\\">API Development, Low-Level Design, OOP, SOLID principles, Design Patterns, Multi-threading</span></p>","completed_modules":"1","skills":[{"id":900,"me_milestone_id":137,"skills_id":292,"ordering":1},{"id":901,"me_milestone_id":137,"skills_id":293,"ordering":2},{"id":902,"me_milestone_id":137,"skills_id":238,"ordering":3},{"id":903,"me_milestone_id":137,"skills_id":179,"ordering":4},{"id":904,"me_milestone_id":137,"skills_id":178,"ordering":5},{"id":905,"me_milestone_id":137,"skills_id":189,"ordering":6}]},{"id":138,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2024-06-05T14:48:33.000Z","user_updated":null,"date_updated":null,"me_id":"ME_FE_BUILDOUT_XCRUISE","slug":"me-xcruise-milestone-0","title":"XCruise","content":"<h1>Extended Overview</h1>\\n<h2>Image(s)</h2>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/45164cd7-9a35-4d03-9974-51cc00d20c20?\\" alt=\\"XCruise UI (Navbar and Hero Section)\\" /></div>\\n<div class=\\"image-container\\">&nbsp;</div>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/f6653041-d2e4-41fc-b014-3481d3100745?\\" alt=\\"XCruise UI (Discover Grid)\\" /></div>\\n<div class=\\"image-container\\">&nbsp;</div>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/eda78fb7-f08c-4ded-91e8-5c7ea43ac88e?\\" alt=\\"XCruise UI (Contact and Footer Sections)\\" /></div>","completed_modules":"0","skills":[]},{"id":139,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2024-06-05T14:52:06.000Z","user_updated":null,"date_updated":null,"me_id":"ME_FE_BUILDOUT_XCRUISE","slug":"me-xcruise-milestone-1","title":"Build the XCruise Landing Page","content":"<h1>Build the XCruise Landing Page</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li><span style=\\"font-weight: 400;\\">Designed and implemented a responsive navigation bar that integrates a custom logo and interactive links to various sections of the site.</span></li>\\n<li><span style=\\"font-weight: 400;\\">Designed the hero section with a background image and a call-to-action button.<br /></span></li>\\n<li><span style=\\"font-weight: 400;\\">Created a \'Discover\' section to showcase popular and exotic cruise destinations using dynamically styled </span><span style=\\"font-weight: 400;\\">cards and interactive image pills.&nbsp;<br /></span></li>\\n<li><span style=\\"font-weight: 400;\\">Leveraged CSS Grids to facilitate a more structured and aesthetically consistent arrangement of content, contributing significantly to the overall user experience.<br /></span></li>\\n<li><span style=\\"font-weight: 400;\\">Implemented responsive design for the contact section to ensure readability and ease of access on mobile devices.<br /></span></li>\\n<li><span style=\\"font-weight: 400;\\">Designed a comprehensive footer section with categorized links for easy navigation and social media icons to increase user engagement.<br /></span><span style=\\"font-weight: 400;\\"><br /></span></li>\\n</ul>\\n<h2>Skills used</h2>\\n<p>HTML5, Semantic HTML, CSS, CSS Positioning, Media Queries, CSS Flexbox, CSS Grids, Responsive Design</p>","completed_modules":"1","skills":[{"id":906,"me_milestone_id":139,"skills_id":10,"ordering":1},{"id":907,"me_milestone_id":139,"skills_id":12,"ordering":2},{"id":908,"me_milestone_id":139,"skills_id":136,"ordering":3}]},{"id":140,"status":"published","sort":null,"user_created":"96947060-767d-4dc3-8a57-ab05646a591f","date_created":"2024-06-13T11:48:45.000Z","user_updated":null,"date_updated":null,"me_id":"ME_QA_XFLIX","slug":"me-qaxflix-milestone-0","title":"Automating XFlix!","content":"<h1><span style=\\"font-weight: 400;\\">Automating XFlix!</span></h1>\\n<h2>Scope of Work</h2>\\n<p>Automated the following test cases:</p>\\n<ol>\\n<li>Verify the XFlix Homepage URL.</li>\\n<li>Verify Search Functionality.</li>\\n<li>Verify the Functionality of Filters.</li>\\n<li>Verify the Functionality of Upload Video.</li>\\n<li>Verify the Like Counter Functionality.</li>\\n</ol>\\n<h2>Skills used</h2>\\n<p>Selenium, Java, Xpath</p>","completed_modules":"0","skills":[{"id":909,"me_milestone_id":140,"skills_id":42,"ordering":1},{"id":910,"me_milestone_id":140,"skills_id":26,"ordering":2},{"id":911,"me_milestone_id":140,"skills_id":182,"ordering":3}]},{"id":141,"status":"published","sort":null,"user_created":"96947060-767d-4dc3-8a57-ab05646a591f","date_created":"2024-06-18T09:24:27.000Z","user_updated":"96947060-767d-4dc3-8a57-ab05646a591f","date_updated":"2024-06-19T12:48:31.000Z","me_id":"ME_QA_XGOOGLE_FORM","slug":"me-xgoogle-form-milestone-0","title":"Automating Google Forms!","content":"<h2>Scope of work</h2>\\n<p>&nbsp;</p>\\n<p>Automated the following Flow:</p>\\n<ul>\\n<li>Navigating to <a href=\\"https://forms.gle/wjPkzeSEk1CM7KgGA\\" target=\\"_blank\\" rel=\\"noopener\\">this google form</a>.</li>\\n</ul>\\n<p><img src=\\"https://directus.crio.do/assets/d513656b-f21c-41c9-b4e0-5dde846a05b9?\\" alt=\\"null\\" /></p>\\n<ul>\\n<li>Filling in text in the a text box</li>\\n</ul>\\n<p><img src=\\"https://directus.crio.do/assets/ae9c89fc-542c-412f-b5d2-466d1dab7972?\\" alt=\\"null\\" /></p>\\n<ul>\\n<li>Doing date-time operations to fill in a dynamic value in a text-area.</li>\\n</ul>\\n<p><img src=\\"https://directus.crio.do/assets/089fadd1-82ec-49ec-bb98-0e635efa4c83?\\" alt=\\"null\\" /></p>\\n<ul>\\n<li>Choosing experience from a radio-button input</li>\\n</ul>\\n<p><img src=\\"https://directus.crio.do/assets/2a7059d9-58f0-405c-8f21-416c7c88ae81?\\" alt=\\"null\\" /></p>\\n<ul>\\n<li>Choosing certain skills from a checklist</li>\\n</ul>\\n<p><img src=\\"https://directus.crio.do/assets/47357cb3-a2cb-475c-a16b-d7aca809aaaf?\\" alt=\\"null\\" /></p>\\n<ul>\\n<li>Choosing a value from the dropdown menu</li>\\n</ul>\\n<p><img src=\\"https://directus.crio.do/assets/4d14a702-8135-4cb9-b696-19da8ec6670a?\\" alt=\\"null\\" /></p>\\n<ul>\\n<li>Dynamically calculating the date</li>\\n</ul>\\n<p><img src=\\"https://directus.crio.do/assets/fee5edf6-faaa-409d-bc66-2b3f811e3295?\\" alt=\\"null\\" /></p>\\n<ul>\\n<li>Providing the time dynamically</li>\\n</ul>\\n<p><img src=\\"https://directus.crio.do/assets/3a9cb79d-8e42-483c-b34e-d5d7bd11a4aa?\\" alt=\\"null\\" /></p>\\n<ul>\\n<li>Submitting the form and printing the final message</li>\\n</ul>\\n<p><img src=\\"https://directus.crio.do/assets/06c54d97-e387-47d0-8c20-249b9c99756b?\\" alt=\\"null\\" /></p>\\n<p><img src=\\"https://directus.crio.do/assets/d56a3d57-8f56-45a4-96e3-bb318f1040de?\\" alt=\\"null\\" /></p>\\n<h3>Skills used</h3>\\n<p>Selenium, Xpath, TestNG</p>","completed_modules":"0","skills":[{"id":912,"me_milestone_id":141,"skills_id":42,"ordering":1},{"id":913,"me_milestone_id":141,"skills_id":182,"ordering":2},{"id":931,"me_milestone_id":141,"skills_id":34,"ordering":3}]},{"id":142,"status":"published","sort":null,"user_created":"96947060-767d-4dc3-8a57-ab05646a591f","date_created":"2024-06-18T11:23:17.000Z","user_updated":"96947060-767d-4dc3-8a57-ab05646a591f","date_updated":"2024-06-19T12:51:37.000Z","me_id":"ME_QA_XFLIPKART_SEARCH","slug":"me-qa-xflipkart-search-milestone-0","title":"Automating Flipkart!","content":"<h2>Scope of work</h2>\\n<p>&nbsp;</p>\\n<p>Automated the following Test Cases:</p>\\n<ul>\\n<li>Went to <a href=\\"http://www.flipkart.com\\" target=\\"_blank\\" rel=\\"noopener\\">www.flipkart.com</a>. Searched for &ldquo;Washing Machine&rdquo;. Sorted by popularity and printed the count of items with rating less than or equal to 4 stars.</li>\\n</ul>\\n<p><img src=\\"https://directus.crio.do/assets/a0c8e422-d89b-4443-bad8-402da94be5bb?\\" alt=\\"null\\" /></p>\\n<ul>\\n<li>Searched &ldquo;iPhone&rdquo;, printed the Titles and discount % of items with more than 17% discount</li>\\n</ul>\\n<p><img src=\\"https://directus.crio.do/assets/fd129817-fb2d-4847-b3b8-b5639fe87738?\\" alt=\\"null\\" /></p>\\n<ul>\\n<li>Searched &ldquo;Coffee Mug&rdquo;, selected 4 stars and above, and printed the Title and image URL of the 5 items with highest number of reviews</li>\\n</ul>\\n<p><img src=\\"https://directus.crio.do/assets/f67a7904-a6ad-481b-8e18-abf5e5e82dab?\\" alt=\\"null\\" /></p>\\n<h3>Skills used</h3>\\n<p>Selenium, Xpath, TestNG</p>","completed_modules":"0","skills":[{"id":918,"me_milestone_id":142,"skills_id":42,"ordering":1},{"id":919,"me_milestone_id":142,"skills_id":182,"ordering":2},{"id":932,"me_milestone_id":142,"skills_id":34,"ordering":3}]},{"id":143,"status":"published","sort":null,"user_created":"96947060-767d-4dc3-8a57-ab05646a591f","date_created":"2024-06-18T12:03:01.000Z","user_updated":"96947060-767d-4dc3-8a57-ab05646a591f","date_updated":"2024-06-19T12:54:47.000Z","me_id":"ME_QA_XYOUTUBE_SEARCH","slug":"me-qa-xyoutube-search-milestone-0","title":"Automating YouTube!","content":"<h2>Scope of work</h2>\\n<p>&nbsp;</p>\\n<p>Automated the following Test Cases:</p>\\n<ul>\\n<li>Went to YouTube.com and Asserted we are on the correct URL. Clicked on &ldquo;About&rdquo; at the bottom of the sidebar, and printed the message on the screen.</li>\\n</ul>\\n<p><img src=\\"https://directus.crio.do/assets/fb348ef8-59c4-44d9-b865-dcb7cb539a50?\\" alt=\\"null\\" /></p>\\n<ul>\\n<li>Went to the &ldquo;Films&rdquo; tab and in the &ldquo;Top Selling&rdquo; section, scrolled to the extreme right. Applied a Soft Assert on whether the movie is marked &ldquo;A&rdquo; for Mature or not. Applied a Soft assert on whether the movie is either &ldquo;Comedy&rdquo; or &ldquo;Animation&rdquo;.</li>\\n</ul>\\n<p><img src=\\"https://directus.crio.do/assets/5d073d54-0937-48f7-bfb1-0459d2b5de1b?\\" alt=\\"null\\" /></p>\\n<ul>\\n<li>Went to the &ldquo;Music&rdquo; tab and in the 1st section, scrolled to the extreme right. Printed the name of the playlist. Soft Assert on whether the number of tracks listed is less than or equal to 50.</li>\\n</ul>\\n<p><img src=\\"https://directus.crio.do/assets/3ba23f1b-ba9c-4fdd-894e-2bfeb691b2e6?\\" alt=\\"null\\" /></p>\\n<ul>\\n<li>Went to the &ldquo;News&rdquo; tab and printed the title and body of the 1st 3 &ldquo;Latest News Posts&rdquo; along with the sum of the number of likes on all 3 of them.</li>\\n</ul>\\n<p><img src=\\"https://directus.crio.do/assets/aef0b732-8c24-46eb-af20-99da59b885aa?\\" alt=\\"null\\" /></p>\\n<ul>\\n<li>Searched for each of the items given,</li>\\n</ul>\\n<p><img src=\\"https://directus.crio.do/assets/3651fc5b-8688-4e50-bdb2-a61da65e9594?\\" alt=\\"null\\" /></p>\\n<h3>Skills used</h3>\\n<p><span style=\\"font-weight: 400;\\">Selenium, Xpath, TestNG</span></p>","completed_modules":"0","skills":[{"id":922,"me_milestone_id":143,"skills_id":42,"ordering":1},{"id":923,"me_milestone_id":143,"skills_id":182,"ordering":2},{"id":933,"me_milestone_id":143,"skills_id":34,"ordering":3}]},{"id":144,"status":"published","sort":null,"user_created":"96947060-767d-4dc3-8a57-ab05646a591f","date_created":"2024-06-18T12:48:09.000Z","user_updated":"96947060-767d-4dc3-8a57-ab05646a591f","date_updated":"2024-06-19T14:21:51.000Z","me_id":"ME_QA_XSCRAPE_DATA","slug":"me-qa-xscrape-data-milestone-0","title":"Automating YouTube!","content":"<h2>Scope of work</h2>\\n<p>&nbsp;</p>\\n<p>Automated the <a href=\\"https://www.scrapethissite.com/pages/\\" target=\\"_blank\\" rel=\\"noopener\\">following site</a>:</p>\\n<ul>\\n<li>Searched through an array of multiple sets of hockey team data and curated the winning rate of each of the teams</li>\\n<li>Curated a list of oscar winning films.</li>\\n</ul>\\n<h3>Skills used</h3>\\n<p>Selenium, Xpath</p>","completed_modules":"0","skills":[{"id":927,"me_milestone_id":144,"skills_id":42,"ordering":1},{"id":928,"me_milestone_id":144,"skills_id":182,"ordering":2}]},{"id":145,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2024-07-25T11:16:13.000Z","user_updated":null,"date_updated":null,"me_id":"ME_BUILDOUT_AWS_DEPLOYMENT_HLD","slug":"me-buildoutawsdeployment-milestone-0","title":"Extended Overview","content":"<p><img src=\\"https://directus.crio.do/assets/6af8473d-8ec8-47a1-968d-bc3fe5e94d67?\\" alt=\\"Aws\\" /></p>","completed_modules":"0","skills":[]},{"id":146,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2024-07-25T11:21:04.000Z","user_updated":null,"date_updated":null,"me_id":"ME_BUILDOUT_AWS_DEPLOYMENT_HLD","slug":"me-buildoutawsdeployment-milestone-1","title":"Configuring the cloud infrastructure","content":"<h1>Configuring the cloud infrastructure</h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li><span style=\\"font-weight: 400;\\">Managed a GitHub repository and integrated code from a GitLab repository for seamless collaboration.</span></li>\\n<li><span style=\\"font-weight: 400;\\">Created an S3 bucket for static frontend hosting with enabled website hosting and public access.<br /></span></li>\\n<li><span style=\\"font-weight: 400;\\">Deployed the backend on a Ubuntu EC2 instance with configured security groups and assigned an Elastic IP.<br /></span></li>\\n<li><span style=\\"font-weight: 400;\\">Configured a MySQL database on Amazon RDS with secure external access and tested connectivity.<br /></span></li>\\n<li><span style=\\"font-weight: 400;\\">Developed an IAM user with AmazonS3FullAccess policy and generated access keys for CI/CD.<br /></span></li>\\n<li><span style=\\"font-weight: 400;\\">Configured GitHub Actions for automated deployment and secured AWS credentials through GitHub secrets.<br /></span></li>\\n<li><span style=\\"font-weight: 400;\\">Configured backend connectivity to RDS, updated frontend settings, and deployed both applications.<br /></span></li>\\n<li><span style=\\"font-weight: 400;\\">Verified backend API endpoints using Postman and validated frontend functionality via the S3 bucket URL.<br /></span></li>\\n</ul>\\n<h2>Skills used</h2>\\n<p><span style=\\"font-weight: 400;\\">AWS, CI/CD, Cloud computing</span></p>","completed_modules":"1","skills":[{"id":934,"me_milestone_id":146,"skills_id":29,"ordering":1},{"id":935,"me_milestone_id":146,"skills_id":305,"ordering":2},{"id":936,"me_milestone_id":146,"skills_id":306,"ordering":3}]},{"id":147,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2024-08-01T15:01:23.000Z","user_updated":null,"date_updated":null,"me_id":"ME_QCONTEST_V2","slug":"me-qcontest-milestone-0","title":"Extended Overview","content":"<p><img src=\\"https://directus.crio.do/assets/4aa3ff6e-76a7-4812-ac7e-3376ff8210f1\\" alt=\\"Qcon\\" /></p>","completed_modules":"0","skills":[]},{"id":148,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2024-08-01T15:04:43.000Z","user_updated":null,"date_updated":null,"me_id":"ME_QCONTEST_V2","slug":"me-qcontest-milestone-1","title":"Implement Services","content":"<h1>Implement Services</h1>\\n<h2>Scope of work</h2>\\n<ul>\\n<li>Implement services layer of QContest adhering to the SOLID principles.</li>\\n<li>Follow Test Driven Development to ensure correctness and better code coverage.&nbsp;</li>\\n</ul>\\n<h3>Skills used</h3>\\n<p>Object Oriented Design, Java, Unit Testing, Design Patterns, SOLID Principles, Exception Handling</p>","completed_modules":"1","skills":[{"id":937,"me_milestone_id":148,"skills_id":175,"ordering":1},{"id":938,"me_milestone_id":148,"skills_id":26,"ordering":2},{"id":939,"me_milestone_id":148,"skills_id":148,"ordering":3},{"id":940,"me_milestone_id":148,"skills_id":178,"ordering":4},{"id":941,"me_milestone_id":148,"skills_id":179,"ordering":5},{"id":942,"me_milestone_id":148,"skills_id":188,"ordering":6}]},{"id":149,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2024-08-01T15:09:37.000Z","user_updated":null,"date_updated":null,"me_id":"ME_QCONTEST_V2","slug":"me-qcontest-milestone-2","title":"Implement Commands","content":"<h1><span style=\\"font-weight: 400;\\">Implement Commands</span></h1>\\n<h2>Scope of work</h2>\\n<ul>\\n<li>Implement commands layer of QContest adhering to the SOLID principles.</li>\\n<li>Follow Test Driven Development to ensure correctness and better code coverage.&nbsp;<br /><br /></li>\\n</ul>\\n<h3>Skills used</h3>\\n<p>Object Oriented Design, Java, Unit Testing, Design Patterns, SOLID Principles, Exception Handling</p>","completed_modules":"2","skills":[]},{"id":150,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2024-08-01T15:30:31.000Z","user_updated":null,"date_updated":null,"me_id":"ME_BUILDOUT_XLIDO","slug":"me-xlido-milestone-0","title":"Extended Overview","content":"<p><img src=\\"https://directus.crio.do/assets/09e276a5-edb6-4f81-8170-bc9636283758\\" alt=\\"Xlido1\\" /></p>","completed_modules":"0","skills":[]},{"id":151,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2024-08-01T16:03:38.000Z","user_updated":null,"date_updated":null,"me_id":"ME_BUILDOUT_XLIDO","slug":"me-xlido-milestone-1","title":"Low-level Design Implementation of the functional features","content":"<h1>Low-level Design Implementation of the functional features</h1>\\n<h2>Scope of work</h2>\\n<ul>\\n<li>Developed user registration with unique email validation, following SOLID principles and OOP.&nbsp;</li>\\n<li>Enabled event organizers to create new events with titles, descriptions and implemented event management endpoints.&nbsp;</li>\\n<li>Allowed organizers to add Q&amp;A sessions to events, developed creation and management endpoints, ensuring correct association with respective events.&nbsp;</li>\\n<li>Developed Q&amp;A session features with correct event association, ensuring maintainability and adherence to SOLID principles.</li>\\n</ul>\\n<h3>Image(s)</h3>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/e4702900-2eda-4069-8ac5-355f32fd6dbf\\" alt=\\"Xlido2\\" /></div>\\n<p>&nbsp;</p>\\n<h3>Skills used</h3>\\n<p>API Development, Low-Level Design, OOP, SOLID principles</p>","completed_modules":"1","skills":[{"id":943,"me_milestone_id":151,"skills_id":292,"ordering":1},{"id":944,"me_milestone_id":151,"skills_id":307,"ordering":2},{"id":945,"me_milestone_id":151,"skills_id":294,"ordering":3},{"id":946,"me_milestone_id":151,"skills_id":179,"ordering":4}]},{"id":152,"status":"published","sort":null,"user_created":"96947060-767d-4dc3-8a57-ab05646a591f","date_created":"2024-08-13T12:04:32.000Z","user_updated":"96947060-767d-4dc3-8a57-ab05646a591f","date_updated":"2024-08-16T11:59:45.000Z","me_id":"ME_BUILDOUT_XPENSE_TRACKER","slug":"me-buildout-xpense-tracker-milestone-0","title":"Build XPenseTracker","content":"<h1><span style=\\"font-weight: 400;\\">Build XPenseTracker</span></h1>\\n<h2><span style=\\"font-weight: 400;\\">Scope of work</span></h2>\\n<ol>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Configured global state using Redux Toolkit, with slices (userSlice, expenseSlice, transactionSlice) for managing user data, budgets, and transactions.<br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\">Developed a form for collecting user and budget data, with robust validation logic ensuring accurate budget distribution and preventing invalid entries. Provided real-time feedback using react-hot-toast.<br /><br /></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\">Implemented a transactions page with a dynamic form for adding and managing expenses. Integrated budget checks to alert users if expenses exceed the total or category-specific budgets, ensuring data consistency via Redux actions.<br /><br /></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\">Created a table to display category-wise expenses, with dynamic updates to budget insights using Redux. Visual indicators highlight whether categories are within budget.<br /><br /></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\">Utilized React Router for seamless navigation between the Landing Page and Transactions Page, with data persistence across sessions and options to update budgets or start a new tracker.</li>\\n</ol>","completed_modules":"1","skills":[{"id":947,"me_milestone_id":152,"skills_id":285,"ordering":1},{"id":948,"me_milestone_id":152,"skills_id":308,"ordering":2},{"id":949,"me_milestone_id":152,"skills_id":22,"ordering":3},{"id":950,"me_milestone_id":152,"skills_id":169,"ordering":4},{"id":951,"me_milestone_id":152,"skills_id":309,"ordering":5},{"id":952,"me_milestone_id":152,"skills_id":310,"ordering":6}]},{"id":153,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2024-08-24T06:55:30.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2024-08-24T09:52:00.000Z","me_id":"ME_BUILDOUT_QTIFY_V2","slug":"me-qtify-v2-milestone-0","title":"Extended Overview","content":"<h3>Image</h3>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/67fb433b-ca88-44c3-94a3-a2952f8aafd7?\\" alt=\\"QTify Component Architecture\\" /></div>\\n<div class=\\"image-container\\">&nbsp;</div>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/a793cb61-d1ce-4414-b9e4-d0f008fb8b59?\\" alt=\\"QTify UI (Albums Section)\\" /></div>\\n<div class=\\"image-container\\">&nbsp;</div>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/054b0289-0930-42c5-823c-19ebaef6949e?\\" alt=\\"Top Albums Carousel View (Conditional Rendering)\\" /></div>\\n<div class=\\"image-container\\">&nbsp;</div>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/322a9af5-a07d-43e9-bf23-b788e8ae7010?\\" alt=\\"Top Albums Grid View (Conditional Rendering)\\" /></div>\\n<div class=\\"image-container\\">&nbsp;</div>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/fddffd0b-32b9-4cce-91b7-f6d2d543f42c?\\" alt=\\"Songs Section reusing the Section component as Albums Section but includes Tab as well\\" /></div>\\n<div class=\\"image-container\\">&nbsp;</div>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/7f6c8c42-27d2-4fc3-834c-0cb0dfdba962?\\" alt=\\"Songs Section (now filtered as per Jazz genre)\\" /></div>","completed_modules":"0","skills":[]},{"id":154,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2024-08-24T07:09:45.000Z","user_updated":"e839b411-7d12-449d-a0c7-94e446e63246","date_updated":"2024-08-24T07:17:38.000Z","me_id":"ME_BUILDOUT_QTIFY_V2","slug":"me-qtify-v2-milestone-1","title":"Build QTify","content":"<h1>Build QTify</h1>\\n<h2>Scope of work</h2>\\n<ol>\\n<li>Analyzed the Figma design to identify and document necessary front-end components.</li>\\n<li>Designed a reusable button component with unique styling, adaptable for various functionalities across the application.</li>\\n<li>Implemented a carousel feature using the Swiper library and enhanced it by implementing custom navigation.</li>\\n<li>Developed a dynamic Section component capable of dynamically displaying content in both carousel and grid layouts using conditional rendering.</li>\\n<li>Created a Filters component with Material-UI Tabs for seamless user interaction, integrated Axios for fetching genre options and song data, and handled errors effectively.</li>\\n<li>Implemented conditional rendering logic to display filter options within the Section component exclusively in the Songs section.</li>\\n<li>Deployed the QTify React app to Vercel by importing the project repository from GitHub.</li>\\n</ol>\\n<h2>Skills used</h2>\\n<p><br />ReactJS, Module-scoped CSS, Flexbox, CSS variables, Condition Rendering, Component Reusability, Swiper.js, Material UI, Customizing Third-Party Components, Deployment</p>","completed_modules":"1","skills":[{"id":953,"me_milestone_id":154,"skills_id":285,"ordering":1},{"id":962,"me_milestone_id":154,"skills_id":281,"ordering":1},{"id":954,"me_milestone_id":154,"skills_id":276,"ordering":2},{"id":955,"me_milestone_id":154,"skills_id":279,"ordering":3},{"id":956,"me_milestone_id":154,"skills_id":277,"ordering":4},{"id":957,"me_milestone_id":154,"skills_id":278,"ordering":5},{"id":958,"me_milestone_id":154,"skills_id":280,"ordering":6},{"id":959,"me_milestone_id":154,"skills_id":170,"ordering":7},{"id":960,"me_milestone_id":154,"skills_id":282,"ordering":8},{"id":961,"me_milestone_id":154,"skills_id":140,"ordering":9}]},{"id":155,"status":"published","sort":null,"user_created":"5510f2c8-1978-48f2-b672-9484b0611511","date_created":"2024-09-09T09:52:19.000Z","user_updated":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_updated":"2024-09-10T06:19:20.000Z","me_id":"ME_EXCEL_QSTOCKS_TEST_BLANK","slug":"me-excel-qstock-test-blank-milestone-1","title":"Stock Trend Analysis","content":"<h1><span style=\\"font-weight: 400;\\">Extended Overview</span></h1>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Data Collection &amp; Cleaning</strong><span style=\\"font-weight: 400;\\">: Imported historical stock price data into Excel, removed inconsistencies, duplicates, and irrelevant data points. Focused on dates, opening/closing prices, volume, and other key metrics.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Data Analysis with Pivot Tables</strong><span style=\\"font-weight: 400;\\">: Used pivot tables to organize and summarize stock data. Analyzed stock trends over time by creating custom views of the data (e.g., monthly, quarterly performance).</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Data Visualization</strong><span style=\\"font-weight: 400;\\">: Created various charts such as line charts for tracking stock trends over time, and bar charts for comparing performance across different time periods. These visualizations help in identifying key movements in stock prices.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Trend Analysis</strong><span style=\\"font-weight: 400;\\">: Identified key performance indicators such as stock price volatility, growth rates, and average performance. Used these insights to simulate the role of a stock analyst in providing actionable insights.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Reporting</strong><span style=\\"font-weight: 400;\\">: Compiled all findings into a comprehensive report, showcasing trends, patterns, and recommendations based on the analysis. The report mimics professional stock performance reports used by investment firms.</span></li>\\n</ul>\\n<p>&nbsp;</p>\\n<div class=\\"image-container\\">&nbsp;</div>","completed_modules":"1","skills":[{"id":963,"me_milestone_id":155,"skills_id":314,"ordering":1},{"id":969,"me_milestone_id":155,"skills_id":326,"ordering":1},{"id":970,"me_milestone_id":155,"skills_id":325,"ordering":2},{"id":971,"me_milestone_id":155,"skills_id":327,"ordering":3}]},{"id":156,"status":"published","sort":null,"user_created":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_created":"2024-09-09T10:36:39.000Z","user_updated":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_updated":"2024-09-09T11:19:04.000Z","me_id":"ME_SQL_QMATO_TEST_BLANK","slug":"me-sql-qmato-test-blank-milestone-1","title":"Food Order Insights","content":"<h1><span style=\\"font-weight: 400;\\">Extended Overview</span></h1>\\n<p><strong>Data Extraction using SQL</strong><span style=\\"font-weight: 400;\\">: Queried Zomato&rsquo;s food order database to pull relevant data points like order quantity, cuisine types, delivery times, and customer locations. Used JOINs, GROUP BY, and WHERE clauses to clean and structure data.</span></p>\\n<p><strong>Data Aggregation &amp; Analysis</strong><span style=\\"font-weight: 400;\\">: Performed aggregations to summarize data by city, cuisine type, and order volume. Identified trends such as which cuisines perform best in certain cities and the busiest ordering times.</span></p>\\n<p><strong>Business Insights</strong><span style=\\"font-weight: 400;\\">: Unlocked key insights about customer ordering behavior, repeat order patterns, and high-demand areas. These insights help businesses optimize marketing campaigns and improve customer targeting.</span></p>\\n<p><strong>Reporting &amp; Recommendations</strong><span style=\\"font-weight: 400;\\">: Compiled the analysis into a professional report. This report includes data-driven recommendations on how to optimize Zomato&rsquo;s operations, focusing on peak times, top cuisines, and high-revenue cities.</span></p>","completed_modules":"1","skills":[{"id":964,"me_milestone_id":156,"skills_id":242,"ordering":1},{"id":972,"me_milestone_id":156,"skills_id":329,"ordering":1},{"id":973,"me_milestone_id":156,"skills_id":330,"ordering":2},{"id":974,"me_milestone_id":156,"skills_id":331,"ordering":3}]},{"id":157,"status":"published","sort":null,"user_created":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_created":"2024-09-09T11:02:52.000Z","user_updated":null,"date_updated":null,"me_id":"ME_BUILDOUT_XUBER_TEST_BLANK","slug":"me-buildout-xuber-test-blank-milestone-1","title":"Ride Pattern Analysis","content":"<h1><span style=\\"font-weight: 400;\\">Extended Overview</span></h1>\\n<p><strong>Data Preparation with Pandas</strong><span style=\\"font-weight: 400;\\">: Loaded Uber ride datasets and cleaned data by removing duplicates, handling missing values, and transforming data formats.</span></p>\\n<p><strong>Statistical Analysis</strong><span style=\\"font-weight: 400;\\">: Analyzed ride frequency, ride duration, and geographical patterns to uncover peak times, popular routes, and other patterns. Used summary statistics like means, medians, and distribution measures to understand ride behavior.</span></p>\\n<p><strong>Data Visualization with Seaborn</strong><span style=\\"font-weight: 400;\\">: Created visualizations such as heatmaps to show peak ride hours, bar charts for the most popular locations, and line charts to show trends in ride durations over time.</span></p>\\n<p><strong>Reporting Insights</strong><span style=\\"font-weight: 400;\\">: Compiled findings into a detailed report that includes data-driven recommendations for optimizing Uber\'s operations. Suggested route optimization strategies and resource allocation to handle peak ride hours.</span></p>","completed_modules":"1","skills":[{"id":965,"me_milestone_id":157,"skills_id":319,"ordering":1},{"id":966,"me_milestone_id":157,"skills_id":320,"ordering":2},{"id":967,"me_milestone_id":157,"skills_id":318,"ordering":3},{"id":968,"me_milestone_id":157,"skills_id":332,"ordering":4}]},{"id":158,"status":"published","sort":null,"user_created":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_created":"2024-09-09T11:24:37.000Z","user_updated":null,"date_updated":null,"me_id":"ME_PYTHON_QSPINNY_TEST_BLANK","slug":"me-python-qspinny-test-blank-milestone-1","title":"Vehicle Sell Price Prediction","content":"<h1><span style=\\"font-weight: 400;\\">Extended Overview</span></h1>\\n<p><strong>Data Analysis with Pandas</strong><span style=\\"font-weight: 400;\\">: Loaded and cleaned used car datasets, analyzed features like make, model, year, and mileage to identify their correlation with selling price.</span></p>\\n<p><strong>Regression Modelling</strong><span style=\\"font-weight: 400;\\">: Developed a regression model to predict the selling price of a car based on its features. The model was built using NumPy for calculations and evaluated for accuracy using standard metrics.</span></p>\\n<p><strong>Data Visualization</strong><span style=\\"font-weight: 400;\\">: Visualized the relationships between price and key factors such as mileage and model year using Matplotlib. Plotted regression lines to illustrate the model&rsquo;s predictions.</span></p>\\n<p><strong>Price Prediction</strong><span style=\\"font-weight: 400;\\">: The final deliverable is a model that accurately predicts used car prices based on historical data. This helps dealers price vehicles competitively while maximizing profit margins.</span></p>","completed_modules":"1","skills":[{"id":975,"me_milestone_id":158,"skills_id":319,"ordering":1},{"id":976,"me_milestone_id":158,"skills_id":320,"ordering":2},{"id":977,"me_milestone_id":158,"skills_id":318,"ordering":3},{"id":978,"me_milestone_id":158,"skills_id":332,"ordering":4}]},{"id":159,"status":"published","sort":null,"user_created":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_created":"2024-09-09T11:39:54.000Z","user_updated":"ea2fb751-43c1-43af-b9d9-d8aa13f737c4","date_updated":"2025-05-05T06:27:26.000Z","me_id":"ME_BUILDOUT_XFLIPKART_TEST_BLANK","slug":"me-buildout-xflipkart-test-blank-milestone-1","title":"eCommerce Sales insights","content":"<h1><span style=\\"font-weight: 400;\\">Extended Overview</span></h1>\\n<p><strong>Data Preparation</strong><span style=\\"font-weight: 400;\\">: Cleaned and structured raw sales data, including product sales, categories, regions, and revenue, for analysis.</span></p>\\n<p><strong>Dashboard Creation</strong><span style=\\"font-weight: 400;\\">: Used PowerBI to create interactive dashboards that visualize key metrics such as revenue, product performance, and sales trends. Dashboards were designed to be user-friendly with filtering options for specific time periods and product categories.</span></p>\\n<p><strong>Business Intelligence Insights</strong><span style=\\"font-weight: 400;\\">: Generated insights on sales performance, including identifying top-performing products, regions with high demand, and seasonal trends. These insights were used to guide business strategy and decision-making.</span></p>\\n<p><strong>Reporting</strong><span style=\\"font-weight: 400;\\">: Delivered a fully interactive dashboard that offers real-time insights into eCommerce performance. The dashboard helps stakeholders track sales and adjust strategies dynamically.</span></p>","completed_modules":"1","skills":[{"id":979,"me_milestone_id":159,"skills_id":317,"ordering":1},{"id":981,"me_milestone_id":159,"skills_id":325,"ordering":3},{"id":982,"me_milestone_id":159,"skills_id":336,"ordering":4},{"id":983,"me_milestone_id":159,"skills_id":330,"ordering":5}]},{"id":160,"status":"published","sort":null,"user_created":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_created":"2024-09-09T11:42:45.000Z","user_updated":null,"date_updated":null,"me_id":"ME_PYTHON_QMMTAGENT_TEST_BLANK","slug":"me-python-qmmtagent-test-blank-milestone-1","title":"Agentic AI Project","content":"<h1><span style=\\"font-weight: 400;\\">Extended Overview</span></h1>\\n<p><strong>AI Agent Design</strong><span style=\\"font-weight: 400;\\">: Built multiple AI agents, each handling a different aspect of itinerary planning, such as flight bookings, hotel reservations, and activity suggestions. Agents interact with each other to create cohesive travel plans.</span></p>\\n<p><strong>API Integration</strong><span style=\\"font-weight: 400;\\">: Integrated several third-party APIs to fetch real-time data on flights, hotels, and activities. The agents use this data to recommend options based on user preferences.</span></p>\\n<p><strong>Machine Learning Optimization</strong><span style=\\"font-weight: 400;\\">: Implemented machine learning algorithms to optimize the itineraries based on factors like cost, travel time, and user preferences. The system continuously learns from user feedback to improve suggestions.</span></p>\\n<p><strong>Holiday Planner</strong><span style=\\"font-weight: 400;\\">: The final deliverable is a dynamic holiday planner that intelligently recommends personalized travel plans, mimicking the work of ML engineers at MakeMyTrip.</span></p>","completed_modules":"1","skills":[{"id":984,"me_milestone_id":160,"skills_id":315,"ordering":1},{"id":985,"me_milestone_id":160,"skills_id":333,"ordering":2},{"id":986,"me_milestone_id":160,"skills_id":334,"ordering":3},{"id":987,"me_milestone_id":160,"skills_id":335,"ordering":4},{"id":988,"me_milestone_id":160,"skills_id":241,"ordering":5}]},{"id":161,"status":"published","sort":null,"user_created":"96947060-767d-4dc3-8a57-ab05646a591f","date_created":"2025-05-02T11:40:20.000Z","user_updated":null,"date_updated":null,"me_id":"ME_FE_BUILDOUT_XPROFILE","slug":"me-xprofile-milestone-0","title":"XProfile","content":"<h1>Extended Overview<br /><br /></h1>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/587d96f3-5bd9-46cb-93ee-b18c8c7609c4\\" alt=\\"Image2\\" /></div>","completed_modules":"0","skills":[]},{"id":162,"status":"published","sort":null,"user_created":"96947060-767d-4dc3-8a57-ab05646a591f","date_created":"2025-05-02T11:43:52.000Z","user_updated":null,"date_updated":null,"me_id":"ME_FE_BUILDOUT_XPROFILE","slug":"me-xprofile-milestone-1","title":"Build XProfile using HTML and CSS","content":"<h1><strong>Build XProfile using HTML and CSS</strong></h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Structured the profile card layout using HTML.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Applied CSS styling for responsiveness and visual design.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Implemented features such as profile image, name, role, company, and social media icons.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Verified the responsiveness and design correctness through assessment tests.</span><span style=\\"font-weight: 400;\\"><br /></span></li>\\n</ul>\\n<h2>Skills used</h2>\\n<p><span style=\\"font-weight: 400;\\">HTML, CSS</span></p>","completed_modules":"1","skills":[{"id":989,"me_milestone_id":162,"skills_id":10,"ordering":1},{"id":990,"me_milestone_id":162,"skills_id":12,"ordering":2}]},{"id":163,"status":"published","sort":null,"user_created":"96947060-767d-4dc3-8a57-ab05646a591f","date_created":"2025-05-02T12:14:14.000Z","user_updated":null,"date_updated":null,"me_id":"ME_SPRING_BOOT_XBLOG","slug":"me-spring-boot-xblog-milestone-0","title":"XBlog","content":"<h1>Extended Overview<br /><br /></h1>\\n<div class=\\"image-container\\"><img src=\\"https://directus.crio.do/assets/e55238ae-50e3-4238-b73b-0a861f71283f\\" alt=\\"Image1\\" /></div>","completed_modules":"0","skills":[]},{"id":164,"status":"published","sort":null,"user_created":"96947060-767d-4dc3-8a57-ab05646a591f","date_created":"2025-05-04T04:38:37.000Z","user_updated":null,"date_updated":null,"me_id":"ME_SPRING_BOOT_XBLOG","slug":"me-spring-boot-xblog-milestone-1","title":"Backend","content":"<h1><strong>Backend</strong></h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Built RESTful APIs for authentication, users, posts, likes, and comments</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Integrated JWT-based authentication and role-based access control</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Managed image uploads using Cloudinary</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Implemented secure error handling and environment config</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Validated implementation via automated tests</span></li>\\n</ul>\\n<h2>Skills used</h2>\\n<p><span style=\\"font-weight: 400;\\">Java, Spring Boot, MongoDB, JWT</span></p>","completed_modules":"1","skills":[{"id":991,"me_milestone_id":164,"skills_id":26,"ordering":1},{"id":992,"me_milestone_id":164,"skills_id":24,"ordering":2},{"id":993,"me_milestone_id":164,"skills_id":19,"ordering":3},{"id":994,"me_milestone_id":164,"skills_id":145,"ordering":4}]},{"id":165,"status":"published","sort":null,"user_created":"96947060-767d-4dc3-8a57-ab05646a591f","date_created":"2025-05-04T12:03:24.000Z","user_updated":null,"date_updated":null,"me_id":"ME_SPRING_BOOT_XBLOG","slug":"me-spring-boot-xblog-milestone-2","title":"Frontend","content":"<h1><strong>Frontend</strong></h1>\\n<h2>Scope of Work</h2>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Created UI with form handling, routing, and protected views</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Build dynamic components for blog posts, dashboard, admin view, and user profile</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Integrated with backend APIs for full functionality</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Ensured design accuracy and responsiveness</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Verified correctness through test assessments</span></li>\\n</ul>\\n<h2>Skills used</h2>\\n<p><span style=\\"font-weight: 400;\\">HTML, CSS, JavaScript, ReactJS</span></p>","completed_modules":"2","skills":[{"id":995,"me_milestone_id":165,"skills_id":10,"ordering":1},{"id":996,"me_milestone_id":165,"skills_id":12,"ordering":2},{"id":997,"me_milestone_id":165,"skills_id":22,"ordering":3},{"id":998,"me_milestone_id":165,"skills_id":285,"ordering":4}]},{"id":166,"status":"published","sort":null,"user_created":"96947060-767d-4dc3-8a57-ab05646a591f","date_created":"2025-07-22T12:11:15.000Z","user_updated":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_updated":"2025-09-16T08:05:36.000Z","me_id":"ME_JUPYTER_AIRBNBANALYSIS","slug":"me-jupyter-airbnbanalysis-milestone-0","title":"Extended Overview","content":"<p><strong>Data Collection &amp; Cleaning:</strong></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Data was collected from Airbnb listing information. The dataset contains various columns such as room type, price, number of reviews, and geographical data.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Cleaning steps involved filling or dropping missing values, especially in columns like reviews_per_month and last_review. Any irrelevant or duplicate rows were removed to ensure accurate analysis.</span></li>\\n</ul>\\n<p><strong>Data Analysis:</strong></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Descriptive statistics were generated to understand the central tendencies and dispersions in key variables like price and number_of_reviews.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Relationships between room_type, price, and neighbourhood were examined to identify patterns that could influence the listing prices.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">We explored correlations between numerical variables like price, reviews_per_month, and availability.</span></li>\\n</ul>\\n<p><strong>Data Visualization:</strong></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Various charts (e.g., histograms, scatter plots) were used to represent data distribution and the relationship between variables like price vs. room type and neighbourhood.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Geospatial visualizations were also created to showcase how listings are spread across different neighbourhoods in the city.</span></li>\\n</ul>\\n<p><strong>Trend Analysis:</strong></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Identified price trends based on room type and neighbourhood, helping pinpoint where the most lucrative listings are located.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">A trend analysis was conducted to uncover peak times in reviews and availability.</span></li>\\n</ul>\\n<p><strong>Summary:</strong></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Key insights were drawn from the analysis, which included the impact of location on listing price, how room types affect occupancy and reviews, and which features most influence pricing.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">The analysis also highlighted areas for hosts to improve their listings in terms of reviews and visibility.</span></li>\\n</ul>","completed_modules":"0","skills":[{"id":1050,"me_milestone_id":166,"skills_id":356,"ordering":1},{"id":1031,"me_milestone_id":166,"skills_id":318,"ordering":2},{"id":1032,"me_milestone_id":166,"skills_id":319,"ordering":3},{"id":1033,"me_milestone_id":166,"skills_id":320,"ordering":4},{"id":1034,"me_milestone_id":166,"skills_id":323,"ordering":5},{"id":1035,"me_milestone_id":166,"skills_id":353,"ordering":6},{"id":1029,"me_milestone_id":166,"skills_id":327,"ordering":7},{"id":1036,"me_milestone_id":166,"skills_id":328,"ordering":8}]},{"id":167,"status":"published","sort":null,"user_created":"42670516-02dd-418e-abaa-d5ff0d183714","date_created":"2025-07-22T12:36:48.000Z","user_updated":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_updated":"2025-09-16T08:05:22.000Z","me_id":"ME_JUPYTER_UBERANALYSIS","slug":"me-jupyter-uberanalysis-milestone-0","title":"Extended Overview","content":"<p><span style=\\"font-weight: 400;\\">Data Collection &amp; Cleaning</span></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Source &amp; Scope:</strong><span style=\\"font-weight: 400;\\"> Ingested ~6,945 Uber ride records with 13 fields, including request/start/drop timestamps, pickup/drop locations, trip cost, tip, ride type, payment method, driver ID, status, and weather conditions.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Preprocessing Steps:</strong></li>\\n<ol>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><strong>Timestamp conversion:</strong><span style=\\"font-weight: 400;\\"> Transformed request, start, and drop time strings to datetime objects; derived request_hour, request_dayofweek, wait_time (start&minus;request), and trip_duration (drop&minus;start).</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><strong>Missing data handling:</strong><span style=\\"font-weight: 400;\\"> Identified that all &ldquo;Trip Cancelled&rdquo; and &ldquo;No Cars Available&rdquo; trips lack start/drop times. Retained these for cancellation-rate analysis but excluded them from trip-duration and revenue metrics.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><strong>Feature engineering:</strong><span style=\\"font-weight: 400;\\"> Standardized pickup/drop names; encoded ride_type, payment_method, and weather; categorized hours into &ldquo;peak&rdquo; vs. &ldquo;off-peak.&rdquo;</span></li>\\n</ol>\\n</ul>\\n<p><span style=\\"font-weight: 400;\\">Data Analysis</span></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Temporal Demand &amp; Supply:</strong></li>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><strong>Request volume by hour:</strong><span style=\\"font-weight: 400;\\"> Two daily peaks at 8&ndash;10 AM and 6&ndash;8 PM; supply shortfall (fulfilled vs. requested) highest at 6&ndash;7 PM.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><strong>Day-of-week patterns:</strong><span style=\\"font-weight: 400;\\"> Weekend mornings show elevated leisure travel demand; weekday evening commutes dominate.</span></li>\\n</ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Cancellation &amp; &ldquo;No Cars Available&rdquo; Patterns:</strong></li>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Cancellation rate spikes (~25%) during peak hours; &ldquo;No Cars Available&rdquo; events concentrated in high-density zones (e.g., Majestic, Koramangala).</span></li>\\n</ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Revenue &amp; Ride-Type Mix:</strong></li>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">UberGo comprises ~33% of trips but only ~28% of revenue; UberXL (~32% of trips) yields ~40% of total fare.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Average tip correlates positively with trip duration (r&asymp;0.45).</span></li>\\n</ul>\\n</ul>\\n<p><span style=\\"font-weight: 400;\\">Data Visualization</span></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Heatmap:</strong><span style=\\"font-weight: 400;\\"> Requests vs. hour and pickup zone to pinpoint underserved areas during rush hours.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Line Chart:</strong><span style=\\"font-weight: 400;\\"> Hourly request fulfillment rate overlaid on request volume.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Bar Charts:</strong><span style=\\"font-weight: 400;\\"> Cancellation and &ldquo;No Cars Available&rdquo; percentages by ride type and payment method.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Box Plots:</strong><span style=\\"font-weight: 400;\\"> Distribution of wait times and trip durations for each ride type.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Scatter Plot:</strong><span style=\\"font-weight: 400;\\"> Trip cost vs. duration colored by weather.</span></li>\\n</ul>\\n<p><span style=\\"font-weight: 400;\\">Trend Analysis</span></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Weather Impact:</strong><span style=\\"font-weight: 400;\\"> &ldquo;Rainy&rdquo; and &ldquo;Stormy&rdquo; conditions see a ~20% increase in &ldquo;No Cars Available&rdquo; and ~15% higher cancellations.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Service Gaps Over Time:</strong><span style=\\"font-weight: 400;\\"> Month-over-month growth in late-night demand not matched by driver availability, suggesting incentive adjustments needed.</span></li>\\n</ul>\\n<p><span style=\\"font-weight: 400;\\">Summary</span></p>\\n<p><span style=\\"font-weight: 400;\\">This analysis uncovers critical service bottlenecks during peak and adverse-weather conditions, reveals high-value ride types, and quantifies cancellation drivers. Recommendations include dynamic driver-incentive schemes for rush hours and poor weather, targeted marketing for underutilized ride tiers, and real-time supply reallocation to high-demand zones.</span></p>","completed_modules":"0","skills":[{"id":1049,"me_milestone_id":167,"skills_id":356,"ordering":1},{"id":1022,"me_milestone_id":167,"skills_id":318,"ordering":2},{"id":1023,"me_milestone_id":167,"skills_id":319,"ordering":3},{"id":1024,"me_milestone_id":167,"skills_id":320,"ordering":4},{"id":1025,"me_milestone_id":167,"skills_id":323,"ordering":5},{"id":1026,"me_milestone_id":167,"skills_id":353,"ordering":6},{"id":1027,"me_milestone_id":167,"skills_id":327,"ordering":7},{"id":1028,"me_milestone_id":167,"skills_id":328,"ordering":8}]},{"id":168,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2025-07-22T13:01:48.000Z","user_updated":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_updated":"2025-09-16T08:05:00.000Z","me_id":"ME_JUPYTER_BANKATTRITIONANALYSIS","slug":"me-jupyter-bankattritionanalysis-milestone-0","title":"Bank Attrition Analysis","content":"<h1>Extended Overview</h1>\\n<h2>Data Collection &amp; Cleaning</h2>\\n<ul>\\n<li><strong>Source &amp; Scope:</strong> Loaded the Bank Customer Attrition dataset (&asymp; 10 k records, 20+ features) containing demographics, financials, product holding, and engagement indicators.</li>\\n<li><strong>Preprocessing Steps:</strong></li>\\n<li><strong>Column normalization</strong>: Renamed to lowercase and replaced spaces/&rsquo;-&rsquo; with underscores.</li>\\n<li><strong>Null handling: </strong>Converted blank strings in gender, card_type, salary to NaN; imputed or dropped rows with critical missing entries in card_type, salary.</li>\\n<li><strong>Feature engineering:</strong> Created categorical bins for tenure, age, credit score, balance, satisfaction score, salary, and number of complaints to facilitate grouped analyses.</li>\\n</ul>\\n<h2>Data Analysis</h2>\\n<ul>\\n<li><strong>Univariate Analysis: </strong>Assessed distributions of all features; e.g., the majority of customers have a tenure of &le; 5 years and credit scores between 600&ndash;800.</li>\\n<li><strong>Bivariate Analysis</strong>: Explored churn rate vs. single variables&mdash;found that customers with tenure &lt; 3 years and satisfaction score &le; 3 have churn rates &gt; 40%.</li>\\n<li><strong>Multivariate Analysis:</strong> Investigated interactions (e.g., age &amp; salary; credit score &amp; number of products) revealing compounded risk factors, such as older customers with low balances and no active membership being most at-risk.</li>\\n</ul>\\n<h2>Data Visualization</h2>\\n<ul>\\n<li><strong>Techniques Used:</strong></li>\\n<li>Histograms &amp; KDE plots to show distributions (age, salary).</li>\\n<li>Boxplots comparing balance and credit score by churn status.</li>\\n<li>Bar charts for categorical churn rates (gender, card type, product count).</li>\\n<li>Heatmaps of correlation matrix to highlight feature interdependencies.</li>\\n<li>Interactive dashboards (Plotly Express) for stakeholder exploration.</li>\\n</ul>\\n<h2>Trend Analysis</h2>\\n<ul>\\n<li><strong>Customer Lifecycle Patterns:</strong> Identified a steep drop-off in retention after 2&ndash;3 years of tenure.</li>\\n<li><strong>Product Engagement:</strong> Higher attrition among customers holding only one product; upsell opportunities (e.g., introducing additional products) could bolster retention.</li>\\n<li><strong>Satisfaction &amp; Complaints:</strong> Satisfaction scores &le; 3 and any customer complaints increased churn likelihood by over 50%.</li>\\n</ul>\\n<h2>Summary</h2>\\n<ul>\\n<li>Through systematic EDA, the analysis pinpoints actionable levers&mdash;enhancing early tenure engagement, improving service satisfaction, targeting product cross-sells, and reactivating inactive members&mdash;that can reduce attrition.</li>\\n</ul>","completed_modules":"0","skills":[{"id":1048,"me_milestone_id":168,"skills_id":356,"ordering":2},{"id":1014,"me_milestone_id":168,"skills_id":318,"ordering":3},{"id":1015,"me_milestone_id":168,"skills_id":319,"ordering":4},{"id":1016,"me_milestone_id":168,"skills_id":320,"ordering":5},{"id":1017,"me_milestone_id":168,"skills_id":323,"ordering":6},{"id":1018,"me_milestone_id":168,"skills_id":328,"ordering":7},{"id":1019,"me_milestone_id":168,"skills_id":327,"ordering":8},{"id":1020,"me_milestone_id":168,"skills_id":353,"ordering":9}]},{"id":169,"status":"published","sort":null,"user_created":"e839b411-7d12-449d-a0c7-94e446e63246","date_created":"2025-07-23T07:20:22.000Z","user_updated":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_updated":"2025-09-16T08:05:52.000Z","me_id":"ME_JUPYTER_AMAZONFEEDBACKANALYSIS","slug":"me-jupyter-amazonfeedbackanalysis-milestone-0","title":"Amazon Product Feedback Analysis","content":"<h1>Extended Overview</h1>\\n<h2>Data Collection &amp; Cleaning</h2>\\n<ul>\\n<li><strong>Source &amp; Scope:</strong> Loaded ~3,077 Amazon product reviews covering 13 fields&mdash;including review text, rating (1&ndash;5), recommendation flag, helpfulness votes, brand, and categories.</li>\\n<li><strong>Preprocessing Steps:</strong>\\n<ol>\\n<li><strong>Column normalization:</strong> Renamed fields to snake_case (e.g. reviews_date_added).</li>\\n<li><strong>Date parsing:</strong> Converted reviews_date_added to datetime; noted only ~276 entries had dates, so time-based trend analysis was limited.</li>\\n<li><strong>Missing data:</strong> Imputed missing reviews_do_recommend as &ldquo;Unknown&rdquo;; dropped any rows without review text.</li>\\n<li><strong>Feature engineering:</strong><br />\\n<ul>\\n<li><strong>Review length</strong>: Counted words in reviews_text.</li>\\n<li><strong>Sentiment polarity</strong>: Computed using a lexicon-based approach to score each review from &ndash;1 (negative) to +1 (positive).</li>\\n<li><strong>Helpfulness ratio</strong>: reviews_num_helpful divided by review length to normalize engagement.</li>\\n</ul>\\n</li>\\n</ol>\\n</li>\\n</ul>\\n<h2>Data Analysis</h2>\\n<ul>\\n<li><strong>Rating &amp; Recommendation Distribution:</strong><br /><br />\\n<ul>\\n<li><strong>Ratings</strong>: Approximately 70% of reviews are 4&ndash;5 stars; 1&ndash;2 star reviews represent ~15%.</li>\\n<li><strong>Recommendation Flag</strong>: &ldquo;doRecommend = True&rdquo; aligns strongly with 4&ndash;5 star ratings; ~10% of high-rated reviews did not explicitly recommend.</li>\\n</ul>\\n</li>\\n<li><strong>Brand &amp; Category Sentiment:</strong>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Brands A and B show average sentiment scores above 0.6, while Brand C averages 0.2 with frequent 1&ndash;2 star reviews.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Certain categories (e.g., Electronics) have wider sentiment variability versus more uniform categories like Books.</span></li>\\n</ul>\\n</li>\\n<li><strong>Textual Insights:</strong>\\n<ul>\\n<li><strong>Word Cloud Analysis:</strong> Positive reviews frequently mention &ldquo;quality,&rdquo; &ldquo;easy,&rdquo; and &ldquo;recommend,&rdquo; while negative reviews highlight &ldquo;defective,&rdquo; &ldquo;return,&rdquo; and &ldquo;battery.&rdquo;</li>\\n<li><strong>Length vs. Helpfulness: </strong>Longer reviews (200+ words) receive on average 2&times; more helpful votes than short reviews (&lt;50 words).</li>\\n</ul>\\n</li>\\n</ul>\\n<h2>Data Visualization</h2>\\n<ul>\\n<li><strong>Bar Charts</strong>: Rating counts and recommendation rates by category.</li>\\n<li><strong>Heatmap</strong>: Average sentiment polarity across top 10 brands and categories.</li>\\n<li><strong>Word Clouds</strong>: Side-by-side for 5-star vs. 1-star reviews to contrast key terms.</li>\\n<li><strong>Scatter Plot</strong>: Review length vs. number of helpful votes with a LOESS smoothing line.</li>\\n<li><strong>Box Plots</strong>: Distribution of helpfulness ratio across rating levels</li>\\n</ul>\\n<h2>Trend Analysis</h2>\\n<ul>\\n<li><strong>Sentiment Extremes</strong>: While most reviews are positive, negative reviews are more textually rich&mdash;offering deeper insights into pain points (e.g., durability, customer service).</li>\\n<li><strong>Engagement Patterns</strong>: Reviews that include product comparisons or detailed pros/cons lists see the highest helpfulness ratios, indicating value in structured feedback.</li>\\n</ul>\\n<h2>Summary</h2>\\n<p>This analysis distills the volumetric and semantic dimensions of Amazon product feedback. Key recommendations include prioritizing improvements on common defect areas, encouraging longer &ldquo;pros and cons&rdquo; style reviews to boost helpfulness and trust, and tailoring product messaging around features that drive the highest sentiment in your strongest-performing brands and categories.</p>","completed_modules":"0","skills":[{"id":1037,"me_milestone_id":169,"skills_id":330,"ordering":1},{"id":1051,"me_milestone_id":169,"skills_id":356,"ordering":1},{"id":1038,"me_milestone_id":169,"skills_id":336,"ordering":2},{"id":1040,"me_milestone_id":169,"skills_id":318,"ordering":4},{"id":1041,"me_milestone_id":169,"skills_id":319,"ordering":5},{"id":1042,"me_milestone_id":169,"skills_id":320,"ordering":6},{"id":1043,"me_milestone_id":169,"skills_id":323,"ordering":7},{"id":1044,"me_milestone_id":169,"skills_id":354,"ordering":8},{"id":1045,"me_milestone_id":169,"skills_id":353,"ordering":9},{"id":1046,"me_milestone_id":169,"skills_id":327,"ordering":10},{"id":1047,"me_milestone_id":169,"skills_id":328,"ordering":11}]},{"id":170,"status":"published","sort":null,"user_created":"96947060-767d-4dc3-8a57-ab05646a591f","date_created":"2025-07-24T09:14:05.000Z","user_updated":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_updated":"2025-09-08T15:37:39.000Z","me_id":"ME_POWERBI_FOODELIVERY","slug":"me-powerbi-foodelivery-milestone-0","title":"Extended Overview","content":"<p><strong>Data Collection &amp; Cleaning:</strong></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Data was collected from multiple sources: Order_details, Delivery_details, User_details, Restaurant_details, and Delivery_person_details.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Transformation tasks included removing duplicates, handling missing values (NaN), and converting data types (e.g., Time Order Picked to time format).</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">We merged these tables using left joins to build a comprehensive dataset for analysis.</span></li>\\n</ul>\\n<p><strong>Data Analysis:</strong></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">DAX measures were created for critical KPIs:</span></li>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><strong>Total Sales</strong><span style=\\"font-weight: 400;\\">: The sum of all order values.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><strong>Average Order Value</strong><span style=\\"font-weight: 400;\\">: The average value of each order.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><strong>Total Deliveries</strong><span style=\\"font-weight: 400;\\">: The distinct count of orders.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><strong>On-time Delivery %</strong><span style=\\"font-weight: 400;\\">: Percentage of deliveries completed on time (within 30 minutes).</span></li>\\n</ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Additionally, we categorized data by food type, age group, and order value category (Low, Medium, High).</span></li>\\n</ul>\\n<p><strong>Data Visualization:</strong></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Various visualizations were created, including:</span></li>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><strong>Card Visuals</strong><span style=\\"font-weight: 400;\\"> to show aggregate metrics like total sales, average order value, and on-time delivery percentage.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><strong>Donut Chart</strong><span style=\\"font-weight: 400;\\"> to show the sales percentage by order value category.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><strong>Stacked Column Chart</strong><span style=\\"font-weight: 400;\\"> for order value distribution across food categories.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><strong>Line and Clustered Column Chart</strong><span style=\\"font-weight: 400;\\"> for delivery performance based on road traffic density.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><strong>Scatter Plot</strong><span style=\\"font-weight: 400;\\"> for analyzing delivery person efficiency, based on age and vehicle type.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><strong>Treemap</strong><span style=\\"font-weight: 400;\\"> to show restaurant performance by food category.</span></li>\\n</ul>\\n</ul>\\n<p><strong>Trend Analysis:</strong></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">A detailed trend analysis was conducted on customer demographics, highlighting the relationship between age group and average order value.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">We observed that the Vegetarian food category performed better in certain regions, while Non-vegetarian had higher sales in others.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">A deeper analysis of delivery performance showed that higher road traffic density had a slight negative correlation with delivery time efficiency.</span></li>\\n</ul>\\n<p><strong>Summary:</strong></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">The insights gained from this project allow ZestyEats to optimize their menu offerings, delivery operations, and marketing strategies.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">The interactive Power BI dashboard provides a comprehensive view of the company\'s performance, enabling better resource allocation and decision-making.</span></li>\\n</ul>","completed_modules":"5","skills":[{"id":1005,"me_milestone_id":170,"skills_id":317,"ordering":1},{"id":1008,"me_milestone_id":170,"skills_id":336,"ordering":1},{"id":1006,"me_milestone_id":170,"skills_id":327,"ordering":2},{"id":1007,"me_milestone_id":170,"skills_id":328,"ordering":3}]},{"id":171,"status":"published","sort":null,"user_created":"42670516-02dd-418e-abaa-d5ff0d183714","date_created":"2025-07-24T10:19:37.000Z","user_updated":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_updated":"2025-09-08T15:38:04.000Z","me_id":"ME_POWERBI_ECOMMERCE","slug":"me-powerbi-ecommerce-milestone-0","title":"Ecommerce Sales Dashboard","content":"<h1>Extended Overview</h1>\\n<p>&nbsp;</p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Data Collection &amp; Cleaning:</strong>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"3\\"><span style=\\"font-weight: 400;\\">Removing duplicates (e.g., Customer ID, Product ID).</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"3\\"><span style=\\"font-weight: 400;\\">Verifying and correcting data types (e.g., Date, Discount, and Quantity fields).</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"3\\"><span style=\\"font-weight: 400;\\">Filtering out zero values in the Quantity column and creating new columns for discount categories (No Discount, Low, Medium, High).</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Data was collected from several tables: Customers, Dates, Products, and Sales.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">The dataset underwent several cleaning steps such as:</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Custom columns like Product Amount (Quantity * List Price) and Sales Amount (Product Amount - Discount) were added for further analysis.</span></li>\\n</ul>\\n</li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Data Analysis:</strong>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"3\\"><strong>Total Sales</strong><span style=\\"font-weight: 400;\\">: Sum of sales amounts.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"3\\"><strong>Total Orders</strong><span style=\\"font-weight: 400;\\">: Distinct count of orders.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"3\\"><strong>Average Order Value (AOV)</strong><span style=\\"font-weight: 400;\\">: Total sales divided by total orders.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"3\\"><strong>Average Items per Order (AIPO)</strong><span style=\\"font-weight: 400;\\">: Total quantity sold divided by total orders.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"3\\"><strong>Revenue per Customer (ARPC)</strong><span style=\\"font-weight: 400;\\">: Total sales divided by the number of customers.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">DAX measures were created for:</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Additional calculations such as </span><strong>Total Profit</strong><span style=\\"font-weight: 400;\\"> and </span><strong>Profit Margin</strong><span style=\\"font-weight: 400;\\"> were derived to assess the profitability of the business.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">A Discount Category was created to analyze the impact of different discount levels on sales.</span></li>\\n</ul>\\n</li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Data Visualization:</strong>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><strong>Card Visuals</strong><span style=\\"font-weight: 400;\\"> were created to show aggregate metrics like total sales, quantity sold, orders, and customers.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><strong>Line Chart</strong><span style=\\"font-weight: 400;\\"> was used to visualize sales trends over time.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><strong>Stacked Bar Charts</strong><span style=\\"font-weight: 400;\\"> were used to compare total sales by customer segment and product category across different regions.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><strong>Donut Chart</strong><span style=\\"font-weight: 400;\\"> visualized the distribution of orders by shipping method, and </span><strong>Matrix Visuals</strong><span style=\\"font-weight: 400;\\"> were used to analyze sales by discount levels and product categories.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><strong>Gauge Visuals</strong><span style=\\"font-weight: 400;\\"> showed average discount and delivery time metrics.</span></li>\\n</ul>\\n</li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Trend Analysis:</strong>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">A sales trend analysis was conducted to examine the relationship between order quantities and sales over time, highlighting the effects of promotional campaigns and seasonal sales.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Profit margin trends were analyzed to evaluate how discounts affected profitability across different product categories.</span></li>\\n</ul>\\n</li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Summary:</strong>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"3\\"><strong>Discount Impact</strong><span style=\\"font-weight: 400;\\">: Higher discounts generally led to increased sales but reduced profit margins, particularly for certain product categories like Furniture and Office Supplies.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"3\\"><strong>Regional Performance</strong><span style=\\"font-weight: 400;\\">: Certain regions showed higher sales in specific product categories, allowing for better-targeted marketing strategies.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"3\\"><strong>Order Fulfillment &amp; Delivery</strong><span style=\\"font-weight: 400;\\">: Shipping methods like Standard Class and Second Class had the highest order volumes, whereas </span><strong>Same Day</strong><span style=\\"font-weight: 400;\\"> deliveries had the highest profit margins.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">The analysis revealed several key insights:</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">The Power BI report serves as an interactive dashboard, enabling stakeholders to explore various aspects of sales performance, customer segmentation, and discount strategies.</span></li>\\n</ul>\\n</li>\\n</ul>","completed_modules":"5","skills":[{"id":999,"me_milestone_id":171,"skills_id":327,"ordering":1},{"id":1009,"me_milestone_id":171,"skills_id":330,"ordering":1},{"id":1000,"me_milestone_id":171,"skills_id":328,"ordering":2},{"id":1010,"me_milestone_id":171,"skills_id":336,"ordering":2},{"id":1001,"me_milestone_id":171,"skills_id":317,"ordering":3}]},{"id":172,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2025-07-24T15:22:21.000Z","user_updated":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_updated":"2025-09-08T15:38:17.000Z","me_id":"ME_POWERBI_ECOMMERCE","slug":"me-powerrbi-ecommerce-milestone-0","title":"Extended Overview","content":"<p><strong>Data Collection &amp; Cleaning:</strong></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\">Data was collected from two primary tables: Customer_Details and Loan_Details. The data was categorized into age groups, income brackets, credit score buckets, and loan types.</li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Data Categorization:</strong></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Age Groups</strong>: Categorized into Young, Middle-aged, Senior, and Elder.</li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Credit Score: </strong>Divided into Poor, Fair, Good, Very Good, and Excellent.</li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Income</strong>: Segmented into Low, Medium, and High based on income ranges.</li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\">Data types were verified, and the necessary changes were made to ensure the proper categorization and formatting for analysis.</li>\\n</ul>\\n<p><strong>Data Analysis:</strong></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Various DAX measures were created to calculate key metrics:<br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\"><strong>Total Loan Amount:</strong> The sum of all loan amounts.<br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\"><strong>Average Monthly Installment:</strong> The average of monthly loan payments.<br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\"><strong>Defaulted Loans:</strong> The number of loans that have defaulted.<br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\"><strong>High-Risk Loans:</strong> Loans that are at high risk based on credit score.<br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\"><strong>Loan Status</strong>: Categorized by Active, Closed, and Defaulted.<br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Relationships were established between Customer_Details, Loan_Details, and Date tables for more comprehensive analysis.<br /></span>.</li>\\n</ul>\\n<p><strong>Data Visualization:</strong></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\"><strong>Customer Demographics:</strong><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\"><strong>Pie Charts</strong> were used to display gender distribution and education level of customers.<br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\"><strong>Clustered Bar Chart</strong> explored the relationship between gender, education level, and credit score.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\"><strong>Loan Portfolio &amp; Performance:</strong><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\"><strong>Pie Chart</strong> displayed the distribution of loan types.<br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\"><strong>The 100% Stacked Column Chart</strong> was used to break down loans by type and status.<br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\"><strong>Tables </strong>were created to list top loans by amount, categorized by status (Active, Defaulted).</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\"><strong>Financial Risk Analysis:</strong><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\"><strong>Pie Charts</strong> displayed defaulted loan amounts based on employment type and credit score.<br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\"><strong>Matrix visualizations</strong> revealed the relationship between income, education level, and the amount of defaulted loans.<br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\"><strong>Stacked Column Chart</strong> examined the number of customers by credit score and employment type.<br /></span></li>\\n</ul>\\n<p><strong>Trend Analysis:</strong></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">The financial risk analysis showed that customers with lower credit scores and incomes were more likely to default, with High Risk loans showing a direct correlation with poor credit scores and high loan amounts.<br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Risk Category: The High Risk category included those with credit scores below 580, and this group contributed significantly to the total defaulted loan amounts.</span><span style=\\"font-weight: 400;\\"><br /></span></li>\\n</ul>\\n<p><strong>Summary:</strong></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Key insights showed that the default rates and loan amounts were higher in the lower income and lower credit score categories.<br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Customers with poor credit scores (below 580) represented the highest default risk, making them a focal point for risk mitigation strategies.<br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">The Power BI dashboard provides an interactive tool for stakeholders to monitor customer demographics, loan performance, and financial risks, aiding in better decision-making for loan approvals and financial planning.<br /></span></li>\\n</ul>","completed_modules":"5","skills":[{"id":1002,"me_milestone_id":172,"skills_id":317,"ordering":1},{"id":1011,"me_milestone_id":172,"skills_id":330,"ordering":1},{"id":1003,"me_milestone_id":172,"skills_id":327,"ordering":2},{"id":1012,"me_milestone_id":172,"skills_id":336,"ordering":2},{"id":1004,"me_milestone_id":172,"skills_id":328,"ordering":3}]},{"id":173,"status":"draft","sort":null,"user_created":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_created":"2026-01-08T06:32:21.000Z","user_updated":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_updated":"2026-01-10T11:00:27.000Z","me_id":"ME_QTREND_ANALYTICS","slug":"me-qtrend-analytics-milestone-1","title":"Metric Analysis and Insight Generation","content":"<ol>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Ingested dataset of social media posts with engagement stats.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Calculated \\"Engagement Rate\\" and ranked posts by performance.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Analyzed correlation between \\"Day of Week\\" / \\"Time\\" and engagement.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Identified top performing content categories (e.g., \\"Educational\\" vs \\"Entertainment\\").</span></li>\\n</ol>","completed_modules":"0","skills":[{"id":1052,"me_milestone_id":173,"skills_id":241,"ordering":1},{"id":1053,"me_milestone_id":173,"skills_id":315,"ordering":2},{"id":1054,"me_milestone_id":173,"skills_id":329,"ordering":3},{"id":1055,"me_milestone_id":173,"skills_id":335,"ordering":4}]},{"id":174,"status":"draft","sort":null,"user_created":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_created":"2026-01-08T06:33:14.000Z","user_updated":null,"date_updated":null,"me_id":"ME_QTREND_ANALYTICS","slug":"me-qtrend-analytics-milestone-2","title":"Engagement Performance Heatmap","content":"<ol>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Extracted text from top 10% of posts to serve as \\"Style Reference\\".</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Designed a Prompt Template for an LLM to generate 5 new hook ideas.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Implemented a \\"Refine\\" feature where users can adjust the tone (e.g., \\"More Professional\\").</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Displayed generated content side-by-side with predicted performance scores.</span></li>\\n</ol>","completed_modules":"1","skills":[]},{"id":175,"status":"draft","sort":null,"user_created":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_created":"2026-01-08T06:34:02.000Z","user_updated":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_updated":"2026-01-10T11:01:37.000Z","me_id":"ME_QFACTORY_IOT","slug":"me-qfactory-iot-milestone-1","title":"Data Processing and Anomaly Detection","content":"<ol>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Ingested historical sensor logs (e.g., NASA Turbofan dataset).</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Resampled and normalized sensor readings.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Trained an Isolation Forest (or PCA-based model) to identify outliers.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Visualized \\"Normal\\" vs \\"Anomalous\\" vibration patterns.</span></li>\\n</ol>","completed_modules":"0","skills":[{"id":1056,"me_milestone_id":175,"skills_id":241,"ordering":1},{"id":1057,"me_milestone_id":175,"skills_id":322,"ordering":2},{"id":1058,"me_milestone_id":175,"skills_id":320,"ordering":3},{"id":1059,"me_milestone_id":175,"skills_id":317,"ordering":4}]},{"id":176,"status":"draft","sort":null,"user_created":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_created":"2026-01-08T06:34:59.000Z","user_updated":null,"date_updated":null,"me_id":"ME_QFACTORY_IOT","slug":"me-qfactory-iot-milestone-2","title":"RUL Prediction and Dashboarding","content":"<ol>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Labelled data with \\"Time to Failure\\" based on historical breakdown logs.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Trained a Regression model (LSTM/Random Forest) to predict RUL.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Created a Streamlit dashboard showing \\"Machine Health Score\\".</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Implemented an alerting threshold (e.g., \\"Alert if RUL &lt; 5 days\\").</span></li>\\n</ol>","completed_modules":"1","skills":[]},{"id":177,"status":"published","sort":null,"user_created":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_created":"2026-01-08T06:35:57.000Z","user_updated":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_updated":"2026-01-10T11:02:33.000Z","me_id":"ME_QTRAFFIC_GEO","slug":"me-qtraffic-geo-milestone-1","title":"Spatial Data Processing and Mapping","content":"<ol>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Loaded road network and accident CSV data.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Performed Spatial Join to attribute accidents to nearest road segments.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Visualized \\"Accident Hotspots\\" using Heatmaps.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Analyzed correlations with external factors (Rain/Fog, Rush Hour).</span></li>\\n</ol>","completed_modules":"0","skills":[{"id":1060,"me_milestone_id":177,"skills_id":241,"ordering":1},{"id":1061,"me_milestone_id":177,"skills_id":324,"ordering":2},{"id":1062,"me_milestone_id":177,"skills_id":357,"ordering":3}]},{"id":178,"status":"published","sort":null,"user_created":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_created":"2026-01-08T06:36:38.000Z","user_updated":null,"date_updated":null,"me_id":"ME_QTRAFFIC_GEO","slug":"me-qtraffic-geo-milestone-2","title":"Risk Prediction Modeling","content":"<ol>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Created a labelled dataset (Segments with accidents vs. without).</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Trained a Classifier to predict accident probability for a given time/condition.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Generated a \\"Risk Map\\" for the city under current weather conditions.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Listed top 10 most dangerous intersections for intervention.</span></li>\\n</ol>","completed_modules":"1","skills":[]},{"id":179,"status":"draft","sort":null,"user_created":"d8eaf900-d162-4433-8b01-8c0d4b05f20e","date_created":"2026-01-13T05:33:45.000Z","user_updated":null,"date_updated":null,"me_id":"ME_QA_XSTACKOVERFLOW_QUERY","slug":"me-qa-xstackoverflow-query-milestone-1","title":"Automate Stack Overflow Functionality","content":"<ol>\\n<li aria-level=\\"1\\">Analyze Application Under Test (AUT)</li>\\n<ol>\\n<li aria-level=\\"2\\">Understand the flow and functionality of the Stack Overflow website.</li>\\n</ol>\\n<li aria-level=\\"1\\">Develop Test Scripts</li>\\n<ol>\\n<li aria-level=\\"2\\">Write Java/Selenium code to automate specific test cases.</li>\\n<li aria-level=\\"2\\">Implement synchronization strategies (e.g., sleep) to handle dynamic elements or captchas.</li>\\n</ol>\\n<li aria-level=\\"1\\">Version Control Best Practices</li>\\n<ol>\\n<li aria-level=\\"2\\">Perform incremental commits after writing test cases.</li>\\n<li aria-level=\\"2\\">Add explanatory comments to the code for better maintainability.</li>\\n</ol>\\n</ol>","completed_modules":"0","skills":[]},{"id":180,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2026-01-21T10:40:09.000Z","user_updated":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_updated":"2026-01-21T10:46:40.000Z","me_id":"ME_MERN_XEXIT","slug":"me-xexit-milestone-1","title":"XEXIT","content":"<h1>Scope of work</h1>\\n<ul>\\n<li>\\n<h3><strong>Objective</strong><span style=\\"font-size: 15px; font-weight: 500; color: #4f5464;\\">:</span></h3>\\nDevelop a full stack application - XExit for managing employee resignations and exit interviews with two user roles: Employees and HR.</li>\\n<li><strong>Key Features &amp; Design:</strong><br /><strong>Authentication &amp; Role-Based Access:</strong><br />- Employee registration endpoint to onboard new employees<br />- Login flow for both Employee and HR with token-based authentication.<br />- Fixed HR credentials: username \\"admin\\" and password \\"admin\\".</li>\\n<li><strong>Employee Resignation Workflow:</strong><br />-Employees can submit a resignation request with the last working day (LWD).<br />- Resignation submission is rejected if LWD falls on a weekend or a holiday based on the employee&rsquo;s - - country (holiday check via Calendarific in backend).</li>\\n<li><strong>HR Review &amp; Approval Flow:</strong><br />- HR can view all resignation requests submitted by employees.<br />- HR can approve or reject resignations and set/modify the final last working day.<br />- Employees receive approval/rejection + exit date notifications via Nodemailer.</li>\\n<li><strong>Exit Interview Module:</strong><br />- After resignation approval, employees get access to an exit interview questionnaire.<br />- Employees can submit their exit questionnaire responses.<br />- HR can view all completed exit interview responses for review.</li>\\n<li><strong>API-Driven Architecture:</strong><br />- Implemented backend endpoints as per provided API contract:<br />- POST api/auth/register<br />- POST api/auth/login<br />- POST api/user/resign<br />- GET api/admin/resignations<br />- PUT api/admin/conclude_resignation<br />- POST api/user/responses<br />- GET api/admin/exit_responses</li>\\n<li><strong>Testing &amp; Deployment Requirements:</strong><br />- Backend runs on PORT 3001.<br />- Verified correctness using Cypress test suite (assessment folder).<br />- Deployment instructions include backend on Render and frontend on Vercel</li>\\n<li><strong>Tech Stack:</strong><br />MongoDB, Express.js, React.js, Node.js (MERN), JWT/Auth Tokens, Nodemailer, Calendarific API, Cypress</li>\\n<li>\\n<p><strong>Outcome:</strong><br />Delivered a production-style full-stack HR exit management system with role-based workflows, resignation validation rules, approval/rejection handling, exit interview submission, and admin-side review capabilities.<br />Built according to a strict API contract and validated using automated end-to-end tests for assessment readiness.</p>\\n<p>&nbsp;</p>\\n</li>\\n</ul>\\n<h3>Skills used</h3>\\n<p>React.js, Node.js, Express.js, MongoDB, REST APIs, Authentication, Role-Based Access Control, Email Notifications (Nodemailer), External API Integration (Calendarific), Cypress Testing, Git/GitHub, Deployment (Render, Vercel)</p>","completed_modules":"1","skills":[{"id":1063,"me_milestone_id":180,"skills_id":285,"ordering":1},{"id":1064,"me_milestone_id":180,"skills_id":17,"ordering":2},{"id":1065,"me_milestone_id":180,"skills_id":15,"ordering":3},{"id":1066,"me_milestone_id":180,"skills_id":19,"ordering":4},{"id":1067,"me_milestone_id":180,"skills_id":362,"ordering":5}]},{"id":181,"status":"published","sort":null,"user_created":"96947060-767d-4dc3-8a57-ab05646a591f","date_created":"2026-01-21T12:07:16.000Z","user_updated":"96947060-767d-4dc3-8a57-ab05646a591f","date_updated":"2026-01-21T12:12:57.000Z","me_id":"ME_FE_XEXPENSETRACKER_V2","slug":"me-fe-xexpensetracker-v2-milestone-1","title":"Expense Tracker","content":"<h1>Scope of work</h1>\\n<p>&nbsp;</p>\\n<p><strong>Objective:</strong><strong><br /></strong><span style=\\"font-weight: 400;\\">Built a web-based expense tracker that lets users manage daily expenses by adding, editing, and deleting transactions, while tracking wallet balance and viewing spending insights through charts.</span></p>\\n<p><strong>Key Features &amp; Design:</strong></p>\\n<ul>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Wallet Balance Management:</strong><span style=\\"font-weight: 400;\\"> Implemented a default wallet balance of Rs. 5000, supports adding income, and blocks users from spending more than the available balance with proper alerts.</span></li>\\n</ul>\\n</ul>\\n<ul>\\n<li aria-level=\\"1\\"><strong>Expense CRUD Workflow:</strong></li>\\n</ul>\\n<ul>\\n<ul>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Add expenses using a modal-based form with inputs for title, amount (price), category, and date.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Validated required fields before submission and cleared inputs after successful creation.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Enabled users to edit and delete existing expenses with instant wallet recalculation.</span></li>\\n</ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Data Persistence:</strong><span style=\\"font-weight: 400;\\"> Stored wallet balance and expense history in localStorage (using key \\"expenses\\") to retain data even after refresh.</span></li>\\n</ul>\\n</ul>\\n<ul>\\n<li aria-level=\\"1\\"><strong>Expense Insights &amp; Visualization:</strong></li>\\n</ul>\\n<ul>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Displayed category-wise summary using a Pie Chart for quick spending breakdown.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Showed expense trends using a Bar Chart to highlight category-based spending patterns.</span></li>\\n</ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Responsive UI:</strong><span style=\\"font-weight: 400;\\"> Designed the application to work smoothly across desktop, mobile, and tablet views, matching the provided UI reference closely.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Testing &amp; Compliance:</strong><span style=\\"font-weight: 400;\\"> Followed strict UI/text requirements to pass integration tests (button labels, heading usage, input names, input placeholders, etc.) and verified correctness using the provided assessment script.</span></li>\\n</ul>\\n<p><strong>Tech Stack:</strong></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>React.js, JavaScript, HTML, CSS, Recharts, React-Modal, localStorage</strong><strong><br /><br /></strong></li>\\n</ul>\\n<h3><strong>Outcome:</strong></h3>\\n<ul>\\n<li style=\\"list-style-type: none;\\">\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Delivered a complete React expense tracking app with real-time balance handling, persistent transaction history, and analytics dashboards through interactive charts.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Implemented production-ready UX features like modals, validations, responsive layouts, and test-aligned UI behavior for successful deployment and assessment readiness.</span></li>\\n</ul>\\n</li>\\n</ul>\\n<h3><strong>Skills &amp; Tools:</strong></h3>\\n<p><strong>React.js, JavaScript, State Management, Form Validation, localStorage, Responsive Design, Recharts, React-Modal, Git/GitHub</strong></p>","completed_modules":"1","skills":[{"id":1068,"me_milestone_id":181,"skills_id":285,"ordering":1},{"id":1069,"me_milestone_id":181,"skills_id":22,"ordering":2},{"id":1070,"me_milestone_id":181,"skills_id":310,"ordering":3},{"id":1072,"me_milestone_id":181,"skills_id":132,"ordering":5},{"id":1073,"me_milestone_id":181,"skills_id":136,"ordering":6},{"id":1074,"me_milestone_id":181,"skills_id":31,"ordering":7}]},{"id":182,"status":"published","sort":null,"user_created":"96947060-767d-4dc3-8a57-ab05646a591f","date_created":"2026-01-21T12:33:33.000Z","user_updated":null,"date_updated":null,"me_id":"ME_FE_XBOTAI_V2","slug":"me-fe-xbotai-v2-milestone-1","title":"XBot AI","content":"<h1>Scope of work</h1>\\n<p>&nbsp;</p>\\n<p><strong>Objective:</strong><strong><br /></strong><span style=\\"font-weight: 400;\\">Built a frontend application that allows users to chat with an AI model and provide feedback at different stages of the conversation, including reactions per message and rating-based feedback at the end.</span></p>\\n<p><strong>Key Features &amp; Design:</strong></p>\\n<ul>\\n<li aria-level=\\"1\\"><strong>AI Chat Interface:</strong></li>\\n</ul>\\n<ul>\\n<ul>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Implemented a chat UI where users can type a query and receive an AI response.</span></li>\\n</ul>\\n</ul>\\n</ul>\\n<ul>\\n<li aria-level=\\"1\\"><strong>Multi-Conversation Support:</strong></li>\\n</ul>\\n<ul>\\n<ul>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Users can start a new chat and have multiple conversations.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Conversations can be saved and revisited later.</span></li>\\n</ul>\\n</ul>\\n</ul>\\n<ul>\\n<li aria-level=\\"1\\"><strong>Conversation History View:</strong></li>\\n</ul>\\n<ul>\\n<ul>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Added a Past Conversations section that navigates to the \\"/history\\" route.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Users can revisit saved conversations from a side/top panel.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Past chats display the feedback that was provided earlier.</span></li>\\n</ul>\\n</ul>\\n</ul>\\n<ul>\\n<li aria-level=\\"1\\"><strong>Feedback System:</strong></li>\\n</ul>\\n<ul>\\n<ul>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Like/Dislike reactions using thumbs up / thumbs down buttons on the AI responses.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Buttons are hidden by default and appear (floating) when the user hovers over the AI model\'s response.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Added an end-of-conversation rating system (out of 5).</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Added a subjective feedback input at the end of the conversation.</span></li>\\n</ul>\\n</ul>\\n</ul>\\n<ul>\\n<li aria-level=\\"1\\"><strong>Feedback Dashboard + Filtering:</strong></li>\\n</ul>\\n<ul>\\n<ul>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Included a view that aggregates feedback points across conversations.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Supports filtering feedback based on rating.</span></li>\\n</ul>\\n</ul>\\n</ul>\\n<ul>\\n<li aria-level=\\"1\\"><strong>UI &amp; Responsiveness:</strong></li>\\n</ul>\\n<ul>\\n<ul>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">UI matches the provided design reference and supports desktop + mobile/tablet layouts.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Chat input uses placeholder: \\"Message Bot AI&hellip;\\"</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Ensured required UI rules like using &lt;span&gt; for Soul AI and &lt;p&gt; for AI response display.</span></li>\\n</ul>\\n</ul>\\n</ul>\\n<ul>\\n<li aria-level=\\"1\\"><strong>Testing &amp; Assessment Readiness:</strong></li>\\n</ul>\\n<ul>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Followed strict UI and attribute requirements (button types, placeholders, route usage, default responses).</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Ran integration tests using the provided assessment script before submission.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Deployment link stored in submit.txt for evaluation.</span></li>\\n</ul>\\n</ul>\\n<p><strong>Tech Stack:</strong></p>\\n<ul>\\n<li aria-level=\\"1\\"><strong>React.js, JavaScript, HTML, CSS, localStorage, Routing (React Router)</strong></li>\\n</ul>\\n<h3><strong>Outcome:</strong></h3>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Delivered a complete frontend AI chat system with conversation saving, history navigation, and multi-layer feedback collection.</span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Implemented responsive UI workflows, strict validation rules for evaluation, and ensured the app meets test-case specific requirements for successful assessment.</span></li>\\n</ul>\\n<h3><strong>Skills &amp; Tools:</strong></h3>\\n<p><strong>React.js, JavaScript, State Management, UI/UX Implementation, localStorage, Routing, Responsive Design, Component Design, Testing Readiness, Git/GitHub, Deployment (Netlify/Vercel)</strong></p>","completed_modules":"1","skills":[{"id":1075,"me_milestone_id":182,"skills_id":285,"ordering":1},{"id":1076,"me_milestone_id":182,"skills_id":22,"ordering":2},{"id":1077,"me_milestone_id":182,"skills_id":310,"ordering":3},{"id":1078,"me_milestone_id":182,"skills_id":132,"ordering":4},{"id":1079,"me_milestone_id":182,"skills_id":169,"ordering":5},{"id":1080,"me_milestone_id":182,"skills_id":136,"ordering":6},{"id":1081,"me_milestone_id":182,"skills_id":31,"ordering":7},{"id":1082,"me_milestone_id":182,"skills_id":140,"ordering":8}]},{"id":183,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2026-01-21T13:18:15.000Z","user_updated":null,"date_updated":null,"me_id":"ME_QEVENT","slug":"me-qevent-milestone-1","title":"QEVENT","content":"<h1>Scope of work</h1>\\n<ul>\\n<li>\\n<h3><strong>Objective</strong><span style=\\"font-size: 15px; font-weight: 500; color: #4f5464;\\">:</span></h3>\\n<p>Built an event management platform where users can browse upcoming events, explore artists and tags, view detailed event pages, filter events using query parameters, and create new events after logging in with Google OAuth.</p>\\n<p><br /><strong>Key Features &amp; Design:</strong></p>\\n</li>\\n<li>\\n<p><strong>Routing &amp; Navigation:</strong><br />- Implemented core routes: /events, /artists, /tags with working navbar navigation.<br />- Created dynamic event detail pages using /events/[eventId].</p>\\n</li>\\n<li>\\n<p><strong>API-Driven Data Fetching:</strong><br />- Fetches events from: https://qevent-backend.labs.crio.do/events<br />- Fetches artists from: https://qevent-backend.labs.crio.do/artists<br />- Fetches tags from: https://qevent-backend.labs.crio.do/tags<br />- Fetches single event details using: https://qevent-backend.labs.crio.do/events/&lt;event-id&gt;</p>\\n</li>\\n<li>\\n<p><strong>Event &amp; Artist Listings UI:</strong><br />- Rendered event cards using the provided EventCard component.<br />- Rendered artist cards using the provided ArtistCard component.<br />- Rendered tags using the Tag component.<br />- Images for event cards are dynamic and can change on every refresh.</p>\\n</li>\\n<li>\\n<p><strong>Filtering via Query Params:</strong><br />- Clicking &ldquo;View Events&rdquo; on an artist redirects to /events?artist=&lt;artist-name&gt; and filters events.<br />- Clicking a tag redirects to /events?tag=&lt;tag-name&gt; and filters events.<br />- Extracted query parameters using Next.js navigation utilities and displayed filtered results.</p>\\n</li>\\n<li>\\n<p><strong>Authentication with Google OAuth:</strong><br />- Integrated NextAuth and configured Google Provider.<br />- Added session wrapper using SessionProvider to wrap the app.<br />- Implemented login/logout experience through Google OAuth.<br />- \\"Create Event\\" link is visible only when logged in.<br />- Protected /create-event route: redirects unauthenticated users back to events page.</p>\\n</li>\\n<li>\\n<p><strong>Create Event Workflow:</strong><br />- Built /create-event route to create and submit new events.<br />- Created new events using POST https://qevent-backend.labs.crio.do/events<br />- Redirects to /events after successful creation.<br />- Shows alert \\"Event creation failed\\" when API fails.</p>\\n</li>\\n<li>\\n<p><strong>Deployment:</strong><br />- Deployed the application on Vercel.<br />- Updated Google OAuth authorized origins/redirect URLs for production and added env keys in Vercel settings.</p>\\n</li>\\n<li>\\n<p><strong>Tech Stack:</strong><br />Next.js, React.js, JavaScript, NextAuth, Google OAuth, REST APIs, Vercel</p>\\n<p>&nbsp;</p>\\n</li>\\n<li>\\n<p><strong>Outcome</strong>:<br />Delivered a complete event discovery and management platform with API-based event browsing, dynamic pages, artist/tag filtering, secure Google login, and event creation support.<br />Implemented real-world Next.js features such as dynamic routing, query-based filtering, session-based UI control, and production deployment setup.</p>\\n</li>\\n</ul>\\n<h3>Skills used</h3>\\n<p>React.js, Node.js, Express.js, MongoDB, REST APIs, Authentication, Role-Based Access Control, Email Notifications (Nodemailer), External API Integration (Calendarific), Cypress Testing, Git/GitHub, Deployment (Render, Vercel)</p>","completed_modules":"1","skills":[{"id":1083,"me_milestone_id":183,"skills_id":363,"ordering":1},{"id":1084,"me_milestone_id":183,"skills_id":285,"ordering":2},{"id":1085,"me_milestone_id":183,"skills_id":284,"ordering":3},{"id":1086,"me_milestone_id":183,"skills_id":274,"ordering":4},{"id":1087,"me_milestone_id":183,"skills_id":140,"ordering":5},{"id":1088,"me_milestone_id":183,"skills_id":31,"ordering":6}]},{"id":184,"status":"published","sort":null,"user_created":"96947060-767d-4dc3-8a57-ab05646a591f","date_created":"2026-01-21T13:19:34.000Z","user_updated":null,"date_updated":null,"me_id":"ME_FE_XMEDIFY_V2","slug":"me-fe-xmedify-v2-milestone-1","title":"XMedify","content":"<h1>Scope of work</h1>\\n<p>&nbsp;</p>\\n<p><strong>Objective:</strong><strong><br /></strong><span style=\\"font-weight: 400;\\">Built a React-based web application that allows users to find medical centers in a specific state and city across the USA and book appointments.</span></p>\\n<p><strong>Key Features &amp; Design:</strong></p>\\n<p><strong>Landing Page Navigation:</strong></p>\\n<p><span style=\\"font-weight: 400;\\">Top navigation bar with access to sections like Find Doctors, Hospitals, Medicines, etc.</span></p>\\n<ul>\\n<li aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Search section to select state and city and fetch available medical centers.</span></li>\\n</ul>\\n<p><strong>Dynamic Search with API Integration:</strong></p>\\n<ul>\\n<li aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">State and city dropdowns populated using backend APIs.</span></li>\\n</ul>\\n<ul>\\n<li aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Fetches medical centers based on the selected state and city.</span></li>\\n</ul>\\n<ul>\\n<li aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Extracted and displayed key hospital details such as Hospital Name, Address, City, State, ZIP Code, and Overall Rating.</span></li>\\n</ul>\\n<p><strong>Search Results Experience:</strong></p>\\n<ul>\\n<li aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Displays a listing view of available medical centers with booking options.</span></li>\\n</ul>\\n<ul>\\n<li aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Shows a heading in the format:&nbsp; \\"{number} medical centers available in {city}\\"</span></li>\\n</ul>\\n<p><strong>Appointment Booking Workflow:</strong></p>\\n<ul>\\n<li aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Booking section includes a calendar to select appointment dates.</span></li>\\n</ul>\\n<ul>\\n<li aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Allows booking appointments only within a week in advance.</span></li>\\n</ul>\\n<ul>\\n<li aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Provides selection of time slots for the chosen day.</span></li>\\n</ul>\\n<ul>\\n<li aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Booking CTA button labeled &ldquo;Book FREE Center Visit&rdquo;.</span></li>\\n</ul>\\n<p><strong>My Bookings Page:</strong></p>\\n<ul>\\n<li aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Dedicated route \\"/my-bookings\\" to view user bookings.</span></li>\\n</ul>\\n<ul>\\n<li aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Displays booking details including medical center name, appointment date, and time.</span></li>\\n</ul>\\n<ul>\\n<li aria-level=\\"1\\"><strong>Data Persistence:</strong></li>\\n</ul>\\n<ul>\\n<li aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Stores bookings in localStorage using the key \\"bookings\\" so data remains after refresh.</span></li>\\n</ul>\\n<p><strong>UI &amp; Responsiveness:</strong></p>\\n<ul>\\n<li aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Fully responsive design following the Figma reference.</span></li>\\n</ul>\\n<ul>\\n<li aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Implemented carousels using the Swiper library.</span></li>\\n</ul>\\n<p><strong>Testing &amp; Compliance:</strong></p>\\n<ul>\\n<li aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Followed strict UI structure requirements (IDs for dropdown wrappers, specific tags for headings and hospital names, correct button labels, etc.)</span></li>\\n</ul>\\n<ul>\\n<li aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Ran the provided integration tests using run_assessment.sh before submission.</span></li>\\n</ul>\\n<ul>\\n<li aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Created submit.txt containing only the deployed project link.</span></li>\\n</ul>\\n<p><strong>Tech Stack:</strong></p>\\n<ul>\\n<li aria-level=\\"1\\"><strong>React.js, JavaScript, HTML, CSS, Swiper.js, localStorage, REST APIs</strong></li>\\n</ul>\\n<h3><strong>Outcome:</strong></h3>\\n<ul>\\n<li><span style=\\"font-weight: 400;\\">Delivered a complete frontend medical booking application with state/city based hospital search, booking workflows with date/time selection, and persistent booking history.</span></li>\\n<li><span style=\\"font-weight: 400;\\">Ensured responsive UI, API-driven dynamic data loading, and test-compliant implementation aligned with real-world product requirements.</span></li>\\n</ul>\\n<h3><strong>Skills &amp; Tools:</strong></h3>\\n<p><strong>React.js, JavaScript, API Integration, State Management, Routing, localStorage, Responsive Design, Swiper.js, UI Implementation, Testing Readiness, Git/GitHub, Deployment (Vercel/Netlify)</strong></p>","completed_modules":"1","skills":[{"id":1089,"me_milestone_id":184,"skills_id":285,"ordering":1},{"id":1090,"me_milestone_id":184,"skills_id":22,"ordering":2},{"id":1091,"me_milestone_id":184,"skills_id":284,"ordering":3},{"id":1092,"me_milestone_id":184,"skills_id":310,"ordering":4},{"id":1093,"me_milestone_id":184,"skills_id":169,"ordering":5},{"id":1094,"me_milestone_id":184,"skills_id":132,"ordering":6},{"id":1095,"me_milestone_id":184,"skills_id":136,"ordering":7},{"id":1096,"me_milestone_id":184,"skills_id":31,"ordering":8},{"id":1097,"me_milestone_id":184,"skills_id":140,"ordering":9}]},{"id":185,"status":"published","sort":null,"user_created":"2cdfd27c-eea4-4ad0-9c35-0eba2c29b45f","date_created":"2026-01-21T13:44:35.000Z","user_updated":null,"date_updated":null,"me_id":"ME_BUILDOUT_CODERHACK","slug":"me-buildout-coderhack-milestone-1","title":"Buildout Coderhack","content":"<h1>Scope of work</h1>\\n<ul>\\n<li>\\n<h3><strong>Objective</strong><span style=\\"font-size: 15px; font-weight: 500; color: #4f5464;\\">:</span></h3>\\n- Developed a RESTful API to manage a coding contest leaderboard, handling user registration, score updates, and badge assignments based on performance. The backend service supports full CRUD operations and ensures users are retrieved in ascending order based on scores.<br /><br /></li>\\n<li><strong>Key Features &amp; Design:</strong><br />\\n<p>&nbsp;</p>\\n</li>\\n<li>\\n<p><strong>User Registration</strong>: Users are registered with unique IDs, usernames, a starting score of 0, and no badges.</p>\\n<p>&nbsp;</p>\\n</li>\\n<li>\\n<p><strong>Score Updates:</strong> The score can be updated via PUT requests. Badges are awarded based on predefined thresholds (e.g., Code Ninja for scores &ge; 1, Code Champ for scores &ge; 30, and Code Master for scores &ge; 60).</p>\\n<p>&nbsp;</p>\\n</li>\\n<li>\\n<p><strong>Sorting:</strong> Users are listed sorted by score (O(nlogn) time complexity).</p>\\n<p>&nbsp;</p>\\n</li>\\n<li>\\n<p><strong>CRUD Operations: </strong>Implemented Create (POST), Read (GET), Update (PUT for score only), and Delete (DELETE) operations.</p>\\n<p>&nbsp;</p>\\n</li>\\n<li>\\n<p><strong>Error Handling:</strong> Validation ensures proper data input, returning relevant HTTP response codes (e.g., 400 for invalid input).</p>\\n</li>\\n<li><strong>Tech Stack:</strong><br />Java, Spring Boot, MongoDB, JUnit (for testing)</li>\\n<li>\\n<p><strong>Outcome:</strong></p>\\n<p>- Built a scalable RESTful API with Spring Boot and MongoDB, demonstrating skills in Java backend development, data validation, and error handling.</p>\\n<p>- Delivered a fully functional backend system that can manage users, track scores, and assign badges dynamically.</p>\\n<p>&nbsp;</p>\\n</li>\\n</ul>\\n<h3>Skills used</h3>\\n<p>Java, Spring Boot, MongoDB, JUnit, Postman, Git/GitHub</p>","completed_modules":"1","skills":[{"id":1098,"me_milestone_id":185,"skills_id":26,"ordering":1},{"id":1099,"me_milestone_id":185,"skills_id":24,"ordering":2},{"id":1100,"me_milestone_id":185,"skills_id":19,"ordering":3},{"id":1101,"me_milestone_id":185,"skills_id":30,"ordering":4},{"id":1102,"me_milestone_id":185,"skills_id":194,"ordering":5},{"id":1103,"me_milestone_id":185,"skills_id":31,"ordering":6}]},{"id":186,"status":"published","sort":null,"user_created":"42670516-02dd-418e-abaa-d5ff0d183714","date_created":"2026-01-21T17:04:08.000Z","user_updated":null,"date_updated":null,"me_id":"ME_BUILDOUT_LEARNING_NAVIGATOR","slug":"me-buildout-learning-navigator-milestone-1","title":"Buildout Learning Navigator","content":"<h1>Scope of work</h1>\\n<p>&nbsp;</p>\\n<h3><strong>Objective:</strong></h3>\\n<p><span style=\\"font-weight: 400;\\">&nbsp;- Created an API service to handle the exam enrollment process in a Learning Management System (LMS). This service supports managing student registrations, subject enrollments, exam creation, and enrollment in exams.</span></p>\\n<p>&nbsp;</p>\\n<p><strong>Key Features &amp; Design:</strong></p>\\n<p>&nbsp;</p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Student Management:</strong><span style=\\"font-weight: 400;\\"> Handle student registrations, storing details like name and list of enrolled subjects/exams.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Subject Management:</strong><span style=\\"font-weight: 400;\\"> Manage subjects that students can enroll in, associating them with exams.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Exam Enrollment:</strong><span style=\\"font-weight: 400;\\"> Ensure students can only enroll in exams after enrolling in the corresponding subject.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>CRUD Operations:</strong><span style=\\"font-weight: 400;\\"> Implemented full CRUD operations for students, subjects, and exams.</span></li>\\n</ul>\\n<p>&nbsp;</p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\"><strong>Easter Egg Feature:</strong><span> Added a fun Easter egg feature that generates a fact about a number via the Numbers API.</span></span></li>\\n</ul>\\n<p>&nbsp;</p>\\n<p><strong>Tech Stack:</strong></p>\\n<p><span style=\\"font-weight: 400;\\"><span><strong>Java</strong>, <strong>Spring Boot</strong>, <strong>MySQL</strong>, <strong>JUnit</strong> (for testing)<br /></span></span></p>\\n<p>&nbsp;</p>\\n<h3><strong>Extended Overview:</strong></h3>\\n<p>&nbsp;</p>\\n<h4><strong>Problem Context:</strong></h4>\\n<p><span style=\\"font-weight: 400;\\">The project simulates an exam enrollment service for an LMS, focusing on managing students, subjects, and exams. The service ensures proper relationships between students, subjects, and exams, while also handling common errors and validations.</span></p>\\n<p>&nbsp;</p>\\n<h4><strong>Backend Design:</strong></h4>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Layered Architecture:</strong><span style=\\"font-weight: 400;\\"> Split into Controller, Service, and Repository layers for clear separation of concerns.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>MySQL Persistence:</strong><span style=\\"font-weight: 400;\\"> MySQL used to store student, subject, and exam data, with foreign key relationships to maintain data integrity.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n</ul>\\n<h4><strong>Key Features Implemented:</strong></h4>\\n<ol>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Student Management:</strong><strong><br /><br /></strong></li>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">POST </span><span style=\\"font-weight: 400;\\">/students</span><span style=\\"font-weight: 400;\\"> for creating new students.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Enroll students in subjects and exams with appropriate validation checks.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n</ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Subject Management:</strong><strong><br /><br /></strong></li>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">POST </span><span style=\\"font-weight: 400;\\">/subjects</span><span style=\\"font-weight: 400;\\"> for creating new subjects and linking them to exams.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n</ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Exam Enrollment:</strong><strong><br /><br /></strong></li>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Students can enroll in exams only after they&rsquo;ve enrolled in the corresponding subject.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">POST </span><span style=\\"font-weight: 400;\\">/students/{studentId}/exams/{examId}</span><span style=\\"font-weight: 400;\\"> for exam registration.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n</ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Easter Egg Feature:</strong><strong><br /><br /></strong></li>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">A hidden GET endpoint </span><span style=\\"font-weight: 400;\\">/easter-egg/hidden-feature/{number}</span><span style=\\"font-weight: 400;\\"> that fetches a random fact about the provided number via the Numbers API.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n</ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Error Handling &amp; Validation:</strong><strong><br /><br /></strong></li>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Used </span><strong>GlobalExceptionHandler</strong><span style=\\"font-weight: 400;\\"> and </span><strong>@ControllerAdvice</strong><span style=\\"font-weight: 400;\\"> for centralized error management.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Returned appropriate HTTP status codes for invalid inputs and missing resources.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n</ul>\\n</ol>\\n<h4><strong>Testing:</strong></h4>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>JUnit</strong><span style=\\"font-weight: 400;\\"> tests implemented for all CRUD operations, including the Easter egg feature.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Mocked dependencies using </span><strong>Mockito</strong><span style=\\"font-weight: 400;\\"> and tested API endpoints with </span><strong>MockMvc</strong><span style=\\"font-weight: 400;\\">.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n</ul>\\n<h3><strong>Outcome:</strong></h3>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Built a </span><strong>RESTful API</strong><span style=\\"font-weight: 400;\\"> with </span><strong>Spring Boot</strong><span style=\\"font-weight: 400;\\"> and </span><strong>MySQL</strong><span style=\\"font-weight: 400;\\">, capable of managing the entire exam enrollment process.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Demonstrated expertise in </span><strong>Java backend development</strong><span style=\\"font-weight: 400;\\">, </span><strong>database management</strong><span style=\\"font-weight: 400;\\">, and </span><strong>error handling</strong><span style=\\"font-weight: 400;\\">.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n</ul>\\n<h3><strong>Skills &amp; Tools:</strong></h3>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Java</strong><span style=\\"font-weight: 400;\\">, </span><strong>Spring Boot</strong><span style=\\"font-weight: 400;\\">, </span><strong>MySQL</strong><span style=\\"font-weight: 400;\\">, </span><strong>JUnit</strong><span style=\\"font-weight: 400;\\">, </span><strong>Mockito</strong><span style=\\"font-weight: 400;\\">, </span><strong>Postman</strong><span style=\\"font-weight: 400;\\">, </span><strong>Git/GitHub</strong></li>\\n</ul>","completed_modules":"1","skills":[{"id":1104,"me_milestone_id":186,"skills_id":26,"ordering":1},{"id":1105,"me_milestone_id":186,"skills_id":24,"ordering":2},{"id":1106,"me_milestone_id":186,"skills_id":364,"ordering":3},{"id":1107,"me_milestone_id":186,"skills_id":30,"ordering":4},{"id":1108,"me_milestone_id":186,"skills_id":28,"ordering":5},{"id":1109,"me_milestone_id":186,"skills_id":194,"ordering":6},{"id":1110,"me_milestone_id":186,"skills_id":31,"ordering":7}]},{"id":187,"status":"published","sort":null,"user_created":"42670516-02dd-418e-abaa-d5ff0d183714","date_created":"2026-01-21T17:52:42.000Z","user_updated":null,"date_updated":null,"me_id":"ME_BUILDOUT_RENTREAD","slug":"me-buildout-rentread-milestone-1","title":"Buildout RentRead","content":"<h1>Scope of work</h1>\\n<p>&nbsp;</p>\\n<h3><strong>Objective:</strong></h3>\\n<p><span style=\\"font-weight: 400;\\">Built a RESTful backend service for an online book rental platform that supports secure user authentication, role-based authorization, book management, and rental workflows.</span></p>\\n<p><strong>Key Features &amp; Design:</strong></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Authentication &amp; Authorization:</strong><span style=\\"font-weight: 400;\\"> Implemented </span><strong>Basic Authentication</strong><span style=\\"font-weight: 400;\\"> with </span><strong>USER</strong><span style=\\"font-weight: 400;\\"> and </span><strong>ADMIN</strong><span style=\\"font-weight: 400;\\"> roles. Passwords are securely hashed using </span><strong>BCrypt</strong><span style=\\"font-weight: 400;\\">.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Role-Based Access Control:</strong><strong><br /><br /></strong></li>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Public endpoints for user registration and login.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Private endpoints secured for authenticated users.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Admin-only access for creating, updating, and deleting books.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n</ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Book Management:</strong><span style=\\"font-weight: 400;\\"> Store and manage book details such as title, author, genre, and availability status.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Rental Management:</strong><strong><br /><br /></strong></li>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Users can rent and return books.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Enforced a business rule limiting users to </span><strong>a maximum of two active rentals</strong><span style=\\"font-weight: 400;\\"> at a time.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Automatically updates book availability during rental and return operations.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n</ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Validation &amp; Error Handling:</strong><span style=\\"font-weight: 400;\\"> Centralized exception handling with meaningful HTTP status codes (400, 403, 404).</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Logging &amp; Testing:</strong><span style=\\"font-weight: 400;\\"> Added application logs and wrote unit tests using </span><strong>JUnit, MockMvc, and Mockito</strong><span style=\\"font-weight: 400;\\">.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n</ul>\\n<p><strong>Tech Stack:</strong></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Java</strong><span style=\\"font-weight: 400;\\">, </span><strong>Spring Boot</strong><span style=\\"font-weight: 400;\\">, </span><strong>Spring Security</strong><span style=\\"font-weight: 400;\\">, </span><strong>MySQL</strong><span style=\\"font-weight: 400;\\">, </span><strong>JUnit</strong><span style=\\"font-weight: 400;\\">, </span><strong>Mockito</strong><strong><br /><br /></strong></li>\\n</ul>\\n<h3><strong>Outcome:</strong></h3>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Delivered a </span><strong>secure, production-style backend API</strong><span style=\\"font-weight: 400;\\"> with authentication, authorization, and real-world business rules.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Demonstrated strong backend fundamentals including </span><strong>security</strong><span style=\\"font-weight: 400;\\">, </span><strong>database design</strong><span style=\\"font-weight: 400;\\">, </span><strong>API validation</strong><span style=\\"font-weight: 400;\\">, and </span><strong>error handling</strong><span style=\\"font-weight: 400;\\">.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Generated a runnable </span><strong>JAR</strong><span style=\\"font-weight: 400;\\">, documented APIs via </span><strong>Postman</strong><span style=\\"font-weight: 400;\\">, and provided a complete README for local execution.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n</ul>\\n<h3><strong>Skills &amp; Tools:</strong></h3>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Java</strong><span style=\\"font-weight: 400;\\">, </span><strong>Spring Boot</strong><span style=\\"font-weight: 400;\\">, </span><strong>Spring Security</strong><span style=\\"font-weight: 400;\\">, </span><strong>MySQL</strong><span style=\\"font-weight: 400;\\">, </span><strong>BCrypt</strong><span style=\\"font-weight: 400;\\">, </span><strong>JUnit</strong><span style=\\"font-weight: 400;\\">, </span><strong>Mockito</strong><span style=\\"font-weight: 400;\\">, </span><strong>Postman</strong><span style=\\"font-weight: 400;\\">, </span><strong>Git/GitHub</strong></li>\\n</ul>","completed_modules":"1","skills":[{"id":1111,"me_milestone_id":187,"skills_id":26,"ordering":1},{"id":1112,"me_milestone_id":187,"skills_id":24,"ordering":2},{"id":1113,"me_milestone_id":187,"skills_id":366,"ordering":3},{"id":1114,"me_milestone_id":187,"skills_id":364,"ordering":4},{"id":1115,"me_milestone_id":187,"skills_id":365,"ordering":5},{"id":1116,"me_milestone_id":187,"skills_id":30,"ordering":6},{"id":1117,"me_milestone_id":187,"skills_id":28,"ordering":7},{"id":1118,"me_milestone_id":187,"skills_id":194,"ordering":8},{"id":1119,"me_milestone_id":187,"skills_id":31,"ordering":9}]},{"id":188,"status":"published","sort":null,"user_created":"42670516-02dd-418e-abaa-d5ff0d183714","date_created":"2026-01-21T18:22:24.000Z","user_updated":null,"date_updated":null,"me_id":"ME_BUILDOUT_STAYEASE","slug":"me-buildout-stayease-milestone-1","title":"Buildout Stayease","content":"<h1>Scope of work</h1>\\n<p>&nbsp;</p>\\n<p><strong>Objective:</strong><strong><br /></strong><span style=\\"font-weight: 400;\\"> Built a RESTful backend service to streamline hotel room bookings for a hotel management aggregator. The system supports secure user authentication, role-based authorization, hotel management, and booking workflows.</span></p>\\n<p><strong>Key Features &amp; Design:</strong></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Authentication &amp; Authorization:</strong><span style=\\"font-weight: 400;\\"> Implemented </span><strong>JWT-based stateless authentication</strong><span style=\\"font-weight: 400;\\"> with secure password hashing using </span><strong>BCrypt</strong><span style=\\"font-weight: 400;\\">.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Role-Based Access Control:</strong><strong><br /><br /></strong></li>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><strong>CUSTOMER:</strong><span style=\\"font-weight: 400;\\"> Browse hotels and create bookings.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><strong>HOTEL_MANAGER:</strong><span style=\\"font-weight: 400;\\"> Update hotel details and cancel bookings.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><strong>ADMIN:</strong><span style=\\"font-weight: 400;\\"> Create and delete hotels.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n</ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Hotel Management:</strong><span style=\\"font-weight: 400;\\"> Manage hotel details such as name, location, description, total rooms, and available rooms. Prevents overbooking by tracking room availability.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Booking Management:</strong><strong><br /><br /></strong></li>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Customers can book rooms with validated check-in and check-out dates.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Enforced business rules such as future check-in dates and valid date ranges.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"2\\"><span style=\\"font-weight: 400;\\">Only managers can cancel bookings.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n</ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Validation &amp; Error Handling:</strong><span style=\\"font-weight: 400;\\"> Centralized exception handling with proper HTTP status codes (400, 401, 403, 404).</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Testing &amp; Logging:</strong><span style=\\"font-weight: 400;\\"> Added application logging and unit tests using </span><strong>JUnit, MockMvc, and Mockito</strong><span style=\\"font-weight: 400;\\">.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n</ul>\\n<p><strong>Tech Stack:</strong></p>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Java</strong><span style=\\"font-weight: 400;\\">, </span><strong>Spring Boot</strong><span style=\\"font-weight: 400;\\">, </span><strong>Spring Security</strong><span style=\\"font-weight: 400;\\">, </span><strong>JWT</strong><span style=\\"font-weight: 400;\\">, </span><strong>MySQL</strong><span style=\\"font-weight: 400;\\">, </span><strong>JUnit</strong><span style=\\"font-weight: 400;\\">, </span><strong>Mockito</strong><strong><br /><br /></strong></li>\\n</ul>\\n<h3><strong>Outcome:</strong></h3>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Delivered a </span><strong>production-style backend system</strong><span style=\\"font-weight: 400;\\"> with </span><strong>JWT security</strong><span style=\\"font-weight: 400;\\">, </span><strong>multi-role authorization</strong><span style=\\"font-weight: 400;\\">, and </span><strong>strict business constraints</strong><span style=\\"font-weight: 400;\\">.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Demonstrated strong skills in </span><strong>secure API design</strong><span style=\\"font-weight: 400;\\">, </span><strong>database-backed systems</strong><span style=\\"font-weight: 400;\\">, and </span><strong>real-world backend architecture</strong><span style=\\"font-weight: 400;\\">.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><span style=\\"font-weight: 400;\\">Generated a runnable </span><strong>JAR</strong><span style=\\"font-weight: 400;\\">, documented APIs using </span><strong>Postman</strong><span style=\\"font-weight: 400;\\">, and provided full setup instructions via README.</span><span style=\\"font-weight: 400;\\"><br /><br /></span></li>\\n</ul>\\n<h3><strong>Skills &amp; Tools:</strong></h3>\\n<ul>\\n<li style=\\"font-weight: 400;\\" aria-level=\\"1\\"><strong>Java</strong><span style=\\"font-weight: 400;\\">, </span><strong>Spring Boot</strong><span style=\\"font-weight: 400;\\">, </span><strong>Spring Security</strong><span style=\\"font-weight: 400;\\">, </span><strong>JWT</strong><span style=\\"font-weight: 400;\\">, </span><strong>MySQL</strong><span style=\\"font-weight: 400;\\">, </span><strong>BCrypt</strong><span style=\\"font-weight: 400;\\">, </span><strong>JUnit</strong><span style=\\"font-weight: 400;\\">, </span><strong>Mockito</strong><span style=\\"font-weight: 400;\\">, </span><strong>Postman</strong><span style=\\"font-weight: 400;\\">, </span><strong>Git/GitHub</strong><strong><br /><br /></strong></li>\\n</ul>","completed_modules":"1","skills":[{"id":1120,"me_milestone_id":188,"skills_id":26,"ordering":1},{"id":1121,"me_milestone_id":188,"skills_id":24,"ordering":2},{"id":1122,"me_milestone_id":188,"skills_id":366,"ordering":3},{"id":1123,"me_milestone_id":188,"skills_id":367,"ordering":4},{"id":1124,"me_milestone_id":188,"skills_id":364,"ordering":5},{"id":1125,"me_milestone_id":188,"skills_id":365,"ordering":6},{"id":1126,"me_milestone_id":188,"skills_id":30,"ordering":7},{"id":1127,"me_milestone_id":188,"skills_id":28,"ordering":8},{"id":1128,"me_milestone_id":188,"skills_id":194,"ordering":9},{"id":1129,"me_milestone_id":188,"skills_id":31,"ordering":10}]}]}')}}]);