f your knowledge and engagement in the course."},{question:"What is an estimated grade and how is it calculated?",answer:"An estimated grade is a real-time forecast of your sprint grade based on your performance in the course up until the last completed week. It is calculated weekly, factoring in your cumulative scores from quizzes, mocks, and other graded tasks, as well as your attendance record. This ongoing estimate helps you gauge your progress and identify areas needing improvement throughout the sprint."},{question:"Will watching recorded sessions count towards my attendance?",answer:"Yes, watching the recorded sessions counts towards your attendance score, ensuring you can still earn attendance points even if you are unable to attend live sessions."},{question:"How can I improve my grade during the course?",answer:"You can improve your grade by actively participating in all scheduled sessions, completing tasks on time, performing well in quizzes and mocks, and ensuring you watch session recordings if you miss a live session."}]})})]})]})]})},er=r(69136),tr=function(e){var t=e.children,r=e.className,a=e.gradeData,o=e.totalWeightage,s=e.hasFinalScore,i=a||{},l=i.scores,c=i.grade,u=(0,U.qY)(),d=u.isOpen,m=u.onOpen,f=u.onClose,p=(0,q.Z)().sendPlatformProgressEvent,x=(0,K.Z)(),g=function(e,t){var r;return null===(r=e.scores[t])||void 0===r?void 0:r.scores.reduce((function(e,t){return t.score?e+1:e}),0)},h=function(e,t){switch(e){case V.Qj.ACTIVITY:return"".concat(t.score.toFixed(1),"/").concat(t.assignedAggregate);case V.Qj.SESSION_ATTENDANCE:var r=t.scores.length,n=t.scores.reduce((function(e,t){return t.score?e+1:e}),0);return"".concat(n,"/").concat(r);case V.Qj.ON_TIME_COMPLETION:var o=g(a,V.Qj.ACTIVITY)||0,s=g(a,V.Qj.DSA_MOCK)||0,i=g(a,V.Qj.ME_MODULE)||0;return"".concat(i+s+o,"/").concat(function(e){var t,r,n;return((null===(t=e.scores[V.Qj.ACTIVITY])||void 0===t?void 0:t.scores.length)||0)+((null===(r=e.scores[V.Qj.ME_MODULE])||void 0===r?void 0:r.scores.leng